{% extends 'base_front.html.twig' %}

{% block title %}Mes Réclamations - Villa Agency{% endblock %}

{% block body %}
    {% include 'home/partials/header.html.twig' %}

    <div class="page-heading header-text">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <span class="breadcrumb"><a href="{{ path('app_home') }}">Home</a> / Réclamations</span>
                    <h3>Mes Réclamations</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-5 mb-5 pb-5 pt-3" style="min-height: 50vh;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4>Toutes vos réclamations</h4>
            <a href="{{ path('reclamation_new') }}" class="btn text-white rounded-pill px-4 py-2" style="background-color: #f35525; border-color: #f35525; font-weight:500;">
                <i class="fas fa-plus"></i> Nouvelle réclamation
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="table-responsive shadow-sm bg-white p-3 rounded">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Priorité</th>
                        <th>Statut</th>
                        <th>Avis lié</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for rec in reclamations %}
                    <tr>
                        <td class="fw-bold">{{ rec.titre }}</td>
                        <td>{{ rec.type.nom }}</td>
                        <td>
                            {% if rec.priorite == 'Basse' %}
                                <span class="badge bg-secondary">Basse</span>
                            {% elseif rec.priorite == 'Moyenne' %}
                                <span class="badge bg-info text-dark">Moyenne</span>
                            {% elseif rec.priorite == 'Haute' %}
                                <span class="badge bg-warning text-dark">Haute</span>
                            {% elseif rec.priorite == 'Urgente' %}
                                <span class="badge bg-danger">Urgente</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if rec.statut == 'Fermée' %}
                                <span class="badge bg-secondary">Fermée</span>
                            {% elseif rec.statut == 'Traitée' %}
                                <span class="badge bg-success">Traitée</span>
                            {% elseif rec.statut == 'En cours' %}
                                <span class="badge bg-primary">En cours</span>
                            {% else %}
                                <span class="badge bg-warning text-dark">En attente</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if rec.avis %}
                                <a href="{{ path('avis_show', {'id': rec.avis.id}) }}" class="badge rounded-pill border bg-light text-dark text-decoration-none">Voir l'avis</a>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td>{{ rec.dateCreation ? rec.dateCreation|date('d/m/Y') : '' }}</td>
                        <td>
                            <a href="{{ path('reclamation_show', {'id': rec.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                            {% if rec.statut != 'Fermée' %}
                                <a href="{{ path('reclamation_edit', {'id': rec.id}) }}" class="btn btn-sm btn-outline-dark">Modifier</a>
                            {% endif %}
                            <form method="post" action="{{ path('reclamation_delete', {'id': rec.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ?');" style="display:inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ rec.id) }}">
                                <button class="btn btn-sm btn-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-4">Aucune réclamation trouvée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% include 'home/partials/footer.html.twig' %}
{% endblock %}
