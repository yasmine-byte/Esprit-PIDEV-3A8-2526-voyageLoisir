{% extends 'base_front.html.twig' %}

{% block title %}Modifier la réclamation - Villa Agency{% endblock %}

{% block body %}
    {% include 'home/partials/header.html.twig' %}

    <div class="page-heading header-text">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <span class="breadcrumb"><a href="{{ path('reclamation_index') }}">Réclamations</a> / Modifier</span>
                    <h3>Modifier la réclamation</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-5 mb-5 pb-5 pt-3">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm border-0 p-4">
                    <h4 class="mb-4">Mise à jour de la réclamation</h4>
                    
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'needs-validation'}}) }}
                        
                        <div class="mb-3">
                            {{ form_label(form.titre, 'Titre', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'Résumé du problème'}}) }}
                            <div class="text-danger small mt-1">{{ form_errors(form.titre) }}</div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.type, 'Type de réclamation', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
                            <div class="text-danger small mt-1">{{ form_errors(form.type) }}</div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.priorite, 'Priorité', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.priorite, {'attr': {'class': 'form-select'}}) }}
                            <div class="text-danger small mt-1">{{ form_errors(form.priorite) }}</div>
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.contenu, 'Détails de la réclamation', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.contenu, {'attr': {'class': 'form-control', 'rows': 5, 'placeholder': 'Expliquez en détail...'}}) }}
                            <div class="text-danger small mt-1">{{ form_errors(form.contenu) }}</div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn text-white px-5 py-2 rounded-pill w-100" style="background-color: #f35525; font-weight:600;">
                                Enregistrer
                            </button>
                            <a href="{{ path('reclamation_index') }}" class="btn btn-outline-secondary px-4 py-2 rounded-pill w-100">Annuler</a>
                        </div>
                        <div class="d-none">
                            {{ form_rest(form) }}
                        </div>
                    {{ form_end(form, {'render_rest': false}) }}
                </div>
            </div>
        </div>
    </div>

    {% include 'home/partials/footer.html.twig' %}
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const formObj = document.querySelector('form.needs-validation');
            if (formObj) {
                const initialData = new URLSearchParams(new FormData(formObj)).toString();
                formObj.addEventListener('submit', function(e) {
                    const currentData = new URLSearchParams(new FormData(formObj)).toString();
                    if (currentData === initialData) {
                        e.preventDefault();
                        alert("Vous devez modifier au moins un champ pour pouvoir enregistrer.");
                    }
                });
            }
        });
    </script>
{% endblock %}
