{% extends 'admin/base_admin.html.twig' %}

{% block title %}Destinations{% endblock %}

{% block admin_content %}
<style>
.dest-table { width:100%; border-collapse:separate; border-spacing:0; }
.dest-table thead tr { background:#12122a; }
.dest-table thead th {
    padding:12px 16px;
    font-size:11px;
    font-weight:700;
    letter-spacing:.08em;
    text-transform:uppercase;
    color:#6b7280;
    border-bottom:1px solid #1e1e3a;
    white-space:nowrap;
}
.dest-table thead th a { color:inherit; text-decoration:none; }
.dest-table thead th a:hover { color:#e0e0e0; }
.dest-table tbody tr { transition:background .15s; border-bottom:1px solid #1a1a30; }
.dest-table tbody tr:hover { background:#14142a; }
.dest-table tbody td { padding:13px 16px; vertical-align:middle; }

.dbadge-id   { background:#1e1e2a; color:#818cf8; border-radius:6px; padding:3px 9px; font-size:12px; font-weight:700; }
.dbadge-nom  { font-size:13px; font-weight:600; color:#e2e8f0; }
.dbadge-pays { background:#1e1e2a; color:#94a3b8; border:1px solid #2a2a3a; border-radius:6px; padding:3px 9px; font-size:12px; }
.dbadge-saison-Printemps { background:#1a2e10; color:#86efac; border:1px solid #1e4020; border-radius:6px; padding:3px 9px; font-size:11px; font-weight:600; }
.dbadge-saison-Ete       { background:#2e1e06; color:#fbbf24; border:1px solid #4a3010; border-radius:6px; padding:3px 9px; font-size:11px; font-weight:600; }
.dbadge-saison-Automne   { background:#2e1506; color:#fb923c; border:1px solid #4a2808; border-radius:6px; padding:3px 9px; font-size:11px; font-weight:600; }
.dbadge-saison-Hiver     { background:#0a1a2e; color:#7dd3fc; border:1px solid #0e2a4a; border-radius:6px; padding:3px 9px; font-size:11px; font-weight:600; }
.dbadge-actif   { background:#0d2b1a; color:#4ade80; border:1px solid #1a3d28; border-radius:20px; padding:3px 10px; font-size:11px; font-weight:700; }
.dbadge-inactif { background:#2b0d0d; color:#f87171; border:1px solid #3d1a1a; border-radius:20px; padding:3px 10px; font-size:11px; font-weight:700; }
.dbadge-voyage  { background:#1e1e2a; color:#a78bfa; border-radius:6px; padding:3px 9px; font-size:11px; font-weight:600; }

.dact { display:flex; gap:6px; align-items:center; flex-wrap:nowrap; }
.dbtn {
    display:inline-flex; align-items:center; gap:4px;
    padding:5px 11px; border-radius:6px; font-size:12px; font-weight:500;
    text-decoration:none; border:1px solid #2a2a3a; cursor:pointer;
    background:#1a1a28; color:#94a3b8;
    transition:color .15s, border-color .15s; white-space:nowrap;
}
.dbtn:hover { color:#e0e0e0; border-color:#444; }
.dbtn-edit  { color:#818cf8; border-color:#2e2e50; }
.dbtn-img   { color:#4ade80; border-color:#1a3d28; }
.dbtn-voy   { color:#a78bfa; border-color:#3a2060; }
.dbtn-del   { color:#f87171; border-color:#3d1f1f; }
.dbtn-del form, .dbtn-del button {
    margin:0; padding:0; background:none; border:none;
    color:inherit; font:inherit; font-size:12px; font-weight:500;
    cursor:pointer; display:inline;
}
</style>

<div class="page-header">
    <h1>Destinations</h1>
    <p>Gérer toutes les destinations</p>
</div>

{# ===== FILTRES ===== #}
<div class="card" style="margin-bottom:20px">
    <div class="card-header">
        <h3 class="card-title">Filtres & Recherche</h3>
    </div>
    <form method="GET" action="{{ path('app_destination_index') }}"
          style="display:flex;flex-wrap:wrap;gap:12px;padding:16px;align-items:flex-end">
        <div style="flex:1;min-width:180px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Recherche (nom, pays, ID)</label>
            <input type="text" name="search" value="{{ search }}" placeholder="Rechercher..."
                   style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
        </div>
        <div style="min-width:150px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Saison</label>
            <select name="saison" style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="">Toutes</option>
                <option value="Printemps" {{ saison == 'Printemps' ? 'selected' : '' }}>Printemps</option>
                <option value="Ete"       {{ saison == 'Ete'       ? 'selected' : '' }}>Été</option>
                <option value="Automne"   {{ saison == 'Automne'   ? 'selected' : '' }}>Automne</option>
                <option value="Hiver"     {{ saison == 'Hiver'     ? 'selected' : '' }}>Hiver</option>
            </select>
        </div>
        <div style="min-width:130px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Statut</label>
            <select name="statut" style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="">Tous</option>
                <option value="1" {{ statut == '1' ? 'selected' : '' }}>Actif</option>
                <option value="0" {{ statut == '0' ? 'selected' : '' }}>Inactif</option>
            </select>
        </div>
        <div style="min-width:150px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Trier par</label>
            <select name="tri" style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="id"               {{ tri == 'id'               ? 'selected' : '' }}>ID</option>
                <option value="nom"              {{ tri == 'nom'              ? 'selected' : '' }}>Nom</option>
                <option value="pays"             {{ tri == 'pays'             ? 'selected' : '' }}>Pays</option>
                <option value="nb_visites"       {{ tri == 'nb_visites'       ? 'selected' : '' }}>Nb Visites</option>
                <option value="meilleure_saison" {{ tri == 'meilleure_saison' ? 'selected' : '' }}>Saison</option>
            </select>
        </div>
        <div style="min-width:120px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Ordre</label>
            <select name="ordre" style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="ASC"  {{ ordre == 'ASC'  ? 'selected' : '' }}>▲ Croissant</option>
                <option value="DESC" {{ ordre == 'DESC' ? 'selected' : '' }}>▼ Décroissant</option>
            </select>
        </div>
        <div style="display:flex;gap:8px">
            <button type="submit" style="padding:8px 18px;border-radius:6px;border:none;background:#6c63ff;color:#fff;font-size:13px;cursor:pointer;font-weight:600">🔍 Filtrer</button>
            <a href="{{ path('app_destination_index') }}" style="padding:8px 18px;border-radius:6px;border:1px solid #555;color:#aaa;font-size:13px;text-decoration:none;display:flex;align-items:center">✕ Reset</a>
        </div>
    </form>
</div>

{# ===== TABLEAU ===== #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Liste des Destinations
            <span style="font-size:13px;color:#888;font-weight:normal;margin-left:8px">
                ({{ destinations|length }} résultat{{ destinations|length > 1 ? 's' : '' }})
            </span>
        </h3>
        <div style="display:flex;gap:8px">
            <button onclick="openStatsPopup()"
                style="padding:8px 16px;border-radius:6px;border:none;background:#6c63ff;color:#fff;font-size:13px;font-weight:600;cursor:pointer">
                📊 Statistiques
            </button>
            <a href="{{ path('app_destination_new') }}" class="action-btn primary">+ Ajouter</a>
        </div>
    </div>

    {% set params = {search: search, saison: saison, statut: statut} %}

    <div style="overflow-x:auto">
    <table class="dest-table">
        <thead>
            <tr>
                <th><a href="{{ path('app_destination_index', params|merge({tri: 'id', ordre: (tri == 'id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">ID {% if tri == 'id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th><a href="{{ path('app_destination_index', params|merge({tri: 'nom', ordre: (tri == 'nom' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">Nom {% if tri == 'nom' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th><a href="{{ path('app_destination_index', params|merge({tri: 'pays', ordre: (tri == 'pays' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">Pays {% if tri == 'pays' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th><a href="{{ path('app_destination_index', params|merge({tri: 'meilleure_saison', ordre: (tri == 'meilleure_saison' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">Saison {% if tri == 'meilleure_saison' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th><a href="{{ path('app_destination_index', params|merge({tri: 'nb_visites', ordre: (tri == 'nb_visites' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">Visites {% if tri == 'nb_visites' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th>Statut</th>
                <th>Voyages</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for destination in destinations %}
            <tr>
                <td><span class="dbadge-id">#{{ destination.id }}</span></td>
                <td><span class="dbadge-nom">{{ destination.nom }}</span></td>
                <td><span class="dbadge-pays">{{ destination.pays }}</span></td>
                <td>
                    {% set s = destination.meilleureSaison %}
                    <span class="dbadge-saison-{{ s }}">{{ s ?? '—' }}</span>
                </td>
                <td>
                    <span style="font-size:13px;font-weight:600;color:#e2e8f0">{{ destination.nbVisites }}</span>
                </td>
                <td>
                    {% if destination.statut %}
                        <span class="dbadge-actif">Actif</span>
                    {% else %}
                        <span class="dbadge-inactif">Inactif</span>
                    {% endif %}
                </td>
                <td>
                    {% if destination.voyages|length > 0 %}
                        <span class="dbadge-voyage">{{ destination.voyages|length }} voyage{{ destination.voyages|length > 1 ? 's' : '' }}</span>
                    {% else %}
                        <span style="color:#4b5563;font-size:12px">—</span>
                    {% endif %}
                </td>
                <td>
                    <div class="dact">
                        <a href="{{ path('app_destination_show', {'id': destination.id}) }}" class="dbtn">👁 Voir</a>
                        <a href="{{ path('app_destination_edit', {'id': destination.id}) }}" class="dbtn dbtn-edit">✏️ Modifier</a>
                        <a href="{{ path('app_image_new', {'destination_id': destination.id}) }}" class="dbtn dbtn-img">+ Image</a>
                        <a href="{{ path('app_voyage_new', {'destination_id': destination.id}) }}" class="dbtn dbtn-voy">+ Voyage</a>
                        <span class="dbtn dbtn-del">{{ include('destination/_delete_form.html.twig') }}</span>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="8" style="text-align:center;color:#4b5563;padding:40px;font-size:14px">Aucune destination trouvée</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
</div>

{# ===== MODAL SUPPRESSION ===== #}
<div id="dest-delete-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);align-items:center;justify-content:center;">
    <div style="background:#1e1e2e;border:1px solid #3a3a4a;border-radius:16px;padding:32px 36px;max-width:460px;width:92%;box-shadow:0 24px 64px rgba(0,0,0,.7);">
        <div style="text-align:center;margin-bottom:20px">
            <div style="font-size:44px;margin-bottom:10px">⚠️</div>
            <h3 id="dest-modal-title" style="margin:0 0 6px;color:#fff;font-size:17px"></h3>
            <p style="margin:0;color:#999;font-size:13px">Cette action est irréversible.</p>
        </div>
        <div id="dest-modal-voyages-box" style="display:none;margin-bottom:20px">
            <div style="background:#2a1a1a;border:1px solid #5a2a2a;border-radius:10px;padding:14px 16px">
                <p style="margin:0 0 10px;font-size:12px;font-weight:700;color:#e57373;text-transform:uppercase;letter-spacing:.5px">🗓 Voyages qui seront supprimés :</p>
                <ul id="dest-modal-voyages-list" style="margin:0;padding:0 0 0 16px;font-size:12px;color:#ccc;line-height:1.9"></ul>
            </div>
        </div>
        <div id="dest-modal-no-voyages-box" style="display:none;margin-bottom:20px">
            <div style="background:#1a2a1a;border:1px solid #2a5a2a;border-radius:10px;padding:10px 16px;font-size:12px;color:#81c784">
                ✅ Aucun voyage associé à cette destination.
            </div>
        </div>
        <div style="display:flex;gap:12px">
            <button onclick="closeDestinationDeleteModal()" style="flex:1;padding:11px;border-radius:9px;border:1px solid #444;background:none;color:#aaa;font-size:14px;cursor:pointer;font-weight:500">Annuler</button>
            <button id="dest-modal-confirm" style="flex:1;padding:11px;border-radius:9px;border:none;background:#c0392b;color:#fff;font-size:14px;cursor:pointer;font-weight:700">Supprimer quand même</button>
        </div>
    </div>
</div>

{# ===== POPUP STATISTIQUES ===== #}
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<div id="stats-popup" style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.8);backdrop-filter:blur(4px);align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto">
    <div style="background:#1a1a2e;border:1px solid #3a3a4a;border-radius:20px;width:100%;max-width:1100px;margin:auto;box-shadow:0 30px 80px rgba(0,0,0,.8)">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 28px;border-bottom:1px solid #3a3a4a">
            <h3 style="margin:0;color:#fff;font-size:18px;font-weight:700">📊 Statistiques des Destinations</h3>
            <button onclick="closeStatsPopup()" style="width:36px;height:36px;border-radius:50%;border:1px solid #555;background:none;color:#aaa;font-size:18px;cursor:pointer">✕</button>
        </div>
        <div style="padding:28px">
            <div id="stats-loading" style="text-align:center;padding:40px;color:#888;font-size:15px">Chargement des statistiques...</div>
            <div id="stats-loaded" style="display:none">

                {# 7 cartes résumé #}
                <div id="stats-cards" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px"></div>

                {# Ligne 1 : Top visites + Top likes #}
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #3b82f6;padding-left:10px">👁 Top 5 — Plus visitées</h5>
                        <canvas id="chartVisites" height="220"></canvas>
                    </div>
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #e11d48;padding-left:10px">❤️ Top 5 — Plus likées</h5>
                        <canvas id="chartLikes" height="220"></canvas>
                    </div>
                </div>

                {# Ligne 2 : Visites & Likes par saison + Recherches vocales par saison #}
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #10b981;padding-left:10px">Visites & Likes par saison</h5>
                        <canvas id="chartSaisonDetail" height="200"></canvas>
                    </div>
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #6c63ff;padding-left:10px">🎙 Recherches vocales par saison</h5>
                        <canvas id="chartRecherchesSaison" height="200"></canvas>
                    </div>
                </div>

                {# Ligne 3 : Par pays + Statut #}
                <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:20px">
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #f97316;padding-left:10px">Destinations par pays</h5>
                        <canvas id="chartPays" height="140"></canvas>
                    </div>
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #10b981;padding-left:10px">Statut</h5>
                        <canvas id="chartStatut" height="140"></canvas>
                    </div>
                </div>

                {# Ligne 4 : Réservations #}
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #10b981;padding-left:10px">📅 Top 5 — Plus réservées</h5>
                        <canvas id="chartReservations" height="220"></canvas>
                    </div>
                    <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                        <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #10b981;padding-left:10px">📅 Réservations par saison</h5>
                        <canvas id="chartReservationsSaison" height="220"></canvas>
                    </div>
                </div>

                {# Tableau classement #}
                <div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a">
                    <h5 style="margin:0 0 16px;color:#fff;font-size:14px;font-weight:600;border-left:3px solid #f97316;padding-left:10px">Classement des destinations</h5>
                    <table style="width:100%;border-collapse:collapse;font-size:13px">
                        <thead>
                            <tr style="border-bottom:1px solid #2a2a4a">
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">#</th>
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">Destination</th>
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">Pays</th>
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">Saison</th>
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">👁 Visites</th>
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">❤️ Likes</th>
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">📅 Réservations</th>
                                <th style="padding:10px;text-align:left;color:#888;font-weight:600">Statut</th>
                            </tr>
                        </thead>
                        <tbody id="stats-table-body"></tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
var _destForm = null;
function openDestinationDeleteModal(id, nom, voyages) {
    _destForm = document.getElementById('delete-form-' + id);
    document.getElementById('dest-modal-title').textContent = 'Supprimer "' + nom + '" ?';
    var listEl = document.getElementById('dest-modal-voyages-list');
    var voyagesBox = document.getElementById('dest-modal-voyages-box');
    var noVoyageBox = document.getElementById('dest-modal-no-voyages-box');
    listEl.innerHTML = '';
    if (voyages.length > 0) {
        voyages.forEach(function(v) { var li = document.createElement('li'); li.textContent = v; listEl.appendChild(li); });
        voyagesBox.style.display = 'block'; noVoyageBox.style.display = 'none';
    } else {
        voyagesBox.style.display = 'none'; noVoyageBox.style.display = 'block';
    }
    document.getElementById('dest-delete-modal').style.display = 'flex';
}
function closeDestinationDeleteModal() {
    document.getElementById('dest-delete-modal').style.display = 'none';
    _destForm = null;
}
document.getElementById('dest-modal-confirm').addEventListener('click', function() { if (_destForm) _destForm.submit(); });
document.getElementById('dest-delete-modal').addEventListener('click', function(e) { if (e.target === this) closeDestinationDeleteModal(); });

// ===== STATS POPUP =====
var statsCharts = [];

function openStatsPopup() {
    document.getElementById('stats-popup').style.display = 'flex';
    loadStats();
}
function closeStatsPopup() {
    document.getElementById('stats-popup').style.display = 'none';
}
document.getElementById('stats-popup').addEventListener('click', function(e) { if (e.target === this) closeStatsPopup(); });

function loadStats() {
    document.getElementById('stats-loading').style.display = 'block';
    document.getElementById('stats-loaded').style.display  = 'none';
    statsCharts.forEach(function(c){ c.destroy(); });
    statsCharts = [];
    fetch('{{ path("app_destination_stats") }}')
        .then(function(r){ return r.json(); })
        .then(function(data){ renderStats(data); })
        .catch(function(){ document.getElementById('stats-loading').textContent = 'Erreur de chargement.'; });
}

function renderStats(data) {
    document.getElementById('stats-loading').style.display = 'none';
    document.getElementById('stats-loaded').style.display  = 'block';

    // ✅ 7 cartes résumé
    var cards = [
        { label: 'Total destinations',      value: data.total,                color: '#f97316' },
        { label: 'Actives',                 value: data.actifs,               color: '#16a34a' },
        { label: 'Inactives',               value: data.inactifs,             color: '#e11d48' },
        { label: '👁 Visites totales',      value: data.totalVisites,         color: '#3b82f6' },
        { label: '❤️ Likes totaux',         value: data.totalLikes,           color: '#e11d48' },
        { label: '🎙 Recherches vocales',   value: data.totalRechercheVocale, color: '#6c63ff' },
        { label: '📅 Réservations totales', value: data.totalReservations,    color: '#10b981' },
    ];
    document.getElementById('stats-cards').innerHTML = cards.map(function(c) {
        return '<div style="background:#12122a;border-radius:12px;padding:20px;border:1px solid #2a2a4a;text-align:center">'
             + '<div style="font-size:28px;font-weight:800;color:' + c.color + '">' + c.value + '</div>'
             + '<div style="font-size:12px;color:#888;margin-top:6px">' + c.label + '</div>'
             + '</div>';
    }).join('');

    Chart.defaults.color = '#888';

    // ✅ Top 5 visites — barre horizontale bleue
    statsCharts.push(new Chart(document.getElementById('chartVisites'), {
        type: 'bar',
        data: {
            labels: data.topVisites.map(function(d){ return d.nom; }),
            datasets: [{ label: '👁 Visites', data: data.topVisites.map(function(d){ return d.nbVisites; }),
                backgroundColor: '#3b82f6', borderRadius: 6, borderSkipped: false }]
        },
        options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false } },
            scales: { x: { grid: { color: '#2a2a4a' }, ticks: { color: '#888' } }, y: { grid: { display: false }, ticks: { color: '#ccc' } } } }
    }));

    // ✅ Top 5 likes — barre horizontale rouge
    statsCharts.push(new Chart(document.getElementById('chartLikes'), {
        type: 'bar',
        data: {
            labels: data.topLikes.map(function(d){ return d.nom; }),
            datasets: [{ label: '❤️ Likes', data: data.topLikes.map(function(d){ return d.nbLikes; }),
                backgroundColor: '#e11d48', borderRadius: 6, borderSkipped: false }]
        },
        options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false } },
            scales: { x: { grid: { color: '#2a2a4a' }, ticks: { color: '#888' } }, y: { grid: { display: false }, ticks: { color: '#ccc' } } } }
    }));

    // ✅ Visites & Likes par saison — barres groupées
    statsCharts.push(new Chart(document.getElementById('chartSaisonDetail'), {
        type: 'bar',
        data: {
            labels: Object.keys(data.visitesSaison),
            datasets: [
                { label: '👁 Visites', data: Object.values(data.visitesSaison),
                    backgroundColor: '#3b82f6', borderRadius: 6, borderSkipped: false },
                { label: '❤️ Likes', data: Object.values(data.likesSaison),
                    backgroundColor: '#e11d48', borderRadius: 6, borderSkipped: false }
            ]
        },
        options: { responsive: true,
            plugins: { legend: { display: true, position: 'top', labels: { color: '#888', padding: 12 } } },
            scales: { y: { beginAtZero: true, ticks: { color: '#888' }, grid: { color: '#2a2a4a' } },
                x: { grid: { display: false }, ticks: { color: '#ccc' } } } }
    }));

    // ✅ Recherches vocales par saison — barre violette
    statsCharts.push(new Chart(document.getElementById('chartRecherchesSaison'), {
        type: 'bar',
        data: {
            labels: Object.keys(data.recherchesSaison),
            datasets: [{ label: '🎙 Recherches', data: Object.values(data.recherchesSaison),
                backgroundColor: '#6c63ff', borderRadius: 6, borderSkipped: false }]
        },
        options: { responsive: true, plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1, color: '#888' }, grid: { color: '#2a2a4a' } },
                x: { grid: { display: false }, ticks: { color: '#ccc' } } } }
    }));

    // ✅ Par pays
    statsCharts.push(new Chart(document.getElementById('chartPays'), {
        type: 'bar',
        data: {
            labels: Object.keys(data.parPays),
            datasets: [{ label: 'Destinations', data: Object.values(data.parPays),
                backgroundColor: '#f97316', borderRadius: 6, borderSkipped: false }]
        },
        options: { responsive: true, plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1, color: '#888' }, grid: { color: '#2a2a4a' } },
                x: { grid: { display: false }, ticks: { color: '#ccc' } } } }
    }));

    // ✅ Statut — pie
    statsCharts.push(new Chart(document.getElementById('chartStatut'), {
        type: 'pie',
        data: {
            labels: ['Actives', 'Inactives'],
            datasets: [{ data: [data.actifs, data.inactifs],
                backgroundColor: ['#16a34a','#e11d48'],
                borderColor: '#1a1a2e', borderWidth: 3 }]
        },
        options: { responsive: true,
            plugins: { legend: { position: 'bottom', labels: { color: '#888', padding: 12 } } } }
    }));

    // ✅ Top 5 réservations — barre horizontale verte
    statsCharts.push(new Chart(document.getElementById('chartReservations'), {
        type: 'bar',
        data: {
            labels: data.topReservations.map(function(d){ return d.nom; }),
            datasets: [{ label: '📅 Réservations', data: data.topReservations.map(function(d){ return d.nbRes; }),
                backgroundColor: '#10b981', borderRadius: 6, borderSkipped: false }]
        },
        options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false } },
            scales: { x: { grid: { color: '#2a2a4a' }, ticks: { color: '#888', stepSize: 1 } },
                      y: { grid: { display: false }, ticks: { color: '#ccc' } } } }
    }));

    // ✅ Réservations par saison — barre verte verticale
    statsCharts.push(new Chart(document.getElementById('chartReservationsSaison'), {
        type: 'bar',
        data: {
            labels: Object.keys(data.reservationsParSaison),
            datasets: [{ label: '📅 Réservations', data: Object.values(data.reservationsParSaison),
                backgroundColor: '#10b981', borderRadius: 6, borderSkipped: false }]
        },
        options: { responsive: true, plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1, color: '#888' }, grid: { color: '#2a2a4a' } },
                      x: { grid: { display: false }, ticks: { color: '#ccc' } } } }
    }));

    // ✅ Tableau classement — visites, likes ET réservations
    var maxV = data.topVisites.length > 0 ? data.topVisites[0].nbVisites : 1;
    document.getElementById('stats-table-body').innerHTML = data.topVisites.map(function(d, i) {
        var pct = maxV > 0 ? Math.round(d.nbVisites / maxV * 100) : 0;
        return '<tr style="border-bottom:1px solid #2a2a4a">'
             + '<td style="padding:10px;color:#f97316;font-weight:700">' + (i+1) + '</td>'
             + '<td style="padding:10px;color:#fff;font-weight:600">' + d.nom + '</td>'
             + '<td style="padding:10px;color:#888">' + d.pays + '</td>'
             + '<td style="padding:10px;color:#888">' + (d.saison || '—') + '</td>'
             + '<td style="padding:10px"><div style="display:flex;align-items:center;gap:8px">'
             +   '<div style="flex:1;height:6px;background:#2a2a4a;border-radius:3px;max-width:80px">'
             +     '<div style="height:6px;background:#3b82f6;border-radius:3px;width:' + pct + '%"></div>'
             +   '</div>'
             +   '<span style="color:#3b82f6;font-weight:700">👁 ' + d.nbVisites + '</span>'
             + '</div></td>'
             + '<td style="padding:10px"><span style="color:#e11d48;font-weight:700">❤️ ' + (d.nbLikes || 0) + '</span></td>'
             + '<td style="padding:10px"><span style="color:#10b981;font-weight:700">📅 ' + (d.nbRes || 0) + '</span></td>'
             + '<td style="padding:10px"><span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:'
             + (d.statut ? '#16a34a' : '#e11d48') + ';color:#fff">' + (d.statut ? 'Actif' : 'Inactif') + '</span></td>'
             + '</tr>';
    }).join('');
}
</script>

