{{ form_start(form, {'attr': {'id': 'form-destination'}}) }}

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
    <div>
        <label class="form-label">Nom *</label>
        {{ form_widget(form.nom, {'attr': {'class': 'form-input', 'id': 'f-nom', 'placeholder': 'Ex: Paris', 'oninput': 'lvNom("f-nom", this.value)'}}) }}
        <small id="msg-nom" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.nom.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Pays *</label>
        {{ form_widget(form.pays, {'attr': {'class': 'form-input', 'id': 'f-pays', 'placeholder': 'Ex: France', 'oninput': 'lvPays("f-pays", this.value)'}}) }}
        <small id="msg-pays" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.pays.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div style="grid-column: span 2;">
        <label class="form-label">Description <span id="cc-desc" style="font-size:11px;color:#888;font-weight:400">0/2000</span></label>
        {{ form_widget(form.description, {'attr': {'class': 'form-input', 'id': 'f-desc', 'placeholder': 'Description de la destination...', 'rows': 4, 'oninput': 'lvDesc(this)'}}) }}
        <div style="height:3px;background:#333;border-radius:2px;margin-top:4px"><div id="bar-desc" style="height:100%;width:0;border-radius:2px;transition:width .3s,background .3s"></div></div>
        <small id="msg-desc" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.description.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Meilleure Saison *</label>
        {{ form_widget(form.meilleure_saison, {'attr': {'class': 'form-select', 'id': 'f-saison', 'onchange': 'lvSelect("f-saison")'}}) }}
        <small id="msg-saison" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.meilleure_saison.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Nb Visites *</label>
        {{ form_widget(form.nb_visites, {'attr': {'class': 'form-input', 'id': 'f-nb', 'placeholder': 'Ex: 5000', 'oninput': 'lvNbVisites("f-nb", this.value)'}}) }}
        <small id="msg-nb" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.nb_visites.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Latitude * (entre -90 et 90)</label>
        {{ form_widget(form.latitude, {'attr': {'class': 'form-input', 'id': 'f-lat', 'placeholder': 'Ex: 48.8566', 'oninput': 'lvCoord("f-lat", this.value, -90, 90)'}}) }}
        <small id="msg-lat" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.latitude.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Longitude * (entre -180 et 180)</label>
        {{ form_widget(form.longitude, {'attr': {'class': 'form-input', 'id': 'f-lng', 'placeholder': 'Ex: 2.3522', 'oninput': 'lvCoord("f-lng", this.value, -180, 180)'}}) }}
        <small id="msg-lng" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.longitude.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div style="grid-column: span 2;">
        <label class="form-label">Video (fichier)</label>
        {{ form_widget(form.video_path, {'attr': {'class': 'form-input', 'id': 'f-video', 'accept': 'video/*', 'onchange': 'lvVideo(this)'}}) }}
        <small id="msg-video" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
    </div>
    <div>
        <label class="form-label">Voyage *</label>
        {{ form_widget(form.voyage, {'attr': {'class': 'form-select', 'id': 'f-voyage', 'onchange': 'lvSelect("f-voyage")'}}) }}
        <small id="msg-voyage" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.voyage.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Statut *</label>
        {{ form_widget(form.statut, {'attr': {'class': 'form-select', 'id': 'f-statut', 'onchange': 'lvSelect("f-statut")'}}) }}
        <small id="msg-statut" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.statut.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
</div>

<button type="submit" class="btn primary">Sauvegarder</button>
{{ form_end(form) }}

<script>
function ok(id, msg) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "#1D9E75";
    if (m)  { m.style.color = "#1D9E75"; m.textContent = "OK - " + msg; }
}
function er(id, msg) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "#E24B4A";
    if (m)  { m.style.color = "#E24B4A"; m.textContent = "Erreur - " + msg; }
}
function clr(id) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "";
    if (m)  m.textContent = "";
}

function lvNom(id, val) {
    var v = val.trim();
    if (!v)                { clr(id); return; }
    if (/[0-9]/.test(v))   { er(id, "Les chiffres ne sont pas autorises"); return; }
    if (/[<>{}@#]/.test(v)){ er(id, "Caracteres speciaux interdits"); return; }
    if (v.length < 2)      { er(id, "Minimum 2 caracteres"); return; }
    if (v.length > 100)    { er(id, "Maximum 100 caracteres"); return; }
    ok(id, "Valide");
}

function lvPays(id, val) {
    var v = val.trim();
    if (!v)                      { clr(id); return; }
    if (/[0-9]/.test(v))         { er(id, "Les chiffres ne sont pas autorises"); return; }
    if (/[<>{}@#0-9]/.test(v))   { er(id, "Caracteres speciaux interdits"); return; }
    if (v.length < 2)            { er(id, "Minimum 2 caracteres"); return; }
    if (v.length > 100)          { er(id, "Maximum 100 caracteres"); return; }
    ok(id, "Valide");
}

function lvDesc(el) {
    var v   = el.value.trim();
    var len = el.value.length;
    var cc  = document.getElementById("cc-desc");
    var bar = document.getElementById("bar-desc");
    if (cc) cc.textContent = len + "/2000";
    var pct = Math.min(100, Math.round(len / 2000 * 100));
    bar.style.width      = pct + "%";
    bar.style.background = len < 20 ? "#E24B4A" : len < 100 ? "#BA7517" : "#1D9E75";
    if (!v)        { clr("f-desc"); return; }
    if (v.length < 20)  { er("f-desc", "Minimum 20 caracteres (actuel: " + v.length + ")"); return; }
    if (v.length > 2000){ er("f-desc", "Maximum 2000 caracteres"); return; }
    ok("f-desc", v.length + " caracteres");
}

function lvNbVisites(id, val) {
    if (val === "") { clr(id); return; }
    if (/[^0-9]/.test(val))   { er(id, "Seulement des chiffres entiers"); return; }
    var v = parseInt(val);
    if (v < 0)       { er(id, "Doit etre positif ou zero"); return; }
    if (v > 9999999) { er(id, "Valeur trop grande"); return; }
    ok(id, v.toLocaleString() + " visites");
}

function lvCoord(id, val, min, max) {
    if (val === "") { clr(id); return; }
    if (/[a-zA-Z]/.test(val)) { er(id, "Seulement des chiffres"); return; }
    var v = parseFloat(val);
    if (isNaN(v))    { er(id, "Valeur invalide"); return; }
    if (v < min || v > max) { er(id, "Doit etre entre " + min + " et " + max); return; }
    ok(id, v + " (valide)");
}

function lvSelect(id) {
    var el = document.getElementById(id);
    if (!el.value || el.value === "") { er(id, "Veuillez faire un choix"); return; }
    ok(id, "Valide");
}

function lvVideo(input) {
    var f = input.files[0];
    if (!f) { clr("f-video"); return; }
    var max = 50 * 1024 * 1024;
    var allowed = ["video/mp4","video/webm","video/ogg","video/avi","video/quicktime"];
    if (!allowed.includes(f.type)) { er("f-video", "Format non accepte (mp4, webm, ogg, avi, mov)"); return; }
    if (f.size > max) { er("f-video", "Fichier trop lourd - max 50 Mo (actuel: " + (f.size/1024/1024).toFixed(1) + " Mo)"); return; }
    ok("f-video", f.name + " (" + (f.size/1024/1024).toFixed(1) + " Mo)");
}

document.getElementById("form-destination").addEventListener("submit", function(e) {
    var valide = true;

    var nom = document.getElementById("f-nom");
    if (!nom.value.trim()) {
        er("f-nom", "Le nom est obligatoire"); valide = false;
    } else if (/[0-9]/.test(nom.value)) {
        er("f-nom", "Les chiffres ne sont pas autorises"); valide = false;
    } else if (nom.value.trim().length < 2) {
        er("f-nom", "Minimum 2 caracteres"); valide = false;
    }

    var pays = document.getElementById("f-pays");
    if (!pays.value.trim()) {
        er("f-pays", "Le pays est obligatoire"); valide = false;
    } else if (/[0-9]/.test(pays.value)) {
        er("f-pays", "Les chiffres ne sont pas autorises"); valide = false;
    }

    var desc = document.getElementById("f-desc");
    if (desc.value.trim().length > 0 && desc.value.trim().length < 20) {
        er("f-desc", "Minimum 20 caracteres"); valide = false;
    }

    var nb = document.getElementById("f-nb");
    if (!nb.value) {
        er("f-nb", "Le nombre de visites est obligatoire"); valide = false;
    } else if (/[^0-9]/.test(nb.value)) {
        er("f-nb", "Seulement des chiffres entiers"); valide = false;
    }

    var lat = document.getElementById("f-lat");
    if (!lat.value) {
        er("f-lat", "La latitude est obligatoire"); valide = false;
    } else {
        var lv = parseFloat(lat.value);
        if (isNaN(lv) || lv < -90 || lv > 90) { er("f-lat", "Entre -90 et 90"); valide = false; }
    }

    var lng = document.getElementById("f-lng");
    if (!lng.value) {
        er("f-lng", "La longitude est obligatoire"); valide = false;
    } else {
        var lnv = parseFloat(lng.value);
        if (isNaN(lnv) || lnv < -180 || lnv > 180) { er("f-lng", "Entre -180 et 180"); valide = false; }
    }

    var saison = document.getElementById("f-saison");
    if (!saison.value) { er("f-saison", "Veuillez choisir une saison"); valide = false; }

    var voyage = document.getElementById("f-voyage");
    if (!voyage.value) { er("f-voyage", "Veuillez choisir un voyage"); valide = false; }

    if (!valide) {
        e.preventDefault();
        window.scrollTo(0, 0);
    }
});
</script>
