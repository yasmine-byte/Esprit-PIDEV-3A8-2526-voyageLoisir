{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
    <div>
        <label class="form-label">Nom *</label>
        {{ form_widget(form.nom, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Paris'}}) }}
        {% for err in form.nom.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
        {% endfor %}
    </div>

    <div>
        <label class="form-label">Pays *</label>
        {{ form_widget(form.pays, {'attr': {'class': 'form-input', 'placeholder': 'Ex: France'}}) }}
        {% for err in form.pays.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
        {% endfor %}
    </div>

   <div style="grid-column: span 2;">
    <label class="form-label">Description</label>
    {{ form_widget(form.description, {
        'attr': {
            'class': 'form-input',
            'placeholder': 'Description de la destination...',
            'rows': 4
        },
        'value': destination.description
    }) }}
    <button type="submit" name="generate_ai"
        style="margin-top:10px;padding:8px 14px;border:none;border-radius:8px;background:#6c63ff;color:white;cursor:pointer;">
         Générer avec IA
    </button>
</div>

    <div>
        <label class="form-label">Meilleure Saison *</label>
        {{ form_widget(form.meilleure_saison, {'attr': {'class': 'form-select'}}) }}
        {% for err in form.meilleure_saison.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
        {% endfor %}
    </div>

    <div>
        <label class="form-label">Nb Visites *</label>
        {{ form_widget(form.nb_visites, {'attr': {'class': 'form-input', 'placeholder': 'Ex: 5000'}}) }}
        {% for err in form.nb_visites.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
        {% endfor %}
    </div>

    {# ===== CARTE LEAFLET ===== #}
    <div style="grid-column: span 2;">
        <label class="form-label">Rechercher une destination sur la carte</label>
        <div style="display:flex;gap:8px;margin-bottom:10px">
            <input type="text" id="map-search"
                   placeholder="Ex: Paris, Tokyo, Casablanca..."
                   style="flex:1;padding:10px 14px;border-radius:8px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
            <button type="button" onclick="searchLocation()"
                    style="padding:10px 18px;border-radius:8px;border:none;background:#6c63ff;color:#fff;font-size:13px;cursor:pointer;font-weight:600">
                Rechercher
            </button>
        </div>
        <div id="destination-map" style="height:320px;border-radius:10px;border:1px solid #333;margin-bottom:10px;z-index:1"></div>
        <small style="color:#888;font-size:12px">
            Cliquez sur la carte OU recherchez une ville — latitude et longitude seront remplies automatiquement.
        </small>
    </div>

    {# Latitude #}
    <div>
    <label class="form-label">Latitude (entre -90 et 90)</label>
    {{ form_widget(form.latitude, {'attr': {'class': 'form-input', 'placeholder': 'Ex: 48.8566', 'readonly': 'readonly'}}) }}
    {% for err in form.latitude.vars.errors %}
        <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
    {% endfor %}
    </div>

    {# Longitude #}
    <div>
    <label class="form-label">Longitude (entre -180 et 180)</label>
    {{ form_widget(form.longitude, {'attr': {'class': 'form-input', 'placeholder': 'Ex: 2.3522', 'readonly': 'readonly'}}) }}
    {% for err in form.longitude.vars.errors %}
        <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
    {% endfor %}
</div>

    <div style="grid-column: span 2;">
        <label class="form-label">Video (fichier)</label>
        {{ form_widget(form.video_path, {'attr': {'class': 'form-input'}}) }}
    </div>

    <div>
        <label class="form-label">Statut *</label>
        {{ form_widget(form.statut, {'attr': {'class': 'form-select'}}) }}
        {% for err in form.statut.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
        {% endfor %}
    </div>
</div>

<button type="submit" class="btn primary">Sauvegarder</button>

{{ form_end(form) }}

{# ===== LEAFLET CSS + JS ===== #}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
(function() {
    var map = L.map('destination-map').setView([20, 10], 2);

   L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap © CARTO'
}).addTo(map);

    var marker = null;

    function setCoords(lat, lng, zoom) {
        lat = Math.round(lat * 1000000) / 1000000;
        lng = Math.round(lng * 1000000) / 1000000;

       document.getElementById('destination_latitude').value  = lat;
        document.getElementById('destination_longitude').value = lng;
        if (marker) {
            marker.setLatLng([lat, lng]);
        } else {
            marker = L.marker([lat, lng], {draggable: true}).addTo(map);
            marker.on('dragend', function(e) {
                var p = e.target.getLatLng();
                setCoords(p.lat, p.lng, null);
            });
        }
        if (zoom) map.setView([lat, lng], zoom);
    }

    // Remplir le champ pays depuis une réponse Nominatim
    function fillPays(address) {
        if (!address) return;
        var country = address.country || '';
        if (country) {
            var paysField = document.getElementById('destination_pays');
            if (paysField) paysField.value = country;
        }
    }

    // Clic sur la carte → affiche coords immédiates, puis récupère le pays + centroïde
    map.on('click', function(e) {
        var clickLat = e.latlng.lat;
        var clickLng = e.latlng.lng;

        // Feedback immédiat : place le marqueur au point cliqué
        setCoords(clickLat, clickLng, 5);

        // Reverse geocode → nom du pays (sans zoom=3 pour meilleure compatibilité)
        fetch('https://nominatim.openstreetmap.org/reverse?lat=' + clickLat
            + '&lon=' + clickLng
            + '&format=json&addressdetails=1',
            { headers: { 'Accept-Language': 'fr' } }
        )
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data || !data.address || !data.address.country) return;

            // Remplir le champ Pays
            fillPays(data.address);

            // 2e requête : recherche le centroïde du pays
            var countryName = data.address.country;
            return fetch('https://nominatim.openstreetmap.org/search?q='
                + encodeURIComponent(countryName)
                + '&format=json&limit=1&addressdetails=0',
                { headers: { 'Accept-Language': 'fr' } }
            )
            .then(function(r2) { return r2.json(); })
            .then(function(data2) {
                if (!data2 || data2.length === 0) return;
                var lat2 = parseFloat(data2[0].lat);
                var lng2 = parseFloat(data2[0].lon);
                if (!isNaN(lat2) && !isNaN(lng2)) {
                    setCoords(lat2, lng2, 5);
                }
            });
        })
        .catch(function() { /* coords déjà placées */ });
    });

    // Pre-remplir si valeurs existantes (mode edition)
   var existLat = parseFloat(document.getElementById('destination_latitude').value);
    var existLng = parseFloat(document.getElementById('destination_longitude').value);
    if (!isNaN(existLat) && !isNaN(existLng)) {
        setCoords(existLat, existLng, 10);
    }

    // Recherche par nom de ville
    window.searchLocation = function() {
        var q = document.getElementById('map-search').value.trim();
        if (!q) return;

        fetch('https://nominatim.openstreetmap.org/search?q='
    + encodeURIComponent(q)
    + '&format=json&limit=1&accept-language=fr'
    )
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data || data.length === 0) {
                alert('Destination non trouvée. Essayez un autre nom.');
                return;
            }
            var lat = parseFloat(data[0].lat);
            var lng = parseFloat(data[0].lon);
            setCoords(lat, lng, 12);

            // Remplir le champ nom si vide
            var nomField = document.getElementById('destination_nom');
            if (nomField && !nomField.value) {
                nomField.value = data[0].display_name.split(',')[0];
            }

            // Remplir le champ pays
            if (data[0].address) fillPays(data[0].address);
        })
        .catch(function() {
            alert('Erreur de recherche. Vérifiez votre connexion.');
        });
    };

    // Recherche avec touche Entrée
    document.getElementById('map-search').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            window.searchLocation();
        }
    });
})();
</script>