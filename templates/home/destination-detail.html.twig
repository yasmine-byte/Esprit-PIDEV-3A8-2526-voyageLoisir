          <div class="vl-gallery-overlay">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

{# LIGHTBOX #}
<div id="vl-lightbox" onclick="closeLightbox()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.96);z-index:9999;align-items:center;justify-content:center">
  <button onclick="prevLight(event)" style="position:absolute;left:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:white;font-size:26px;width:50px;height:50px;border-radius:50%;cursor:pointer">&#8249;</button>
  <img id="vl-lightbox-img" src="" alt="" style="max-width:90vw;max-height:85vh;border-radius:12px;object-fit:contain">
  <button onclick="nextLight(event)" style="position:absolute;right:20px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:white;font-size:26px;width:50px;height:50px;border-radius:50%;cursor:pointer">&#8250;</button>
  <span onclick="closeLightbox()" style="position:absolute;top:20px;right:24px;color:rgba(255,255,255,0.5);font-size:24px;cursor:pointer">✕</span>
</div>
<script>
var imgUrls=[{% for image in destination.images %}"{{ asset(image.urlImage) }}"{% if not loop.last %},{% endif %}{% endfor %}];
var lbCurrent=0;
function openLightbox(i){lbCurrent=i;document.getElementById('vl-lightbox').style.display='flex';document.getElementById('vl-lightbox-img').src=imgUrls[i];}
function closeLightbox(){document.getElementById('vl-lightbox').style.display='none';}
function prevLight(e){e.stopPropagation();lbCurrent=(lbCurrent-1+imgUrls.length)%imgUrls.length;openLightbox(lbCurrent);}
function nextLight(e){e.stopPropagation();lbCurrent=(lbCurrent+1)%imgUrls.length;openLightbox(lbCurrent);}
document.addEventListener('keydown',function(e){if(document.getElementById('vl-lightbox').style.display==='flex'){if(e.key==='ArrowLeft')prevLight({stopPropagation:function(){}});if(e.key==='ArrowRight')nextLight({stopPropagation:function(){}});if(e.key==='Escape')closeLightbox();}});
</script>

{# ======================================================
   MÉTÉO — PLEIN ÉCRAN HORIZONTAL
   ====================================================== #}
{% if destination.latitude and destination.longitude %}
{% set voyagesAvecDates = [] %}
{% for v in destination.voyages %}{% if v.dateDepart and v.dateArrivee %}{% set voyagesAvecDates = voyagesAvecDates|merge([v]) %}{% endif %}{% endfor %}

<div style="height:20px"></div>
<div class="vl-sep">
  <div class="vl-sep-line"></div>
  <span class="vl-sep-label">Conditions climatiques</span>
  <div class="vl-sep-line"></div>
</div>

<div class="vl-fullwidth-section">
  <div class="vl-fullwidth-card">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:20px">
      <div>
        <div class="vl-section-label">Météo en temps réel</div>
        <h3 class="vl-section-title" style="font-size:28px;margin-bottom:0">Conditions pendant le voyage</h3>
      </div>
      {% if voyagesAvecDates|length > 0 %}
      <div style="display:flex;flex-wrap:wrap;gap:8px">
        {% for v in voyagesAvecDates %}
        <button type="button" onclick="selectVoyage({{ loop.index0 }})" id="btn-voyage-{{ loop.index0 }}" class="vl-voyage-btn{% if loop.first %} active{% endif %}">
          Voyage #{{ v.id }} — {{ v.dateDepart|date('d/m/Y') }} → {{ v.dateArrivee|date('d/m/Y') }}
        </button>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    <div id="meteo-voyage-info" style="background:#f9f8f5;border-radius:10px;padding:12px 16px;margin-bottom:16px;border:1px solid var(--card-border);font-size:13px;color:var(--body-text);display:none"></div>
    <div id="meteo-loading" style="text-align:center;color:var(--muted-text);padding:40px;font-size:13px">Chargement de la météo...</div>
    <div id="meteo-days" class="vl-meteo-grid"></div>
    <div id="meteo-msg" style="display:none;text-align:center;font-size:13px;padding:10px;margin-top:8px;border-radius:8px"></div>
    <div style="margin-top:16px;text-align:right"><small style="color:#ccc;font-size:11px">Source : Open-Meteo.com</small></div>
  </div>
</div>

<script>
(function(){
  var lat={{ destination.latitude }},lng={{ destination.longitude }};
  var VOYAGES=[{% for v in voyagesAvecDates %}{id:{{ v.id }},start:"{{ v.dateDepart|date("Y-m-d") }}",end:"{{ v.dateArrivee|date("Y-m-d") }}",depart:"{{ v.pointDepart ?? '' }}",arrivee:"{{ v.pointArrivee ?? '' }}"}{% if not loop.last %},{% endif %}{% endfor %}];
  var WC={0:"Ciel clair",1:"Princ. clair",2:"Part. nuageux",3:"Couvert",45:"Brouillard",48:"Brouillard",51:"Bruine",53:"Bruine",55:"Bruine dense",61:"Pluie légère",63:"Pluie",65:"Pluie forte",71:"Neige légère",73:"Neige",75:"Neige forte",80:"Averses",81:"Averses",82:"Averses",95:"Orage",96:"Orage",99:"Orage fort"};
  var DAYS=["Dim","Lun","Mar","Mer","Jeu","Ven","Sam"];
  function fmt(d){return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");}
  function iconType(c){if(c===0)return"sun";if(c<=2)return"partly";if(c===3)return"cloud";if(c<=48)return"fog";if(c<=67)return"rain";if(c<=77)return"snow";if(c<=82)return"shower";return"storm";}
  function svgIcon(t,s){s=s||40;var ic={sun:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><circle cx='24' cy='24' r='10' fill='#c8956c'/><g stroke='#c8956c' stroke-width='2.5' stroke-linecap='round'><line x1='24' y1='4' x2='24' y2='10'/><line x1='24' y1='38' x2='24' y2='44'/><line x1='4' y1='24' x2='10' y2='24'/><line x1='38' y1='24' x2='44' y2='24'/></g></svg>",partly:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><circle cx='20' cy='20' r='8' fill='#c8956c'/><rect x='10' y='26' width='28' height='12' rx='6' fill='#90caf9'/></svg>",cloud:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><rect x='6' y='18' width='36' height='18' rx='9' fill='#90caf9'/><ellipse cx='20' cy='20' rx='10' ry='8' fill='#bbdefb'/></svg>",fog:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><g stroke='#90a4ae' stroke-width='3' stroke-linecap='round'><line x1='8' y1='16' x2='40' y2='16'/><line x1='8' y1='24' x2='40' y2='24'/><line x1='8' y1='32' x2='40' y2='32'/></g></svg>",rain:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><rect x='8' y='10' width='32' height='16' rx='8' fill='#90caf9'/><g stroke='#1976d2' stroke-width='2.5' stroke-linecap='round'><line x1='16' y1='32' x2='14' y2='40'/><line x1='24' y1='32' x2='22' y2='40'/><line x1='32' y1='32' x2='30' y2='40'/></g></svg>",snow:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><rect x='8' y='10' width='32' height='16' rx='8' fill='#bbdefb'/><g fill='#90caf9'><circle cx='16' cy='36' r='3'/><circle cx='24' cy='36' r='3'/><circle cx='32' cy='36' r='3'/></g></svg>",shower:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><circle cx='22' cy='14' r='7' fill='#c8956c'/><rect x='8' y='18' width='32' height='12' rx='6' fill='#90caf9'/><g stroke='#1976d2' stroke-width='2.5' stroke-linecap='round'><line x1='16' y1='34' x2='14' y2='42'/><line x1='24' y1='34' x2='22' y2='42'/><line x1='32' y1='34' x2='30' y2='42'/></g></svg>",storm:"<svg width='"+s+"' height='"+s+"' viewBox='0 0 48 48' fill='none'><rect x='6' y='8' width='36' height='16' rx='8' fill='#546e7a'/><polyline points='26,26 20,36 25,36 19,46' stroke='#fdd835' stroke-width='3' fill='none'/></svg>"};return ic[t]||ic["sun"];}
  function showMsg(txt,color){var m=document.getElementById("meteo-msg");m.style.display="block";m.style.color=color||"#e07070";m.textContent=txt;}
  function clearMsg(){document.getElementById("meteo-msg").style.display="none";}
  window.selectVoyage=function(idx){var v=VOYAGES[idx];if(!v)return;
    VOYAGES.forEach(function(_,i){var btn=document.getElementById("btn-voyage-"+i);if(!btn)return;if(i===idx)btn.classList.add("active");else btn.classList.remove("active");});
    var info=document.getElementById("meteo-voyage-info");if(info){var sd=v.start.split("-"),ed=v.end.split("-");info.style.display="block";info.innerHTML=(v.depart?"<strong>"+v.depart+"</strong> → <strong>"+(v.arrivee||'?')+"</strong> &nbsp;|&nbsp; ":"")+"du <strong style='color:var(--accent)'>"+sd[2]+"/"+sd[1]+"/"+sd[0]+"</strong> au <strong style='color:var(--accent)'>"+ed[2]+"/"+ed[1]+"/"+ed[0]+"</strong>";}
    if(window.showVoyageRoute)window.showVoyageRoute(v.id);loadMeteo(v.start,v.end);};
  function loadMeteo(startDate,endDate){clearMsg();var loading=document.getElementById("meteo-loading"),daysDiv=document.getElementById("meteo-days");loading.style.display="block";daysDiv.innerHTML="";var today=new Date();today.setHours(0,0,0,0);var maxDate=new Date(today);maxDate.setDate(today.getDate()+14);var sDate=new Date(startDate),eDate=new Date(endDate);if(sDate>maxDate){loading.style.display="none";showMsg("Météo non disponible pour cette période.");return;}if(sDate<today)sDate=today;var partiel=false;if(eDate>maxDate){eDate=maxDate;partiel=true;}var url="https://api.open-meteo.com/v1/forecast?latitude="+lat+"&longitude="+lng+"&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_sum,windspeed_10m_max&timezone=auto&start_date="+fmt(sDate)+"&end_date="+fmt(eDate);
    fetch(url).then(function(r){return r.json();}).then(function(data){loading.style.display="none";if(data.error){showMsg("Erreur API");return;}var daily=data.daily;if(!daily||!daily.time||daily.time.length===0){showMsg("Aucune donnée.");return;}daysDiv.innerHTML="";for(var i=0;i<daily.time.length;i++){var d=new Date(daily.time[i]),code=daily.weathercode[i];var tmax=Math.round(daily.temperature_2m_max[i]),tmin=Math.round(daily.temperature_2m_min[i]);var pluie=Math.round(daily.precipitation_sum[i]),vent=Math.round(daily.windspeed_10m_max[i]);var card=document.createElement("div");card.className="vl-meteo-card";card.innerHTML="<div style='font-size:13px;font-weight:500;color:var(--body-text)'>"+DAYS[d.getDay()]+"</div><div style='font-size:11px;color:var(--muted-text);margin-bottom:10px'>"+d.getDate()+"/"+(d.getMonth()+1)+"</div><div style='display:flex;justify-content:center;margin-bottom:8px'>"+svgIcon(iconType(code),40)+"</div><div style='font-size:11px;color:var(--muted-text);margin-bottom:10px;min-height:28px;line-height:1.4'>"+(WC[code]||"")+"</div><div style='font-size:18px;font-weight:500;color:var(--accent)'>"+tmax+"°</div><div style='font-size:12px;color:var(--muted-text);margin-bottom:6px'>"+tmin+"°</div><div style='font-size:11px;color:#7ec5e0'>🌧 "+pluie+" mm</div><div style='font-size:11px;color:var(--muted-text)'>💨 "+vent+" km/h</div>";daysDiv.appendChild(card);}if(partiel)showMsg("Affichage partiel (limite 14 jours).");}).catch(function(){document.getElementById("meteo-loading").style.display="none";showMsg("Erreur réseau.");});}
  if(VOYAGES.length>0){selectVoyage(0);}else{document.getElementById("meteo-loading").style.display="none";showMsg("Aucun voyage associé.");}
})();
</script>
{% endif %}

{# ======================================================
   YOUTUBE — PLEIN ÉCRAN HORIZONTAL
   ====================================================== #}
<div style="height:20px"></div>
<div class="vl-sep">
  <div class="vl-sep-line"></div>
  <span class="vl-sep-label">Découverte en vidéo</span>
  <div class="vl-sep-line"></div>
</div>

<div class="vl-fullwidth-section vl-page-bottom">
  <div class="vl-fullwidth-card">
    <div class="vl-section-label">YouTube</div>
    <h3 class="vl-section-title" style="font-size:28px">{{ destination.nom }} en vidéo</h3>

    <div class="vl-yt-fullwidth">
      {# Vidéo #}
      <div>
        <div id="yt-loading" style="text-align:center;color:var(--muted-text);padding:60px;font-size:14px;background:#f9f8f5;border-radius:var(--radius-sm)">⟳ Recherche de la meilleure vidéo...</div>
        <div id="yt-container" style="display:none">
          <div class="vl-video-wrap">
            <iframe id="yt-iframe" src="" frameborder="0" allowfullscreen style="border-radius:var(--radius-sm)"></iframe>
          </div>
          <p id="yt-titre" style="font-size:13px;color:var(--muted-text);margin-top:12px;font-weight:400;line-height:1.5"></p>
        </div>
        <div id="yt-error" style="display:none;font-size:14px;color:var(--muted-text);text-align:center;padding:40px">Aucune vidéo trouvée.</div>
      </div>

      {# Infos destination à droite #}
      <div style="display:flex;flex-direction:column;gap:16px;padding-top:4px">
        <div style="background:#f9f8f5;border-radius:var(--radius-sm);border:1px solid var(--card-border);padding:24px">
          <div class="vl-section-label" style="margin-bottom:12px">À propos</div>
          <h4 style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;color:var(--body-text);margin-bottom:12px">{{ destination.nom }}, {{ destination.pays }}</h4>
          <p style="font-size:14px;font-weight:300;color:var(--muted-text);line-height:1.8">{{ destination.description|slice(0,200) }}{% if destination.description|length > 200 %}…{% endif %}</p>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
          <div style="background:#f9f8f5;border:1px solid var(--card-border);border-radius:var(--radius-sm);padding:16px;text-align:center">
            <div style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--accent)">{{ destination.nbVisites ?? 0 }}</div>
            <div style="font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted-text);margin-top:4px">Visites</div>
          </div>
          <div style="background:#f9f8f5;border:1px solid var(--card-border);border-radius:var(--radius-sm);padding:16px;text-align:center">
            <div style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--accent)">{{ destination.meilleureSaison ?? '—' }}</div>
            <div style="font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted-text);margin-top:4px">Meilleure saison</div>
          </div>
        </div>
        <a href="{{ path('app_destinations') }}" style="display:flex;align-items:center;justify-content:center;gap:8px;padding:14px;border:1px solid var(--accent-border);border-radius:var(--radius-sm);color:var(--accent);font-size:13px;font-weight:500;text-decoration:none;transition:all 0.2s" onmouseover="this.style.background='var(--accent-light)'" onmouseout="this.style.background='transparent'">
          ← Voir toutes les destinations
        </a>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  fetch('{{ path("app_destination_videos", {"id": destination.id}) }}')
    .then(function(r){return r.json();})
    .then(function(v){
      document.getElementById('yt-loading').style.display='none';
      if(!v||!v.id){document.getElementById('yt-error').style.display='block';return;}
      document.getElementById('yt-iframe').src='https://www.youtube.com/embed/'+v.id;
      document.getElementById('yt-titre').textContent=v.titre||'';
      document.getElementById('yt-container').style.display='block';
    })
    .catch(function(){
      document.getElementById('yt-loading').style.display='none';
      document.getElementById('yt-error').style.display='block';
    });
})();
</script>

{# MODAL ITINÉRAIRE #}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<div id="modal-itineraire">
  <div id="modal-inner">
    <div style="padding:24px 28px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0">
      <div>
        <h3 id="modal-titre" style="color:white;margin:0;font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400"></h3>
        <p id="modal-sous-titre" style="color:rgba(255,255,255,0.35);margin:4px 0 0;font-size:12px;letter-spacing:1px;text-transform:uppercase"></p>
      </div>
      <div style="display:flex;gap:10px">
        <button id="btn-pdf" onclick="telechargerPDF()" style="padding:9px 20px;border-radius:30px;border:1px solid var(--accent-border);background:transparent;color:var(--accent);font-size:12px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif">Télécharger PDF</button>
        <button onclick="fermerModal()" style="width:36px;height:36px;border-radius:50%;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.5);font-size:16px;cursor:pointer">✕</button>
      </div>
    </div>
    <div id="modal-contenu" style="overflow-y:auto;padding:24px 28px;flex:1"></div>
  </div>
</div>

<script>
function genererItineraire(duree){
  document.getElementById('itineraire-loading').style.display='inline';
  fetch('{{ path("app_destination_itineraire", {"id": destination.id}) }}',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'duree='+duree})
  .then(function(r){return r.json();})
  .then(function(data){document.getElementById('itineraire-loading').style.display='none';if(!data||!data.jours){alert('Erreur.');return;}afficherModal(data.jours,duree);})
  .catch(function(){document.getElementById('itineraire-loading').style.display='none';});
}
function afficherModal(jours,duree){
  document.getElementById('modal-titre').textContent='Itinéraire {{ destination.nom|e("js") }} — '+duree+' jours';
  document.getElementById('modal-sous-titre').textContent='{{ destination.pays|e("js") }} · Généré par IA';
  var slots=[{key:'matin',label:'Matin',icon:'🌅'},{key:'dejeuner',label:'Déjeuner',icon:'🍽️'},{key:'apres_midi',label:'Après-midi',icon:'☀️'},{key:'diner',label:'Dîner',icon:'🌙'},{key:'transport',label:'Transport',icon:'🚗'},{key:'conseil',label:'Conseil',icon:'💡'}];
  var html='';
  jours.forEach(function(j){html+='<div class="itin-day-card"><div class="itin-day-header"><div class="itin-day-num">'+j.jour+'</div><div><p class="itin-day-title">'+(j.titre||'Jour '+j.jour)+'</p></div></div><div class="itin-slots">';
  slots.forEach(function(s){if(!j[s.key])return;html+='<div class="itin-slot"><div class="itin-slot-icon">'+s.icon+'</div><div><div class="itin-slot-lbl">'+s.label+'</div><p class="itin-slot-txt">'+j[s.key]+'</p></div></div>';});
  html+='</div></div>';});
  document.getElementById('modal-contenu').innerHTML=html;
  document.getElementById('modal-itineraire').style.display='flex';
}
function fermerModal(){document.getElementById('modal-itineraire').style.display='none';}
function telechargerPDF(){var btn=document.getElementById('btn-pdf'),titre=document.getElementById('modal-titre').textContent,el=document.getElementById('modal-contenu');btn.textContent='⟳ PDF...';btn.disabled=true;var prevOverflow=el.style.overflow;el.style.overflow='visible';html2canvas(el,{scale:2,useCORS:true,backgroundColor:'#0f172a',logging:false,scrollY:0}).then(function(canvas){el.style.overflow=prevOverflow;var{jsPDF}=window.jspdf;var imgData=canvas.toDataURL('image/png');var cw=canvas.width,ch=canvas.height;var pdf=new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});pdf.addImage(imgData,'PNG',6,6,198,198*(ch/cw));pdf.save(titre.replace(/[^a-zA-Z0-9\s\-]/g,'').trim().replace(/\s+/g,'_')+'.pdf');btn.textContent='Télécharger PDF';btn.disabled=false;}).catch(function(){el.style.overflow=prevOverflow;btn.textContent='Télécharger PDF';btn.disabled=false;});}
document.getElementById('modal-itineraire').addEventListener('click',function(e){if(e.target===this)fermerModal();});
</script>

{% endblock %}
