{% extends "base_front.html.twig" %}

{% block title %}{{ destination.nom }} - VoyageLoisir{% endblock %}

{% block body %}

<div id="js-preloader" class="js-preloader">
  <div class="preloader-inner">
    <span class="dot"></span>
    <div class="dots"><span></span><span></span><span></span></div>
  </div>
</div>

<div class="sub-header">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-md-8">
        <ul class="info">
          <li><i class="fa fa-envelope"></i> info@voyageloisir.com</li>
          <li><i class="fa fa-map"></i> Tunis, Tunisie</li>
        </ul>
      </div>
      <div class="col-lg-4 col-md-4">
        <ul class="social-links">
          <li><a href="#"><i class="fab fa-facebook"></i></a></li>
          <li><a href="#"><i class="fab fa-twitter"></i></a></li>
          <li><a href="#"><i class="fab fa-linkedin"></i></a></li>
          <li><a href="#"><i class="fab fa-instagram"></i></a></li>
        </ul>
      </div>
    </div>
  </div>
</div>

<header class="header-area header-sticky">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <nav class="main-nav">
          <a href="{{ path("app_home") }}" class="logo"><h1>VoyageLoisir</h1></a>
          <ul class="nav">
            <li><a href="{{ path("app_home") }}">Accueil</a></li>
            <li><a href="{{ path("app_destinations") }}" class="active">Destinations</a></li>
            <li><a href="{{ path("app_contact") }}">Contact</a></li>
          </ul>
          <a class="menu-trigger"><span>Menu</span></a>
        </nav>
      </div>
    </div>
  </div>
</header>

<div class="page-heading header-text">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <span class="breadcrumb">
          <a href="{{ path("app_home") }}">Accueil</a> /
          <a href="{{ path("app_destinations") }}">Destinations</a> /
          {{ destination.nom }}
        </span>
        <h3>{{ destination.nom }}</h3>
      </div>
    </div>
  </div>
</div>

<div class="single-property section">
  <div class="container">
    <div class="row">

      <div class="col-lg-8">

        {% if destination.images|length > 0 %}
          <div class="main-image">
            <img id="main-img"
                 src="{{ asset(destination.images[0].urlImage) }}"
                 alt="{{ destination.nom }}"
                 style="width:100%;border-radius:10px;object-fit:cover;max-height:420px;transition:opacity 0.3s ease">
          </div>

          {% if destination.images|length > 1 %}
            <div class="row" style="margin-top:12px">
              {% for image in destination.images %}
                <div class="col-4" style="margin-bottom:10px">
                  <img src="{{ asset(image.urlImage) }}"
                       alt="{{ destination.nom }}"
                       onclick="switchImage(this)"
                       style="width:100%;border-radius:8px;height:120px;object-fit:cover;cursor:pointer;border:3px solid {{ loop.first ? '#f97316' : 'transparent' }};transition:border 0.2s ease">
                </div>
              {% endfor %}
            </div>
          {% endif %}

        {% else %}
          <div class="main-image">
            <img src="{{ asset("assets_front/images/images/single-property.jpg") }}"
                 alt="{{ destination.nom }}"
                 style="width:100%;border-radius:10px">
          </div>
        {% endif %}

        <div class="main-content" style="margin-top:30px">
          <span class="category">{{ destination.pays }}</span>
          <h4>{{ destination.nom }} - {{ destination.pays }}</h4>
          <p>{{ destination.description ?? "Aucune description disponible." }}</p>
        </div>

        {% if destination.videoPath %}
          <div style="margin-top:30px">
            <h5 style="margin-bottom:15px">Video de presentation</h5>
            <video controls style="width:100%;border-radius:10px;max-height:360px">
              <source src="{{ asset(destination.videoPath) }}" type="video/mp4">
            </video>
          </div>
        {% endif %}

        {% if destination.latitude and destination.longitude %}
          <div style="margin-top:30px">
            <h5 style="margin-bottom:15px">Localisation</h5>
            <iframe
              src="https://www.google.com/maps?q={{ destination.latitude }},{{ destination.longitude }}&z=12&output=embed"
              width="100%" height="300" frameborder="0"
              style="border:0;border-radius:10px" allowfullscreen="">
            </iframe>
          </div>
        {% endif %}

      </div>

      <div class="col-lg-4">

        <div class="info-table">
          <ul>
            <li>
              <img src="{{ asset("assets_front/images/images/info-icon-01.png") }}" alt="" style="max-width:52px">
              <h4>{{ destination.pays }}<br><span>Pays</span></h4>
            </li>
            <li>
              <img src="{{ asset("assets_front/images/images/info-icon-02.png") }}" alt="" style="max-width:52px">
              <h4>{{ destination.meilleureSaison ?? "-" }}<br><span>Meilleure saison</span></h4>
            </li>
            <li>
              <img src="{{ asset("assets_front/images/images/info-icon-03.png") }}" alt="" style="max-width:52px">
              <h4>{{ destination.nbVisites ?? 0 }}<br><span>Visites</span></h4>
            </li>
            <li>
              <img src="{{ asset("assets_front/images/images/info-icon-04.png") }}" alt="" style="max-width:52px">
              <h4>{{ destination.statut ? "Actif" : "Inactif" }}<br><span>Statut</span></h4>
            </li>
          </ul>
        </div>

        {% if destination.voyage %}
          <div class="info-table" style="margin-top:20px">
            <ul>
              <li style="display:block;padding:15px">
                <h5 style="margin-bottom:12px;border-bottom:1px solid #eee;padding-bottom:8px">Voyage associe</h5>
                <p style="margin:6px 0">Depart : <strong>{{ destination.voyage.pointDepart ?? "-" }}</strong></p>
                <p style="margin:6px 0">Arrivee : <strong>{{ destination.voyage.pointArrivee ?? "-" }}</strong></p>
                <p style="margin:6px 0">Date depart : <strong>{{ destination.voyage.dateDepart ? destination.voyage.dateDepart|date("d/m/Y") : "-" }}</strong></p>
                <p style="margin:6px 0">Date arrivee : <strong>{{ destination.voyage.dateArrivee ? destination.voyage.dateArrivee|date("d/m/Y") : "-" }}</strong></p>
                <p style="margin:6px 0">Prix : <strong>{{ destination.voyage.prix ? destination.voyage.prix ~ " EUR" : "-" }}</strong></p>
              </li>
            </ul>
          </div>
        {% endif %}

        {% if destination.transports is defined and destination.transports|length > 0 %}
          <div class="info-table" style="margin-top:20px">
            <ul>
              <li style="display:block;padding:15px">
                <h5 style="margin-bottom:12px;border-bottom:1px solid #eee;padding-bottom:8px">Transports disponibles</h5>
                {% for transport in destination.transports %}
                  <p style="margin:6px 0">
                    {% if transport.typeTransport == "Avion" %}
                      <i class="fa fa-plane" style="color:#f97316;margin-right:6px"></i>
                    {% elseif transport.typeTransport == "Bus" %}
                      <i class="fa fa-bus" style="color:#f97316;margin-right:6px"></i>
                    {% elseif transport.typeTransport == "Train" %}
                      <i class="fa fa-train" style="color:#f97316;margin-right:6px"></i>
                    {% elseif transport.typeTransport == "Voiture" %}
                      <i class="fa fa-car" style="color:#f97316;margin-right:6px"></i>
                    {% endif %}
                    <strong>{{ transport.typeTransport }}</strong>
                  </p>
                {% endfor %}
              </li>
            </ul>
          </div>
        {% endif %}

        <div class="main-button" style="margin-top:20px">
          <a href="{{ path("app_contact") }}">Reserver cette destination</a>
        </div>
        <div style="margin-top:15px;text-align:center">
          <a href="{{ path("app_destinations") }}" style="color:#888;font-size:13px">Retour aux destinations</a>
        </div>

      </div>
    </div>
  </div>
</div>

<footer>
  <div class="container">
    <div class="col-lg-12">
      <p>Copyright &copy; 2026 VoyageLoisir. Design: <a href="https://templatemo.com" target="_blank">TemplateMo</a></p>
    </div>
  </div>
</footer>

<script>
function switchImage(thumb) {
  var main = document.getElementById('main-img');
  main.style.opacity = '0';
  setTimeout(function() {
    main.src = thumb.src;
    main.style.opacity = '1';
  }, 150);

  document.querySelectorAll('.row img[onclick]').forEach(function(img) {
    img.style.border = '3px solid transparent';
  });
  thumb.style.border = '3px solid #f97316';
}
</script>

{% endblock %}