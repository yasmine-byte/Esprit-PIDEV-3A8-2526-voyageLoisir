{% extends "base_front.html.twig" %}

{% block title %}{{ destination.nom }} — VoyageLoisir{% endblock %}

{% block body %}

<div id="js-preloader" class="js-preloader">
  <div class="preloader-inner">
    <span class="dot"></span>
    <div class="dots"><span></span><span></span><span></span></div>
  </div>
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap');

:root {
  --accent: #c8956c;
  --accent-light: rgba(200,149,108,0.15);
  --accent-border: rgba(200,149,108,0.3);
  --dark: #0d0e12;
  --dark2: #13141a;
  --dark3: #1a1b22;
  --text-white: rgba(255,255,255,0.92);
  --text-muted: rgba(255,255,255,0.42);
  --text-mid: rgba(255,255,255,0.65);
  --card-bg: #ffffff;
  --card-border: #eeece8;
  --body-text: #2c2b28;
  --muted-text: #8a8880;
  --radius: 20px;
  --radius-sm: 12px;
  --cream: #f7f5f1;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
body, html { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--body-text); }

/* ===== HERO ===== */
.vl-hero {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  max-height: 800px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.vl-hero-slider { position: absolute; inset: 0; }

.vl-slide {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  opacity: 0;
  transition: opacity 1.2s ease;
}

.vl-slide.active { opacity: 1; }

.vl-hero-veil {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to top, rgba(10,9,8,0.96) 0%, rgba(10,9,8,0.6) 40%, rgba(10,9,8,0.15) 100%),
    linear-gradient(to right, rgba(10,9,8,0.4) 0%, transparent 60%);
  z-index: 1;
}

.vl-hero-content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 0 80px 72px;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: flex-end;
  gap: 60px;
}

.vl-breadcrumb {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 24px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
}
.vl-breadcrumb a { color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
.vl-breadcrumb a:hover { color: var(--accent); }
.vl-breadcrumb-sep { opacity: 0.3; }

.vl-hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--accent-light);
  border: 1px solid var(--accent-border);
  color: var(--accent);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  padding: 6px 16px;
  border-radius: 30px;
  margin-bottom: 20px;
}

.vl-hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(52px, 7vw, 96px);
  font-weight: 300;
  color: var(--text-white);
  line-height: 0.95;
  letter-spacing: -2px;
  margin-bottom: 28px;
}
.vl-hero-title em { font-style: italic; color: var(--accent); }

.vl-hero-desc {
  font-size: 15px;
  font-weight: 300;
  color: var(--text-mid);
  line-height: 1.8;
  max-width: 520px;
  margin-bottom: 36px;
}

.vl-hero-meta { display: flex; align-items: center; gap: 0; }

.vl-meta-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-right: 28px;
  margin-right: 28px;
  border-right: 1px solid rgba(255,255,255,0.12);
}
.vl-meta-item:last-child { border-right: none; margin-right: 0; padding-right: 0; }
.vl-meta-val { font-size: 18px; font-weight: 500; color: var(--text-white); line-height: 1; }
.vl-meta-key { font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-muted); }

.vl-hero-score { text-align: right; }
.vl-score-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 88px;
  font-weight: 300;
  color: var(--text-white);
  line-height: 1;
  letter-spacing: -4px;
}
.vl-score-sub { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-top: 4px; }
.vl-stars { display: flex; justify-content: flex-end; gap: 4px; margin-top: 10px; }
.vl-star { width: 14px; height: 14px; fill: var(--accent); }
.vl-star.empty { fill: rgba(255,255,255,0.15); }

.vl-dots { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 3; }
.vl-dot { width: 6px; height: 6px; border-radius: 3px; background: rgba(255,255,255,0.25); cursor: pointer; transition: all 0.3s; }
.vl-dot.active { width: 24px; background: var(--accent); }

/* ===== TRANSLATE BAR ===== */
.vl-trad-bar {
  position: sticky;
  top: 0;
  z-index: 500;
  background: rgba(247,245,241,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--card-border);
  padding: 10px 80px;
  display: flex;
  align-items: center;
  gap: 16px;
}

#pt-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  border: 1px solid var(--card-border);
  box-shadow: 0 12px 40px rgba(0,0,0,0.1);
  min-width: 190px;
  overflow: hidden;
  z-index: 600;
  display: none;
}
#pt-dropdown.open { display: block; }

.pt-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  font-size: 13px;
  color: var(--body-text);
  cursor: pointer;
  transition: background 0.15s;
  border: none;
  background: none;
  width: 100%;
  text-align: left;
}
.pt-option:hover, .pt-option.active { background: var(--accent-light); color: var(--accent); }

/* ===== LAYOUT PRINCIPAL — 2 colonnes ===== */
.vl-main {
  max-width: 1320px;
  margin: 0 auto;
  padding: 60px 80px 0;
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 40px;
  align-items: start;
}

/* ===== CARDS ===== */
.vl-card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: var(--radius);
  padding: 36px 40px;
  margin-bottom: 24px;
}

.vl-section-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 10px;
}

.vl-section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 30px;
  font-weight: 400;
  color: var(--body-text);
  margin-bottom: 16px;
  line-height: 1.2;
}

.vl-section-divider { width: 40px; height: 1px; background: var(--accent); margin-bottom: 20px; opacity: 0.5; }
.vl-section-text { font-size: 15px; font-weight: 300; color: var(--muted-text); line-height: 1.9; }

/* ===== GALERIE PLEIN ÉCRAN ===== */
.vl-fullwidth-section {
  max-width: 1320px;
  margin: 0 auto;
  padding: 0 80px;
}

.vl-fullwidth-card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: var(--radius);
  padding: 48px 52px;
  margin-bottom: 32px;
}

/* Galerie masonry plein écran */
.vl-gallery-full {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 240px;
  gap: 12px;
  margin-top: 28px;
}

.vl-gallery-full .vl-gallery-item:nth-child(1) { grid-column: span 2; grid-row: span 2; }
.vl-gallery-full .vl-gallery-item:nth-child(5) { grid-column: span 2; }

.vl-gallery-item {
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
  cursor: pointer;
}

.vl-gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.vl-gallery-item:hover img { transform: scale(1.06); }

.vl-gallery-overlay {
  position: absolute;
  inset: 0;
  background: rgba(200,149,108,0.25);
  opacity: 0;
  transition: opacity 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vl-gallery-item:hover .vl-gallery-overlay { opacity: 1; }

/* ===== METEO PLEIN ÉCRAN ===== */
.vl-meteo-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
  gap: 12px;
  margin-top: 20px;
}

.vl-meteo-card {
  background: #f9f8f5;
  border: 1px solid var(--card-border);
  border-radius: var(--radius-sm);
  padding: 20px 14px;
  text-align: center;
  transition: all 0.2s;
}

.vl-meteo-card:hover {
  border-color: var(--accent-border);
  background: var(--accent-light);
}

/* ===== YOUTUBE PLEIN ÉCRAN ===== */
.vl-yt-fullwidth {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 40px;
  align-items: start;
  margin-top: 24px;
}

.vl-video-wrap {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.vl-video-wrap iframe,
.vl-video-wrap video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* ===== ITINÉRAIRE ===== */
.vl-itin-btns { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px; }

.vl-btn-itin {
  padding: 10px 26px;
  border-radius: 30px;
  border: 1px solid var(--accent-border);
  background: transparent;
  color: var(--accent);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.2s;
}

.vl-btn-itin:hover { background: var(--accent); color: white; border-color: var(--accent); }

/* ===== MODAL ITINÉRAIRE ===== */
#modal-itineraire {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(10,9,8,0.82);
  backdrop-filter: blur(8px);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

#modal-inner {
  background: #13141a;
  border-radius: var(--radius);
  width: 100%;
  max-width: 960px;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.itin-day-card {
  background: #1a1b22;
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-bottom: 14px;
  border: 1px solid rgba(255,255,255,0.06);
}

.itin-day-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 18px 24px;
  background: rgba(200,149,108,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.itin-day-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 300;
  color: var(--accent);
  line-height: 1;
  min-width: 44px;
}

.itin-day-title { font-size: 15px; font-weight: 500; color: rgba(255,255,255,0.9); }
.itin-slots { padding: 8px 24px 16px; }

.itin-slot {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.itin-slot:last-child { border-bottom: none; }

.itin-slot-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: rgba(255,255,255,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}

.itin-slot-lbl { font-size: 10px; font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); margin-bottom: 4px; }
.itin-slot-txt { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.7; }

/* ===== VOYAGE BTN ===== */
.vl-voyage-btn {
  padding: 7px 16px;
  border-radius: 20px;
  border: 1px solid var(--card-border);
  background: white;
  color: var(--muted-text);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.2s;
}
.vl-voyage-btn.active, .vl-voyage-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }

/* ===== MAP ===== */
.vl-map-btn {
  padding: 7px 16px;
  border-radius: 20px;
  border: 1px solid var(--card-border);
  background: white;
  color: var(--muted-text);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.2s;
  white-space: nowrap;
}
.vl-map-btn.active, .vl-map-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }

/* ===== SIDEBAR ===== */
.vl-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 20px;
}

.vl-stat {
  background: #f9f8f5;
  border: 1px solid var(--card-border);
  border-radius: var(--radius-sm);
  padding: 18px 16px;
}

.vl-stat-val { font-size: 17px; font-weight: 500; color: var(--body-text); margin-bottom: 4px; line-height: 1.2; }
.vl-stat-key { font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted-text); }

/* ===== TICKET ===== */
.vl-ticket {
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
  min-height: 200px;
  margin-bottom: 14px;
  cursor: pointer;
  transition: transform 0.3s;
}
.vl-ticket:hover { transform: translateY(-4px); }

.vl-ticket-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.45) saturate(1.1);
  transition: transform 0.5s;
}
.vl-ticket:hover .vl-ticket-bg { transform: scale(1.05); }

.vl-ticket-veil {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, rgba(0,0,0,0.05), rgba(0,0,0,0.7));
}

.vl-ticket-notch { position: absolute; top: 50%; width: 20px; height: 20px; border-radius: 50%; background: var(--cream); z-index: 2; }
.vl-ticket-notch.l { left: -10px; transform: translateY(-50%); }
.vl-ticket-notch.r { right: -10px; transform: translateY(-50%); }

.vl-ticket-inner {
  position: relative;
  z-index: 3;
  padding: 22px 22px 18px;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.vl-ticket-route {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  padding: 14px 16px;
  margin: 12px 0;
  gap: 10px;
}

.vl-ticket-city { flex: 1; font-size: 15px; font-weight: 500; color: white; text-transform: uppercase; letter-spacing: 0.5px; }
.vl-ticket-city-date { font-size: 10px; color: rgba(255,255,255,0.45); margin-top: 3px; font-weight: 400; text-transform: none; letter-spacing: 0; }
.vl-ticket-arr { text-align: right; }
.vl-ticket-line { display: flex; align-items: center; gap: 0; flex: 0; }
.vl-ticket-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.4); }
.vl-ticket-seg { width: 22px; height: 1px; background: rgba(255,255,255,0.25); }

.vl-conv-btn {
  padding: 3px 10px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.7);
  font-size: 10px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.2s;
}
.vl-conv-btn.active { background: rgba(255,255,255,0.25); font-weight: 700; }

.vl-reserve-btn {
  display: block;
  width: 100%;
  padding: 11px;
  background: var(--accent);
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  margin-top: 14px;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.2s;
  text-align: center;
  text-decoration: none;
}
.vl-reserve-btn:hover { background: #b8845a; color: white; }

/* ===== SHARE CARD ===== */
.vl-share-card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: var(--radius);
  padding: 28px 32px;
  text-align: center;
  margin-top: 4px;
}

.vl-back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--muted-text);
  text-decoration: none;
  margin-top: 16px;
  transition: color 0.2s;
}
.vl-back:hover { color: var(--accent); }

/* ===== SECTION SEPARATOR ===== */
.vl-sep {
  max-width: 1320px;
  margin: 0 auto 40px;
  padding: 0 80px;
  display: flex;
  align-items: center;
  gap: 20px;
}
.vl-sep-line { flex: 1; height: 1px; background: var(--card-border); }
.vl-sep-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--accent);
  white-space: nowrap;
}

/* ===== BOTTOM PADDING ===== */
.vl-page-bottom { padding-bottom: 100px; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-up { animation: fadeUp 0.6s ease both; }
</style>

{# ===== HERO ===== #}
<div class="vl-hero">
  <div class="vl-hero-slider">
    {% if destination.images|length > 0 %}
      {% for image in destination.images %}
        <img src="{{ asset(image.urlImage) }}" alt="{{ destination.nom }}" class="vl-slide{% if loop.first %} active{% endif %}">
      {% endfor %}
    {% else %}
      <img src="{{ asset('assets_front/images/images/single-property.jpg') }}" alt="{{ destination.nom }}" class="vl-slide active">
    {% endif %}
  </div>
  <div class="vl-hero-veil"></div>

  <div class="vl-hero-content fade-up">
    <div>
      <div class="vl-breadcrumb">
        <a href="{{ path('app_destinations') }}">Accueil</a>
        <span class="vl-breadcrumb-sep">—</span>
        <a href="{{ path('app_destinations') }}">Destinations</a>
        <span class="vl-breadcrumb-sep">—</span>
        <span style="color: var(--text-mid)">{{ destination.nom }}</span>
      </div>

      <div class="vl-hero-tag">
        <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);display:inline-block;flex-shrink:0"></span>
        {{ destination.pays }}
      </div>

      <h1 class="vl-hero-title">
        {% set words = destination.nom|split(' ') %}
        {% if words|length > 1 %}
          {{ words[0] }} <em>{{ words[1:]|join(' ') }}</em>
        {% else %}
          <em>{{ destination.nom }}</em>
        {% endif %}
      </h1>

      <p class="vl-hero-desc">{{ destination.description|slice(0, 160) }}{% if destination.description|length > 160 %}…{% endif %}</p>

      <div class="vl-hero-meta">
        <div class="vl-meta-item">
          <div class="vl-meta-val">{{ destination.nbVisites ?? 0 }}</div>
          <div class="vl-meta-key">Visites</div>
        </div>
        {% if destination.meilleureSaison %}
        <div class="vl-meta-item">
          <div class="vl-meta-val">{{ destination.meilleureSaison }}</div>
          <div class="vl-meta-key">Meilleure saison</div>
        </div>
        {% endif %}
        <div class="vl-meta-item">
          <div class="vl-meta-val" style="color: {% if destination.statut %}#7ec99a{% else %}#e07070{% endif %}">
            {{ destination.statut ? 'Actif' : 'Inactif' }}
          </div>
          <div class="vl-meta-key">Statut</div>
        </div>
        <div class="vl-meta-item">
          <div class="vl-meta-val">{{ destination.nbLikes ?? 0 }}</div>
          <div class="vl-meta-key">J'aime</div>
        </div>
      </div>
    </div>

    <div class="vl-hero-score">
      {% set note_visites = 0 %}
      {% if destination.nbVisites >= 10000 %}{% set note_visites = 2.5 %}
      {% elseif destination.nbVisites >= 5000 %}{% set note_visites = 2 %}
      {% elseif destination.nbVisites >= 2000 %}{% set note_visites = 1.5 %}
      {% elseif destination.nbVisites >= 1000 %}{% set note_visites = 1 %}
      {% elseif destination.nbVisites >= 500 %}{% set note_visites = 0.5 %}{% endif %}
      {% set note_saison = 0 %}
      {% if destination.meilleureSaison == "Ete" %}{% set note_saison = 2.5 %}
      {% elseif destination.meilleureSaison == "Printemps" %}{% set note_saison = 2 %}
      {% elseif destination.meilleureSaison == "Automne" %}{% set note_saison = 1.5 %}
      {% elseif destination.meilleureSaison == "Hiver" %}{% set note_saison = 1 %}{% endif %}
      {% set note_jaimes = 0 %}
      {% if destination.nbLikes >= 50 %}{% set note_jaimes = 1 %}
      {% elseif destination.nbLikes >= 20 %}{% set note_jaimes = 0.75 %}
      {% elseif destination.nbLikes >= 10 %}{% set note_jaimes = 0.5 %}
      {% elseif destination.nbLikes >= 5 %}{% set note_jaimes = 0.25 %}
      {% elseif destination.nbLikes >= 1 %}{% set note_jaimes = 0.1 %}{% endif %}
      {% set note_totale = note_visites + note_saison + note_jaimes %}
      {% if note_totale > 5 %}{% set note_totale = 5 %}{% endif %}
      {% set etoiles_pleines = note_totale|round(0, 'floor') %}
      {% set demi_etoile = ((note_totale - etoiles_pleines) >= 0.5) ? 1 : 0 %}
      {% set etoiles_vides = 5 - etoiles_pleines - demi_etoile %}

      <div class="vl-score-num">{{ note_totale|number_format(1) }}</div>
      <div class="vl-score-sub">/ 5 · Note globale</div>
      <div class="vl-stars">
        {% for i in 1..etoiles_pleines %}
          <svg class="vl-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endfor %}
        {% if demi_etoile %}
          <svg class="vl-star" viewBox="0 0 24 24"><defs><linearGradient id="h2"><stop offset="50%" stop-color="#c8956c"/><stop offset="50%" stop-color="rgba(255,255,255,0.15)"/></linearGradient></defs><path fill="url(#h2)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endif %}
        {% for i in 1..etoiles_vides %}
          <svg class="vl-star empty" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="vl-dots" id="vl-dots"></div>
</div>

<script>
(function(){
  var cur=0, timer=null;
  var slides=document.querySelectorAll('.vl-slide');
  var dotsEl=document.getElementById('vl-dots');
  if(!slides||slides.length<=1) return;
  var dots=[];
  for(var i=0;i<slides.length;i++){
    (function(idx){
      var d=document.createElement('div');
      d.className='vl-dot'+(idx===0?' active':'');
      d.onclick=function(){go(idx);};
      dotsEl.appendChild(d);
      dots.push(d);
    })(i);
  }
  function go(i){
    slides[cur].classList.remove('active');dots[cur].classList.remove('active');
    cur=i;slides[cur].classList.add('active');dots[cur].classList.add('active');
    clearInterval(timer);timer=setInterval(function(){go((cur+1)%slides.length);},7000);
  }
  timer=setInterval(function(){go((cur+1)%slides.length);},7000);
})();
</script>

{# ===== BARRE DE TRADUCTION ===== #}
<div class="vl-trad-bar">
  <div style="position:relative">
    <button id="pt-toggle-btn" onclick="toggleDropdown()" style="display:flex;align-items:center;gap:8px;padding:8px 18px;border-radius:30px;border:1px solid var(--accent-border);background:transparent;color:var(--accent);font-size:12px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;letter-spacing:0.5px">
      <span id="pt-flag">🌍</span>
      <span id="pt-label">Traduire la page</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div id="pt-dropdown">
      <button class="pt-option" data-lang="en" onclick="choisirLang('en','🇬🇧','English')">🇬🇧 English</button>
      <button class="pt-option" data-lang="ar" onclick="choisirLang('ar','🇸🇦','العربية')">🇸🇦 العربية</button>
      <button class="pt-option" data-lang="es" onclick="choisirLang('es','🇪🇸','Español')">🇪🇸 Español</button>
      <button class="pt-option" data-lang="de" onclick="choisirLang('de','🇩🇪','Deutsch')">🇩🇪 Deutsch</button>
      <button class="pt-option" data-lang="it" onclick="choisirLang('it','🇮🇹','Italiano')">🇮🇹 Italiano</button>
      <button class="pt-option" data-lang="tr" onclick="choisirLang('tr','🇹🇷','Türkçe')">🇹🇷 Türkçe</button>
      <button class="pt-option" data-lang="zh" onclick="choisirLang('zh','🇨🇳','中文')">🇨🇳 中文</button>
      <button class="pt-option" data-lang="ja" onclick="choisirLang('ja','🇯🇵','日本語')">🇯🇵 日本語</button>
      <div style="border-top:1px solid var(--card-border);margin:4px 0"></div>
      <button class="pt-option" onclick="restaurerPage();fermerDropdown()">↺ Original (Français)</button>
    </div>
  </div>
  <span id="pt-status" style="font-size:12px;color:var(--accent);font-weight:500;display:none"></span>
</div>

<script>
function toggleDropdown(){document.getElementById('pt-dropdown').classList.toggle('open');}
function fermerDropdown(){document.getElementById('pt-dropdown').classList.remove('open');}
function choisirLang(lang,flag,label){fermerDropdown();document.getElementById('pt-flag').textContent=flag;document.getElementById('pt-label').textContent=label;document.querySelectorAll('.pt-option').forEach(function(b){b.classList.remove('active');});var opt=document.querySelector('.pt-option[data-lang="'+lang+'"]');if(opt)opt.classList.add('active');traduirePage(lang);}
document.addEventListener('click',function(e){if(!e.target.closest('.vl-trad-bar'))fermerDropdown();});
</script>

<script>
(function(){
  var _originals=null,_currentLang=null,MAX=450;
  function collectNodes(){var root=document.body;if(!root)return[];var result=[];var walker=document.createTreeWalker(root,NodeFilter.SHOW_TEXT,{acceptNode:function(node){if(!node.textContent.trim())return NodeFilter.FILTER_REJECT;var p=node.parentElement;if(!p)return NodeFilter.FILTER_REJECT;var tag=p.tagName.toLowerCase();if(['script','style','noscript','iframe','code'].indexOf(tag)>=0)return NodeFilter.FILTER_REJECT;if(p.closest('.vl-trad-bar'))return NodeFilter.FILTER_REJECT;if(p.closest('#pt-dropdown'))return NodeFilter.FILTER_REJECT;if(p.closest('#js-preloader'))return NodeFilter.FILTER_REJECT;return NodeFilter.FILTER_ACCEPT;}});var n;while((n=walker.nextNode()))result.push(n);return result;}
  function sauvegarderOriginaux(nodes){_originals=new Map();nodes.forEach(function(n){_originals.set(n,n.textContent);});}
  function restaurerOriginaux(nodes){if(!_originals)return;nodes.forEach(function(n){if(_originals.has(n))n.textContent=_originals.get(n);});}
  function splitLongText(text,maxLen){var trimmed=text.trim();if(trimmed.length<=maxLen)return[trimmed];var parts=[];var remaining=trimmed;while(remaining.length>maxLen){var cut=remaining.lastIndexOf(' ',maxLen);if(cut<Math.floor(maxLen*0.6))cut=maxLen;parts.push(remaining.slice(0,cut).trim());remaining=remaining.slice(cut).trim();}if(remaining)parts.push(remaining);return parts;}
  function traduireChunk(chunk,lang){return fetch('https://api.mymemory.translated.net/get?q='+encodeURIComponent(chunk)+'&langpair=fr|'+lang).then(function(r){return r.json();}).then(function(d){var t=d&&d.responseData&&d.responseData.translatedText?d.responseData.translatedText:'';if(!t||/QUERY LENGTH LIMIT EXCEEDED/i.test(t))return chunk;return t;}).catch(function(){return chunk;});}
  function grouperNoeuds(nodes){var groupes=[],courant={nodes:[],textes:[],total:0};function pushCurrent(){if(courant.nodes.length>0){groupes.push(courant);courant={nodes:[],textes:[],total:0};}}nodes.forEach(function(n){var text=n.textContent.trim();if(!text)return;splitLongText(text,MAX).forEach(function(part,index,allParts){if(courant.total+part.length+1>MAX)pushCurrent();var nodeRef=index===0?n:null;courant.nodes.push(nodeRef);courant.textes.push(part);courant.total+=part.length+1;if(index<allParts.length-1)pushCurrent();});});pushCurrent();return groupes;}
  function appliquerTraductionAuGroupe(groupe,traduit){var lignes=traduit.split('\n');var buffer=[];groupe.nodes.forEach(function(nodeRef,i){buffer.push(lignes[i]!==undefined?lignes[i]:groupe.textes[i]);if(nodeRef){nodeRef.textContent=buffer.join(' ');buffer=[];}});}
  window.traduirePage=function(lang){if(_currentLang===lang)return;_currentLang=lang;var nodes=collectNodes();if(!_originals)sauvegarderOriginaux(nodes);else restaurerOriginaux(nodes);var groupes=grouperNoeuds(nodes);var status=document.getElementById('pt-status');status.style.display='inline';status.textContent='⟳ Traduction... (0/'+groupes.length+')';var done=0;Promise.all(groupes.map(function(g){return traduireChunk(g.textes.join('\n'),lang).then(function(traduit){appliquerTraductionAuGroupe(g,traduit);done++;status.textContent='⟳ ('+done+'/'+groupes.length+')';});})).then(function(){status.textContent='✓ Traduit';setTimeout(function(){status.style.display='none';},3000);});};
  window.restaurerPage=function(){_currentLang=null;var nodes=collectNodes();if(_originals)restaurerOriginaux(nodes);document.getElementById('pt-status').style.display='none';};
})();
</script>

{# ===== LAYOUT PRINCIPAL 2 COLONNES — description + sidebar ===== #}
<div id="vl-page-content">
<div class="vl-main">

  {# COLONNE GAUCHE #}
  <div>
    {# DESCRIPTION #}
    <div class="vl-card fade-up">
      <div class="vl-section-label">À propos</div>
      <h2 class="vl-section-title">{{ destination.nom }}, {{ destination.pays }}</h2>
      <div class="vl-section-divider"></div>
      <p class="vl-section-text">{{ destination.description ?? 'Aucune description disponible.' }}</p>
    </div>

    {# ITINÉRAIRE IA #}
    <div class="vl-card fade-up">
      <div class="vl-section-label">Intelligence artificielle</div>
      <h3 class="vl-section-title" style="font-size:22px">Programme de voyage</h3>
      <p class="vl-section-text" style="margin-bottom:20px">Choisissez la durée et l'IA génère votre programme complet jour par jour.</p>
      <div class="vl-itin-btns">
        {% for d in [3, 5, 7] %}
        <button type="button" class="vl-btn-itin" onclick="genererItineraire({{ d }})">{{ d }} jours</button>
        {% endfor %}
        <span id="itineraire-loading" style="display:none;font-size:13px;color:var(--accent);align-self:center">⟳ Génération...</span>
      </div>
    </div>

    {# CARTE LEAFLET #}
    {% if destination.latitude and destination.longitude %}
    {% set voyagesAvecDepart = [] %}
    {% for v in destination.voyages %}{% if v.pointDepart %}{% set voyagesAvecDepart = voyagesAvecDepart|merge([v]) %}{% endif %}{% endfor %}
    <div class="vl-card fade-up">
      <div class="vl-section-label">Localisation</div>
      <h3 class="vl-section-title" style="font-size:22px">Carte & Trajets</h3>
      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      {% if voyagesAvecDepart|length > 0 %}
      <div style="margin-bottom:14px;display:flex;flex-wrap:wrap;gap:8px">
        {% for v in voyagesAvecDepart %}
          {% set ticons = {'Avion': '✈', 'Bus': '🚌', 'Train': '🚆', 'Voiture': '🚗'} %}
          {% set transportIcons = '' %}
          {% for t in v.transports %}{% set transportIcons = transportIcons ~ (ticons[t.typeTransport] ?? '') %}{% endfor %}
          <button type="button" id="map-btn-{{ v.id }}" onclick="showVoyageRoute({{ v.id }})" class="vl-map-btn{% if loop.first %} active{% endif %}">
            {{ transportIcons }} Voyage {{ v.id }}
          </button>
        {% endfor %}
      </div>
      {% endif %}
      <div id="trajet-map" style="height:380px;border-radius:var(--radius-sm);border:1px solid var(--card-border);z-index:1;position:relative;margin-top:16px"></div>
      <div id="route-info" style="display:none;margin-top:12px;padding:14px 18px;background:#f9f8f5;border-radius:10px;border:1px solid var(--card-border);font-size:13px;color:var(--body-text);line-height:1.7"></div>
      <small style="color:#ccc;font-size:11px;margin-top:8px;display:block;text-align:right">OpenStreetMap / OSRM</small>
    </div>
    <script>
    (function(){
      var destLat={{ destination.latitude }},destLng={{ destination.longitude }},destNom="{{ destination.nom|e('js') }}",destPays="{{ destination.pays|e('js') }}";
      var VOYAGES_MAP=[{% for v in voyagesAvecDepart %}{id:{{ v.id }},depart:"{{ v.pointDepart|e('js') }}",arrivee:"{{ v.pointArrivee ? v.pointArrivee|e('js') : '' }}",transports:[{% for t in v.transports %}"{{ t.typeTransport|e('js') }}"{% if not loop.last %},{% endif %}{% endfor %}],dateD:"{{ v.dateDepart ? v.dateDepart|date('d/m/Y') : '' }}",dateA:"{{ v.dateArrivee ? v.dateArrivee|date('d/m/Y') : '' }}"}{% if not loop.last %},{% endif %}{% endfor %}];
      var map=L.map("trajet-map").setView([destLat,destLng],5);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{attribution:"© OpenStreetMap"}).addTo(map);
      var destIcon=L.divIcon({className:"",html:"<div style='width:16px;height:16px;border-radius:50%;background:#c8956c;border:3px solid white;box-shadow:0 2px 8px rgba(200,149,108,0.5)'></div>",iconSize:[16,16],iconAnchor:[8,8]});
      L.marker([destLat,destLng],{icon:destIcon}).addTo(map).bindPopup("<strong style='color:#c8956c'>"+destNom+"</strong><br><small>Destination</small>").openPopup();
      var routeLayers=[];
      function clearRoute(){routeLayers.forEach(function(l){map.removeLayer(l);});routeLayers=[];document.getElementById("route-info").style.display="none";}
      function addLayer(l){l.addTo(map);routeLayers.push(l);return l;}
      function geocode(q,cb){fetch("https://nominatim.openstreetmap.org/search?q="+encodeURIComponent(q)+"&format=json&limit=1",{headers:{"Accept-Language":"fr"}}).then(function(r){return r.json();}).then(function(d){cb(d&&d.length>0?[parseFloat(d[0].lat),parseFloat(d[0].lon)]:null);}).catch(function(){cb(null);});}
      function findAirport(name,cb){geocode(name+" aéroport international",function(c){if(c){cb(c);return;}geocode(name+" airport",cb);});}
      function getOsrmRoute(la1,lo1,la2,lo2,cb){fetch("https://router.project-osrm.org/route/v1/driving/"+lo1+","+la1+";"+lo2+","+la2+"?overview=full&geometries=geojson").then(function(r){return r.json();}).then(function(d){cb(d&&d.code==="Ok"&&d.routes&&d.routes[0]?d.routes[0]:null);}).catch(function(){cb(null);});}
      function haversine(la1,lo1,la2,lo2){var R=6371,dLa=(la2-la1)*Math.PI/180,dLo=(lo2-lo1)*Math.PI/180;var a=Math.sin(dLa/2)*Math.sin(dLa/2)+Math.cos(la1*Math.PI/180)*Math.cos(la2*Math.PI/180)*Math.sin(dLo/2)*Math.sin(dLo/2);return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));}
      function fmtDur(min){min=Math.round(min);if(min<60)return min+" min";var h=Math.floor(min/60),m=min%60;return h+"h"+(m>0?m+"min":"");}
      function makeArc(la1,lo1,la2,lo2,color,dashed){var mLa=(la1+la2)/2+Math.abs(lo2-lo1)*0.14,mLo=(lo1+lo2)/2,pts=[];for(var t=0;t<=1;t+=0.02)pts.push([(1-t)*(1-t)*la1+2*(1-t)*t*mLa+t*t*la2,(1-t)*(1-t)*lo1+2*(1-t)*t*mLo+t*t*lo2]);return L.polyline(pts,{color:color,weight:3,opacity:0.8,dashArray:dashed?"8 5":null});}
      function mkIcon(la,lo,color,size,popup){var m=L.marker([la,lo],{icon:L.divIcon({className:"",html:"<div style='width:"+size+"px;height:"+size+"px;border-radius:50%;background:"+color+";border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,.3)'></div>",iconSize:[size,size],iconAnchor:[size/2,size/2]})});if(popup)m.bindPopup(popup);return m;}
      function showInfo(html){var el=document.getElementById("route-info");el.innerHTML=html;el.style.display="block";}
      window.showVoyageRoute=function(vid){
        clearRoute();
        VOYAGES_MAP.forEach(function(v){var btn=document.getElementById("map-btn-"+v.id);if(!btn)return;if(v.id===vid)btn.classList.add("active");else btn.classList.remove("active");});
        var voyage=null;for(var i=0;i<VOYAGES_MAP.length;i++){if(VOYAGES_MAP[i].id===vid){voyage=VOYAGES_MAP[i];break;}}
        if(!voyage)return;
        var hasAvion=voyage.transports.indexOf("Avion")>=0,hasTrain=voyage.transports.indexOf("Train")>=0,hasBus=voyage.transports.indexOf("Bus")>=0;
        showInfo("<span style='color:var(--muted-text);font-style:italic'>⟳ Calcul en cours...</span>");
        geocode(voyage.depart,function(depC){
          if(!depC){showInfo("<span style='color:#e07070'>Impossible de localiser : <strong>"+voyage.depart+"</strong></span>");return;}
          var dLa=depC[0],dLo=depC[1];
          addLayer(mkIcon(dLa,dLo,"#c8956c",14,"<strong style='color:#c8956c'>Départ — "+voyage.depart+"</strong>"+(voyage.dateD?"<br><small>"+voyage.dateD+"</small>":"")));
          if(hasAvion){findAirport(voyage.depart,function(depAirC){if(!depAirC)depAirC=depC;findAirport(destNom+" "+destPays,function(destAirC){var aLa=destAirC?destAirC[0]:destLat,aLo=destAirC?destAirC[1]:destLng;if(haversine(dLa,dLo,depAirC[0],depAirC[1])>2){addLayer(makeArc(dLa,dLo,depAirC[0],depAirC[1],"#c8956c",true));addLayer(mkIcon(depAirC[0],depAirC[1],"#7ec9a0",14,"<strong>✈ Aéroport de départ</strong>"));}addLayer(makeArc(depAirC[0],depAirC[1],aLa,aLo,"#c8956c",false));if(destAirC&&haversine(aLa,aLo,destLat,destLng)>2){addLayer(mkIcon(aLa,aLo,"#7ec9a0",14,"<strong>✈ Aéroport d'arrivée</strong>"));addLayer(makeArc(aLa,aLo,destLat,destLng,"#c8956c",true));}var fd=haversine(depAirC[0],depAirC[1],aLa,aLo);showInfo("✈ <strong>"+voyage.depart+" → "+destNom+"</strong> · "+Math.round(fd)+" km · <strong style='color:#c8956c'>"+fmtDur(fd/800*60+120)+"</strong>");var b=L.latLngBounds([[destLat,destLng],[dLa,dLo],[depAirC[0],depAirC[1]]]);if(destAirC)b.extend([aLa,aLo]);map.fitBounds(b,{padding:[40,40]});});});}
          else{getOsrmRoute(dLa,dLo,destLat,destLng,function(route){var tColor="#c8956c",tLabel=hasTrain?"🚆 Train":hasBus?"🚌 Bus":"🚗 Voiture",speed=hasTrain?160:hasBus?70:100;if(route&&route.geometry){var pts=route.geometry.coordinates.map(function(c){return[c[1],c[0]];});addLayer(L.polyline(pts,{color:tColor,weight:3,opacity:0.8}));var distKm=Math.round(route.distance/1000);showInfo(tLabel+" <strong>"+voyage.depart+" → "+destNom+"</strong> · "+distKm+" km · <strong style='color:#c8956c'>"+fmtDur((distKm/speed)*60)+"</strong>");}else{var dist=haversine(dLa,dLo,destLat,destLng);addLayer(makeArc(dLa,dLo,destLat,destLng,tColor,true));showInfo(tLabel+" <strong>"+voyage.depart+" → "+destNom+"</strong> · "+Math.round(dist)+" km");}map.fitBounds(L.latLngBounds([[destLat,destLng],[dLa,dLo]]),{padding:[40,40]});});}
        });
      };
      if(VOYAGES_MAP.length>0)showVoyageRoute(VOYAGES_MAP[0].id);
    })();
    </script>
    {% endif %}

    {# VIDÉO LOCALE #}
    {% if destination.videoPath %}
    <div class="vl-card fade-up">
      <div class="vl-section-label">Présentation</div>
      <h3 class="vl-section-title" style="font-size:22px">Vidéo de la destination</h3>
      <div class="vl-video-wrap" style="margin-top:16px">
        <video controls style="border-radius:var(--radius-sm)">
          <source src="{{ asset(destination.videoPath) }}" type="video/mp4">
        </video>
      </div>
    </div>
    {% endif %}
  </div>

  {# SIDEBAR #}
  <div>
    <div class="vl-stats-grid">
      <div class="vl-stat">
        <div class="vl-stat-val">{{ destination.pays }}</div>
        <div class="vl-stat-key">Pays</div>
      </div>
      <div class="vl-stat">
        <div class="vl-stat-val">{{ destination.meilleureSaison ?? '—' }}</div>
        <div class="vl-stat-key">Saison</div>
      </div>
      <div class="vl-stat">
        <div class="vl-stat-val">{{ destination.nbVisites ?? 0 }}</div>
        <div class="vl-stat-key">Visites</div>
      </div>
      <div class="vl-stat">
        <div class="vl-stat-val" style="color:{% if destination.statut %}#7ec99a{% else %}#e07070{% endif %}">
          {{ destination.statut ? 'Actif' : 'Inactif' }}
        </div>
        <div class="vl-stat-key">Statut</div>
      </div>
    </div>

    {# CONVERTISSEUR #}
    <script>
    var _rateCache={};
    var _rateSym={'EUR':'€','USD':'$','GBP':'£','TND':'TND','MAD':'MAD','JPY':'¥','CAD':'C$','CHF':'Fr'};
    function getRate(from,to,cb){var key=from+'_'+to;if(_rateCache[key]){cb(_rateCache[key]);return;}fetch('{{ path("app_exchange_rate", {"from": "__F__", "to": "__T__"}) }}'.replace('__F__',from).replace('__T__',to)).then(function(r){return r.json();}).then(function(d){if(d.rate){_rateCache[key]=d.rate;cb(d.rate);}}).catch(function(){});}
    function convertirPrix(voyageId,prix,devise){['EUR','USD','GBP','TND','MAD'].forEach(function(d){var btn=document.getElementById('conv-btn-'+voyageId+'-'+d);if(btn){btn.classList.toggle('active',d===devise);}});var displayEl=document.getElementById('conv-display-'+voyageId);if(devise==='EUR'){displayEl.textContent=prix+' €';return;}getRate('EUR',devise,function(rate){displayEl.textContent=(prix*rate).toFixed(2)+' '+(_rateSym[devise]||devise);});}
    </script>

    {# VOYAGES #}
    {% if destination.voyages|length > 0 %}
    <div style="margin-bottom:20px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
        <div>
          <div class="vl-section-label">Offres disponibles</div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:var(--body-text)">Voyages</div>
        </div>
        <span style="background:var(--accent-light);color:var(--accent);border:1px solid var(--accent-border);border-radius:20px;padding:4px 14px;font-size:12px;font-weight:500">
          {{ destination.voyages|length }} voyage{{ destination.voyages|length > 1 ? 's' : '' }}
        </span>
      </div>

      {% set tp_icons = {'Avion': '✈', 'Bus': '🚌', 'Train': '🚆', 'Voiture': '🚗'} %}
      {% for v in destination.voyages %}
        {% if v.dateDepart and v.dateArrivee %}{% set duree = ((v.dateArrivee|date("U") - v.dateDepart|date("U")) / 86400)|round %}{% else %}{% set duree = null %}{% endif %}
        {% set primaryTransport = v.transports|first %}
        {% set bgImg = destination.images|first %}

        <div class="vl-ticket" onclick="if(window.showVoyageRoute)showVoyageRoute({{ v.id }})">
          {% if bgImg %}
            <img class="vl-ticket-bg" src="{{ asset(bgImg.urlImage) }}" alt="">
          {% else %}
            <div style="position:absolute;inset:0;background:linear-gradient(135deg,#1e1a15,#0d0e12)"></div>
          {% endif %}
          <div class="vl-ticket-veil"></div>
          <div class="vl-ticket-notch l"></div>
          <div class="vl-ticket-notch r"></div>

          <div class="vl-ticket-inner">
            <div style="display:flex;justify-content:space-between;align-items:flex-start">
              <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.35)">Voyage #{{ v.id }}</div>
              {% if v.prix %}
              <div style="text-align:right">
                <div style="font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300;color:white;letter-spacing:-1px;line-height:1" id="conv-display-{{ v.id }}">{{ v.prix }} €</div>
                {% if duree %}<div style="font-size:10px;color:rgba(255,255,255,0.35);margin-top:2px">{{ duree }} jour{{ duree > 1 ? 's' : '' }}</div>{% endif %}
              </div>
              {% endif %}
            </div>

            <div class="vl-ticket-route">
              <div class="vl-ticket-city">
                <div>{{ v.pointDepart ?? '?' }}</div>
                <div class="vl-ticket-city-date">{{ v.dateDepart ? v.dateDepart|date('d/m/Y') : '—' }}</div>
              </div>
              <div class="vl-ticket-line">
                <div class="vl-ticket-dot"></div>
                <div class="vl-ticket-seg"></div>
                <span style="font-size:14px;margin:0 4px">{{ primaryTransport ? (tp_icons[primaryTransport.typeTransport] ?? '✈') : '✈' }}</span>
                <div class="vl-ticket-seg"></div>
                <div class="vl-ticket-dot"></div>
              </div>
              <div class="vl-ticket-city vl-ticket-arr">
                <div>{{ v.pointArrivee ?? '?' }}</div>
                <div class="vl-ticket-city-date">{{ v.dateArrivee ? v.dateArrivee|date('d/m/Y') : '—' }}</div>
              </div>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
              <div style="display:flex;gap:5px;flex-wrap:wrap">
                {% for t in v.transports %}
                  <span style="background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);border-radius:30px;padding:3px 10px;font-size:10px;color:rgba(255,255,255,0.65);font-weight:500">{{ tp_icons[t.typeTransport] ?? '' }} {{ t.typeTransport }}</span>
                {% endfor %}
              </div>
            </div>

            {% if v.prix %}
            <div style="display:flex;gap:5px;flex-wrap:wrap;margin-top:10px" onclick="event.stopPropagation()">
              {% for devise in ['EUR','USD','GBP','TND','MAD'] %}
              <button id="conv-btn-{{ v.id }}-{{ devise }}" onclick="convertirPrix({{ v.id }}, {{ v.prix }}, '{{ devise }}')" class="vl-conv-btn {% if devise == 'EUR' %}active{% endif %}">{{ devise }}</button>
              {% endfor %}
            </div>
            {% endif %}

            {% if app.user and v.isReservedByUser(app.user) %}
              <div onclick="event.stopPropagation()" style="margin-top:12px;padding:10px 16px;background:rgba(126,201,154,0.15);border:1px solid rgba(126,201,154,0.3);border-radius:10px;font-size:12px;font-weight:500;text-align:center;color:rgba(126,201,154,0.9)">
                ✓ Déjà réservé
              </div>
            {% elseif app.user %}
              <form action="{{ path('app_voyage_reserve', {id: v.id}) }}" method="POST" onclick="event.stopPropagation()">
                <input type="hidden" name="_token" value="{{ csrf_token('reserve' ~ v.id) }}">
                <button type="submit" class="vl-reserve-btn">Réserver ce voyage</button>
              </form>
            {% else %}
              <a href="{{ path('front_login') }}" onclick="event.stopPropagation()" class="vl-reserve-btn">Connexion requise</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {# PARTAGE QR #}
    <div class="vl-share-card">
      <div class="vl-section-label" style="margin-bottom:16px">Partager</div>
      <div style="display:inline-flex;padding:10px;background:#f9f8f5;border-radius:var(--radius-sm);border:1px solid var(--card-border);margin-bottom:12px">
        <img src="{{ qr_code_url }}" alt="QR Code" style="width:130px;height:130px;display:block">
      </div>
      <p style="font-size:12px;color:var(--muted-text);margin-bottom:14px">Scannez pour partager</p>
      <a href="{{ qr_code_url }}" download="qrcode-{{ destination.nom|replace({' ': '-'}) }}.png"
         style="display:block;padding:11px;background:var(--accent);color:white;border-radius:var(--radius-sm);font-size:13px;font-weight:500;text-decoration:none;transition:all 0.2s"
         onmouseover="this.style.background='#b8845a'" onmouseout="this.style.background='var(--accent)'">
        Télécharger le QR Code
      </a>
      <div style="font-size:10px;color:#ccc;margin-top:12px;word-break:break-all;line-height:1.5">{{ share_url }}</div>
    </div>

    <a href="{{ path('app_destinations') }}" class="vl-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m15 18-6-6 6-6"/></svg>
      Toutes les destinations
    </a>
  </div>
</div>
</div>

{# ======================================================
   GALERIE — PLEIN ÉCRAN HORIZONTAL
   ====================================================== #}
{% if destination.images|length > 0 %}
<div style="height:60px"></div>
<div class="vl-sep">
  <div class="vl-sep-line"></div>
  <span class="vl-sep-label">Galerie photos</span>
  <div class="vl-sep-line"></div>
</div>

<div class="vl-fullwidth-section">
  <div class="vl-fullwidth-card">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:8px">
      <div>
        <div class="vl-section-label">Galerie</div>
        <h3 class="vl-section-title" style="font-size:28px;margin-bottom:0">Photos de {{ destination.nom }}</h3>
      </div>
      <span style="font-size:13px;color:var(--muted-text)">{{ destination.images|length }} photo{{ destination.images|length > 1 ? 's' : '' }}</span>
    </div>

    <div class="vl-gallery-full">
      {% for image in destination.images %}
        <div class="vl-gallery-item" onclick="openLightbox({{ loop.index0 }})">
