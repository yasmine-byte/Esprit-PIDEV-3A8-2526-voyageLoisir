{% extends 'base_front.html.twig' %}

{% block title %}Villa Agency - Home{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .top-destinations-section {
      padding: 48px 0 24px;
      background: #f3f4f6;
    }

    .properties.section + .properties.section {
      display: none;
    }

    .top-destinations-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
      gap: 24px;
      align-items: end;
      margin-bottom: 28px;
    }

    .top-destinations-kicker {
      display: inline-block;
      margin-bottom: 10px;
      color: #f97316;
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .top-destinations-title {
      margin: 0;
      color: #111827;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    .top-destinations-subtitle {
      margin: 0;
      color: #6b7280;
      font-size: 0.98rem;
      line-height: 1.8;
      text-align: right;
    }

    .top-destinations-viewport {
      overflow: hidden;
    }

    .top-destinations-track {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 22px;
      transition: transform 0.35s ease;
    }

    .top-destination-card {
      position: relative;
      min-height: 410px;
      border-radius: 28px;
      overflow: hidden;
      background: #d1d5db;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
      isolation: isolate;
    }

    .top-destination-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.78) 78%, rgba(15, 23, 42, 0.92) 100%);
      z-index: 1;
    }

    .top-destination-media,
    .top-destination-media img {
      width: 100%;
      height: 100%;
    }

    .top-destination-media img {
      display: block;
      object-fit: cover;
    }

    .top-destination-price {
      position: absolute;
      top: 18px;
      right: 18px;
      z-index: 2;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      color: #111827;
      font-size: 0.82rem;
      font-weight: 700;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.14);
    }

    .top-destination-content {
      position: absolute;
      right: 18px;
      bottom: 18px;
      left: 18px;
      z-index: 2;
      color: #fff;
    }

    .top-destination-name {
      margin: 0 0 10px;
      color: #fff;
      font-size: 1.45rem;
      font-weight: 700;
      line-height: 1.15;
    }

    .top-destination-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      margin-bottom: 12px;
    }

    .top-destination-tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      backdrop-filter: blur(8px);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .top-destination-rating,
    .top-destination-location {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      color: rgba(255, 255, 255, 0.92);
      font-size: 0.88rem;
    }

    .top-destinations-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-top: 26px;
    }

    .top-destinations-view-more {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 24px;
      border-radius: 999px;
      background: #111827;
      color: #fff;
      font-size: 0.94rem;
      font-weight: 600;
      text-decoration: none;
      box-shadow: 0 12px 28px rgba(17, 24, 39, 0.16);
    }

    .top-destinations-nav {
      display: flex;
      gap: 10px;
    }

    .top-destinations-arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border: 0;
      border-radius: 50%;
      background: #fff;
      color: #111827;
      box-shadow: 0 10px 26px rgba(15, 23, 42, 0.1);
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .top-destinations-arrow:hover {
      background: #e5e7eb;
      transform: translateY(-1px);
    }

    @media (max-width: 1199px) {
      .top-destinations-track {
        grid-template-columns: repeat(4, minmax(280px, 1fr));
      }
    }

    @media (max-width: 991px) {
      .top-destinations-head {
        grid-template-columns: 1fr;
      }

      .top-destinations-subtitle {
        text-align: left;
      }
    }

    @media (max-width: 767px) {
      .top-destinations-section {
        padding-top: 28px;
      }

      .top-destination-card {
        min-height: 360px;
      }

      .top-destinations-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .top-destinations-nav {
        justify-content: flex-end;
      }
    }
  </style>
{% endblock %}

