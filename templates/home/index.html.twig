            <div class="col-12 text-center">
                <p>Aucun hébergement disponible pour le moment.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

  <div class="properties section">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 offset-lg-4">
                <div class="section-heading text-center">
                    <h6>| Destinations</h6>
                    <h2>Quelques Destinations à Découvrir</h2>
                </div>
            </div>
        </div>
        <div class="row">
            {% for destination in destinations|slice(0, 3) %}
            <div class="col-lg-4 col-md-6">
                <div class="item">
                    {% if destination.images|length > 0 %}
                        <img src="{{ asset(destination.images[0].urlImage) }}" alt="{{ destination.nom }}" style="height: 240px; object-fit: cover;">
                    {% else %}
                        <img src="{{ asset('assets_front/images/images/property-02.jpg') }}" alt="{{ destination.nom }}" style="height: 240px; object-fit: cover;">
                    {% endif %}
                    <span class="category">{{ destination.meilleureSaison ?: 'Destination' }}</span>
                    <h6>{{ destination.pays }}</h6>
                    <h4>{{ destination.nom }}</h4>
                    <ul>
                        <li>Visites: <span>{{ destination.nbVisites ?? 0 }}</span></li>
                        <li>Statut: <span>{{ destination.statut ? 'Actif' : 'Inactif' }}</span></li>
                    </ul>
                    <div class="main-button">
                        <a href="{{ path('app_destination_detail', {'id': destination.id}) }}">Voir la destination</a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center">
                <p>Aucune destination disponible pour le moment.</p>
            </div>
            {% endfor %}
        </div>
        <div class="row">
            <div class="col-12 text-center" style="margin-top: 10px;">
                <div class="main-button">
                    <a href="{{ path('app_destinations') }}">Explorer toutes les destinations</a>
                </div>
            </div>
        </div>
    </div>
  </div>

  <section class="top-destinations-section">
    <div class="container">
      <div class="top-destinations-head">
        <div>
          <span class="top-destinations-kicker">Curated Picks</span>
          <h2 class="top-destinations-title">Top Destinations</h2>
        </div>
        <p class="top-destinations-subtitle">
          Handpicked escapes with beautiful scenery, memorable stays, and inspiring routes for your next trip.
        </p>
      </div>

      <div class="top-destinations-viewport">
        <div class="top-destinations-track" id="top-destinations-track">
          {% for destination in destinations|slice(0, 4) %}
            {% set ratingBase = 3.8 %}
            {% set ratingBoost = (destination.nbVisites ?? 0) >= 5000 ? 1.0 : ((destination.nbVisites ?? 0) >= 2000 ? 0.7 : ((destination.nbVisites ?? 0) >= 500 ? 0.4 : 0.1)) %}
            {% set rating = min(ratingBase + ratingBoost, 5) %}
            {% set reviews = destination.nbVisites ?? 0 %}
            {% set firstVoyage = destination.voyages|length > 0 ? destination.voyages[0] : null %}
            {% set startPrice = firstVoyage and firstVoyage.prix ? firstVoyage.prix : ((destination.nbVisites ?? 0) * 2 + 1499) %}
            <article class="top-destination-card">
              <a href="{{ path('app_destination_detail', {'id': destination.id}) }}" class="top-destination-media">
                {% if destination.images|length > 0 %}
                  <img src="{{ asset(destination.images[0].urlImage) }}" alt="{{ destination.nom }}">
                {% else %}
                  <img src="{{ asset('assets_front/images/images/property-03.jpg') }}" alt="{{ destination.nom }}">
                {% endif %}
              </a>

              <div class="top-destination-price">
                starts at &#8369;{{ startPrice|number_format(0, '.', ',') }}
              </div>

              <div class="top-destination-content">
                <h3 class="top-destination-name">{{ destination.nom }}</h3>
                <div class="top-destination-meta">
                  <span class="top-destination-tag">{{ destination.meilleureSaison ?: 'Signature Escape' }}</span>
                </div>
                <div class="top-destination-meta">
                  <span class="top-destination-rating">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="#fbbf24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <span>{{ rating|number_format(1) }} ({{ reviews }})</span>
                  </span>
                </div>
                <div class="top-destination-location">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" aria-hidden="true"><path d="M12 21s-6-5.33-6-11a6 6 0 1 1 12 0c0 5.67-6 11-6 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
                  <span>{{ destination.pays }}</span>
                </div>
              </div>
            </article>
          {% else %}
            <article class="top-destination-card">
              <div class="top-destination-content">
                <h3 class="top-destination-name">No destinations yet</h3>
                <div class="top-destination-location">
                  <span>New travel spots will appear here soon.</span>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>
      </div>

      <div class="top-destinations-actions">
        <a href="{{ path('app_destinations') }}" class="top-destinations-view-more">View more</a>
        <div class="top-destinations-nav">
          <button class="top-destinations-arrow" id="top-destinations-prev" type="button" aria-label="Previous destinations">&#8249;</button>
          <button class="top-destinations-arrow" id="top-destinations-next" type="button" aria-label="Next destinations">&#8250;</button>
        </div>
      </div>
    </div>
  </section>

  <section class="reviews-section">
    <div class="container">
      <div class="reviews-heading">
        <h2>Blogs</h2>
        <p>Fresh travel stories, destination ideas, and highlights from our latest published blogs.</p>
      </div>

      <div class="reviews-carousel-shell">
        <div class="reviews-track" id="reviews-track">
        {% for blog in blogs %}
          <article class="review-card">
            <div class="review-card-image">
              <img src="{{ blog.image }}" alt="{{ blog.title }}" onerror="this.src='https://picsum.photos/seed/blog-home-fallback-{{ blog.id }}/900/650'">
              <div class="review-rating-badge">{% if blog.rating > 0 %}&#9733; {{ blog.rating }}{% else %}Blog{% endif %}</div>
            </div>
            <div class="review-content">
              <h3>{{ blog.title }}</h3>
              <span class="review-trip">
                {{ blog.published_at ? blog.published_at|date('M d, Y') : 'Recently published' }}
                {% if blog.slug %} - {{ blog.slug }}{% endif %}
              </span>
              <p>{{ blog.excerpt }}</p>
              <div class="review-author">
                <span>{{ blog.author }}</span>
                <a href="{{ path('app_blog_show', {'id': blog.id}) }}">Read more</a>
              </div>
            </div>
          </article>
        {% endfor %}
        {% if blogs is empty %}
          <article class="review-card">
            <div class="review-content">
              <h3>No blogs available yet</h3>
              <span class="review-trip">Publishing queue</span>
              <p>Once blog posts are published, they will appear here on the home page.</p>
              <div class="review-author">
                <span>VoyageLoisir</span>
                <a href="{{ path('app_blog_index') }}">Browse blog area</a>
              </div>
            </div>
          </article>
        {% endif %}
        </div>
      </div>

      <div class="reviews-controls">
        <button class="reviews-arrow" id="reviews-prev" type="button" aria-label="Previous blogs">&#8249;</button>
        <button class="reviews-arrow" id="reviews-next" type="button" aria-label="Next blogs">&#8250;</button>
      </div>

      <div class="reviews-dots" id="reviews-dots" aria-label="Blogs pagination"></div>

      <div class="reviews-action">
        <a href="{{ path('app_blog_index') }}">Explore all blogs</a>
      </div>
    </div>
  </section>

  {% include 'home/partials/footer.html.twig' %}

{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const destinationTrack = document.getElementById('top-destinations-track');
      const destinationPrev = document.getElementById('top-destinations-prev');
      const destinationNext = document.getElementById('top-destinations-next');

      if (destinationTrack && destinationPrev && destinationNext) {
        let destinationIndex = 0;

        const getDestinationCards = () => Array.from(destinationTrack.querySelectorAll('.top-destination-card'));

        const getDestinationStep = () => {
          const firstCard = getDestinationCards()[0];
          if (!firstCard) {
            return 0;
          }

          const styles = window.getComputedStyle(destinationTrack);
          const gap = parseFloat(styles.columnGap || styles.gap || '0');
          return firstCard.getBoundingClientRect().width + gap;
        };

        const getVisibleDestinationCount = () => {
          const firstCard = getDestinationCards()[0];
          if (!firstCard) {
            return 1;
          }

          const shellWidth = destinationTrack.parentElement.getBoundingClientRect().width;
          const cardWidth = firstCard.getBoundingClientRect().width;
          return Math.max(1, Math.floor(shellWidth / cardWidth));
        };

        const scrollDestinations = (index) => {
          const maxIndex = Math.max(0, getDestinationCards().length - getVisibleDestinationCount());
          destinationIndex = Math.max(0, Math.min(index, maxIndex));
          destinationTrack.style.transform = `translateX(-${getDestinationStep() * destinationIndex}px)`;
        };

        destinationPrev.addEventListener('click', function () {
          scrollDestinations(destinationIndex - 1);
        });

        destinationNext.addEventListener('click', function () {
          scrollDestinations(destinationIndex + 1);
        });

        window.addEventListener('resize', function () {
          scrollDestinations(destinationIndex);
        });
      }

      const track = document.getElementById('reviews-track');
      const prev = document.getElementById('reviews-prev');
      const next = document.getElementById('reviews-next');
      const dotsWrap = document.getElementById('reviews-dots');

      if (!track || !prev || !next || !dotsWrap) {
        return;
      }

      const getCards = () => Array.from(track.querySelectorAll('.review-card'));
      let currentIndex = 0;
      let dots = [];

      const getStep = () => {
        const firstCard = getCards()[0];
        if (!firstCard) {
          return 0;
        }

        const styles = window.getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap || '0');
        return firstCard.getBoundingClientRect().width + gap;
      };

      const getVisibleCount = () => {
        const firstCard = getCards()[0];
        if (!firstCard) {
          return 1;
        }

        const shellWidth = track.parentElement.getBoundingClientRect().width;
        const cardWidth = firstCard.getBoundingClientRect().width;
        return Math.max(1, Math.floor(shellWidth / cardWidth));
      };

      const getPageCount = () => {
        const visibleCount = getVisibleCount();
        return Math.max(1, getCards().length - visibleCount + 1);
      };

      const renderDots = () => {
        const pageCount = getPageCount();
        dotsWrap.innerHTML = '';

        for (let index = 0; index < pageCount; index += 1) {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'reviews-dot';
          dot.dataset.index = String(index);
          dot.setAttribute('aria-label', `Go to blog slide ${index + 1}`);
          dotsWrap.appendChild(dot);
        }

        dots = Array.from(dotsWrap.querySelectorAll('.reviews-dot'));
        dots.forEach((dot) => {
          dot.addEventListener('click', function () {
            scrollToIndex(Number(dot.dataset.index || 0));
          });
        });
      };

      const updateDots = () => {
        if (!dots.length) {
          return;
        }

        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle('is-active', dotIndex === currentIndex);
        });
      };

      const scrollToIndex = (index) => {
        const maxIndex = getPageCount() - 1;
        currentIndex = Math.max(0, Math.min(index, maxIndex));
        const step = getStep();
        track.style.transform = `translateX(-${step * currentIndex}px)`;
        updateDots();
      };

      prev.addEventListener('click', function () {
        scrollToIndex(currentIndex - 1);
      });

      next.addEventListener('click', function () {
        scrollToIndex(currentIndex + 1);
      });

      window.addEventListener('resize', function () {
        renderDots();
        scrollToIndex(currentIndex);
      });

      renderDots();
      scrollToIndex(0);
    });
  </script>
{% endblock %}
