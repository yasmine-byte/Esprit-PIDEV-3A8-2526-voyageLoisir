  <div class="properties section">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 offset-lg-4">
                <div class="section-heading text-center">
                    <h6>| Hébergements</h6>
                    <h2>Nos Meilleurs Hébergements</h2>
                </div>
            </div>
        </div>
        <div class="row">
            {% for hebergement in hebergements %}
            <div class="col-lg-4 col-md-6">
                <div class="item">
                    {% if hebergement.imagePath %}
                        <img src="{{ asset('uploads/hebergements/' ~ hebergement.imagePath) }}" alt="{{ hebergement.description }}">
                    {% else %}
                        <img src="{{ asset('assets_front/images/images/property-01.jpg') }}" alt="">
                    {% endif %}
                    <span class="category">{{ hebergement.type ? hebergement.type.nom : 'Hébergement' }}</span>
                    <h6>{{ hebergement.prix }} TND</h6>
                    <h4>{{ hebergement.description|slice(0,40) }}</h4>
                    <ul>
                        <li>Chambres: <span>{{ hebergement.no|length }}</span></li>
                    </ul>
                    <div class="main-button">
                        <a href="{{ path('app_property_details', {'id': hebergement.id}) }}">Voir & Réserver</a>
                    </div>
                </div>
            </div>
