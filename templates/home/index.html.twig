      <div class="reviews-controls">
        <button class="reviews-arrow" id="reviews-prev" type="button" aria-label="Previous blogs">&#8249;</button>
        <button class="reviews-arrow" id="reviews-next" type="button" aria-label="Next blogs">&#8250;</button>
      </div>

      <div class="reviews-dots" id="reviews-dots" aria-label="Blogs pagination"></div>

      <div class="reviews-action">
        <a href="{{ path('app_blog_index') }}">Explore all blogs</a>
      </div>
    </div>
  </section>

