</div>

<header class="header-area header-sticky">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <nav class="main-nav">
          <a href="{{ path('app_home') }}" class="logo"><h1>Vianova</h1></a>
          <ul class="nav">
            <li><a href="{{ path('app_home') }}">Home</a></li>
            <li><a href="{{ path('app_destinations') }}">Destination</a></li>
            <li><a href="{{ path('app_hebergements_front') }}">Hébergement</a></li>
            <li><a href="{{ path('app_activite_index') }}">Activité</a></li>
            <li><a href="{{ path('app_properties') }}">Properties</a></li>
            <li><a href="{{ path('avis_index') }}">Avis</a></li>
            <li><a href="{{ path('reclamation_index') }}">Réclamations</a></li>
            <li><a href="{{ path('app_blog_index') }}">Blog</a></li>
            <li>
              <a href="{{ path('app_contact') }}">
                <i class="fa fa-envelope" style="margin-right:5px;"></i> Contact
              </a>
            </li>

            {% if app.user %}
              {% if is_granted('ROLE_ADMIN') %}
                <li>
                  <a href="{{ path('app_admin') }}" style="color:#d4845a; font-weight:600;">
                    <i class="fa fa-cog"></i> Admin
                  </a>
                </li>
              {% endif %}
              {% if is_granted('ROLE_USER') %}
                <li>
                  <a href="{{ path('app_mon_espace') }}" style="color:#E8602D; font-weight:600;">
                    <i class="fa fa-compass"></i> Mon Espace
                  </a>
                </li>
              {% endif %}
              <li>
                <a href="{{ path('front_profile') }}" style="font-weight:600;">
                  <i class="fa fa-user-circle"></i>
                  {{ (app.user.prenom|default('') ~ ' ' ~ app.user.nom|default(''))|trim ?: app.user.userIdentifier }}
                </a>
              </li>
              <li>
                <a href="{{ path('front_logout') }}" title="Déconnexion" style="color:#ef4444;">
                  <i class="fa fa-sign-out-alt"></i>
                </a>
              </li>
            {% else %}
  <li>
    <a href="http://127.0.0.1:8000/admin/login"
       style="background:#1a1a1a; color:#fff; padding:10px 22px; border-radius:30px; font-weight:600; font-size:14px; text-decoration:none;"
       onmouseover="this.style.background='#f97316'"
       onmouseout="this.style.background='#1a1a1a'">
      <i class="fa fa-sign-in-alt"></i> Login
    </a>
  </li>
{% endif %}
          </ul>
          <a class="menu-trigger"><span>Menu</span></a>
        </nav>
      </div>
    </div>
  </div>
</header>

{% if not app.user %}
<div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:16px;border:none">
      <div class="modal-header border-0 pb-0">
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4 pb-4">
        <div class="text-center mb-3">
          <h3 style="color:#d4845a;font-weight:700">ViaNoVa</h3>
          <p class="text-muted" style="font-size:14px">Bienvenue sur votre plateforme de voyage</p>
        </div>
        <ul class="nav nav-pills mb-4" style="background:#f8f9fa;border-radius:10px;padding:4px;gap:4px">
          <li class="nav-item flex-fill">
            <button class="nav-link active w-100" data-bs-toggle="pill" data-bs-target="#signIn">Se connecter</button>
          </li>
          <li class="nav-item flex-fill">
            <button class="nav-link w-100" data-bs-toggle="pill" data-bs-target="#signUp">S'inscrire</button>
          </li>
        </ul>
        <div class="tab-content">
          <div class="tab-pane fade show active" id="signIn">
            <form method="POST" action="{{ path('front_login_check') }}">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token('front_authenticate') }}">
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="_username" class="form-control" placeholder="votre@email.com" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Mot de passe</label>
                <input type="password" name="_password" class="form-control" placeholder="Mot de passe" required>
              </div>
              <button type="submit" class="btn w-100" style="background:linear-gradient(135deg,#e8a87c,#d4845a);color:#fff;border:none;border-radius:8px;padding:12px;font-weight:600">
                Se connecter
              </button>
            </form>

            {# ===== BOUTON CONNEXION FACIALE ===== #}
            <div style="text-align:center; margin-top:16px;">
              <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
                <hr style="flex:1; border-color:#eee;">
                <span style="color:#aaa; font-size:12px;">ou</span>
                <hr style="flex:1; border-color:#eee;">
              </div>
              <a href="{{ path('face_login_page') }}"
                 style="display:flex; align-items:center; justify-content:center; gap:8px; width:100%; padding:12px; background:#f8f9fa; border:1.5px solid #e0e0e0; border-radius:8px; color:#333; font-size:14px; font-weight:600; text-decoration:none; transition:all 0.2s;"
                 onmouseover="this.style.background='#fff3f0'; this.style.borderColor='#f75959'; this.style.color='#f75959';"
                 onmouseout="this.style.background='#f8f9fa'; this.style.borderColor='#e0e0e0'; this.style.color='#333';">
                📷 Se connecter avec mon visage
              </a>
            </div>

          </div>
          <div class="tab-pane fade" id="signUp">
            <form method="POST" action="{{ path('front_register') }}">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token('front_register') }}">
              <div class="row">
                <div class="col-6 mb-3">
                  <label class="form-label">Nom</label>
                  <input type="text" name="nom" class="form-control" placeholder="Votre nom" required>
                </div>
                <div class="col-6 mb-3">
                  <label class="form-label">Prénom</label>
                  <input type="text" name="prenom" class="form-control" placeholder="Votre prénom" required>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="votre@email.com" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Mot de passe</label>
                <input type="password" name="password" class="form-control" placeholder="Minimum 8 caractères" required minlength="8">
              </div>
              <div class="mb-3">
                <label class="form-label">Confirmer le mot de passe</label>
                <input type="password" name="confirm_password" class="form-control" placeholder="Répétez le mot de passe" required>
              </div>
              <button type="submit" class="btn w-100" style="background:linear-gradient(135deg,#e8a87c,#d4845a);color:#fff;border:none;border-radius:8px;padding:12px;font-weight:600">
                Créer mon compte
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endif %}
