{% extends "base_front.html.twig" %}

{% block title %}Destinations — VoyageLoisir{% endblock %}

{% block body %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Outfit:wght@300;400;500;600&display=swap');

:root {
  --accent: #c8956c;
  --accent-dark: #a87550;
  --accent-light: rgba(200,149,108,0.12);
  --accent-border: rgba(200,149,108,0.25);
  --cream: #f5f2ec;
  --dark: #0c0b09;
  --text: #1a1814;
  --muted: #7a7670;
  --border: #e8e4dc;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Outfit', sans-serif;
  background: var(--cream);
  color: var(--text);
  overflow-x: hidden;
}

/* ============================================================
   CLOSING BAND — photo de fond élégante
   ============================================================ */
.vl-closing {
  position: relative;
  padding: 120px 80px;
  text-align: center;
  overflow: hidden;
}

.vl-closing-bg {
  position: absolute;
  inset: 0;
  background-image: url('https://images.unsplash.com/photo-1682687220063-4742bd7fd538?w=1920&q=85&auto=format&fit=crop');
  background-size: cover;
  background-position: center 40%;
  transform: scale(1.03);
  transition: transform 8s ease;
}

.vl-closing:hover .vl-closing-bg {
  transform: scale(1);
}

.vl-closing-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to bottom, rgba(12,11,9,0.55) 0%, rgba(12,11,9,0.45) 50%, rgba(12,11,9,0.7) 100%),
    linear-gradient(135deg, rgba(200,149,108,0.15) 0%, transparent 60%);
}

.vl-closing-watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-family: 'Playfair Display', serif;
  font-size: clamp(120px, 18vw, 260px);
  font-weight: 900;
  color: transparent;
  -webkit-text-stroke: 1px rgba(255,255,255,0.06);
  white-space: nowrap;
  pointer-events: none;
  letter-spacing: -10px;
  z-index: 1;
}

.vl-closing-content {
  position: relative;
  z-index: 2;
}

.vl-closing-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
}

.vl-closing-label::before,
.vl-closing-label::after {
  content: '';
  width: 44px;
  height: 1px;
  background: var(--accent);
}

.vl-closing-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 5.5vw, 76px);
  font-weight: 900;
  color: white;
  line-height: 1.02;
  letter-spacing: -2.5px;
  margin-bottom: 28px;
}

.vl-closing-title em {
  font-style: italic;
  color: var(--accent);
}

.vl-closing-text {
  font-size: 16px;
  font-weight: 300;
  color: rgba(255,255,255,0.6);
  line-height: 1.85;
  max-width: 520px;
  margin: 0 auto 48px;
  letter-spacing: 0.1px;
}

.vl-closing-cta {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  padding: 18px 44px;
  border-radius: 50px;
  background: var(--accent);
  color: white;
  font-size: 12px;
  font-weight: 600;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 2px;
  transition: all 0.35s;
  border: 1px solid transparent;
}

.vl-closing-cta:hover {
  background: transparent;
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-2px);
  box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}

/* ============================================================
   VOICE SEARCH
   ============================================================ */
.vl-voice-section {
  max-width: 1320px;
  margin: 80px auto 80px;
  padding: 0 80px;
}

.vl-voice-card {
  background: white;
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 52px 64px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 64px;
  align-items: center;
}

.vl-voice-title {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8px;
}

.vl-voice-sub {
  font-size: 14px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 20px;
}

.vl-voice-transcript {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px 18px;
  min-height: 46px;
  font-size: 14px;
  color: var(--muted);
  margin-bottom: 14px;
}

.vl-voice-search-btn {
  width: 100%;
  padding: 12px;
  border-radius: 12px;
  border: 1px solid var(--accent-border);
  background: var(--accent-light);
  color: var(--accent-dark);
  font-size: 13px;
  font-weight: 600;
  font-family: 'Outfit', sans-serif;
  cursor: pointer;
  transition: all 0.2s;
}

.vl-voice-search-btn:disabled { opacity: 0.4; cursor: not-allowed; }

.vl-voice-search-btn:not(:disabled):hover {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}

.vl-mic-btn {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 1.5px solid var(--accent-border);
  background: var(--accent-light);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.25s;
  flex-shrink: 0;
  align-self: center;
}

.vl-mic-btn:hover {
  background: var(--accent);
  border-color: var(--accent);
  transform: scale(1.05);
  box-shadow: 0 8px 24px rgba(200,149,108,0.35);
}

.vl-mic-btn:hover svg { stroke: white; }

.vl-mic-status {
  font-size: 11px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--muted);
  text-align: center;
  margin-top: 10px;
}

/* ============================================================
   FILTER BAR
   ============================================================ */
.vl-filter-bar {
  max-width: 1320px;
  margin: 0 auto 48px;
  padding: 0 80px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.vl-filter-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--muted);
  margin-right: 12px;
}

.vl-filter-btn {
  padding: 9px 24px;
  border-radius: 4px;
  border: 1px solid var(--border);
  background: white;
  color: var(--muted);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  font-family: 'Outfit', sans-serif;
  transition: all 0.2s;
}

.vl-filter-btn:hover,
.vl-filter-btn.is_active {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}

/* ============================================================
   DESTINATIONS GRID
   ============================================================ */
.vl-destinations-header {
  max-width: 1320px;
  margin: 0 auto 40px;
  padding: 0 80px;
}

.vl-dest-section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.vl-dest-section-label::before {
  content: '';
  width: 30px;
  height: 1px;
  background: var(--accent);
}

.vl-dest-section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 3.5vw, 48px);
  font-weight: 700;
  color: var(--text);
  letter-spacing: -1.5px;
  line-height: 1.1;
}

.vl-dest-section-title em { font-style: italic; color: var(--accent); }

.vl-grid {
  max-width: 1320px;
  margin: 0 auto 120px;
  padding: 0 80px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}

.vl-card {
  background: white;
  border-radius: 24px;
  overflow: hidden;
  border: 1px solid var(--border);
  transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  display: flex;
  flex-direction: column;
}

.vl-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 24px 60px rgba(0,0,0,0.1);
  border-color: var(--accent-border);
}

.vl-card-img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
}

.vl-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.vl-card:hover .vl-card-img { transform: scale(1.06); }

.vl-card-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10,9,8,0.65) 0%, transparent 50%);
}

.vl-card-tag {
  position: absolute;
  top: 16px;
  left: 16px;
  background: rgba(10,9,8,0.6);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.85);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 20px;
}

.vl-card-rating {
  position: absolute;
  bottom: 14px;
  right: 14px;
  background: rgba(10,9,8,0.65);
  backdrop-filter: blur(8px);
  border-radius: 20px;
  padding: 5px 12px;
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  font-weight: 600;
  color: white;
}

.vl-card-stars { display: flex; gap: 2px; }

.vl-card-body {
  padding: 24px 26px 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.vl-card-country {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 8px;
}

.vl-card-name {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
  margin-bottom: 10px;
  text-decoration: none;
  display: block;
  transition: color 0.2s;
}

.vl-card-name:hover { color: var(--accent); }

.vl-card-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  font-size: 12px;
  color: var(--muted);
  font-weight: 400;
}

.vl-card-meta-item { display: flex; align-items: center; gap: 5px; }

.vl-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16px;
  border-top: 1px solid var(--border);
  margin-top: auto;
}

.vl-card-status {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.vl-status-dot { width: 6px; height: 6px; border-radius: 50%; }

.vl-card-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  transition: gap 0.2s;
}

.vl-card-link:hover { gap: 10px; color: var(--accent-dark); }

.vl-like-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 5px 12px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--muted);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'Outfit', sans-serif;
  transition: all 0.2s;
}

.vl-like-btn:hover, .vl-like-btn.liked {
  border-color: #fca5a5;
  background: #fff0f0;
  color: #e11d48;
}

.properties-items { transition: all 0.4s ease; }
</style>

{# ============================================================
   1. HERO
   ============================================================ #}
<section style="position:relative;width:100%;height:100vh;min-height:680px;overflow:hidden;display:flex;align-items:center;justify-content:center">

  <img
    src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1920&q=85&auto=format&fit=crop"
    alt="Voyage"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center">

  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,9,8,0.88) 0%,rgba(10,9,8,0.4) 55%,rgba(10,9,8,0.7) 100%)"></div>

  <div style="position:absolute;bottom:-40px;left:-20px;font-family:'Playfair Display',serif;font-size:clamp(120px,20vw,280px);font-weight:900;color:transparent;-webkit-text-stroke:1px rgba(255,255,255,0.06);line-height:1;z-index:1;pointer-events:none;letter-spacing:-8px;user-select:none">EXPLORE</div>

  <div style="position:relative;z-index:2;max-width:1320px;width:100%;padding:0 80px;display:grid;grid-template-columns:1fr 420px;gap:80px;align-items:center">

    <div>
      <div style="display:inline-flex;align-items:center;gap:12px;margin-bottom:28px">
        <div style="width:40px;height:1px;background:var(--accent)"></div>
        <span style="font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--accent)">VoyageLoisir</span>
      </div>

      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(52px,6.5vw,96px);font-weight:900;color:white;line-height:0.92;letter-spacing:-3px;margin-bottom:10px">
        Voyager,<br>
        c'est vivre<br>
        <em style="font-style:italic;color:var(--accent)">autrement</em>
      </h1>

      <p style="font-size:16px;font-weight:300;color:rgba(255,255,255,0.55);line-height:1.85;max-width:460px;margin:28px 0 40px">
        Chaque destination est une invitation à découvrir le monde sous un angle nouveau. Des médinas animées aux fjords silencieux, vivez des expériences inoubliables.
      </p>

      <div style="display:flex;align-items:center;gap:32px">
        <a href="#destinations" style="display:inline-flex;align-items:center;gap:12px;padding:16px 32px;background:var(--accent);color:white;border-radius:40px;font-size:12px;font-weight:600;text-decoration:none;text-transform:uppercase;letter-spacing:1.5px;transition:all 0.3s">
          Découvrir
          <span style="width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m7 17 10-10M7 7h10v10"/></svg>
          </span>
        </a>
        <div style="display:flex;gap:24px">
          <div>
            <div style="font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:white;line-height:1">{{ destinations|length }}+</div>
            <div style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:3px">Destinations</div>
          </div>
          <div style="width:1px;background:rgba(255,255,255,0.12)"></div>
          <div>
            <div style="font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:var(--accent);line-height:1">4.8</div>
            <div style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:3px">Note</div>
          </div>
          <div style="width:1px;background:rgba(255,255,255,0.12)"></div>
          <div>
            <div style="font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:white;line-height:1">4</div>
            <div style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:3px">Saisons</div>
          </div>
        </div>
      </div>
    </div>

    <div style="background:rgba(255,255,255,0.07);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.14);border-radius:28px;padding:36px 32px">
      <div style="font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:white;margin-bottom:6px">Trouvez votre destination</div>
      <div style="font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:28px">Recherche rapide</div>

      <form method="GET" action="{{ path('app_destinations') }}">
        <input type="text" name="search" value="{{ search }}"
               placeholder="Destination, pays..."
               style="width:100%;padding:14px 18px;border-radius:14px;border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.08);color:white;font-size:14px;font-family:'Outfit',sans-serif;margin-bottom:12px;outline:none;transition:border 0.2s"
               onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='rgba(255,255,255,0.15)'">

        <select name="saison"
                style="width:100%;padding:14px 18px;border-radius:14px;border:1px solid rgba(255,255,255,0.15);background:rgba(10,9,8,0.55);color:rgba(255,255,255,0.7);font-size:14px;font-family:'Outfit',sans-serif;margin-bottom:20px;outline:none;cursor:pointer;appearance:none">
          <option value="">Toutes les saisons</option>
          <option value="Printemps" {{ saison == 'Printemps' ? 'selected' : '' }}>Printemps</option>
          <option value="Ete"       {{ saison == 'Ete'       ? 'selected' : '' }}>Été</option>
          <option value="Automne"   {{ saison == 'Automne'   ? 'selected' : '' }}>Automne</option>
          <option value="Hiver"     {{ saison == 'Hiver'     ? 'selected' : '' }}>Hiver</option>
        </select>

        <button type="submit"
                style="width:100%;padding:15px;border-radius:14px;border:none;background:var(--accent);color:white;font-size:14px;font-weight:600;font-family:'Outfit',sans-serif;cursor:pointer;letter-spacing:0.5px;transition:all 0.2s"
                onmouseover="this.style.background='var(--accent-dark)'" onmouseout="this.style.background='var(--accent)'">
          Rechercher →
        </button>
      </form>

      <div style="margin-top:20px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.08)">
        <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-bottom:10px">Accès rapide</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          {% for s in ['Printemps', 'Ete', 'Automne', 'Hiver'] %}
          <a href="{{ path('app_destinations', {'saison': s}) }}"
             style="padding:5px 14px;border-radius:4px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.55);font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none;transition:all 0.2s"
             onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='rgba(255,255,255,0.55)'">
            {{ s }}
          </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;z-index:3">
    <span style="font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.28);font-weight:600">Défiler</span>
    <div style="width:1px;height:44px;background:linear-gradient(to bottom,rgba(255,255,255,0.28),transparent)"></div>
  </div>

</section>

{# ============================================================
   2. RECHERCHE VOCALE
   ============================================================ #}
<section class="vl-voice-section">
  <div class="vl-voice-card">
    <div>
      <h3 class="vl-voice-title">Recherche vocale</h3>
      <p class="vl-voice-sub">
        Décrivez votre destination de rêve à voix haute — notre assistant IA analysera votre demande et vous suggèrera les meilleures destinations.
      </p>
      <div id="voiceTranscript" class="vl-voice-transcript">Votre message apparaîtra ici…</div>
      <button id="voiceSearchBtn" disabled onclick="runVoiceSearch()" class="vl-voice-search-btn">
        Lancer la recherche
      </button>
      <div id="voiceResults" style="margin-top:16px"></div>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center;gap:10px">
      <div id="micBtn" onclick="toggleMic()" class="vl-mic-btn">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8956c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="2" width="6" height="12" rx="3"/>
          <path d="M5 10a7 7 0 0 0 14 0"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="9" y1="22" x2="15" y2="22"/>
        </svg>
      </div>
      <div id="voiceStatus" class="vl-mic-status">Appuyez pour parler</div>
    </div>
  </div>
</section>

<script>
(function(){
  var rec=null, tr='', on=false;
  var SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  window.toggleMic=function(){
    if(!SR){document.getElementById('voiceStatus').textContent='Disponible sur Chrome/Edge uniquement.';return;}
    if(on){rec.stop();return;}
    rec=new SR(); rec.lang='fr-FR'; rec.interimResults=true;
    rec.onstart=function(){on=true;document.getElementById('micBtn').style.background='var(--accent)';document.getElementById('micBtn').style.borderColor='var(--accent)';document.getElementById('voiceStatus').textContent='Écoute en cours…';document.getElementById('voiceResults').innerHTML='';document.getElementById('voiceSearchBtn').disabled=true;};
    rec.onresult=function(e){var f='',i='';for(var x=e.resultIndex;x<e.results.length;x++){var t=e.results[x][0].transcript;e.results[x].isFinal?f+=t:i+=t;}document.getElementById('voiceTranscript').textContent=f||i;if(f)tr=f;};
    rec.onend=function(){on=false;document.getElementById('micBtn').style.background='var(--accent-light)';document.getElementById('micBtn').style.borderColor='var(--accent-border)';document.getElementById('voiceStatus').textContent=tr?'Terminé — lancez la recherche':'Rien détecté';if(tr)document.getElementById('voiceSearchBtn').disabled=false;};
    rec.onerror=function(e){on=false;document.getElementById('voiceStatus').textContent='Erreur : '+e.error;};
    rec.start();
  };
  window.runVoiceSearch=function(){
    if(!tr)return;
    document.getElementById('voiceSearchBtn').disabled=true;
    document.getElementById('voiceStatus').textContent='Recherche en cours…';
    document.getElementById('voiceResults').innerHTML='<p style="text-align:center;color:var(--muted);font-size:13px">Analyse…</p>';
    fetch('{{ path("app_destination_voice_query") }}',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:tr})})
    .then(function(r){return r.json();})
    .then(function(data){
      var html='';
      var dispo=data.disponibles||[];
      if(dispo.length>0){
        html+='<div style="font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#16a34a;margin-bottom:10px">Dans notre catalogue</div>';
        dispo.forEach(function(d){
          html+='<div style="background:#f0fdf4;border-radius:12px;padding:14px 16px;margin-bottom:8px;border:1px solid #bbf7d0">'
            +'<strong style="font-size:14px;font-family:Playfair Display,serif;color:var(--text)">'+d.nom+'</strong>'
            +' <span style="font-size:11px;color:var(--muted)">'+d.pays+'</span>'
            +'<p style="font-size:13px;color:var(--muted);margin:6px 0;font-weight:300">'+d.description+'</p>'
            +'<a href="{{ path("app_destination_detail", {"id": 0}) }}'.replace("/0","/"+d.id)+'" style="font-size:12px;color:var(--accent);font-weight:600;text-transform:uppercase;letter-spacing:1px">Voir →</a>'
            +'</div>';
        });
      }
      var hors=data.hors_catalogue;
      if(hors&&hors.existe){
        html+='<div style="background:var(--accent-light);border-radius:12px;padding:14px 16px;border:1px solid var(--accent-border)">'
          +'<strong style="font-family:Playfair Display,serif;font-size:14px;color:var(--text)">'+( hors.nom||'')+'</strong>'
          +(hors.pays?' <span style="font-size:11px;color:var(--muted)">· '+hors.pays+'</span>':'')
          +'<p style="font-size:13px;color:var(--accent-dark);margin:6px 0;font-style:italic">'+( hors.message||'')+'</p>'
          +(hors.infos?'<p style="font-size:13px;color:var(--muted);margin:0;font-weight:300">'+hors.infos+'</p>':'')
          +'</div>';
      }
      if(!html)html='<p style="color:#e07070;font-size:13px;text-align:center">Aucune destination trouvée.</p>';
      document.getElementById('voiceStatus').textContent=dispo.length+' résultat(s) trouvé(s)';
      document.getElementById('voiceResults').innerHTML=html;
    })
    .catch(function(){document.getElementById('voiceResults').innerHTML='<p style="color:#e07070;font-size:13px">Erreur de connexion.</p>';document.getElementById('voiceSearchBtn').disabled=false;});
  };
})();
</script>
{# ============================================================
   BLOC TELEGRAM — à coller après </section> de la recherche vocale
   et avant <div id="destinations">
   ============================================================ #}

<section style="max-width:1320px;margin:0 auto 80px;padding:0 80px">
  <div style="background:white;border:1px solid var(--border);border-radius:24px;padding:48px 64px;display:grid;grid-template-columns:1fr auto;gap:64px;align-items:center">

    <div>
      {# Titre #}
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
          <path d="M21.5 2L2 9.5l7 2.5 2.5 7L21.5 2z" fill="#c8956c" opacity="0.2"/>
          <path d="M21.5 2L2 9.5l7 2.5 2.5 7L21.5 2z" stroke="#c8956c" stroke-width="1.5" stroke-linejoin="round"/>
          <line x1="9" y1="12" x2="15" y2="6" stroke="#c8956c" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span style="font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--text)">
          Notifications Telegram
        </span>
      </div>

      <p style="font-size:14px;font-weight:300;color:var(--muted);line-height:1.7;margin-bottom:24px">
        Recevez des notifications instantanées sur Telegram lors de nouvelles destinations, modifications ou annulations de réservation.
      </p>

      {# Etapes #}
      <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:28px">

        <div style="display:flex;align-items:flex-start;gap:14px">
          <div style="width:26px;height:26px;border-radius:50%;background:var(--accent-light);border:1px solid var(--accent-border);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--accent);flex-shrink:0">1</div>
          <div style="font-size:13px;color:var(--muted);line-height:1.6;padding-top:3px">
            Installez <strong style="color:var(--text)">Telegram</strong> sur votre téléphone et cherchez
            <a href="https://t.me/VoyageLoisirBot" target="_blank"
               style="color:var(--accent);font-weight:600;text-decoration:none">@VoyageLoisirBot</a>
          </div>
        </div>

        <div style="display:flex;align-items:flex-start;gap:14px">
          <div style="width:26px;height:26px;border-radius:50%;background:var(--accent-light);border:1px solid var(--accent-border);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--accent);flex-shrink:0">2</div>
          <div style="font-size:13px;color:var(--muted);line-height:1.6;padding-top:3px">
            Tapez <strong style="color:var(--text);font-family:monospace">/start</strong> — le bot vous envoie votre <strong style="color:var(--text)">Telegram ID</strong>
          </div>
        </div>

        <div style="display:flex;align-items:flex-start;gap:14px">
          <div style="width:26px;height:26px;border-radius:50%;background:var(--accent-light);border:1px solid var(--accent-border);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--accent);flex-shrink:0">3</div>
          <div style="font-size:13px;color:var(--muted);line-height:1.6;padding-top:3px">
            Collez votre ID ci-contre et cliquez <strong style="color:var(--text)">Sauvegarder</strong>
          </div>
        </div>

      </div>

      {# Statut actuel #}
      {% if app.user and app.user.telegramChatId %}
        <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px">
          <span style="width:8px;height:8px;border-radius:50%;background:#16a34a;display:inline-block"></span>
          <span style="font-size:12px;font-weight:600;color:#16a34a">Notifications activées</span>
        </div>
      {% else %}
        <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;background:#fef9f0;border:1px solid var(--accent-border);border-radius:20px">
          <span style="width:8px;height:8px;border-radius:50%;background:var(--accent);display:inline-block"></span>
          <span style="font-size:12px;font-weight:600;color:var(--accent-dark)">Non configuré</span>
        </div>
      {% endif %}
    </div>

    {# Formulaire #}
    <div style="min-width:280px">
      {% if app.user %}
        <form method="POST" action="{{ path('app_telegram_save') }}">
          <input type="hidden" name="_token" value="{{ csrf_token('telegram_save') }}">

          <label style="display:block;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px">
            Votre Telegram ID
          </label>

          <input
            type="text"
            name="telegram_chat_id"
            value="{{ app.user.telegramChatId ?? '' }}"
            placeholder="Ex: 987654321"
            style="width:100%;padding:14px 18px;border-radius:14px;border:1px solid var(--border);background:var(--cream);color:var(--text);font-size:14px;font-family:'Outfit',sans-serif;margin-bottom:12px;outline:none;transition:border 0.2s"
            onfocus="this.style.borderColor='var(--accent)'"
            onblur="this.style.borderColor='var(--border)'"
          >

          <button type="submit"
            style="width:100%;padding:14px;border-radius:14px;border:none;background:var(--accent);color:white;font-size:13px;font-weight:600;font-family:'Outfit',sans-serif;cursor:pointer;letter-spacing:0.5px;transition:background 0.2s"
            onmouseover="this.style.background='var(--accent-dark)'"
            onmouseout="this.style.background='var(--accent)'">
            Sauvegarder
          </button>

          {% if app.user.telegramChatId %}
          <button type="button" onclick="clearTelegram()"
            style="width:100%;padding:10px;margin-top:8px;border-radius:14px;border:1px solid var(--border);background:transparent;color:var(--muted);font-size:12px;font-weight:500;font-family:'Outfit',sans-serif;cursor:pointer;transition:all 0.2s"
            onmouseover="this.style.borderColor='#e07070';this.style.color='#e07070'"
            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
            Désactiver les notifications
          </button>
          {% endif %}

        </form>

        <script>
        function clearTelegram() {
          if (confirm('Désactiver les notifications Telegram ?')) {
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '{{ path("app_telegram_save") }}';
            var token = document.createElement('input');
            token.type = 'hidden'; token.name = '_token';
            token.value = '{{ csrf_token("telegram_save") }}';
            var field = document.createElement('input');
            field.type = 'hidden'; field.name = 'telegram_chat_id'; field.value = '';
            form.appendChild(token); form.appendChild(field);
            document.body.appendChild(form); form.submit();
          }
        }
        </script>

      {% else %}
        <div style="text-align:center;padding:32px 20px;border:1px dashed var(--border);border-radius:14px">
          <p style="font-size:14px;color:var(--muted);margin-bottom:16px">Connectez-vous pour activer les notifications</p>
          <a href="{{ path('front_login') }}"
             style="display:inline-block;padding:12px 28px;background:var(--accent);color:white;border-radius:40px;font-size:12px;font-weight:600;text-decoration:none;text-transform:uppercase;letter-spacing:1px">
            Se connecter
          </a>
        </div>
      {% endif %}
    </div>

  </div>
</section>


{# ============================================================
   3. DESTINATIONS GRID
   ============================================================ #}
<div id="destinations">

  <div class="vl-destinations-header">
    <div class="vl-dest-section-label">Notre sélection</div>
    <h2 class="vl-dest-section-title">
      {% if search or saison %}
        {{ destinations|length }} résultat{{ destinations|length > 1 ? 's' : '' }}
        {% if search %} pour <em>{{ search }}</em>{% endif %}
        {% if saison %} · <em>{{ saison }}</em>{% endif %}
      {% else %}
        Toutes nos <em>destinations</em>
      {% endif %}
    </h2>
  </div>

  {% if not search and not saison %}
  <div class="vl-filter-bar">
    <span class="vl-filter-label">Filtrer</span>
    <button class="vl-filter-btn is_active" data-filter="*">Toutes</button>
    <button class="vl-filter-btn" data-filter=".Printemps">Printemps</button>
    <button class="vl-filter-btn" data-filter=".Ete">Été</button>
    <button class="vl-filter-btn" data-filter=".Automne">Automne</button>
    <button class="vl-filter-btn" data-filter=".Hiver">Hiver</button>
  </div>
  {% else %}
  <div class="vl-filter-bar">
    <a href="{{ path('app_destinations') }}" style="font-size:11px;color:var(--accent);font-weight:600;text-decoration:none;text-transform:uppercase;letter-spacing:2px">← Toutes les destinations</a>
  </div>
  {% endif %}

  <div class="vl-grid" id="dest-grid">

    {% for destination in destinations %}

      {% set nv = 0 %}
      {% if destination.nbVisites >= 10000 %}{% set nv = 2.5 %}
      {% elseif destination.nbVisites >= 5000 %}{% set nv = 2 %}
      {% elseif destination.nbVisites >= 2000 %}{% set nv = 1.5 %}
      {% elseif destination.nbVisites >= 1000 %}{% set nv = 1 %}
      {% elseif destination.nbVisites >= 500 %}{% set nv = 0.5 %}{% endif %}
      {% set ns = 0 %}
      {% if destination.meilleureSaison == "Ete" %}{% set ns = 2.5 %}
      {% elseif destination.meilleureSaison == "Printemps" %}{% set ns = 2 %}
      {% elseif destination.meilleureSaison == "Automne" %}{% set ns = 1.5 %}
      {% elseif destination.meilleureSaison == "Hiver" %}{% set ns = 1 %}{% endif %}
      {% set nl = 0 %}
      {% if destination.nbLikes >= 50 %}{% set nl = 1 %}
      {% elseif destination.nbLikes >= 20 %}{% set nl = 0.75 %}
      {% elseif destination.nbLikes >= 10 %}{% set nl = 0.5 %}
      {% elseif destination.nbLikes >= 5 %}{% set nl = 0.25 %}
      {% elseif destination.nbLikes >= 1 %}{% set nl = 0.1 %}{% endif %}
      {% set nt = nv + ns + nl %}
      {% if nt > 5 %}{% set nt = 5 %}{% endif %}
      {% set ep = nt|round(0, 'floor') %}
      {% set de = ((nt - ep) >= 0.5) ? 1 : 0 %}
      {% set ev = 5 - ep - de %}

      <div class="vl-card properties-items {{ destination.meilleureSaison }}">

        <div class="vl-card-img-wrap">
          <a href="{{ path('app_destination_detail', {'id': destination.id}) }}">
            {% if destination.images|length > 0 %}
              <img class="vl-card-img" src="{{ asset(destination.images[0].urlImage) }}" alt="{{ destination.nom }}">
            {% else %}
              <img class="vl-card-img" src="{{ asset('assets_front/images/images/property-01.jpg') }}" alt="{{ destination.nom }}">
            {% endif %}
          </a>
          <div class="vl-card-img-overlay"></div>
          <div class="vl-card-tag">{{ destination.meilleureSaison ?? '—' }}</div>
          {% if destination.meilleureSaison == 'Hiver' %}
        <div style="position:absolute;top:16px;right:16px;background:linear-gradient(135deg,#1e3a5f,#2563eb);color:white;font-size:16px;font-weight:900;letter-spacing:1px;padding:10px 18px;border-radius:30px;box-shadow:0 6px 20px rgba(37,99,235,0.5);border:2px solid rgba(255,255,255,0.3)">
        ❄️ -20%
        </div>
        {% endif %}
          <div class="vl-card-rating">
            <div class="vl-card-stars">
              {% for i in 1..ep %}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="#c8956c"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% endfor %}
              {% for i in 1..ev %}
                <svg width="11" height="11" viewBox="0 0 24 24" fill="rgba(255,255,255,0.25)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% endfor %}
            </div>
            {{ nt|number_format(1) }}
          </div>
        </div>

        <div class="vl-card-body">
          <div class="vl-card-country">{{ destination.pays }}</div>
          <a href="{{ path('app_destination_detail', {'id': destination.id}) }}" class="vl-card-name">
            {{ destination.nom }}
          </a>
          <div class="vl-card-meta">
            <span class="vl-card-meta-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              {{ destination.nbVisites ?? 0 }} visites
            </span>
            <span class="vl-card-meta-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
             <span class="meta-like-count-{{ destination.id }}">{{ destination.nbLikes ?? 0 }}</span> j'aime
            </span>
          </div>

          <div class="vl-card-footer">
            <div class="vl-card-status">
              <span class="vl-status-dot" style="background:{% if destination.statut %}#7ec99a{% else %}#e07070{% endif %}"></span>
              <span style="font-size:11px;font-weight:600;letter-spacing:0.5px;color:{% if destination.statut %}#16a34a{% else %}#e07070{% endif %}">
                {{ destination.statut ? 'Actif' : 'Inactif' }}
              </span>
            </div>

            <button onclick="toggleLikeCard({{ destination.id }}, this)" class="vl-like-btn">
              <span class="like-icon-{{ destination.id }}">♡</span>
              <span class="like-count-{{ destination.id }}">{{ destination.nbLikes ?? 0 }}</span>
            </button>

            <a href="{{ path('app_destination_detail', {'id': destination.id}) }}" class="vl-card-link">
              Voir
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

    {% else %}
      <div style="grid-column:span 3;text-align:center;padding:80px 0">
        <p style="font-family:'Playfair Display',serif;font-size:24px;color:var(--muted);font-style:italic;margin-bottom:16px">Aucune destination trouvée</p>
        <a href="{{ path('app_destinations') }}" style="color:var(--accent);font-size:11px;font-weight:600;text-decoration:none;text-transform:uppercase;letter-spacing:2px">← Voir toutes les destinations</a>
      </div>
    {% endfor %}

  </div>
</div>

<script>
{% for destination in destinations %}
(function(){
  var id = {{ destination.id }};

  // Vérifie le statut au chargement et met à jour immédiatement
  fetch('/destination/like-status/' + id)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var icon = document.querySelector('.like-icon-' + id);
      var count = document.querySelector('.like-count-' + id);
      var btns = document.querySelectorAll('button[onclick*="toggleLikeCard(' + id + '"]');
      if (icon) icon.textContent = data.liked ? '♥' : '♡';
      if (count) count.textContent = data.total;
      if (data.liked) btns.forEach(function(b) { b.classList.add('liked'); });
      else btns.forEach(function(b) { b.classList.remove('liked'); });
    });
})();
{% endfor %}

function toggleLikeCard(id, btn) {
  var icon = document.querySelector('.like-icon-' + id);
  var count = document.querySelector('.like-count-' + id);
  var metaCount = document.querySelector('.meta-like-count-' + id); // ✅ nouveau
  var isLiked = btn.classList.contains('liked');

  if (isLiked) {
    btn.classList.remove('liked');
    if (icon) icon.textContent = '♡';
    if (count) count.textContent = Math.max(0, parseInt(count.textContent) - 1);
    if (metaCount) metaCount.textContent = Math.max(0, parseInt(metaCount.textContent) - 1); // ✅
  } else {
    btn.classList.add('liked');
    if (icon) icon.textContent = '♥';
    if (count) count.textContent = parseInt(count.textContent) + 1;
    if (metaCount) metaCount.textContent = parseInt(metaCount.textContent) + 1; // ✅
  }

  fetch('/destination/like/' + id, {
    method: 'POST',
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (icon) icon.textContent = data.liked ? '♥' : '♡';
    if (count) count.textContent = data.total;
    if (metaCount) metaCount.textContent = data.total; // ✅
    if (data.liked) btn.classList.add('liked');
    else btn.classList.remove('liked');
  });
}
</script>
<script>
document.querySelectorAll('.vl-filter-btn').forEach(function(btn){
  btn.addEventListener('click',function(){
    document.querySelectorAll('.vl-filter-btn').forEach(function(b){b.classList.remove('is_active');});
    btn.classList.add('is_active');
    var filter=btn.getAttribute('data-filter');
    document.querySelectorAll('.properties-items').forEach(function(item){
      if(filter==='*'){item.style.display='flex';}
      else{item.style.display=item.classList.contains(filter.replace('.',''))?'flex':'none';}
    });
  });
});
</script>

{# ============================================================
   4. BANDE PHOTO — tout en bas ✅
   ============================================================ #}
<section class="vl-closing">
  <div class="vl-closing-bg"></div>
  <div class="vl-closing-overlay"></div>
  <div class="vl-closing-watermark">VOYAGE</div>

  <div class="vl-closing-content">
    <div class="vl-closing-label">Prêt pour l'aventure</div>
    <h2 class="vl-closing-title">
      Votre prochain voyage<br>
      commence <em>ici</em>
    </h2>
    <p class="vl-closing-text">
      Chaque destination est une histoire qui n'attend que vous. Laissez-vous inspirer, planifiez votre itinéraire, et partez explorer le monde avec VoyageLoisir.
    </p>
    <a href="#destinations" class="vl-closing-cta">
      Explorer toutes les destinations
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m7 17 10-10M7 7h10v10"/></svg>
    </a>
  </div>
</section>

{% endblock %}
