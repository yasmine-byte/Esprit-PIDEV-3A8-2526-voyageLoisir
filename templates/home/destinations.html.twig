{% extends "base_front.html.twig" %}

{% block title %}Destinations - VoyageLoisir{% endblock %}

{% block body %}

<div id="js-preloader" class="js-preloader">
  <div class="preloader-inner">
    <span class="dot"></span>
    <div class="dots"><span></span><span></span><span></span></div>
  </div>
</div>

<div class="sub-header">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-md-8">
        <ul class="info">
          <li><i class="fa fa-envelope"></i> info@voyageloisir.com</li>
          <li><i class="fa fa-map"></i> Tunis, Tunisie</li>
        </ul>
      </div>
      <div class="col-lg-4 col-md-4">
        <ul class="social-links">
          <li><a href="#"><i class="fab fa-facebook"></i></a></li>
          <li><a href="#"><i class="fab fa-twitter"></i></a></li>
          <li><a href="#"><i class="fab fa-linkedin"></i></a></li>
          <li><a href="#"><i class="fab fa-instagram"></i></a></li>
        </ul>
      </div>
    </div>
  </div>
</div>

<header class="header-area header-sticky">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <nav class="main-nav">
          <a href="{{ path("app_home") }}" class="logo"><h1>VoyageLoisir</h1></a>
          <ul class="nav">
            <li><a href="{{ path("app_home") }}">Accueil</a></li>
            <li><a href="{{ path("app_destinations") }}" class="active">Destinations</a></li>
            <li><a href="{{ path("app_contact") }}">Contact</a></li>
          </ul>
          <a class="menu-trigger"><span>Menu</span></a>
        </nav>
      </div>
    </div>
  </div>
</header>

<div class="page-heading header-text">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <span class="breadcrumb"><a href="{{ path("app_home") }}">Accueil</a> / Destinations</span>
        <h3>Nos Destinations</h3>
      </div>
    </div>
  </div>
</div>

<div class="section properties">
  <div class="container">

    {# ===== BARRE DE RECHERCHE ===== #}
    <form method="GET" action="{{ path('app_destinations') }}"
          style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-bottom:30px;background:rgba(255,255,255,0.05);padding:20px;border-radius:12px">

      <div style="flex:1;min-width:200px;position:relative">
        <input type="text" name="search" value="{{ search }}"
               placeholder="🔍 Rechercher une destination ou un pays..."
               style="width:100%;padding:12px 16px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);background:rgba(255,255,255,0.1);color:#fff;font-size:14px">
      </div>

      <div style="min-width:160px">
        <select name="saison"
                style="width:100%;padding:12px 16px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);background:rgba(255,255,255,0.1);color:#fff;font-size:14px">
          <option value="">🗓 Toutes les saisons</option>
          <option value="Printemps" {{ saison == 'Printemps' ? 'selected' : '' }}>🌸 Printemps</option>
          <option value="Ete"       {{ saison == 'Ete'       ? 'selected' : '' }}>☀️ Été</option>
          <option value="Automne"   {{ saison == 'Automne'   ? 'selected' : '' }}>🍂 Automne</option>
          <option value="Hiver"     {{ saison == 'Hiver'     ? 'selected' : '' }}>❄️ Hiver</option>
        </select>
      </div>

      <button type="submit"
              style="padding:12px 24px;border-radius:8px;border:none;background:#f97316;color:#fff;font-size:14px;font-weight:600;cursor:pointer">
        Rechercher
      </button>

      {% if search or saison %}
        <a href="{{ path('app_destinations') }}"
           style="padding:12px 20px;border-radius:8px;border:1px solid rgba(255,255,255,0.3);color:#ccc;font-size:14px;text-decoration:none">
          ✕ Réinitialiser
        </a>
      {% endif %}

    </form>

    {# ===== RÉSULTAT ===== #}
    {% if search or saison %}
      <p style="color:#ccc;font-size:14px;margin-bottom:20px">
        {{ destinations|length }} résultat{{ destinations|length > 1 ? 's' : '' }}
        {% if search %} pour "<strong style="color:#f97316">{{ search }}</strong>"{% endif %}
        {% if saison %} — saison : <strong style="color:#f97316">{{ saison }}</strong>{% endif %}
      </p>
    {% endif %}

    {# ===== FILTRE SAISON (tabs) — masqué si recherche active ===== #}
    {% if not search and not saison %}
    <ul class="properties-filter">
      <li><a class="is_active" href="#!" data-filter="*">Toutes</a></li>
      <li><a href="#!" data-filter=".Printemps">Printemps</a></li>
      <li><a href="#!" data-filter=".Ete">Ete</a></li>
      <li><a href="#!" data-filter=".Automne">Automne</a></li>
      <li><a href="#!" data-filter=".Hiver">Hiver</a></li>
    </ul>
    {% endif %}

    <div class="row properties-box">
      {% for destination in destinations %}
      <div class="col-lg-4 col-md-6 align-self-center mb-30 properties-items {{ destination.meilleureSaison }}">
        <div class="item">

          {% if destination.images|length > 0 %}
            <a href="{{ path("app_destination_detail", {"id": destination.id}) }}">
              <img src="{{ asset(destination.images[0].urlImage) }}" alt="{{ destination.nom }}"
                   style="height:220px;object-fit:cover;width:100%">
            </a>
          {% else %}
            <a href="{{ path("app_destination_detail", {"id": destination.id}) }}">
              <img src="{{ asset("assets_front/images/images/property-01.jpg") }}" alt="{{ destination.nom }}"
                   style="height:220px;object-fit:cover;width:100%">
            </a>
          {% endif %}

          <span class="category">{{ destination.meilleureSaison ?? "-" }}</span>
          <h6>{{ destination.nbVisites ?? 0 }} visites</h6>
          <h4>
            <a href="{{ path("app_destination_detail", {"id": destination.id}) }}">
              {{ destination.nom }} - {{ destination.pays }}
            </a>
          </h4>
          <ul>
            <li>Pays : <span>{{ destination.pays }}</span></li>
            <li>Saison : <span>{{ destination.meilleureSaison ?? "-" }}</span></li>
            <li>Statut : <span>{{ destination.statut ? "Actif" : "Inactif" }}</span></li>
          </ul>
          <div class="main-button">
            <a href="{{ path("app_destination_detail", {"id": destination.id}) }}">Voir les détails</a>
          </div>

        </div>
      </div>
      {% else %}
      <div class="col-12 text-center" style="padding:60px 0">
        <h4 style="color:#ccc">Aucune destination trouvée.</h4>
        <a href="{{ path('app_destinations') }}" style="color:#f97316">Voir toutes les destinations</a>
      </div>
      {% endfor %}
    </div>

  </div>
</div>

<footer>
  <div class="container">
    <div class="col-lg-12">
      <p>Copyright &copy; 2026 VoyageLoisir. Design: <a href="https://templatemo.com" target="_blank">TemplateMo</a></p>
    </div>
  </div>
</footer>

{% endblock %}