{% extends "base_front.html.twig" %}

{% block title %}Destinations - Vianova{% endblock %}

{% block body %}

{# ===== HERO BANNER SLIDER ===== #}
<div style="position:relative;width:100%;height:520px;overflow:hidden">

  {% set slideIndex = 0 %}
  {% for destination in destinations %}
    {% for image in destination.images %}
      <img src="{{ asset(image.urlImage) }}"
           alt="{{ destination.nom }}"
           class="hero-slide"
           style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:{{ slideIndex == 0 ? '1' : '0' }};transition:opacity 1s ease">
      {% set slideIndex = slideIndex + 1 %}
    {% endfor %}
  {% endfor %}

  <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%);z-index:1"></div>

  <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:20px;z-index:2">
    <span style="color:#f97316;font-size:14px;font-weight:600;letter-spacing:3px;text-transform:uppercase;margin-bottom:16px">
      Explorez le Monde
    </span>
    <h1 style="color:#fff;font-size:52px;font-weight:700;margin-bottom:16px;text-shadow:0 2px 8px rgba(0,0,0,0.3)">
      Nos Destinations
    </h1>
    <p style="color:rgba(255,255,255,0.85);font-size:18px;max-width:560px;margin-bottom:36px">
      Découvrez les plus beaux endroits du monde et planifiez votre prochain voyage
    </p>

    <form method="GET" action="{{ path('app_destinations') }}"
          style="display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:center;width:100%;max-width:680px">
      <div style="flex:1;min-width:220px">
        <input type="text" name="search" value="{{ search }}"
               placeholder="🔍 Destination, pays..."
               style="width:100%;padding:14px 20px;border-radius:8px;border:none;background:#fff;color:#333;font-size:15px;box-shadow:0 4px 20px rgba(0,0,0,0.2)">
      </div>
      <div style="min-width:160px">
        <select name="saison"
                style="width:100%;padding:14px 16px;border-radius:8px;border:none;background:#fff;color:#333;font-size:15px;box-shadow:0 4px 20px rgba(0,0,0,0.2)">
          <option value="">Toutes les saisons</option>
          <option value="Printemps" {{ saison == 'Printemps' ? 'selected' : '' }}>🌸 Printemps</option>
          <option value="Ete"       {{ saison == 'Ete'       ? 'selected' : '' }}>☀️ Été</option>
          <option value="Automne"   {{ saison == 'Automne'   ? 'selected' : '' }}>🍂 Automne</option>
          <option value="Hiver"     {{ saison == 'Hiver'     ? 'selected' : '' }}>❄️ Hiver</option>
        </select>
      </div>
      <button type="submit"
              style="padding:14px 28px;border-radius:8px;border:none;background:#f97316;color:#fff;font-size:15px;font-weight:600;cursor:pointer;box-shadow:0 4px 20px rgba(249,115,22,0.4);white-space:nowrap">
        Rechercher
      </button>
    </form>

    <div style="margin-top:24px">
      <a href="{{ path('app_home') }}" style="color:rgba(255,255,255,0.7);font-size:13px;text-decoration:none">Accueil</a>
      <span style="color:rgba(255,255,255,0.5);margin:0 8px">/</span>
      <span style="color:#f97316;font-size:13px">Destinations</span>
    </div>
  </div>

  <div style="position:absolute;bottom:20px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:3" id="hero-dots"></div>
</div>

<script>
(function() {
    var slides = document.querySelectorAll('.hero-slide');
    var dotsContainer = document.getElementById('hero-dots');
    var current = 0;
    if (slides.length === 0) return;
    slides.forEach(function(_, i) {
        var dot = document.createElement('div');
        dot.style.cssText = 'width:10px;height:10px;border-radius:50%;background:' + (i === 0 ? '#f97316' : 'rgba(255,255,255,0.5)') + ';cursor:pointer;transition:background 0.3s';
        dot.addEventListener('click', function() { goTo(i); });
        dotsContainer.appendChild(dot);
    });
    function goTo(index) {
        slides[current].style.opacity = '0';
        dotsContainer.children[current].style.background = 'rgba(255,255,255,0.5)';
        current = index;
        slides[current].style.opacity = '1';
        dotsContainer.children[current].style.background = '#f97316';
    }
    setInterval(function() { goTo((current + 1) % slides.length); }, 7000);
})();
</script>
{# RECHERCHE VOCALE #}
<div style="margin-bottom:32px;padding:24px;background:#fff;border-radius:16px;border:1px solid #f0f0f0;box-shadow:0 4px 24px rgba(0,0,0,.07)">
  <h5 class="dd-title" style="margin-bottom:6px">Recherche vocale de destination</h5>
  <p style="font-size:13px;color:#888;margin-bottom:18px">Parlez pour trouver une destination similaire</p>

  <div id="micBtn" onclick="toggleMic()"
    style="width:64px;height:64px;border-radius:50%;border:1.5px solid #fed7aa;background:#fff7ed;display:flex;align-items:center;justify-content:center;cursor:pointer;margin:0 auto 1rem;transition:all .2s">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="2" width="6" height="12" rx="3"/>
      <path d="M5 10a7 7 0 0 0 14 0"/>
      <line x1="12" y1="19" x2="12" y2="22"/>
      <line x1="9" y1="22" x2="15" y2="22"/>
    </svg>
  </div>

  <p id="voiceStatus" style="text-align:center;font-size:13px;color:#aaa;margin-bottom:12px">Cliquez sur le micro pour parler</p>

  <div id="voiceTranscript"
    style="background:#f8fafc;border-radius:10px;padding:12px 16px;min-height:44px;font-size:14px;color:#64748b;margin-bottom:12px;border:1px solid #e8ecf0">
    Votre message apparaîtra ici…
  </div>

  <button id="voiceSearchBtn" disabled onclick="runVoiceSearch()"
    style="width:100%;padding:9px;border:1.5px solid #fed7aa;border-radius:10px;background:#fff7ed;color:#ea6c0a;font-size:14px;font-weight:600;cursor:pointer">
    Rechercher
  </button>

  <div id="voiceResults" style="margin-top:14px"></div>
</div>

<script>
(function(){
  var rec=null, tr='', on=false;
  var SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  window.toggleMic=function(){
    if(!SR){document.getElementById('voiceStatus').textContent='Non supporté sur Chrome/Edge uniquement.';return;}
    if(on){rec.stop();return;}
    rec=new SR(); rec.lang='fr-FR'; rec.interimResults=true;
    rec.onstart=function(){on=true;document.getElementById('micBtn').style.borderColor='#f97316';document.getElementById('micBtn').style.background='#fff3e0';document.getElementById('voiceStatus').textContent='Écoute…';document.getElementById('voiceResults').innerHTML='';document.getElementById('voiceSearchBtn').disabled=true;};
    rec.onresult=function(e){var f='',i='';for(var x=e.resultIndex;x<e.results.length;x++){var t=e.results[x][0].transcript;e.results[x].isFinal?f+=t:i+=t;}document.getElementById('voiceTranscript').textContent=f||i;if(f)tr=f;};
    rec.onend=function(){on=false;document.getElementById('micBtn').style.borderColor='#fed7aa';document.getElementById('micBtn').style.background='#fff7ed';document.getElementById('voiceStatus').textContent=tr?'Terminé — cliquez Rechercher':'Rien détecté, réessayez';if(tr)document.getElementById('voiceSearchBtn').disabled=false;};
    rec.onerror=function(e){on=false;document.getElementById('voiceStatus').textContent='Erreur : '+e.error;};
    rec.start();
  };
  window.runVoiceSearch = function() {
    if (!tr) return;
    document.getElementById('voiceSearchBtn').disabled = true;
    document.getElementById('voiceStatus').textContent = 'Recherche…';
    document.getElementById('voiceResults').innerHTML = '<p style="text-align:center;color:#aaa;font-size:13px">...</p>';

    fetch('{{ path("app_destination_voice_query") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: tr })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        var html = '';

        // ✅ Destinations disponibles dans le catalogue
        var dispo = data.disponibles || [];
        if (dispo.length > 0) {
            html += '<div style="margin-bottom:10px">'
                  + '<span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#16a34a">✅ Disponible dans notre catalogue</span>'
                  + '</div>';
            dispo.forEach(function(d) {
                html += '<div style="background:#f0fdf4;border-radius:10px;padding:12px 14px;margin-bottom:8px;border:1px solid #bbf7d0">'
                    + '<strong style="font-size:14px;color:#0f172a">' + d.nom + '</strong>'
                    + ' <span style="font-size:12px;color:#888">' + d.pays + ' · ' + (d.saison || '') + '</span>'
                    + '<p style="font-size:13px;color:#555;margin:6px 0">' + d.description + '</p>'
                    + (d.activites || []).map(function(a) {
                        return '<span style="background:#dcfce7;color:#15803d;font-size:11px;padding:3px 8px;border-radius:6px;margin-right:4px;border:1px solid #bbf7d0">' + a + '</span>';
                    }).join('')
                    + '<div style="margin-top:8px"><a href="{{ path("app_destination_detail", {"id": 0}) }}'.replace("/0", "/" + d.id) + '" style="font-size:12px;color:#f97316;font-weight:600">Voir la destination →</a></div>'                    + '</div>';
            });
        }

        // 🌍 Destination hors catalogue
        var hors = data.hors_catalogue;
        if (hors && hors.existe) {
            html += '<div style="background:#fff7ed;border-radius:10px;padding:14px 16px;margin-bottom:8px;border:1px solid #fed7aa">'
                  + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">'
                  + '<span style="font-size:16px">🌍</span>'
                  + '<strong style="font-size:14px;color:#0f172a">' + (hors.nom || '') + '</strong>'
                  + (hors.pays ? '<span style="font-size:12px;color:#888"> · ' + hors.pays + '</span>' : '')
                  + '</div>'
                  + '<p style="font-size:13px;color:#ea6c0a;font-style:italic;margin:0 0 8px">' + (hors.message || '') + '</p>'
                  + '<p style="font-size:13px;color:#555;margin:0 0 6px">' + (hors.infos || '') + '</p>'
                  + (hors.conseil ? '<div style="background:#fff;border-radius:8px;padding:8px 12px;border:1px solid #fed7aa;font-size:12px;color:#92400e">💡 ' + hors.conseil + '</div>' : '')
                  + '</div>';
        }

        if (!html) {
            html = '<p style="color:#e11d48;font-size:13px;text-align:center">Aucune destination trouvée.</p>';
        }

        document.getElementById('voiceStatus').textContent =
            dispo.length + ' dans le catalogue' + (hors && hors.existe ? ' · 1 suggestion mondiale' : '');
        document.getElementById('voiceResults').innerHTML = html;
    })
    .catch(function() {
        document.getElementById('voiceResults').innerHTML = '<p style="color:#e11d48;font-size:13px;text-align:center">Erreur de connexion.</p>';
        document.getElementById('voiceSearchBtn').disabled = false;
    });
};
})();
</script>

{# ===== SECTION DESTINATIONS ===== #}
<div class="section properties">
  <div class="container">

    {% if search or saison %}
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px">
        <p style="color:#555;font-size:15px;margin:0">
          <strong style="color:#f97316">{{ destinations|length }}</strong>
          résultat{{ destinations|length > 1 ? 's' : '' }}
          {% if search %} pour "<strong>{{ search }}</strong>"{% endif %}
          {% if saison %} — <strong>{{ saison }}</strong>{% endif %}
        </p>
        <a href="{{ path('app_destinations') }}"
           style="padding:8px 16px;border-radius:6px;border:1px solid #ddd;color:#666;font-size:13px;text-decoration:none">
          ✕ Réinitialiser
        </a>
      </div>
    {% endif %}

    {% if not search and not saison %}
    <ul class="properties-filter">
      <li><a class="is_active" href="#!" data-filter="*">Toutes</a></li>
      <li><a href="#!" data-filter=".Printemps">Printemps</a></li>
      <li><a href="#!" data-filter=".Ete">Ete</a></li>
      <li><a href="#!" data-filter=".Automne">Automne</a></li>
      <li><a href="#!" data-filter=".Hiver">Hiver</a></li>
    </ul>
    {% endif %}

    <div class="row properties-box">
      {% for destination in destinations %}
      <div class="col-lg-4 col-md-6 align-self-center mb-30 properties-items {{ destination.meilleureSaison }}">
        <div class="item">
          {% if destination.images|length > 0 %}
            <a href="{{ path('app_destination_detail', {'id': destination.id}) }}">
              <img src="{{ asset(destination.images[0].urlImage) }}" alt="{{ destination.nom }}"
                   style="height:220px;object-fit:cover;width:100%">
            </a>
          {% else %}
            <a href="{{ path('app_destination_detail', {'id': destination.id}) }}">
              <img src="{{ asset('assets_front/images/images/property-01.jpg') }}" alt="{{ destination.nom }}"
                   style="height:220px;object-fit:cover;width:100%">
            </a>
          {% endif %}

          {% set nv = 0 %}
          {% if destination.nbVisites >= 10000 %}{% set nv = 2.5 %}
          {% elseif destination.nbVisites >= 5000 %}{% set nv = 2 %}
          {% elseif destination.nbVisites >= 2000 %}{% set nv = 1.5 %}
          {% elseif destination.nbVisites >= 1000 %}{% set nv = 1 %}
          {% elseif destination.nbVisites >= 500 %}{% set nv = 0.5 %}
          {% endif %}
          {% set ns = 0 %}
          {% if destination.meilleureSaison == "Ete" %}{% set ns = 2.5 %}
          {% elseif destination.meilleureSaison == "Printemps" %}{% set ns = 2 %}
          {% elseif destination.meilleureSaison == "Automne" %}{% set ns = 1.5 %}
          {% elseif destination.meilleureSaison == "Hiver" %}{% set ns = 1 %}
          {% endif %}
          {% set nt = nv + ns %}
          {% if nt > 5 %}{% set nt = 5 %}{% endif %}
          {% set ep = nt|round(0, "floor") %}
          {% set de = ((nt - ep) >= 0.5) ? 1 : 0 %}
          {% set ev = 5 - ep - de %}

          <span class="category">{{ destination.meilleureSaison ?? "-" }}</span>

          <div style="display:flex;align-items:center;gap:8px;margin:8px 0">
            <div style="display:flex;gap:2px">
              {% for i in 1..ep %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% endfor %}
              {% if de %}
                <svg width="16" height="16" viewBox="0 0 24 24"><defs><linearGradient id="h{{ destination.id }}"><stop offset="50%" stop-color="#f97316"/><stop offset="50%" stop-color="#ddd"/></linearGradient></defs><path fill="url(#h{{ destination.id }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% endif %}
              {% for i in 1..ev %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#ddd"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {% endfor %}
            </div>
            <span style="font-size:12px;font-weight:600;color:#f97316">{{ nt|number_format(1) }}</span>
            <span style="font-size:12px;color:#888">{{ destination.nbVisites ?? 0 }} visites</span>
          </div>

          <h4>
            <a href="{{ path('app_destination_detail', {'id': destination.id}) }}">
              {{ destination.nom }} - {{ destination.pays }}
            </a>
          </h4>
          <ul>
            <li>Pays : <span>{{ destination.pays }}</span></li>
            <li>Saison : <span>{{ destination.meilleureSaison ?? "-" }}</span></li>
            <li>Statut : <span>{{ destination.statut ? "Actif" : "Inactif" }}</span></li>
          </ul>
          {# ===== LIKE CARTE ===== #}
          <div style="margin:8px 0">
              <button onclick="toggleLikeCard({{ destination.id }}, this)"
                  style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;border:1.5px solid #fed7aa;background:#fff7ed;cursor:pointer;font-size:13px;font-weight:600;color:#ea6c0a;transition:all .2s">
                  <span class="like-icon-{{ destination.id }}">🤍</span>
                  <span class="like-count-{{ destination.id }}">{{ destination.nbVisites ?? 0 }}</span>
              </button>
          </div>
          <div class="main-button">
            <a href="{{ path('app_destination_detail', {'id': destination.id}) }}">Voir les détails</a>
          </div>
        </div>
      </div>
      {% else %}
      <div class="col-12 text-center" style="padding:60px 0">
        <h4>Aucune destination trouvée.</h4>
        <a href="{{ path('app_destinations') }}" style="color:#f97316">Voir toutes les destinations</a>
      </div>
      {% endfor %}
    </div>

  </div>
</div>
<script>
{% for destination in destinations %}
(function(){
    var id = {{ destination.id }};
    fetch('/destination/like-status/' + id)
        .then(function(r){ return r.json(); })
        .then(function(data){
            var icon = document.querySelector('.like-icon-' + id);
            var count = document.querySelector('.like-count-' + id);
            if (icon) icon.textContent = data.liked ? '❤️' : '🤍';
            if (count) count.textContent = data.total;
            if (data.liked) {
                var btns = document.querySelectorAll('[onclick*="toggleLikeCard(' + id + '"]');
                btns.forEach(function(btn){
                    btn.style.background  = '#fff0f0';
                    btn.style.borderColor = '#fca5a5';
                    btn.style.color       = '#e11d48';
                });
            }
        });
})();
{% endfor %}

function toggleLikeCard(id, btn) {
    fetch('/destination/like/' + id, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
        var icon = document.querySelector('.like-icon-' + id);
        var count = document.querySelector('.like-count-' + id);
        if (icon) icon.textContent = data.liked ? '❤️' : '🤍';
        if (count) count.textContent = data.total;
        btn.style.background  = data.liked ? '#fff0f0' : '#fff7ed';
        btn.style.borderColor = data.liked ? '#fca5a5' : '#fed7aa';
        btn.style.color       = data.liked ? '#e11d48' : '#ea6c0a';
    });
}
</script>


{% endblock %}