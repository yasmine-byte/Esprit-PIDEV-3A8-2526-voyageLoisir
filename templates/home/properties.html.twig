{% extends 'base_front.html.twig' %}
{% block title %}Hébergements - Vianova{% endblock %}
{% block body %}

  <div id="js-preloader" class="js-preloader">
    <div class="preloader-inner">
      <span class="dot"></span>
      <div class="dots"><span></span><span></span><span></span></div>
    </div>
  </div>

  <div class="sub-header">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 col-md-8">
          <ul class="info">
            <li><i class="fa fa-envelope"></i> vianova.com</li>
            <li><i class="fa fa-map"></i> Tunis, Tunisie Lac1</li>
          </ul>
        </div>
        <div class="col-lg-4 col-md-4">
          <ul class="social-links">
            <li><a href="#"><i class="fab fa-facebook"></i></a></li>
            <li><a href="#"><i class="fab fa-twitter"></i></a></li>
            <li><a href="#"><i class="fab fa-linkedin"></i></a></li>
            <li><a href="#"><i class="fab fa-instagram"></i></a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <header class="header-area header-sticky">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <nav class="main-nav">
            <a href="{{ path('app_home') }}" class="logo"><h1>Vianova</h1></a>
            <ul class="nav">
              <li><a href="{{ path('app_home') }}">Home</a></li>
              <li><a href="#">Destination</a></li>
              <li><a href="{{ path('app_properties') }}" class="active">Hébergement</a></li>
              <li><a href="#">Activité</a></li>
              <li><a href="#">Blog</a></li>
              <li><a href="{{ path('app_contact') }}">Avis</a></li>
            </ul>
            <a class='menu-trigger'><span>Menu</span></a>
          </nav>
        </div>
      </div>
    </div>
  </header>

  <div class="page-heading header-text" style="background-image: url('{{ asset('assets_front/images/images/page-heading-bg.jpg') }}'); background-size:cover; background-position:center; min-height:300px; display:flex; align-items:center;">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <span class="breadcrumb"><a href="{{ path('app_home') }}">Home</a> / Hébergements</span>
          <h3>Nos Hébergements</h3>
          <p style="color:#fff; font-size:16px; margin-top:8px;">{{ hebergements|length }} hébergement(s) trouvé(s)</p>
        </div>
      </div>
    </div>
  </div>

  {# Barre de recherche et filtres #}
  <div style="background:#f9f9f9; padding:30px 0; border-bottom:1px solid #eee;">
    <div class="container">
      <form method="get" action="{{ path('app_properties') }}">
        <div class="row">

          {# Recherche description #}
          <div class="col-lg-3 col-md-6" style="margin-bottom:15px;">
            <label style="font-weight:600; font-size:13px; margin-bottom:5px; display:block;">Rechercher</label>
            <input type="text" name="description" value="{{ filters.description }}"
                   placeholder="Description..."
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px;">
          </div>

          {# Filtre par type #}
          <div class="col-lg-2 col-md-6" style="margin-bottom:15px;">
            <label style="font-weight:600; font-size:13px; margin-bottom:5px; display:block;">Type</label>
            <select name="type" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px;">
              <option value="">Tous les types</option>
              {% for type in types %}
                <option value="{{ type.id }}" {{ filters.type == type.id ? 'selected' : '' }}>{{ type.nom }}</option>
              {% endfor %}
            </select>
          </div>

          {# Prix min/max #}
          <div class="col-lg-2 col-md-6" style="margin-bottom:15px;">
            <label style="font-weight:600; font-size:13px; margin-bottom:5px; display:block;">Prix min (TND)</label>
            <input type="number" name="prixMin" value="{{ filters.prixMin }}"
                   placeholder="0" min="0"
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px;">
          </div>
          <div class="col-lg-2 col-md-6" style="margin-bottom:15px;">
            <label style="font-weight:600; font-size:13px; margin-bottom:5px; display:block;">Prix max (TND)</label>
            <input type="number" name="prixMax" value="{{ filters.prixMax }}"
                   placeholder="9999" min="0"
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px;">
          </div>

          {# Tri #}
          <div class="col-lg-2 col-md-6" style="margin-bottom:15px;">
            <label style="font-weight:600; font-size:13px; margin-bottom:5px; display:block;">Trier par</label>
            <select name="tri" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px;">
              <option value="">Par défaut</option>
              <option value="prix_asc" {{ filters.tri == 'prix_asc' ? 'selected' : '' }}>Prix croissant ↑</option>
              <option value="prix_desc" {{ filters.tri == 'prix_desc' ? 'selected' : '' }}>Prix décroissant ↓</option>
            </select>
          </div>

          {# Bouton rechercher #}
          <div class="col-lg-1 col-md-6" style="margin-bottom:15px; display:flex; align-items:flex-end;">
            <button type="submit" style="width:100%; padding:10px; background:#f75959; color:#fff; border:none; border-radius:6px; font-weight:600; cursor:pointer;">
              🔍
            </button>
          </div>

        </div>

        {# Filtre disponibilité #}
        <div class="row" style="margin-top:5px;">
          <div class="col-lg-3 col-md-6" style="margin-bottom:10px;">
            <label style="font-weight:600; font-size:13px; margin-bottom:5px; display:block;">Disponible du</label>
            <input type="date" name="dateDebut" value="{{ filters.dateDebut }}"
                   min="{{ "now"|date("Y-m-d") }}"
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px;">
          </div>
          <div class="col-lg-3 col-md-6" style="margin-bottom:10px;">
            <label style="font-weight:600; font-size:13px; margin-bottom:5px; display:block;">Au</label>
            <input type="date" name="dateFin" value="{{ filters.dateFin }}"
                   min="{{ "now"|date("Y-m-d") }}"
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px;">
          </div>
          {% if filters.description or filters.type or filters.prixMin or filters.prixMax or filters.tri or filters.dateDebut %}
          <div class="col-lg-2 col-md-6" style="margin-bottom:10px; display:flex; align-items:flex-end;">
            <a href="{{ path('app_properties') }}" style="width:100%; padding:10px; background:#6e6e6e; color:#fff; border-radius:6px; font-weight:600; text-align:center; text-decoration:none; font-size:14px;">
              ✕ Réinitialiser
            </a>
          </div>
          {% endif %}
        </div>
      </form>
    </div>
  </div>

  {# Liste des hébergements #}
  <div class="section properties">
    <div class="container">
      <div class="row properties-box">
        {% for hebergement in hebergements %}
        <div class="col-lg-4 col-md-6 align-self-center mb-30 properties-items">
          <div class="item">
            <a href="{{ path('app_property_details', {'id': hebergement.id}) }}">
              {% if hebergement.imagePath %}
                <img src="{{ asset('uploads/hebergements/' ~ hebergement.imagePath) }}" alt="{{ hebergement.description }}">
              {% else %}
                <img src="{{ asset('assets_front/images/images/property-01.jpg') }}" alt="">
              {% endif %}
            </a>
            <span class="category">{{ hebergement.type ? hebergement.type.nom : 'Hébergement' }}</span>
            <h6>{{ hebergement.prix }} TND / nuit</h6>
            <h4><a href="{{ path('app_property_details', {'id': hebergement.id}) }}">{{ hebergement.description }}</a></h4>
            <ul>
              <li>Chambres: <span>{{ hebergement.no|length }}</span></li>
            </ul>
            <div class="main-button">
              <a href="{{ path('app_property_details', {'id': hebergement.id}) }}">Voir & Réserver</a>
            </div>
          </div>
        </div>
        {% else %}
        <div class="col-12 text-center" style="padding:60px 0;">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" style="margin:0 auto 16px; display:block;">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <h4 style="color:#999;">Aucun hébergement trouvé</h4>
          <p style="color:#bbb;">Essayez de modifier vos critères de recherche.</p>
          <a href="{{ path('app_properties') }}" style="color:#f75959;">Voir tous les hébergements</a>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <footer>
    <div class="container">
      <div class="col-lg-12">
        <p>Copyright &copy; 2026 Vianova. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
  // Date fin > date debut pour le filtre disponibilité
  document.querySelector('input[name="dateDebut"]').addEventListener('change', function() {
      var dateDebut = new Date(this.value);
      dateDebut.setDate(dateDebut.getDate() + 1);
      document.querySelector('input[name="dateFin"]').min = dateDebut.toISOString().split('T')[0];
  });
  </script>

{% endblock %}
