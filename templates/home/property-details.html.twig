{% extends 'base_front.html.twig' %}

{% block title %}Property Details - Villa Agency{% endblock %}

{% block body %}

  {# Popup succès #}
  {% for message in app.flashes('success') %}
  <div id="reservationPopup" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9999; display:flex; align-items:center; justify-content:center;">
      <div style="background:#fff; border-radius:16px; padding:40px; max-width:450px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
          <div style="width:70px; height:70px; background:#22c55e20; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2">
                  <polyline points="20 6 9 17 4 12"/>
              </svg>
          </div>
          <h4 style="color:#1c1c1e; margin-bottom:12px; font-size:22px;">Réservation Confirmée !</h4>
          <p style="color:#6e6e6e; margin-bottom:24px;">{{ message }}</p>
          <button onclick="document.getElementById('reservationPopup').style.display='none'"
                  style="background:#f75959; color:#fff; padding:12px 30px; border:none; border-radius:8px; font-size:16px; font-weight:600; cursor:pointer;">
              Fermer
          </button>
      </div>
  </div>
  {% endfor %}

  {# Popup erreur #}
  {% for message in app.flashes('error') %}
  <div id="errorPopup" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9999; display:flex; align-items:center; justify-content:center;">
      <div style="background:#fff; border-radius:16px; padding:40px; max-width:450px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
          <div style="width:70px; height:70px; background:#ef444420; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
          </div>
          <h4 style="color:#1c1c1e; margin-bottom:12px; font-size:22px;">Réservation impossible !</h4>
          <p style="color:#6e6e6e; margin-bottom:24px;">{{ message }}</p>
          <button onclick="document.getElementById('errorPopup').style.display='none'"
                  style="background:#ef4444; color:#fff; padding:12px 30px; border:none; border-radius:8px; font-size:16px; font-weight:600; cursor:pointer;">
              Fermer
          </button>
      </div>
  </div>
  {% endfor %}

  <div id="js-preloader" class="js-preloader">
    <div class="preloader-inner">
      <span class="dot"></span>
      <div class="dots">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </div>

  <div class="sub-header">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 col-md-8">
          <ul class="info">
            <li><i class="fa fa-envelope"></i> vianova.com</li>
            <li><i class="fa fa-map"></i> Tunis, Tunisie Lac1</li>
          </ul>
        </div>
        <div class="col-lg-4 col-md-4">
          <ul class="social-links">
            <li><a href="#"><i class="fab fa-facebook"></i></a></li>
            <li><a href="#"><i class="fab fa-twitter"></i></a></li>
            <li><a href="#"><i class="fab fa-linkedin"></i></a></li>
            <li><a href="#"><i class="fab fa-instagram"></i></a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <header class="header-area header-sticky">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <nav class="main-nav">
            <a href="{{ path('app_home') }}" class="logo"><h1>Vianova</h1></a>
            <ul class="nav">
              <li><a href="{{ path('app_home') }}">Home</a></li>
              <li><a href="#">Destination</a></li>
              <li><a href="{{ path('app_properties') }}" class="active">Hébergement</a></li>
              <li><a href="#">Activité</a></li>
              <li><a href="#">Blog</a></li>
              <li><a href="{{ path('app_contact') }}">Avis</a></li>
            </ul>
            <a class='menu-trigger'><span>Menu</span></a>
          </nav>
        </div>
      </div>
    </div>
  </header>

  <div class="page-heading header-text" style="background-image: url('{% if hebergement.imagePath %}{{ asset('uploads/hebergements/' ~ hebergement.imagePath) }}{% else %}{{ asset('assets_front/images/images/page-heading-bg.jpg') }}{% endif %}'); background-size:cover; background-position:center; min-height:400px; display:flex; align-items:center;">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <span class="breadcrumb"><a href="{{ path('app_home') }}">Home</a> / {{ hebergement.description|slice(0,30) }}</span>
          <h3>{{ hebergement.description }}</h3>
          <p style="color:#fff; font-size:18px; margin-top:10px;">{{ hebergement.type ? hebergement.type.nom : '' }} — {{ hebergement.prix }} TND / nuit</p>
        </div>
      </div>
    </div>
</div>

  <div class="single-property section">
    <div class="container">
      <div class="row">
        <div class="col-lg-8">
          <div class="main-image">
            {% if hebergement.imagePath %}
                <img src="{{ asset('uploads/hebergements/' ~ hebergement.imagePath) }}" alt="{{ hebergement.description }}" style="width:100%; border-radius:12px;">
            {% else %}
                <img src="{{ asset('assets_front/images/images/single-property.jpg') }}" alt="">
            {% endif %}
          </div>
          <div class="main-content">
            <span class="category">{{ hebergement.type ? hebergement.type.nom : 'Hébergement' }}</span>
            <h4>{{ hebergement.description }}</h4>
            <p>Prix : <strong>{{ hebergement.prix }} TND / nuit</strong></p>
          </div>

          {% if hebergement.no|length > 0 %}
          <div style="margin-top:30px;">
            <h4>Chambres disponibles</h4>
            <div class="row" style="margin-top:15px;">
              {% for chambre in hebergement.no %}
              <div class="col-lg-4 col-md-6" style="margin-bottom:15px;">
                <div style="background:#f9f9f9; border-radius:8px; padding:15px; border:1px solid #eee;">
                  <h6>Chambre {{ chambre.numero }}</h6>
                  <p style="margin:0;">{{ chambre.typeChambre }}</p>
                  <p style="margin:0; color:#f75959; font-weight:600;">{{ chambre.prixNuit }} TND/nuit</p>
                  <p style="margin:0; font-size:13px; color:#888;">{{ chambre.capacite }} personnes</p>
                  {% if chambre.equipements %}
                  <p style="margin:4px 0 0; font-size:12px; color:#aaa;">{{ chambre.equipements }}</p>
                  {% endif %}
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>

        <div class="col-lg-4">
          <div class="info-table">
            <ul>
              <li>
                <img src="{{ asset('assets_front/images/images/info-icon-01.png') }}" alt="" style="max-width: 52px;">
                <h4>{{ hebergement.no|length }} Chambres<br><span>Disponibles</span></h4>
              </li>
              <li>
                <img src="{{ asset('assets_front/images/images/info-icon-03.png') }}" alt="" style="max-width: 52px;">
                <h4>{{ hebergement.prix }} TND<br><span>Prix / nuit</span></h4>
              </li>
              <li>
                <img src="{{ asset('assets_front/images/images/info-icon-02.png') }}" alt="" style="max-width: 52px;">
                <h4>{{ hebergement.type ? hebergement.type.nom : 'N/A' }}<br><span>Type</span></h4>
              </li>
            </ul>
          </div>

          {# Formulaire de réservation #}
          <div style="background:#f9f9f9; border-radius:12px; padding:25px; margin-top:20px; border:1px solid #eee;">
            <h4 style="margin-bottom:20px; color:#f75959;">Réserver maintenant</h4>
            <form method="post" action="{{ path('app_reservation_new', {'id': hebergement.id}) }}" id="reservationForm">
              <div style="margin-bottom:15px;">
                <label style="display:block; font-weight:600; margin-bottom:5px;">Nom complet *</label>
                <input type="text" name="clientNom" required
                       minlength="3" maxlength="100"
                       pattern="[a-zA-ZÀ-ÿ\s]+"
                       title="Le nom doit contenir uniquement des lettres"
                       placeholder="Votre nom"
                       style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px;">
              </div>
              <div style="margin-bottom:15px;">
                <label style="display:block; font-weight:600; margin-bottom:5px;">Téléphone * (8 chiffres)</label>
                <input type="tel" name="clientTel" required
                       pattern="[0-9]{8}"
                       minlength="8" maxlength="8"
                       title="Le téléphone doit contenir exactement 8 chiffres"
                       placeholder="Ex: 22334455"
                       style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px;">
              </div>
              <div style="margin-bottom:15px;">
                <label style="display:block; font-weight:600; margin-bottom:5px;">Email *</label>
                <input type="email" name="clientEmail" required
                       placeholder="email@exemple.com"
                       style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px;">
              </div>
              <div style="margin-bottom:15px;">
                <label style="display:block; font-weight:600; margin-bottom:5px;">Date d'arrivée *</label>
                <input type="date" name="dateDebut" id="dateDebut" required
                       min="{{ "now"|date("Y-m-d") }}"
                       style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px;">
              </div>
              <div style="margin-bottom:20px;">
                <label style="display:block; font-weight:600; margin-bottom:5px;">Date de départ *</label>
                <input type="date" name="dateFin" id="dateFin" required
                       min="{{ "now"|date("Y-m-d") }}"
                       style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px;">
              </div>
              <div id="dateError" style="color:#f75959; font-size:13px; margin-bottom:10px; display:none;">
                  ⚠️ La date de départ doit être après la date d'arrivée.
              </div>
              <button type="submit" id="submitBtn"
                      style="width:100%; background:#f75959; color:#fff; padding:12px; border:none; border-radius:6px; font-size:16px; font-weight:600; cursor:pointer;">
                Confirmer la réservation
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer-no-gap">
    <div class="container">
      <div class="col-lg-12">
        <p>Copyright &copy; 2026 Villa Agency Co., Ltd. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
  document.getElementById('dateFin').addEventListener('change', function() {
      var dateDebut = document.getElementById('dateDebut').value;
      var dateFin = this.value;
      if (dateDebut && dateFin && dateFin <= dateDebut) {
          document.getElementById('dateError').style.display = 'block';
          document.getElementById('submitBtn').disabled = true;
      } else {
          document.getElementById('dateError').style.display = 'none';
          document.getElementById('submitBtn').disabled = false;
      }
  });

  document.getElementById('dateDebut').addEventListener('change', function() {
      var dateDebut = new Date(this.value);
      dateDebut.setDate(dateDebut.getDate() + 1);
      var minDateFin = dateDebut.toISOString().split('T')[0];
      document.getElementById('dateFin').min = minDateFin;

      var dateFin = document.getElementById('dateFin').value;
      if (dateFin && dateFin <= this.value) {
          document.getElementById('dateFin').value = '';
          document.getElementById('dateError').style.display = 'none';
          document.getElementById('submitBtn').disabled = false;
      }
  });
  </script>

{% endblock %}
