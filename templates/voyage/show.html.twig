{% extends "admin/base_admin.html.twig" %}

{% block title %}Voyage #{{ voyage.id }}{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Detail Voyage</h1>
    <p>Informations du voyage</p>
</div>

<div class="card" style="max-width:600px">
    <table class="market-table">
        <tr>
            <th>ID</th>
            <td>{{ voyage.id }}</td>
        </tr>
        <tr>
            <th>Date de depart</th>
            <td>{{ voyage.dateDepart ? voyage.dateDepart|date("d/m/Y") : "-" }}</td>
        </tr>
        <tr>
            <th>Date d arrivee</th>
            <td>{{ voyage.dateArrivee ? voyage.dateArrivee|date("d/m/Y") : "-" }}</td>
        </tr>
        <tr>
            <th>Point de depart</th>
            <td>{{ voyage.pointDepart ?? "-" }}</td>
        </tr>
        <tr>
            <th>Point d arrivee</th>
            <td>{{ voyage.pointArrivee ?? "-" }}</td>
        </tr>
        <tr>
            <th>Prix</th>
            <td>{{ voyage.prix ? voyage.prix ~ " EUR" : "-" }}</td>
        </tr>
      <tr>
    <th>Réservé par</th>
    <td>
        {% if voyage.reservedByUsers|length > 0 %}
            {% for u in voyage.reservedByUsers %}
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:8px;padding:8px 12px;background:#1a1a2e;border-radius:10px;border:1px solid #2a2a3a">
                    <div style="display:flex;align-items:center;gap:8px">
                        <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#f97316,#ea6c0a);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">
                            {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:14px;color:#e2e8f0">{{ u.prenom }} {{ u.nom }}</div>
                            <div style="font-size:12px;color:#6b7280">{{ u.email }}</div>
                        </div>
                    </div>
                    <button type="button"
                            onclick="openCancelModal('{{ path('app_voyage_admin_cancel', {id: voyage.id, userId: u.id}) }}', '{{ csrf_token('admin_cancel' ~ voyage.id ~ u.id) }}', '{{ u.prenom }} {{ u.nom }}')"
                            style="padding:5px 12px;border-radius:6px;border:1px solid #3d1f1f;background:#1a1a28;color:#f87171;font-size:12px;font-weight:600;cursor:pointer">
                        ✕ Annuler
                    </button>
                </div>
            {% endfor %}
        {% else %}
            <span style="color:#6b7280">— Non réservé</span>
        {% endif %}
    </td>
</tr>
    </table>

    <div style="margin-top:20px;display:flex;gap:10px">
        <a href="{{ path("app_voyage_index") }}" class="action-btn">Retour</a>
        <a href="{{ path("app_voyage_edit", {"id": voyage.id}) }}" class="action-btn">Modifier</a>
        {{ include("voyage/_delete_form.html.twig") }}
    </div>
</div>
{# ===== POPUP CONFIRMATION ===== #}
<div id="cancelModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:9999;align-items:center;justify-content:center">
    <div style="background:#1a1a2e;border-radius:16px;padding:32px;max-width:400px;width:90%;border:1px solid #2a2a3a;box-shadow:0 24px 60px rgba(0,0,0,0.5);text-align:center">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(248,113,113,0.15);border:2px solid #f87171;display:flex;align-items:center;justify-content:center;font-size:24px;margin:0 auto 20px">
            ✕
        </div>
        <h3 style="color:#e2e8f0;font-size:18px;font-weight:700;margin:0 0 8px">Annuler la réservation ?</h3>
        <p id="cancelModalText" style="color:#6b7280;font-size:14px;margin:0 0 28px"></p>
        <div style="display:flex;gap:12px;justify-content:center">
            <button onclick="closeCancelModal()"
                    style="padding:10px 24px;border-radius:8px;border:1px solid #2a2a3a;background:#12122a;color:#94a3b8;font-size:14px;font-weight:600;cursor:pointer">
                Non, garder
            </button>
            <form id="cancelModalForm" method="POST" style="margin:0">
                <input type="hidden" name="_token" id="cancelModalToken">
                <button type="submit"
                        style="padding:10px 24px;border-radius:8px;border:none;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(239,68,68,0.35)">
                    Oui, annuler
                </button>
            </form>
        </div>
    </div>
</div>

<script>
function openCancelModal(url, token, nom) {
    document.getElementById('cancelModalForm').action = url;
    document.getElementById('cancelModalToken').value = token;
    document.getElementById('cancelModalText').textContent = 'Voulez-vous annuler la réservation de ' + nom + ' ?';
    document.getElementById('cancelModal').style.display = 'flex';
}
function closeCancelModal() {
    document.getElementById('cancelModal').style.display = 'none';
}
document.getElementById('cancelModal').addEventListener('click', function(e) {
    if (e.target === this) closeCancelModal();
});
</script>
{% endblock %}
