{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
    <div>
        <label class="form-label">Date de Depart *</label>
        {{ form_widget(form.date_depart, {'attr': {'class': 'form-input'}}) }}
        {% for err in form.date_depart.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Date d Arrivee *</label>
        {{ form_widget(form.date_arrivee, {'attr': {'class': 'form-input'}}) }}
        {% for err in form.date_arrivee.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Point de Depart *</label>
        {{ form_widget(form.point_depart, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Tunis'}}) }}
        {% for err in form.point_depart.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Point d Arrivee *</label>
        {{ form_widget(form.point_arrivee, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Paris'}}) }}
        {% for err in form.point_arrivee.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Prix (EUR) *</label>
        {{ form_widget(form.prix, {'attr': {'class': 'form-input', 'placeholder': 'Ex: 299.99'}}) }}
        {% for err in form.prix.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Destination</label>
        {{ form_widget(form.destination, {'attr': {'class': 'form-select'}}) }}
        {% for err in form.destination.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
</div>

<button type="submit" class="btn primary">Sauvegarder</button>
{{ form_end(form) }}
