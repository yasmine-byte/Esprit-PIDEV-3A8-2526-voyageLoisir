{% extends 'admin/base_admin.html.twig' %}
{% block title %}Voyages{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Voyages</h1>
    <p>Gérer tous les voyages</p>
</div>

{# ===== FILTRES ===== #}
<div class="card" style="margin-bottom:20px">
    <div class="card-header">
        <h3 class="card-title">Filtres & Recherche</h3>
    </div>
    <form method="GET" action="{{ path('app_voyage_index') }}"
          style="display:flex;flex-wrap:wrap;gap:12px;padding:16px;align-items:flex-end">

        <div style="flex:1;min-width:180px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Recherche (point départ, arrivée, ID)</label>
            <input type="text" name="search" value="{{ search }}"
                   placeholder="Rechercher..."
                   style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
        </div>

        <div style="min-width:150px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Trier par</label>
            <select name="tri"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="id"            {{ tri == 'id'            ? 'selected' : '' }}>ID</option>
                <option value="date_depart"   {{ tri == 'date_depart'   ? 'selected' : '' }}>Date Départ</option>
                <option value="date_arrivee"  {{ tri == 'date_arrivee'  ? 'selected' : '' }}>Date Arrivée</option>
                <option value="point_depart"  {{ tri == 'point_depart'  ? 'selected' : '' }}>Point Départ</option>
                <option value="point_arrivee" {{ tri == 'point_arrivee' ? 'selected' : '' }}>Point Arrivée</option>
                <option value="prix"          {{ tri == 'prix'          ? 'selected' : '' }}>Prix</option>
            </select>
        </div>

        <div style="min-width:120px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Ordre</label>
            <select name="ordre"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="ASC"  {{ ordre == 'ASC'  ? 'selected' : '' }}>▲ Croissant</option>
                <option value="DESC" {{ ordre == 'DESC' ? 'selected' : '' }}>▼ Décroissant</option>
            </select>
        </div>

        <div style="display:flex;gap:8px">
            <button type="submit"
                    style="padding:8px 18px;border-radius:6px;border:none;background:#6c63ff;color:#fff;font-size:13px;cursor:pointer;font-weight:600">
                🔍 Filtrer
            </button>
            <a href="{{ path('app_voyage_index') }}"
               style="padding:8px 18px;border-radius:6px;border:1px solid #555;color:#aaa;font-size:13px;text-decoration:none;display:flex;align-items:center">
                ✕ Reset
            </a>
        </div>
    </form>
</div>

{# ===== TABLEAU ===== #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Liste des Voyages
            <span style="font-size:13px;color:#888;font-weight:normal;margin-left:8px">
                ({{ voyages|length }} résultat{{ voyages|length > 1 ? 's' : '' }})
            </span>
        </h3>
        <a href="{{ path('app_voyage_new') }}" class="action-btn primary">+ Ajouter</a>
    </div>

    {% set params = {search: search} %}

    <div style="overflow-x:auto">
    <table class="market-table">
        <thead>
            <tr>
                <th>
                    <a href="{{ path('app_voyage_index', params|merge({tri: 'id', ordre: (tri == 'id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        ID {% if tri == 'id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>Destination</th>
                <th>
                    <a href="{{ path('app_voyage_index', params|merge({tri: 'point_depart', ordre: (tri == 'point_depart' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Trajet {% if tri == 'point_depart' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_voyage_index', params|merge({tri: 'date_depart', ordre: (tri == 'date_depart' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Dates {% if tri == 'date_depart' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>Durée</th>
                <th>
                    <a href="{{ path('app_voyage_index', params|merge({tri: 'prix', ordre: (tri == 'prix' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Prix {% if tri == 'prix' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>Transports</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for voyage in voyages %}
            <tr>
                {# ID #}
                <td>
                    <span style="background:#2a2a3e;color:#a0a0c0;border-radius:6px;padding:3px 8px;font-size:12px;font-weight:700">
                        #{{ voyage.id }}
                    </span>
                </td>

                {# Destination #}
                <td>
                    {% if voyage.destination %}
                        <span style="background:#1a2e1a;color:#6fcf97;border-radius:6px;padding:3px 9px;font-size:12px;font-weight:600">
                            {{ voyage.destination.nom }}
                        </span>
                        <div style="font-size:10px;color:#666;margin-top:2px">ID #{{ voyage.destination.id }}</div>
                    {% else %}
                        <span style="color:#555;font-size:12px">—</span>
                    {% endif %}
                </td>

                {# Trajet #}
                <td style="white-space:nowrap">
                    <div style="display:flex;align-items:center;gap:6px;font-size:13px">
                        <span style="font-weight:600;color:#e0e0e0">{{ voyage.pointDepart ?? '?' }}</span>
                        <span style="color:#f97316;font-size:11px">→</span>
                        <span style="font-weight:600;color:#e0e0e0">{{ voyage.pointArrivee ?? '?' }}</span>
                    </div>
                </td>

                {# Dates #}
                <td style="white-space:nowrap">
                    <div style="font-size:12px;color:#aaa">
                        <span style="color:#e0e0e0;font-weight:600">{{ voyage.dateDepart ? voyage.dateDepart|date('d/m/Y') : '—' }}</span>
                        <br>
                        <span style="font-size:10px;color:#666">→ {{ voyage.dateArrivee ? voyage.dateArrivee|date('d/m/Y') : '—' }}</span>
                    </div>
                </td>

                {# Durée #}
                <td>
                    {% if voyage.dateDepart and voyage.dateArrivee %}
                        {% set duree = ((voyage.dateArrivee|date('U') - voyage.dateDepart|date('U')) / 86400)|round %}
                        <span style="background:#1a1a2e;color:#818cf8;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;white-space:nowrap">
                            {{ duree }}j
                        </span>
                    {% else %}
                        <span style="color:#555">—</span>
                    {% endif %}
                </td>

                {# Prix #}
                <td>
                    {% if voyage.prix %}
                        <span style="font-size:14px;font-weight:800;color:#f97316">
                            {{ voyage.prix }}<span style="font-size:10px;font-weight:500;margin-left:1px">€</span>
                        </span>
                    {% else %}
                        <span style="color:#555">—</span>
                    {% endif %}
                </td>

                {# Transports #}
                <td>
                    {% if voyage.transports|length > 0 %}
                        <div style="display:flex;flex-wrap:wrap;gap:4px">
                        {% set icons = {'Avion': '✈', 'Bus': '🚌', 'Train': '🚆', 'Voiture': '🚗'} %}
                        {% for t in voyage.transports %}
                            <span style="background:#2a1a3e;color:#c084fc;border-radius:20px;padding:2px 8px;font-size:11px;font-weight:600;white-space:nowrap">
                                {{ icons[t.typeTransport] ?? '' }} {{ t.typeTransport }}
                            </span>
                        {% endfor %}
                        </div>
                    {% else %}
                        <span style="color:#555;font-size:12px">—</span>
                    {% endif %}
                </td>

                {# Actions #}
                <td style="white-space:nowrap">
                    <a href="{{ path('app_voyage_show', {'id': voyage.id}) }}" class="action-btn">Voir</a>
                    <a href="{{ path('app_voyage_edit', {'id': voyage.id}) }}" class="action-btn">Modifier</a>
                    <a href="{{ path('app_transport_new', {'voyage_id': voyage.id}) }}"
                       class="action-btn"
                       style="background:#6a3fa0;color:#fff;border-color:#6a3fa0">+ Transport</a>
                    {{ include('voyage/_delete_form.html.twig') }}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="8" style="text-align:center;color:#888;padding:30px">
                    Aucun voyage trouvé
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
</div>

<footer class="copyright">Copyright &copy; 2026 VoyageLoisir</footer>
{% endblock %}
