<form id="delete-form-{{ voyage.id }}"
      method="post"
      action="{{ path('app_voyage_delete', {'id': voyage.id}) }}"
      style="display:inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ voyage.id) }}">
    <button type="button"
            onclick="openDeleteModal(document.getElementById('delete-form-{{ voyage.id }}'))"
            class="action-btn"
            style="color:#c27878;border-color:#c27878;background:none;cursor:pointer">
        Supprimer
    </button>
</form>
