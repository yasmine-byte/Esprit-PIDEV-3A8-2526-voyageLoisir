<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; background:#f5f5f5; margin:0; padding:0; }
        .container { max-width:600px; margin:30px auto; background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.08); }
        .header { background:#f75959; padding:30px; text-align:center; }
        .header h1 { color:#fff; margin:0; font-size:24px; }
        .content { padding:30px; }
        .badge { display:inline-block; background:#22c55e; color:#fff; padding:6px 16px; border-radius:20px; font-size:13px; font-weight:600; margin-bottom:20px; }
        table { width:100%; border-collapse:collapse; margin:20px 0; }
        td { padding:12px; border-bottom:1px solid #eee; font-size:14px; }
        td:first-child { color:#888; }
        td:last-child { font-weight:600; text-align:right; }
        .total td { font-size:18px; color:#f75959; }
        .footer { background:#f9f9f9; padding:20px; text-align:center; font-size:12px; color:#888; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>✅ Réservation Confirmée</h1>
            <p style="color:#fff; margin:8px 0 0; font-size:14px;">Merci pour votre confiance !</p>
        </div>
        <div class="content">
            <span class="badge">Paiement reçu</span>
            <h2 style="color:#1c1c1e; margin-bottom:8px;">Bonjour {{ reservation.clientNom }},</h2>
            <p style="color:#666; font-size:14px;">Votre réservation a été confirmée avec succès. Voici le récapitulatif :</p>

            <table>
                <tr>
                    <td>Numéro de réservation</td>
                    <td>#{{ reservation.id }}</td>
                </tr>
                <tr>
                    <td>Hébergement</td>
                    <td>{{ reservation.hebergement ? reservation.hebergement.description : '-' }}</td>
                </tr>
                <tr>
                    <td>Date d'arrivée</td>
                    <td>{{ reservation.dateDebut|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td>Date de départ</td>
                    <td>{{ reservation.dateFin|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td>Nombre de nuits</td>
                    <td>{{ reservation.nbNuits }} nuit(s)</td>
                </tr>
                <tr class="total">
                    <td>Total payé</td>
                    <td>{{ reservation.total }} TND</td>
                </tr>
            </table>

            <p style="color:#666; font-size:13px;">Si vous avez des questions, contactez-nous à <a href="mailto:ferjanimehdi02@gmail.com" style="color:#f75959;">ferjanimehdi02@gmail.com</a></p>
        </div>
        <div class="footer">
            <p>© 2026 Vianova. Tous droits réservés.</p>
        </div>
    </div>
</body>
</html>
