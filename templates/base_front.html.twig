<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <title>{% block title %}Vianova{% endblock %}</title>

    {% block stylesheets %}
        <link href="{{ asset('vendor_front/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('assets_front/css/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('assets_front/css/css/templatemo-villa-agency.css') }}">
        <link rel="stylesheet" href="{{ asset('assets_front/css/css/owl.css') }}">
        <link rel="stylesheet" href="{{ asset('assets_front/css/css/animate.css') }}">
        <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css"/>
    {% endblock %}
</head>
<body>


    {% include 'home/partials/header.html.twig' %}

    <div class="container" style="padding-top: 120px;">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'register_error' ? 'danger' : (label == 'register_success' ? 'success' : label) }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {% block body %}{% endblock %}

    {% include 'home/partials/footer.html.twig' %}

    {% block javascripts %}
        <script src="{{ asset('vendor_front/jquery/jquery.min.js') }}"></script>
        <script src="{{ asset('vendor_front/bootstrap/js/bootstrap.min.js') }}"></script>
        <script src="{{ asset('assets_front/js/js/isotope.min.js') }}"></script>
        <script src="{{ asset('assets_front/js/js/owl-carousel.js') }}"></script>
        <script src="{{ asset('assets_front/js/js/counter.js') }}"></script>
        <script src="{{ asset('assets_front/js/js/custom.js') }}"></script>
    {% endblock %}

    {# ── Widget Chatbot IA — visible uniquement sur les pages réclamation et avis ── #}
    {% if app.request.attributes.get('_route') starts with 'reclamation' or app.request.attributes.get('_route') starts with 'avis' %}
        {% include 'components/chatbot.html.twig' %}
    {% endif %}

</body>
</html>