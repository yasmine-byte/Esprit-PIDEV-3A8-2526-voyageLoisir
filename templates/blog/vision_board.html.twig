{% extends 'base_front.html.twig' %}

{% block title %}Vision board{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .vision-board-page {
            padding: 150px 0 90px;
            background: linear-gradient(180deg, #faf8f5, #fffdfb);
        }

        .vision-board-shell {
            width: min(1180px, calc(100% - 32px));
            margin: 0 auto;
        }

        .vision-board-head {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

        .vision-board-head h1 {
            margin: 0 0 8px;
            font-size: clamp(2.2rem, 4vw, 4rem);
        }

        .vision-board-count {
            padding: 12px 18px;
            border-radius: 999px;
            background: #fff;
            border: 1px solid rgba(30, 28, 26, 0.08);
            font-weight: 700;
        }

        .vision-board-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 22px;
        }

        .vision-board-card {
            overflow: hidden;
            border-radius: 22px;
            background: #fff;
            border: 1px solid rgba(30, 28, 26, 0.08);
            box-shadow: 0 18px 45px rgba(44, 33, 24, 0.08);
        }

        .vision-board-card img {
            width: 100%;
            height: 260px;
            object-fit: cover;
            display: block;
        }

        .vision-board-body {
            padding: 22px;
        }

        .vision-board-body h2 {
            margin: 0 0 12px;
            font-size: 1.2rem;
        }

        .vision-board-body p {
            margin: 0 0 14px;
            color: #7a746e;
            line-height: 1.7;
        }

        .vision-board-empty {
            padding: 36px;
            border-radius: 24px;
            background: #fff;
            border: 1px solid rgba(30, 28, 26, 0.08);
            color: #7a746e;
        }

        .vision-board-link {
            display: inline-flex;
            padding: 12px 18px;
            border-radius: 999px;
            background: #e8652a;
            color: #fff;
            text-decoration: none;
            font-weight: 600;
        }

        @media (max-width: 991px) {
            .vision-board-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main class="vision-board-page">
        <div class="vision-board-shell">
            <div class="vision-board-head">
                <div>
                    <h1>Votre vision board</h1>
                    <p>Retrouvez vos blogs favoris dans un seul espace d inspiration.</p>
                </div>
                <div class="vision-board-count">{{ vision_board_count }} blog{{ vision_board_count > 1 ? 's' : '' }} enregistre{{ vision_board_count > 1 ? 's' : '' }}</div>
            </div>

            {% if blogs is empty %}
                <div class="vision-board-empty">
                    Votre vision board est vide pour le moment. Retournez sur les blogs et enregistrez quelques recits qui vous inspirent.
                    <div style="margin-top:18px;">
                        <a class="vision-board-link" href="{{ path('app_blog_index') }}">Explorer les blogs</a>
                    </div>
                </div>
            {% else %}
                <div class="vision-board-grid">
                    {% for blog in blogs %}
                        {% set coverImage = blog.imageCouverture ?: ('https://picsum.photos/seed/vision-board-' ~ blog.id ~ '/1200/900') %}
                        <article class="vision-board-card">
                            <a href="{{ path('app_blog_show', {'id': blog.id}) }}">
                                <img src="{{ coverImage }}" alt="{{ blog.titre }}">
                            </a>
                            <div class="vision-board-body">
                                <h2>{{ blog.titre }}</h2>
                                <p>{{ blog.extrait ?: (blog.contenu|slice(0, 150) ~ (blog.contenu|length > 150 ? '...' : '')) }}</p>
                                <a class="vision-board-link" href="{{ path('app_blog_show', {'id': blog.id}) }}">Lire l article</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}
