{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        (function () {
            const heroEl = document.querySelector('.magazineHeroSwiper');
            if (heroEl && window.Swiper) {
                const swiper = new Swiper(heroEl, {
                    loop: true,
                    speed: 600,
                    slidesPerView: 1,
                    autoplay: {
                        delay: 4000,
                        disableOnInteraction: false
                    },
                    pagination: {
                        el: '.mag-hero .swiper-pagination',
                        clickable: true
                    },
                    navigation: {
                        nextEl: '.mag-hero .swiper-button-next',
                        prevEl: '.mag-hero .swiper-button-prev'
                    }
                });

                heroEl.addEventListener('mouseenter', function () { swiper.autoplay.stop(); });
                heroEl.addEventListener('mouseleave', function () { swiper.autoplay.start(); });
            }

            const modal = document.getElementById('blogComposeModal');
            if (modal && window.bootstrap) {
                const modalInstance = new bootstrap.Modal(modal);
                {% if show_blog_modal|default(false) %}
                modalInstance.show();
                {% endif %}
            }

            const titleInput = document.getElementById('{{ blog_form.titre.vars.id }}');
            const contentInput = document.getElementById('{{ blog_form.contenu.vars.id }}');
            const excerptInput = document.getElementById('{{ blog_form.extrait.vars.id }}');
            const generateButton = document.getElementById('generateExcerptButton');
            const generateMessage = document.getElementById('generateExcerptMessage');
            if (titleInput && contentInput && excerptInput && generateButton) {
                generateButton.addEventListener('click', async function () {
                    generateButton.disabled = true;
                    if (generateMessage) {
                        generateMessage.textContent = 'Génération de l’extrait...';
                    }

                    const response = await fetch('{{ path('api_blog_generate_excerpt') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({
                            title: titleInput.value,
                            content: contentInput.value,
                            max_length: 180
                        })
                    });

                    const payload = await response.json();
                    generateButton.disabled = false;

                    if (!response.ok || !payload.success) {
                        if (generateMessage) {
                            generateMessage.textContent = payload.message || 'Impossible de générer un extrait pour le moment.';
                        }
                        return;
                    }

                    excerptInput.value = payload.excerpt || '';
                    if (generateMessage) {
                        generateMessage.textContent = 'Extrait généré avec succès.';
                    }
                });
            }

            const coverInput = document.getElementById('{{ blog_form.blogCoverImage.vars.id }}');
            const coverDropzone = document.getElementById('shareCoverDropzone');
            const coverPreview = document.getElementById('shareCoverPreview');
            const renderPreview = function (file) {
                if (!file || !coverPreview) {
                    return;
                }
                const reader = new FileReader();
                reader.onload = function (event) {
                    coverPreview.src = event.target?.result || '';
                    coverPreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            };
            if (coverInput) {
                coverInput.addEventListener('change', function () {
                    renderPreview(coverInput.files && coverInput.files[0] ? coverInput.files[0] : null);
                });
            }
            if (coverDropzone && coverInput) {
                ['dragenter', 'dragover'].forEach(function (evtName) {
                    coverDropzone.addEventListener(evtName, function (event) {
                        event.preventDefault();
                        coverDropzone.classList.add('is-dragover');
                    });
                });
                ['dragleave', 'drop'].forEach(function (evtName) {
                    coverDropzone.addEventListener(evtName, function (event) {
                        event.preventDefault();
                        coverDropzone.classList.remove('is-dragover');
                    });
                });
                coverDropzone.addEventListener('drop', function (event) {
                    const files = event.dataTransfer?.files;
                    if (!files || files.length === 0) {
                        return;
                    }
                    const transfer = new DataTransfer();
                    transfer.items.add(files[0]);
                    coverInput.files = transfer.files;
                    renderPreview(files[0]);
                });
            }

            const editorTextarea = document.getElementById('{{ blog_form.contenu.vars.id }}');
            document.querySelectorAll('[data-editor-action]').forEach(function (button) {
                button.addEventListener('click', function () {
                    if (!editorTextarea) {
                        return;
                    }
                    const action = button.getAttribute('data-editor-action');
                    const start = editorTextarea.selectionStart ?? editorTextarea.value.length;
                    const end = editorTextarea.selectionEnd ?? editorTextarea.value.length;
                    const selected = editorTextarea.value.substring(start, end);
                    let insertion = selected;
                    if (action === 'bold') {
                        insertion = '**' + (selected || 'texte') + '**';
                    } else if (action === 'italic') {
                        insertion = '*' + (selected || 'texte') + '*';
                    } else if (action === 'list') {
                        insertion = '- ' + (selected || 'élément');
                    }
                    editorTextarea.setRangeText(insertion, start, end, 'end');
                    editorTextarea.focus();
                });
            });

            const visionBoardCountNode = document.getElementById('visionBoardCount');
            document.addEventListener('click', async function (event) {
                const favoriteButton = event.target.closest('[data-favorite-toggle]');
                if (!favoriteButton) {
                    return;
                }

                const formData = new FormData();
                formData.append('_token', favoriteButton.dataset.token || '');

                const response = await fetch(favoriteButton.dataset.url || '', {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                const payload = await response.json();
                if (!response.ok) {
                    return;
                }

                favoriteButton.classList.toggle('is-saved', !!payload.saved);
                if (visionBoardCountNode && typeof payload.count !== 'undefined') {
                    visionBoardCountNode.textContent = String(payload.count);
                }
            });

            const listEl = document.getElementById('blogMagazineList');
            const countEl = document.getElementById('blogResultCount');
            const searchInput = document.getElementById('blogSearchInput');
            const sortSelect = document.getElementById('blogSortSelect');
            const categoryRoot = document.getElementById('blogCategoryFilters');
            if (!listEl || !countEl || !searchInput || !sortSelect || !categoryRoot) {
                return;
            }

            let activeCategory = categoryRoot.querySelector('.mag-pill.is-active')?.getAttribute('data-category') || 'all';
            let debounceTimer = null;

            const updateStateFromUrl = function () {
                const params = new URLSearchParams(window.location.search);
                const q = searchInput.value.trim();
                if (q) { params.set('q', q); } else { params.delete('q'); }
                if (activeCategory && activeCategory !== 'all') { params.set('categorie', activeCategory); } else { params.delete('categorie'); }
                params.set('sort', sortSelect.value);
                const query = params.toString();
                history.replaceState({}, '', window.location.pathname + (query ? '?' + query : ''));
            };

            const refreshList = function () {
                const params = new URLSearchParams();
                params.set('sort', sortSelect.value);
                if (searchInput.value.trim()) {
                    params.set('q', searchInput.value.trim());
                }
                if (activeCategory !== 'all') {
                    params.set('categorie', activeCategory);
                }

                fetch(window.location.pathname + '?' + params.toString(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(function (response) { return response.text(); })
                    .then(function (html) {
                        const doc = new DOMParser().parseFromString(html, 'text/html');
                        const newList = doc.getElementById('blogMagazineList');
                        const newCount = doc.getElementById('blogResultCount');
                        if (!newList || !newCount) { return; }
                        listEl.innerHTML = newList.innerHTML;
                        countEl.textContent = newCount.textContent;
                        updateStateFromUrl();
                    });
            };

            searchInput.addEventListener('input', function () {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(refreshList, 320);
            });

            sortSelect.addEventListener('change', refreshList);

            categoryRoot.addEventListener('click', function (event) {
                const button = event.target.closest('[data-category]');
                if (!button) { return; }
                categoryRoot.querySelectorAll('[data-category]').forEach(function (pill) {
                    pill.classList.remove('is-active');
                });
                button.classList.add('is-active');
                activeCategory = button.getAttribute('data-category') || 'all';
                refreshList();
            });
        })();
    </script>
{% endblock %}

