{% extends 'base_front.html.twig' %}

{% block title %}Réservations - Vianova{% endblock %}

{% block body %}

<div class="page-heading header-text" style="
  background-image:
      linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)),
      url('{{ asset('assets_front/images/images/my-banner.jpg') }}');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <span class="breadcrumb">
          <a href="{{ path('app_home') }}">Home</a> / Réservations
        </span>
        <h3>Nos Réservations</h3>
      </div>
    </div>
  </div>
</div>

<div class="section properties">
  <div class="container">

    <div class="row mb-4">
      <div class="col-lg-12 text-end">
        <a href="{{ path('app_activite_index') }}" class="main-button">
          Voir les activités
        </a>
      </div>
    </div>

    <div class="row properties-box">
      {% for reservation in reservation_activites %}
        <div class="col-lg-4 col-md-6 align-self-center mb-30 properties-items">
          <div class="item">

            <a href="{{ path('app_reservation_activite_show', {'id': reservation.id}) }}">
              <img
                src="{{ reservation.activite and reservation.activite.imageUrl
                    ? reservation.activite.imageUrl
                    : asset('assets_front/images/images/property-01.jpg') }}"
                alt="{{ reservation.activite ? reservation.activite.nom : 'Réservation' }}"
                style="height: 260px; object-fit: cover; width: 100%;">
            </a>

            <span class="category">
              {{ reservation.activite and reservation.activite.type
                  ? reservation.activite.type
                  : 'Réservation' }}
            </span>

            <h6>{{ reservation.total }} TND</h6>

            <h4>
              <a href="{{ path('app_reservation_activite_show', {'id': reservation.id}) }}">
                {{ reservation.activite ? reservation.activite.nom : 'Activité non disponible' }}
              </a>
            </h4>

            <ul>
              <li>Date:
                <span>
                  {{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d') : 'N/A' }}
                </span>
              </li>
              <li>Personnes:
                <span>{{ reservation.nombrePersonnes }}</span>
              </li>
              <li>Statut:
                <span>{{ reservation.statut }}</span>
              </li>
              <li>Lieu:
                <span>{{ reservation.activite and reservation.activite.lieu ? reservation.activite.lieu : 'N/A' }}</span>
              </li>
            </ul>

            <div class="d-flex flex-column gap-2 mt-3">
              <a href="{{ path('app_reservation_activite_show', {'id': reservation.id}) }}" class="main-button text-center">
                Voir détails
              </a>

              <a href="{{ path('app_reservation_activite_edit', {'id': reservation.id}) }}" class="btn btn-warning btn-sm">
                Modifier la réservation
              </a>

              {{ include('reservation_activite/_delete_form.html.twig', { reservation_activite: reservation }) }}
            </div>

          </div>
        </div>
      {% else %}
        <div class="col-lg-12">
          <div class="alert alert-info text-center">
            Aucune réservation trouvée.
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</div>

{% endblock %}