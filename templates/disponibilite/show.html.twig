{% extends 'admin/base_admin.html.twig' %}
{% block title %}Détail Disponibilité{% endblock %}
{% block admin_content %}

    <div class="page-header">
        <h1>Disponibilité #{{ disponibilite.id }}</h1>
        <p><a href="{{ path('app_disponibilite_index') }}" style="color:var(--accent-copper);">← Retour à la liste</a></p>
    </div>

    <div class="card" style="max-width:600px;">
        <div class="card-header">
            <h3 class="card-title">Informations</h3>
        </div>
        <div style="display:grid; gap:20px;">
            <div>
                <div style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase; margin-bottom:6px;">Hébergement</div>
                <div>{{ disponibilite.hebergement ? disponibilite.hebergement.description : 'N/A' }}</div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                <div>
                    <div style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase; margin-bottom:6px;">Date Début</div>
                    <div style="font-size:18px; font-weight:600;">{{ disponibilite.dateDebut ? disponibilite.dateDebut|date('d/m/Y') : '-' }}</div>
                </div>
                <div>
                    <div style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase; margin-bottom:6px;">Date Fin</div>
                    <div style="font-size:18px; font-weight:600;">{{ disponibilite.dateFin ? disponibilite.dateFin|date('d/m/Y') : '-' }}</div>
                </div>
            </div>
            <div>
                <div style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase; margin-bottom:6px;">Statut</div>
                {% if disponibilite.disponible %}
                    <span style="background:#22c55e20; color:#22c55e; padding:6px 16px; border-radius:20px; font-weight:600;">✓ Disponible</span>
                {% else %}
                    <span style="background:#ef444420; color:#ef4444; padding:6px 16px; border-radius:20px; font-weight:600;">✗ Indisponible</span>
                {% endif %}
            </div>
        </div>
        <div style="display:flex; gap:12px; margin-top:24px;">
            <a href="{{ path('app_disponibilite_edit', {'id': disponibilite.id}) }}" style="background:#f59e0b20; color:#f59e0b; padding:8px 20px; border-radius:8px; text-decoration:none; font-weight:600;">Modifier</a>
            {{ include('disponibilite/_delete_form.html.twig') }}
        </div>
    </div>

    <footer class="copyright">Copyright &copy; 2026 Voyage</footer>

{% endblock %}
