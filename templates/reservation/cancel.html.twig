{% extends 'base_front.html.twig' %}
{% block title %}Paiement annulé - Vianova{% endblock %}

{% block body %}
<div class="section" style="padding:80px 0; min-height:70vh; display:flex; align-items:center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div style="background:#fff; border-radius:16px; padding:50px; box-shadow:0 4px 24px rgba(0,0,0,0.08);">
                    <div style="width:80px; height:80px; background:#ef444420; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 24px;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="15" y1="9" x2="9" y2="15"/>
                            <line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                    </div>
                    <h3 style="color:#1c1c1e; margin-bottom:12px;">Paiement annulé</h3>
                    <p style="color:#888; margin-bottom:24px;">
                        Votre paiement a été annulé. Votre réservation #{{ reservation.id }} est toujours en attente.
                    </p>
                    <div style="display:flex; gap:12px; justify-content:center;">
                        <form method="post" action="{{ path('app_stripe_checkout', {'id': reservation.id}) }}">
                            <button type="submit"
                                    style="background:#f75959; color:#fff; padding:12px 24px; border:none; border-radius:8px; font-weight:600; cursor:pointer;">
                                Réessayer le paiement
                            </button>
                        </form>
                        <a href="{{ path('app_properties') }}"
                           style="display:inline-block; background:#f0f0f0; color:#555; padding:12px 24px; border-radius:8px; text-decoration:none; font-weight:600;">
                            Retour aux hébergements
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
