{% extends 'admin/base_admin.html.twig' %}
{% block title %}Détail Hébergement{% endblock %}
{% block admin_content %}
<div class="main-content">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:28px;">
        <a href="{{ path('app_hebergement_index') }}" style="color:var(--text-secondary); text-decoration:none; display:flex; align-items:center; gap:6px; font-size:14px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Retour
        </a>
        <span style="color:var(--border-color);">/</span>
        <h2 style="color:var(--text-primary); margin:0;">Hébergement #{{ hebergement.id }}</h2>
    </div>

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; max-width:900px;">

        <div style="background:var(--bg-card); border-radius:12px; padding:28px; border:1px solid var(--border-color);">
            <h3 style="color:var(--text-primary); margin:0 0 20px; font-size:16px;">Informations</h3>

            {# ===== IMAGE ===== #}
            {% if hebergement.imagePath %}
            <div style="margin-bottom:20px;">
                <img src="{{ asset('uploads/hebergements/' ~ hebergement.imagePath) }}"
                     alt="{{ hebergement.description }}"
                     style="width:100%; max-height:280px; object-fit:cover; border-radius:10px; border:1px solid var(--border-color);">
            </div>
            {% endif %}

            <div style="display:grid; gap:16px;">
                <div>
                    <span style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase;">Description</span>
                    <p style="color:var(--text-primary); margin:6px 0 0; line-height:1.6;">{{ hebergement.description }}</p>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div>
                        <span style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase;">Prix</span>
                        <p style="color:#22c55e; margin:6px 0 0; font-size:20px; font-weight:700;">{{ hebergement.prix }} TND</p>
                    </div>
                    <div>
                        <span style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase;">Type</span>
                        <p style="margin:6px 0 0;">
                            <span style="background:var(--bg-secondary); color:var(--accent-primary); padding:4px 12px; border-radius:20px; font-size:13px; font-weight:600;">
                                {{ hebergement.type ? hebergement.type.nom : 'N/A' }}
                            </span>
                        </p>
                    </div>
                </div>
                {% if hebergement.adresse %}
                <div>
                    <span style="color:var(--text-secondary); font-size:12px; font-weight:600; text-transform:uppercase;">Adresse</span>
                    <p style="color:var(--text-primary); margin:6px 0 0;">{{ hebergement.adresse }}</p>
                </div>
                {% endif %}
            </div>
        </div>

        <div style="background:var(--bg-card); border-radius:12px; padding:28px; border:1px solid var(--border-color);">
            <h3 style="color:var(--text-primary); margin:0 0 20px; font-size:16px;">Chambres ({{ hebergement.no|length }})</h3>
            {% for chambre in hebergement.no %}
                <div style="background:var(--bg-secondary); border-radius:8px; padding:12px; margin-bottom:10px;">
                    <p style="color:var(--text-primary); margin:0; font-weight:600;">Chambre {{ chambre.numero }}</p>
                    <p style="color:var(--text-secondary); margin:4px 0 0; font-size:13px;">{{ chambre.typeChambre }} — {{ chambre.prixNuit }} TND/nuit</p>
                </div>
            {% else %}
                <p style="color:var(--text-secondary); font-size:14px;">Aucune chambre</p>
            {% endfor %}
        </div>

    </div>

    <div style="display:flex; gap:12px; margin-top:20px; max-width:900px;">
        <a href="{{ path('app_hebergement_edit', {'id': hebergement.id}) }}" style="background:#f59e0b20; color:#f59e0b; padding:10px 20px; border-radius:8px; text-decoration:none; font-size:14px; font-weight:600;">
            Modifier
        </a>
        <a href="{{ path('app_chambre_new', {'hebergement': hebergement.id}) }}" style="background:#22c55e20; color:#22c55e; padding:10px 20px; border-radius:8px; text-decoration:none; font-size:14px; font-weight:600;">
            + Chambre
        </a>
        {{ include('hebergement/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
