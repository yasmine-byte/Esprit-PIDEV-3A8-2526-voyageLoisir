<div class="header">
    <div class="header-left">
        <h1>Gestion des Utilisateurs</h1>
        <p class="header-subtitle">Administration et gestion des comptes utilisateurs</p>
    </div>
    <div class="header-right">


        {% if app.user %}
    <a href="{{ path('admin_user_profile', {'id': app.user.id}) }}" class="user-info-display" style="text-decoration:none;">
        <div class="user-avatar">
            {% if app.user.nom and app.user.prenom %}
                {{ app.user.nom|first }}{{ app.user.prenom|first }}
            {% else %}
                {{ app.user.email|first|upper }}
            {% endif %}
        </div>
        <div class="user-details">
            <span class="user-name">
                {% if app.user.nom and app.user.prenom %}
                    {{ app.user.nom }} {{ app.user.prenom }}
                {% else %}
                    {{ app.user.email }}
                {% endif %}
            </span>
            <span class="user-status">Connecté · Voir profil</span>
        </div>
    </a>
{% endif %}
    </div>
</div>
