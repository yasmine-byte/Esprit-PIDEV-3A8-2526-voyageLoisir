<div class="header">
    <div class="header-left">
        <h1>Vianova Dashboard</h1>
        <p class="header-subtitle">Bienvenue ! Gerez votre plateforme touristique.</p>
    </div>
    <div class="header-right">
        <div class="header-search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" placeholder="Rechercher...">
        </div>
        <button class="notification-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 01-3.46 0"/>
            </svg>
            <span class="notification-badge">3</span>
        </button>
        {% if app.user %}
        <a href="{{ path('admin_user_profile', {'id': app.user.id}) }}" style="text-decoration:none;display:flex;align-items:center;gap:10px">
            <div class="user-avatar">{{ app.user.nom is defined ? app.user.nom|first : app.user.email|first|upper }}</div>
            <div class="user-info">
                <span class="user-name">{{ app.user.nom is defined ? app.user.nom : app.user.email }}</span>
                <span class="user-role">Connecte</span>
            </div>
        </a>
        {% else %}
        <div class="user-menu">
            <div class="user-avatar">VN</div>
            <div class="user-info">
                <span class="user-name">Admin Vianova</span>
                <span class="user-role">Administrateur</span>
            </div>
        </div>
        {% endif %}
    </div>
</div>
