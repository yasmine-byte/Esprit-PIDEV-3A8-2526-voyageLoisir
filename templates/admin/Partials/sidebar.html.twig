    <script>
    function toggleMenu(e, id) {
        e.preventDefault();
        var menu = document.getElementById(id);
        var arrow = document.getElementById('arrow-' + id.replace('-submenu', ''));
        if (menu.style.display === 'none' || menu.style.display === '') {
            menu.style.display = 'block';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
        } else {
            menu.style.display = 'none';
            if (arrow) arrow.style.transform = 'rotate(0deg)';
        }
    }

    {# Ouvrir automatiquement le sous-menu si on est sur une page utilisateurs #}
    document.addEventListener('DOMContentLoaded', function() {
        const userRoutes = ['app_admin', 'admin_users_list', 'add_user', 'admin_user_edit', 'admin_user_profile'];
        const currentRoute = '{{ app.request.attributes.get("_route") }}';
        if (userRoutes.includes(currentRoute)) {
            var menu = document.getElementById('users-submenu');
            var arrow = document.getElementById('arrow-users');
            if (menu) menu.style.display = 'block';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
        }
    });
    </script>
