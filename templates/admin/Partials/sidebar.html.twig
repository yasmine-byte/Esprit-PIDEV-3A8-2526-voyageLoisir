{% set currentRoute = app.request.attributes.get('_route') %}

<!-- Mobile Menu Toggle -->
<button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
    <div class="hamburger">
        <span></span>
        <span></span>
        <span></span>
    </div>
</button>

<!-- Sidebar Overlay -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
    <div class="logo">
        <div class="logo-icon">V</div>
        <span class="logo-text">Vianova</span>
    </div>

    <nav class="nav-section">
        <div class="nav-label">Main Menu</div>

        {# Dashboard #}
        <a href="{{ path('app_admin') }}"
           class="nav-item {{ currentRoute == 'app_admin' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            Dashboard
        </a>

        {# ── GESTION DESTINATION (accordéon) ── #}
        <div class="nav-item" onclick="toggleGestion()" style="cursor:pointer;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                    <circle cx="12" cy="9" r="2.5"/>
                </svg>
                Gestion Destination
            </div>
            <svg id="gestionArrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transition:transform 0.3s">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </div>

        <div id="gestionMenu" style="display:none; padding-left:16px;">
            <a href="{{ path('app_destination_index') }}" class="nav-item" style="font-size:14px;">Destinations</a>
            <a href="{{ path('app_voyage_index') }}"      class="nav-item" style="font-size:14px;">Voyages</a>
            <a href="{{ path('app_image_index') }}"       class="nav-item" style="font-size:14px;">Images</a>
            <a href="{{ path('app_transport_index') }}"   class="nav-item" style="font-size:14px;">Transports</a>
        </div>

        {# ── GESTION HÉBERGEMENT (accordéon) ── #}
        <a href="#" class="nav-item" onclick="toggleMenu(event, 'hebergement-submenu')">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 21V8a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v13"/>
                <path d="M9 21V12h6v9"/>
                <path d="M9 3v3"/>
                <path d="M15 3v3"/>
            </svg>
            Gestion Hébergement
            <svg id="arrow-hebergement" style="margin-left:auto; width:16px; transition:transform 0.3s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </a>

        <div id="hebergement-submenu" style="display:none; padding-left:16px;">
            <a href="{{ path('app_hebergement_index') }}"
               class="nav-item {{ currentRoute == 'app_hebergement_index' ? 'active' : '' }}"
               style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Hébergements
            </a>
            <a href="{{ path('app_chambre_index') }}"
               class="nav-item {{ currentRoute == 'app_chambre_index' ? 'active' : '' }}"
               style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 22V8a2 2 0 012-2h14a2 2 0 012 2v14"/>
                    <path d="M3 22H21"/><path d="M9 22V12h6v10"/>
                </svg>
                Chambres
            </a>
            <a href="{{ path('app_disponibilite_index') }}"
               class="nav-item {{ currentRoute == 'app_disponibilite_index' ? 'active' : '' }}"
               style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Disponibilités
            </a>
            <a href="{{ path('app_type_index') }}"
               class="nav-item {{ currentRoute == 'app_type_index' ? 'active' : '' }}"
               style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="8" y1="6" x2="21" y2="6"/>
                    <line x1="8" y1="12" x2="21" y2="12"/>
                    <line x1="8" y1="18" x2="21" y2="18"/>
                    <line x1="3" y1="6" x2="3.01" y2="6"/>
                    <line x1="3" y1="12" x2="3.01" y2="12"/>
                    <line x1="3" y1="18" x2="3.01" y2="18"/>
                </svg>
                Types
            </a>
        </div>

        {# ── GESTION ACTIVITÉ ── #}
        <a href="{{ path('admin_activite_index') }}"
           class="nav-item {{ currentRoute starts with 'admin_activite' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9c.36.46.58 1.03.6 1.63"/>
            </svg>
            Gestion Activité
        </a>

        {# ── Gestion Avis & Réclamations (accordéon) ── #}
        <a href="#" class="nav-item" onclick="toggleMenu(event, 'reclamation-submenu')">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Avis &amp; Réclamations
            <svg id="arrow-reclamation" style="margin-left:auto; width:16px; transition:transform 0.3s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </a>
        <div id="reclamation-submenu" style="display:none; padding-left:16px;">
            <a href="{{ path('admin_avis_index') }}" class="nav-item" style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                Gestion Avis
            </a>
            <a href="{{ path('admin_reclamation_index') }}" class="nav-item" style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                Réclamations
            </a>
            <a href="{{ path('admin_avis_stats') }}" class="nav-item" style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                Statistiques
            </a>
        </div>

        {# ── GESTION BLOG (avec route active - branche blog) ── #}
        <a href="{{ path('admin_blogs') }}" class="nav-item {{ currentRoute == 'admin_blogs' or currentRoute starts with 'admin_blog' ? 'active' : '' }}">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            Gestion Blog
        </a>

        {# ── GESTION UTILISATEURS (accordéon) ── #}
        <a href="#"
           class="nav-item {{ currentRoute in ['admin_users_list', 'add_user', 'admin_user_edit', 'admin_user_profile'] ? 'active' : '' }}"
           onclick="toggleMenu(event, 'users-submenu')">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
            Gestion Utilisateurs
            <svg id="arrow-users" style="margin-left:auto; width:16px; transition:transform 0.3s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </a>
        <div id="users-submenu" style="display:none; padding-left:16px;">
            <a href="{{ path('admin_users_list') }}"
               class="nav-item {{ currentRoute == 'admin_users_list' ? 'active' : '' }}"
               style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                    <path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
                Liste des utilisateurs
            </a>
            <a href="{{ path('add_user') }}"
               class="nav-item {{ currentRoute == 'add_user' ? 'active' : '' }}"
               style="font-size:14px;">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                    <circle cx="8.5" cy="7" r="4"/>
                    <line x1="20" y1="8" x2="20" y2="14"/>
                    <line x1="23" y1="11" x2="17" y2="11"/>
                </svg>
                Ajouter utilisateur
            </a>
        </div>
    </nav>

    <nav class="nav-section">
        <div class="nav-label">Account</div>

        <a href="#" class="nav-item">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            Settings
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="theme-toggle">
            <div class="theme-toggle-label">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
                Light Mode
            </div>
            <div class="theme-switch" id="themeSwitch"></div>
        </div>

        {# ── BOUTON DÉCONNEXION ── #}
        <a href="{{ path('admin_logout') }}"
           style="display:flex;align-items:center;gap:10px;color:#E24B4A;text-decoration:none;font-size:14px;font-weight:600;padding:10px;border-radius:8px;transition:background 0.2s"
           onmouseover="this.style.background='rgba(226,75,74,0.1)'"
           onmouseout="this.style.background='transparent'">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Déconnexion
        </a>
    </div>

    <script>
    function toggleGestion() {
        const menu  = document.getElementById('gestionMenu');
        const arrow = document.getElementById('gestionArrow');
        if (menu.style.display === 'none' || menu.style.display === '') {
            menu.style.display = 'block';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
        } else {
            menu.style.display = 'none';
            if (arrow) arrow.style.transform = 'rotate(0deg)';
        }
    }

    function toggleMenu(e, id) {
        e.preventDefault();
        var menu  = document.getElementById(id);
        var arrow = document.getElementById('arrow-' + id.replace('-submenu', ''));
        if (menu && (menu.style.display === 'none' || menu.style.display === '')) {
            menu.style.display = 'block';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
        } else if (menu) {
            menu.style.display = 'none';
            if (arrow) arrow.style.transform = 'rotate(0deg)';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        const currentRoute = '{{ currentRoute }}';

        const hebergementRoutes = ['app_hebergement_index', 'app_chambre_index', 'app_disponibilite_index', 'app_type_index'];
        if (hebergementRoutes.includes(currentRoute)) {
            var menu  = document.getElementById('hebergement-submenu');
            var arrow = document.getElementById('arrow-hebergement');
            if (menu)  menu.style.display = 'block';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
        }

        const userRoutes = ['admin_users_list', 'add_user', 'admin_user_edit', 'admin_user_profile'];
        if (userRoutes.includes(currentRoute)) {
            var menu  = document.getElementById('users-submenu');
            var arrow = document.getElementById('arrow-users');
            if (menu)  menu.style.display = 'block';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
        }

        var p = window.location.pathname;
        if (p.indexOf('/admin/avis') !== -1 || p.indexOf('/admin/reclamation') !== -1) {
            var m = document.getElementById('reclamation-submenu');
            var a = document.getElementById('arrow-reclamation');
            if (m) m.style.display   = 'block';
            if (a) a.style.transform = 'rotate(180deg)';
        }
    });
    </script>
</aside>
