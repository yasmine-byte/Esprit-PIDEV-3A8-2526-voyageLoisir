    <script>
    function toggleMenu(e, id) {
        e.preventDefault();
        var menu  = document.getElementById(id);
        var arrow = document.getElementById('arrow-' + id.replace('-submenu', ''));
        if (menu.style.display === 'none' || menu.style.display === '') {
            menu.style.display = 'block';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
        } else {
            menu.style.display = 'none';
            if (arrow) arrow.style.transform = 'rotate(0deg)';
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        var p = window.location.pathname;
        if (p.indexOf('/admin/avis') !== -1 || p.indexOf('/admin/reclamation') !== -1) {
            var m = document.getElementById('reclamation-submenu');
            var a = document.getElementById('arrow-reclamation');
            if (m) m.style.display   = 'block';
            if (a) a.style.transform = 'rotate(180deg)';
        }
    });
    </script>
