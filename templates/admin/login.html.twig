{% extends 'base.html.twig' %}

{% block title %}Login - VIANOVA{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets_back/css/css/templatemo-crypto-style.css') }}">
    <link rel="stylesheet" href="{{ asset('assets_back/css/css/templatemo-crypto-login.css') }}">
    <style>
        .auth-branding { min-height: 180px !important; padding: 30px 20px !important; }
        .branding-logo { width: 48px !important; height: 48px !important; font-size: 18px !important; margin-bottom: 10px !important; }
        .branding-title { font-size: 22px !important; margin-bottom: 6px !important; }
        .branding-subtitle { font-size: 13px !important; line-height: 1.4 !important; }
        .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; }
        .alert-danger { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }
        .alert-success { background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.3); color: #34d399; }
        .field-error-msg { display: block; color: #ef4444; font-size: 12px; margin-top: 5px; padding-left: 4px; }
        .input-error { border-color: #ef4444 !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.1); }
        .has-error .input-icon { color: #ef4444; }
        .form-panel { display: none; }
        .form-panel.is-active { display: block; }
    </style>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('assets_back/js/js/templatemo-crypto-script.js') }}"></script>
{% endblock %}

{% block body %}
    <div class="auth-branding">
        <div class="branding-content">
            <div class="branding-logo">VN</div>
            <h1 class="branding-title">VIANOVA</h1>
            <p class="branding-subtitle">
                Bienvenue dans l'espace d'administration ViaNoVa.<br>
                Gardez le contrôle total de votre plateforme de voyage.
            </p>
        </div>
    </div>

    <div class="auth-form-container">
        <button class="theme-toggle-btn" id="themeToggle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
        </button>

        <div class="auth-form-wrapper">
            <div class="form-header">
                <h1 id="form-title">Bienvenue</h1>
                <p id="form-subtitle">Connectez-vous à votre compte</p>
            </div>

            <div class="auth-tabs">
                <button class="auth-tab" id="tab-login" type="button">Connexion</button>
                <button class="auth-tab" id="tab-register" type="button">Inscription</button>
            </div>

            {# ══ FORMULAIRE DE CONNEXION ══ #}
            <div class="form-panel" id="panel-login">
                <form method="POST" action="{{ path('admin_login_check') }}">

                    {% for message in app.flashes('register_error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}

                    {% if globalError is defined and globalError %}
                        <div class="alert alert-danger">{{ globalError }}</div>
                    {% endif %}

                    <div class="form-group">
                        <label class="form-label">Adresse email</label>
                        <div class="form-input-wrapper {% if fieldErrors is defined and fieldErrors.email is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            <input type="email"
                                   class="form-input {% if fieldErrors is defined and fieldErrors.email is defined %}input-error{% endif %}"
                                   name="_username"
                                   value="{{ last_username ?? '' }}"
                                   placeholder="Entrez votre email"
                                   autocomplete="email">
                        </div>
                        {% if fieldErrors is defined and fieldErrors.email is defined %}
                            <span class="field-error-msg">{{ fieldErrors.email }}</span>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mot de passe</label>
                        <div class="form-input-wrapper {% if fieldErrors is defined and fieldErrors.password is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                            <input type="password"
                                   class="form-input {% if fieldErrors is defined and fieldErrors.password is defined %}input-error{% endif %}"
                                   id="loginPassword"
                                   name="_password"
                                   placeholder="Entrez votre mot de passe"
                                   autocomplete="current-password">
                            <button type="button" class="password-toggle" data-target="loginPassword">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        {% if fieldErrors is defined and fieldErrors.password is defined %}
                            <span class="field-error-msg">{{ fieldErrors.password }}</span>
                        {% endif %}
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="form-row">
                        <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                            <input type="checkbox" name="_remember_me" style="width:16px; height:16px; accent-color:var(--accent-copper);">
                            <span class="checkbox-label">Se souvenir de moi</span>
                        </label>
                        <a href="{{ path('forgot_password') }}" style="color:var(--accent-copper); font-size:13px;">
                        Mot de passe oublié ?
                        </a>
                    </div>

                    <div style="margin-top:16px; margin-bottom:12px; text-align:center;">
                        <a href="{{ path('connect_google') }}"
                           style="display:inline-flex; align-items:center; justify-content:center; gap:10px; width:100%; padding:12px 24px; border:1px solid #ddd; border-radius:8px; background:#fff; color:#333; text-decoration:none; font-weight:500; font-size:14px;">
                            <img src="https://www.google.com/favicon.ico" width="20" height="20">
                            Connecter avec Google
                        </a>
                    </div>

                    <button type="submit" class="submit-btn">Se connecter</button>

                    <p class="form-footer">
                        Pas encore de compte ?
                        <a href="#" id="go-register">Créer un compte</a>
                    </p>
                </form>
            </div>

            {# ══ FORMULAIRE D'INSCRIPTION ══ #}
            <div class="form-panel" id="panel-register">
                <form method="POST" action="{{ path('front_register') }}" novalidate>

                    {# Message succès #}
                    {% for message in app.flashes('register_success') %}
                        <div class="alert alert-success">✔ {{ message }}</div>
                    {% endfor %}

                    {# Erreur globale #}
                    {% if registerFieldErrors is defined and registerFieldErrors|length > 0 %}
                        <div class="alert alert-danger">Veuillez corriger les erreurs ci-dessous.</div>
                    {% endif %}

                    {# Nom #}
                    <div class="form-group">
                        <label class="form-label">Nom *</label>
                        <div class="form-input-wrapper {% if registerFieldErrors is defined and registerFieldErrors.nom is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <input type="text" class="form-input {% if registerFieldErrors is defined and registerFieldErrors.nom is defined %}input-error{% endif %}"
                                   name="nom" value="{{ registerFormData.nom ?? '' }}"
                                   placeholder="Votre nom" maxlength="50">
                        </div>
                        {% if registerFieldErrors is defined and registerFieldErrors.nom is defined %}
                            <span class="field-error-msg">{{ registerFieldErrors.nom }}</span>
                        {% endif %}
                    </div>

                    {# Prénom #}
                    <div class="form-group">
                        <label class="form-label">Prénom *</label>
                        <div class="form-input-wrapper {% if registerFieldErrors is defined and registerFieldErrors.prenom is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <input type="text" class="form-input {% if registerFieldErrors is defined and registerFieldErrors.prenom is defined %}input-error{% endif %}"
                                   name="prenom" value="{{ registerFormData.prenom ?? '' }}"
                                   placeholder="Votre prénom" maxlength="50">
                        </div>
                        {% if registerFieldErrors is defined and registerFieldErrors.prenom is defined %}
                            <span class="field-error-msg">{{ registerFieldErrors.prenom }}</span>
                        {% endif %}
                    </div>

                    {# Email #}
                    <div class="form-group">
                        <label class="form-label">Adresse email *</label>
                        <div class="form-input-wrapper {% if registerFieldErrors is defined and registerFieldErrors.email is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            <input type="text" class="form-input {% if registerFieldErrors is defined and registerFieldErrors.email is defined %}input-error{% endif %}"
                                   name="email" value="{{ registerFormData.email ?? '' }}"
                                   placeholder="Votre email" maxlength="100">
                        </div>
                        {% if registerFieldErrors is defined and registerFieldErrors.email is defined %}
                            <span class="field-error-msg">{{ registerFieldErrors.email }}</span>
                        {% endif %}
                    </div>

                    {# Téléphone #}
                    <div class="form-group">
                        <label class="form-label">Numéro de téléphone</label>
                        <div class="form-input-wrapper {% if registerFieldErrors is defined and registerFieldErrors.telephone is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.66A2 2 0 012 .84h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/>
                            </svg>
                            <input type="text" class="form-input {% if registerFieldErrors is defined and registerFieldErrors.telephone is defined %}input-error{% endif %}"
                                   name="telephone" value="{{ registerFormData.telephone ?? '' }}"
                                   placeholder="8 chiffres" maxlength="8">
                        </div>
                        {% if registerFieldErrors is defined and registerFieldErrors.telephone is defined %}
                            <span class="field-error-msg">{{ registerFieldErrors.telephone }}</span>
                        {% endif %}
                    </div>

                    {# Mot de passe #}
                    <div class="form-group">
                        <label class="form-label">Mot de passe *</label>
                        <div class="form-input-wrapper {% if registerFieldErrors is defined and registerFieldErrors.password is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                            <input type="password" class="form-input {% if registerFieldErrors is defined and registerFieldErrors.password is defined %}input-error{% endif %}"
                                   id="registerPassword" name="password"
                                   placeholder="Min. 6 car. : Aa1@...">
                            <button type="button" class="password-toggle" data-target="registerPassword">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        {% if registerFieldErrors is defined and registerFieldErrors.password is defined %}
                            <span class="field-error-msg">{{ registerFieldErrors.password }}</span>
                        {% endif %}
                    </div>

                    {# Confirmation mot de passe #}
                    <div class="form-group">
                        <label class="form-label">Confirmer le mot de passe *</label>
                        <div class="form-input-wrapper {% if registerFieldErrors is defined and registerFieldErrors.confirm_password is defined %}has-error{% endif %}">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                            <input type="password" class="form-input {% if registerFieldErrors is defined and registerFieldErrors.confirm_password is defined %}input-error{% endif %}"
                                   id="confirmPassword" name="confirm_password"
                                   placeholder="Confirmez votre mot de passe">
                            <button type="button" class="password-toggle" data-target="confirmPassword">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        {% if registerFieldErrors is defined and registerFieldErrors.confirm_password is defined %}
                            <span class="field-error-msg">{{ registerFieldErrors.confirm_password }}</span>
                        {% endif %}
                    </div>

                    <button type="submit" class="submit-btn">Créer mon compte</button>

                    <p class="form-footer">
                        Déjà un compte ?
                        <a href="#" id="go-login">Se connecter</a>
                    </p>
                </form>
            </div>

        </div>
    </div>

    <script>
    function showPanel(name) {
        document.getElementById('panel-login').classList.toggle('is-active', name === 'login');
        document.getElementById('panel-register').classList.toggle('is-active', name === 'register');
        document.getElementById('tab-login').classList.toggle('active', name === 'login');
        document.getElementById('tab-register').classList.toggle('active', name === 'register');
        document.getElementById('form-title').textContent    = name === 'login' ? 'Bienvenue' : 'Créer un compte';
        document.getElementById('form-subtitle').textContent = name === 'login' ? 'Connectez-vous à votre compte' : 'Rejoignez la plateforme ViaNoVa';
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.auth-tab').forEach(function (btn) {
            var clone = btn.cloneNode(true);
            btn.parentNode.replaceChild(clone, btn);
        });

        document.getElementById('tab-login').addEventListener('click', function () { showPanel('login'); });
        document.getElementById('tab-register').addEventListener('click', function () { showPanel('register'); });
        document.getElementById('go-register').addEventListener('click', function (e) { e.preventDefault(); showPanel('register'); });
        document.getElementById('go-login').addEventListener('click', function (e) { e.preventDefault(); showPanel('login'); });

        {% if registerFieldErrors is defined and registerFieldErrors|length > 0 %}
            showPanel('register');
        {% elseif app.flashes('register_success')|length > 0 %}
            showPanel('register');
        {% else %}
            showPanel('login');
        {% endif %}
    });
    </script>
{% endblock %}
