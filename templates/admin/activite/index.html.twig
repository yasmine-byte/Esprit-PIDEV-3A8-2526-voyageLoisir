{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion Activité{% endblock %}

{% block admin_content %}

<style>
.activities-section {
    margin-top: 10px;
}

.activities-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}

.activities-header-text h2 {
    margin: 0;
    font-size: 46px;
    line-height: 1.1;
    font-weight: 700;
    color: #1e1e1e;
}

.activities-header-text p {
    margin: 8px 0 0;
    font-size: 18px;
    color: #7a7a7a;
}

.activities-add-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    border-radius: 14px;
    background: #e7b67b;
    color: #1c1c1c;
    text-decoration: none;
    font-weight: 600;
    border: 1px solid transparent;
    transition: 0.25s ease;
}

.activities-add-btn:hover {
    background: #dca867;
    color: #1c1c1c;
    transform: translateY(-1px);
}

/* ===== STATS ===== */
.activities-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 26px;
}

.activities-stat-card {
    background: #ffffff;
    border: 1px solid #ececec;
    border-radius: 20px;
    padding: 22px 24px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
}

.activities-stat-label {
    font-size: 14px;
    font-weight: 600;
    color: #8a8a8a;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}

.activities-stat-value {
    font-size: 32px;
    font-weight: 700;
    color: #1e1e1e;
    line-height: 1;
}

.activities-table-card {
    background: #ffffff;
    border: 1px solid #ececec;
    border-radius: 22px;
    padding: 18px 22px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
    overflow-x: auto;
}

.activities-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 950px;
}

.activities-table thead th {
    padding: 18px 14px;
    font-size: 14px;
    font-weight: 600;
    color: #9a9a9a;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-bottom: 1px solid #ececec;
    text-align: left;
}

.activities-table tbody td {
    padding: 20px 14px;
    border-bottom: 1px solid #ececec;
    vertical-align: middle;
    color: #1e1e1e;
    font-size: 16px;
}

.activities-table tbody tr:last-child td {
    border-bottom: none;
}

.activities-table tbody tr:hover {
    background: rgba(231, 182, 123, 0.06);
}

.activity-main-cell {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 260px;
}

.activity-icon {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e7b67b, #d89b5b);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
    flex-shrink: 0;
}

.activity-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.activity-name {
    font-size: 17px;
    font-weight: 600;
    color: #1e1e1e;
    line-height: 1.2;
}

.activity-type {
    font-size: 14px;
    color: #7f7f7f;
}

.activity-price {
    font-weight: 700;
    color: #1e1e1e;
}

.activity-duration,
.activity-location {
    color: #5f5f5f;
}

.activities-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.activities-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 110px;
    padding: 10px 16px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid #e7e7e7;
    transition: 0.25s ease;
    cursor: pointer;
}

.activities-btn-edit {
    background: #f8f8f8;
    color: #1e1e1e;
}

.activities-btn-edit:hover {
    background: #efefef;
    color: #1e1e1e;
}

.activities-btn-delete {
    background: #ffffff;
    color: #d9534f;
    border-color: #f1d0cf;
}

.activities-btn-delete:hover {
    background: #fff5f5;
    color: #c9302c;
}

.activities-empty {
    text-align: center;
    color: #7a7a7a;
    padding: 32px 12px;
    font-size: 16px;
}

.activities-btn-view {
    background: #f8f3ea;
    color: #9a6a2f;
    border-color: #ead7bb;
}

.activities-btn-view:hover {
    background: #f3e6d4;
    color: #8a5c24;
}

.activities-btn-add-reservation {
    background: #e7b67b;
    color: #1c1c1c;
    border-color: #e7b67b;
}

.activities-btn-add-reservation:hover {
    background: #dca867;
    color: #1c1c1c;
}

@media (max-width: 768px) {
    .activities-stats {
        grid-template-columns: 1fr;
    }
}
</style>

<div class="activities-section">

    <div class="activities-header">
        <div class="activities-header-text">
            <h2>Gestion des Activités</h2>
            <p>Gérez toutes les activités de votre plateforme</p>
        </div>

        <a href="{{ path('admin_activite_new') }}" class="activities-add-btn">
            Ajouter une activité
        </a>
    </div>
    <div style="
    background: linear-gradient(135deg, #fff7ed, #ffedd5);
    border: 1px solid #f3d2a2;
    border-radius: 18px;
    padding: 20px 24px;
    margin-bottom: 24px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.05);
">
    <div style="
        font-size: 13px;
        font-weight: 700;
        color: #c67c2f;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    ">
        Résumé IA
    </div>

    <div style="
        font-size: 16px;
        color: #2b2b2b;
        line-height: 1.6;
    ">
        {{ aiSummary ?? '' }}
    </div>
</div>

    <div class="activities-stats">
        <div class="activities-stat-card">
            <div class="activities-stat-label">Total des activités</div>
<div class="activities-stat-value">{{ totalActivites|default(0) }}</div>
        </div>

        <div class="activities-stat-card">
            <div class="activities-stat-label">Prix moyen</div>
            <div class="activities-stat-value">{{ prixMoyen|number_format(2, '.', ' ') }} TND</div>
        </div>
    </div>

    <div class="activities-table-card">
        <table class="activities-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Activité</th>
                    <th>Prix</th>
                    <th>Durée</th>
                    <th>Lieu</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
            {% for activite in activites %}
                <tr>
                    <td>{{ activite.id }}</td>

                    <td>
                        <div class="activity-main-cell">
                            <div class="activity-icon">
                                {{ activite.nom|slice(0,1)|upper }}
                            </div>

                            <div class="activity-info">
                                <div class="activity-name">{{ activite.nom }}</div>
                                <div class="activity-type">{{ activite.type ?: 'Activité' }}</div>
                            </div>
                        </div>
                    </td>

                    <td class="activity-price">{{ activite.prix }} TND</td>
                    <td class="activity-duration">{{ activite.duree }} min</td>
                    <td class="activity-location">{{ activite.lieu }}</td>

                    <td>
                        <div class="activities-actions">
                            <a href="{{ path('admin_reservation_activite_index', {'activite': activite.id}) }}" class="activities-btn activities-btn-view">
                                Réservations
                            </a>

                            <a href="{{ path('admin_activite_edit', {'id': activite.id}) }}" class="activities-btn activities-btn-edit">
                                Modifier
                            </a>

                            

                            <form method="post"
                                  action="{{ path('admin_activite_delete', {'id': activite.id}) }}"
                                  onsubmit="return confirm('Supprimer cette activité ?');"
                                  style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activite.id) }}">
                                <button type="submit" class="activities-btn activities-btn-delete">
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="activities-empty">Aucune activité trouvée</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>

{% endblock %}