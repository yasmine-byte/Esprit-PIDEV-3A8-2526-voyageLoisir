{% extends 'admin/base_admin.html.twig' %}

{% block title %}Réservations Hébergement{% endblock %}

{% block admin_content %}
<style>
.market-table td .action-btn {
    padding: 5px 10px !important;
    font-size: 12px !important;
    display: inline-flex !important;
}
.market-table td form { display: inline !important; }
.market-table td { padding: 10px 12px !important; }
</style>

<div class="page-header">
    <h1>Réservations Hébergement</h1>
    <p>Gérer toutes les réservations</p>
</div>

{# ===== FILTRES ===== #}
<div class="card" style="margin-bottom:20px">
    <div class="card-header">
        <h3 class="card-title">Filtres & Recherche</h3>
    </div>
    <form method="GET" action="{{ path('admin_reservation_hebergement_index') }}"
          style="display:flex;flex-wrap:wrap;gap:12px;padding:16px;align-items:flex-end">

        <div style="flex:1;min-width:180px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Recherche (nom, email, tél)</label>
            <input type="text" name="search" value="{{ search }}"
                   placeholder="Rechercher..."
                   style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
        </div>

        <div style="min-width:150px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Statut</label>
            <select name="statut"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="">Tous</option>
                <option value="en_attente" {{ statut == 'en_attente' ? 'selected' : '' }}>En attente</option>
                <option value="confirmee"  {{ statut == 'confirmee'  ? 'selected' : '' }}>Confirmée</option>
                <option value="annulee"    {{ statut == 'annulee'    ? 'selected' : '' }}>Annulée</option>
            </select>
        </div>

        <div style="display:flex;gap:8px">
            <button type="submit"
                    style="padding:8px 18px;border-radius:6px;border:none;background:#6c63ff;color:#fff;font-size:13px;cursor:pointer;font-weight:600">
                🔍 Filtrer
            </button>
            <a href="{{ path('admin_reservation_hebergement_index') }}"
               style="padding:8px 18px;border-radius:6px;border:1px solid #555;color:#aaa;font-size:13px;text-decoration:none;display:flex;align-items:center">
                ✕ Reset
            </a>
        </div>
    </form>
</div>

{# ===== STATS RAPIDES ===== #}
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px">
    <div style="background:#1e1e2e;border:1px solid #333;border-radius:10px;padding:16px;text-align:center">
        <div style="font-size:24px;font-weight:700;color:#f39c12">
            {{ reservations|filter(r => r.statut == 'en_attente')|length }}
        </div>
        <div style="font-size:13px;color:#888;margin-top:4px">En attente</div>
    </div>
    <div style="background:#1e1e2e;border:1px solid #333;border-radius:10px;padding:16px;text-align:center">
        <div style="font-size:24px;font-weight:700;color:#2ecc71">
            {{ reservations|filter(r => r.statut == 'confirmee')|length }}
        </div>
        <div style="font-size:13px;color:#888;margin-top:4px">Confirmées</div>
    </div>
    <div style="background:#1e1e2e;border:1px solid #333;border-radius:10px;padding:16px;text-align:center">
        <div style="font-size:24px;font-weight:700;color:#e74c3c">
            {{ reservations|filter(r => r.statut == 'annulee')|length }}
        </div>
        <div style="font-size:13px;color:#888;margin-top:4px">Annulées</div>
    </div>
</div>

{# ===== TABLEAU ===== #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Liste des Réservations
            <span style="font-size:13px;color:#888;font-weight:normal;margin-left:8px">
                ({{ reservations|length }} résultat{{ reservations|length > 1 ? 's' : '' }})
            </span>
        </h3>
    </div>

    <div style="overflow-x:auto">
    <table class="market-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Client</th>
                <th>Email</th>
                <th>Tél</th>
                <th>Hébergement</th>
                <th>Date début</th>
                <th>Date fin</th>
                <th>Nuits</th>
                <th>Total</th>
                <th>Statut</th>
                <th>Créée le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for reservation in reservations %}
            <tr>
                <td>{{ reservation.id }}</td>
                <td>{{ reservation.clientNom }}</td>
                <td>{{ reservation.clientEmail }}</td>
                <td>{{ reservation.clientTel }}</td>
                <td>{{ reservation.hebergement ? reservation.hebergement.id : '-' }}</td>
                <td>{{ reservation.dateDebut ? reservation.dateDebut|date('d/m/Y') : '-' }}</td>
                <td>{{ reservation.dateFin ? reservation.dateFin|date('d/m/Y') : '-' }}</td>
                <td>{{ reservation.nbNuits }}</td>
                <td>{{ reservation.total }} TND</td>
                <td>
                    {% if reservation.statut == 'confirmee' %}
                        <span class="transaction-status completed">Confirmée</span>
                    {% elseif reservation.statut == 'en_attente' %}
                        <span class="transaction-status" style="background:#f39c12">En attente</span>
                    {% else %}
                        <span class="transaction-status" style="background:#e74c3c">Annulée</span>
                    {% endif %}
                </td>
                <td>{{ reservation.createdAt ? reservation.createdAt|date('d/m/Y') : '-' }}</td>
                <td style="white-space:nowrap">
                    {# Changer statut #}
                    <form method="post" action="{{ path('admin_reservation_hebergement_statut', {'id': reservation.id}) }}" style="display:inline">
                        <select name="statut" onchange="this.form.submit()"
                                style="padding:4px 8px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:12px;cursor:pointer">
                            <option value="en_attente" {{ reservation.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>
                            <option value="confirmee"  {{ reservation.statut == 'confirmee'  ? 'selected' : '' }}>Confirmée</option>
                            <option value="annulee"    {{ reservation.statut == 'annulee'    ? 'selected' : '' }}>Annulée</option>
                        </select>
                    </form>
                    {# Supprimer #}
                    <form method="post" action="{{ path('admin_reservation_hebergement_delete', {'id': reservation.id}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                        <button type="submit" class="action-btn"
                                style="background:#c0392b;color:#fff;border-color:#c0392b"
                                onclick="return confirm('Supprimer cette réservation ?')">
                            Supprimer
                        </button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="12" style="text-align:center;color:#888;padding:30px">
                    Aucune réservation trouvée
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
</div>

<footer class="copyright">Copyright &copy; 2026 VoyageLoisir</footer>
{% endblock %}
