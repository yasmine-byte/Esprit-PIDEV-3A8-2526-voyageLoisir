{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dashboard — Gestion Utilisateurs{% endblock %}

{% block admin_content %}

{# ─── EN-TÊTE ─────────────────────────────────────────────────────────────── #}
<div class="page-header">
    <div>
        <h1>Tableau de bord</h1>
        <p>Vue d'ensemble de la gestion des utilisateurs</p>
    </div>
    <div class="header-actions">
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('add_user') }}" class="btn btn-primary">
            ➕ Ajouter un utilisateur
        </a>
        {% endif %}
    </div>
</div>

{# ─── CARTES STATISTIQUES ──────────────────────────────────────────────────── #}
{% if totalUsers is defined %}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">{{ totalUsers }}</div>
            <div class="stat-label">Total Utilisateurs</div>
        </div>
        <div class="stat-trend">
            {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_users_list') }}" class="stat-link">Voir tous →</a>
            {% endif %}
        </div>
    </div>

    <div class="stat-card stat-success">
        <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">{{ activeUsers }}</div>
            <div class="stat-label">Utilisateurs Actifs</div>
        </div>
        <div class="stat-trend">
            {% if totalUsers > 0 %}
                <span class="stat-percent">{{ ((activeUsers / totalUsers) * 100)|round }}%</span>
            {% endif %}
        </div>
    </div>

    <div class="stat-card stat-danger">
        <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">{{ inactiveUsers }}</div>
            <div class="stat-label">Utilisateurs Inactifs</div>
        </div>
        <div class="stat-trend">
            {% if totalUsers > 0 %}
                <span class="stat-percent">{{ ((inactiveUsers / totalUsers) * 100)|round }}%</span>
            {% endif %}
        </div>
    </div>

    <div class="stat-card stat-info">
        <div class="stat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">{{ totalRoles }}</div>
            <div class="stat-label">Rôles Définis</div>
        </div>
        <div class="stat-trend">
            {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_users_list') }}" class="stat-link">Gérer →</a>
            {% endif %}
        </div>
    </div>
</div>
{% else %}
<div class="alert-info">
    <p>Chargement des données...</p>
</div>
{% endif %}

{# ─── DERNIERS INSCRITS ───────────────────────────────────────────────────── #}
<div class="card mt-4">
    <div class="card-header">
        <h3>🕐 Derniers utilisateurs inscrits</h3>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_users_list') }}" class="btn btn-sm">Voir tous →</a>
        {% endif %}
    </div>
    <div class="card-body p-0">
        {% if latestUsers|length > 0 %}
        <table class="users-table">
            <thead>
                <tr>
                    <th>Utilisateur</th>
                    <th>Email</th>
                    <th>Rôles</th>
                    <th>Statut</th>
                    <th>Inscrit le</th>
                    {% if is_granted('ROLE_ADMIN') %}
                    <th>Actions</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% for user in latestUsers %}
                <tr>
                    <td>
                        <div class="user-cell">
                            <div class="user-avatar-sm">
                                {{ user.nom|first|upper }}{{ user.prenom|first|upper }}
                            </div>
                            <span>{{ user.nom }} {{ user.prenom }}</span>
                        </div>
                    </td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% for role in user.rolesCollection %}
                            <span class="role-badge">{{ role.name }}</span>
                        {% else %}
                            <span class="text-muted">Aucun</span>
                        {% endfor %}
                    </td>
                    <td>
                        <span class="status-badge {{ user.isActive ? 'active' : 'inactive' }}">
                            {{ user.isActive ? 'Actif' : 'Inactif' }}
                        </span>
                    </td>
                    <td>{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '—' }}</td>
                    {% if is_granted('ROLE_ADMIN') %}
                    <td>
                        <a href="{{ path('admin_user_edit', {'id': user.id}) }}"
                           class="btn btn-sm btn-outline-primary" title="Modifier">✏️</a>
                        <a href="#" onclick="confirmDelete({{ user.id }})"
                           class="btn btn-sm btn-outline-danger" title="Supprimer">🗑️</a>
                    </td>
                    {% endif %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
            <div class="empty-state">
                <p>Aucun utilisateur enregistré.</p>
            </div>
        {% endif %}
    </div>
</div>

{# ─── GRAPHIQUES ──────────────────────────────────────────────────────────── #}
<div class="charts-grid">
    <div class="card">
        <div class="card-header">
            <h3>📈 Inscriptions par mois</h3>
            <span class="badge">6 derniers mois</span>
        </div>
        <div class="card-body">
            <canvas id="monthlyChart" height="120"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>🎭 Répartition des rôles</h3>
            <span class="badge">{{ totalUsers }} utilisateurs</span>
        </div>
        <div class="card-body chart-pie-container">
            {% if roleStats|length > 0 %}
            <canvas id="rolesChart" height="120"></canvas>
            {% else %}
            <div class="empty-chart">Aucun rôle attribué</div>
            {% endif %}
        </div>
    </div>
</div>

{# ─── STYLES ──────────────────────────────────────────────────────────────── #}
<style>
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 28px;
}
.stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: transform 0.2s, box-shadow 0.2s;
}
.stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
.stat-card.stat-success { border-left: 4px solid #34d399; }
.stat-card.stat-danger  { border-left: 4px solid #ef4444; }
.stat-card.stat-info    { border-left: 4px solid #60a5fa; }
.stat-icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: var(--bg-secondary);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: var(--accent-copper);
}
.stat-info { flex: 1; }
.stat-value { font-size: 2rem; font-weight: 700; color: var(--text-primary); line-height: 1; }
.stat-label { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
.stat-percent { font-size: 13px; font-weight: 600; color: var(--text-muted); }
.stat-link { font-size: 12px; color: var(--accent-copper); text-decoration: none; }
.stat-link:hover { text-decoration: underline; }
.charts-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}
.card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
}
.page-header h1 { margin: 0 0 4px 0; color: var(--text-primary); }
.page-header p { margin: 0; color: var(--text-muted); }
.header-actions { display: flex; gap: 12px; align-items: center; }
.card-body.p-0 { padding: 0; }
.mt-4 { margin-top: 20px; }
.badge { background: var(--bg-secondary); color: var(--text-muted); padding: 4px 10px; border-radius: 20px; font-size: 12px; }
.chart-pie-container { display: flex; align-items: center; justify-content: center; }
.empty-chart { color: var(--text-muted); text-align: center; padding: 40px; }
.users-table { width: 100%; border-collapse: collapse; }
.users-table th {
    background: var(--bg-secondary); padding: 12px 16px;
    text-align: left; font-size: 12px; font-weight: 600;
    color: var(--text-muted); text-transform: uppercase;
    border-bottom: 1px solid var(--border);
}
.users-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); color: var(--text-secondary); }
.users-table tr:last-child td { border-bottom: none; }
.users-table tr:hover { background: var(--bg-card-hover); }
.user-cell { display: flex; align-items: center; gap: 10px; }
.user-avatar-sm {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--accent-gradient); color: #1c1c1e;
    font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.role-badge { background: var(--accent-gradient); color: #1c1c1e; padding: 3px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }
.status-badge { padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
.status-badge.active { background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.3); color: #34d399; }
.status-badge.inactive { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }
.alert-info { background: rgba(96,165,250,0.1); border: 1px solid rgba(96,165,250,0.3); color: #60a5fa; padding: 16px; border-radius: 8px; }
.text-muted { color: var(--text-muted); font-style: italic; font-size: 13px; }
.btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card); color: var(--text-primary); text-decoration: none; font-size: 14px; font-weight: 500; cursor: pointer; transition: all 0.2s ease; }
.btn-primary { background: var(--accent-copper); color: #1c1c1e; border-color: var(--accent-copper); font-weight: 600; }
.btn-sm { padding: 6px 12px; font-size: 12px; border-radius: 6px; }
.btn-outline-primary { border: 1px solid var(--accent-copper); color: var(--accent-copper); background: transparent; cursor: pointer; text-decoration: none; }
.btn-outline-primary:hover { background: var(--accent-copper); color: #1c1c1e; }
.btn-outline-danger { border: 1px solid #ef4444; color: #ef4444; background: transparent; cursor: pointer; text-decoration: none; }
.btn-outline-danger:hover { background: #ef4444; color: #fff; }
.empty-state { text-align: center; padding: 32px; color: var(--text-muted); }
@media (max-width: 768px) {
    .charts-grid { grid-template-columns: 1fr; }
    .stats-grid  { grid-template-columns: 1fr 1fr; }
}
</style>

{# ─── CHART.JS ────────────────────────────────────────────────────────────── #}
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
const textColor = isDark ? '#94a3b8' : '#64748b';

const monthlyLabels = {{ monthlyData|keys|json_encode|raw }};
const monthlyValues = {{ monthlyData|map(v => v)|json_encode|raw }};

const monthNames = ['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];
const formattedLabels = monthlyLabels.map(m => {
    const [year, month] = m.split('-');
    return monthNames[parseInt(month) - 1] + ' ' + year;
});

new Chart(document.getElementById('monthlyChart'), {
    type: 'bar',
    data: {
        labels: formattedLabels,
        datasets: [{
            label: 'Inscriptions',
            data: monthlyValues,
            backgroundColor: 'rgba(205,127,50,0.7)',
            borderColor: '#cd7f32',
            borderWidth: 2,
            borderRadius: 6,
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: gridColor }, ticks: { color: textColor } },
            y: { grid: { color: gridColor }, ticks: { color: textColor, stepSize: 1 }, beginAtZero: true }
        }
    }
});

{% if roleStats|length > 0 %}
const roleLabels = {{ roleStats|keys|json_encode|raw }};
const roleValues = {{ roleStats|map(v => v)|json_encode|raw }};

new Chart(document.getElementById('rolesChart'), {
    type: 'doughnut',
    data: {
        labels: roleLabels,
        datasets: [{
            data: roleValues,
            backgroundColor: ['#cd7f32','#60a5fa','#34d399','#f472b6','#a78bfa'],
            borderWidth: 2,
            borderColor: isDark ? '#1a1a2e' : '#ffffff',
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: {
                position: 'bottom',
                labels: { color: textColor, padding: 12, font: { size: 12 } }
            }
        }
    }
});
{% endif %}
</script>

{% endblock %}
