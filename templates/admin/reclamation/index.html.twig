<script>
function openM(id)  { document.getElementById(id).classList.add('open'); }
function closeM(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.m-overlay').forEach(function(m) {
    m.addEventListener('click', function(e) { if(e.target===m) m.classList.remove('open'); });
});

(function() {
    const searchInput    = document.getElementById('searchInput');
    const filterStatut   = document.getElementById('filterStatut');
    const filterPriorite = document.getElementById('filterPriorite');
    const sortSelect     = document.getElementById('sortSelect');
    const tbody          = document.getElementById('reclBody');
    const resultCount    = document.getElementById('resultCount');
    const noResults      = document.getElementById('noResults');

    function run() {
        const q        = searchInput.value.toLowerCase().trim();
        const statut   = filterStatut.value;
        const priorite = filterPriorite.value;
        const sort     = sortSelect.value;

        const rows = Array.from(tbody.querySelectorAll('tr[data-titre]'));
        let visible = 0;

        rows.forEach(function(r) {
            const okQ = !q        || (r.dataset.titre   || '').includes(q) || (r.dataset.contenu || '').includes(q);
            const okS = !statut   || r.dataset.statut   === statut;
            const okP = !priorite || r.dataset.priorite === priorite;
            if (okQ && okS && okP) { r.style.display = ''; visible++; }
            else                    { r.style.display = 'none'; }
        });

        resultCount.textContent = visible + ' réclamation' + (visible > 1 ? 's' : '') + ' affichée' + (visible > 1 ? 's' : '');
        noResults.style.display = visible === 0 ? 'block' : 'none';

        if (sort) {
            const vis = rows.filter(r => r.style.display !== 'none');
            vis.sort(function(a, b) {
                if (sort === 'date-desc')     return b.dataset.date.localeCompare(a.dataset.date);
                if (sort === 'date-asc')      return a.dataset.date.localeCompare(b.dataset.date);
                if (sort === 'priorite-desc') return parseInt(b.dataset.prioriteVal) - parseInt(a.dataset.prioriteVal);
                if (sort === 'priorite-asc')  return parseInt(a.dataset.prioriteVal) - parseInt(b.dataset.prioriteVal);
                return 0;
            });
            vis.forEach(r => tbody.appendChild(r));
        }
    }

    searchInput.addEventListener('input',    run);
    filterStatut.addEventListener('change',   run);
    filterPriorite.addEventListener('change', run);
    sortSelect.addEventListener('change',     run);
    run();
})();
</script>
{% endblock %}
