{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Réclamations{% endblock %}

{% block admin_content %}
    <h2 class="mb-4 text-light">Gestion des Réclamations</h2>

    {% if stats.urgentes > 0 %}
        <div class="mb-4" style="background:#ff4444; color:white; font-weight:bold; padding:15px; border-radius:8px;">
            <i class="fas fa-exclamation-triangle"></i> ⚠️ {{ stats.urgentes }} réclamation(s) URGENTE(s) non traitée(s) !
        </div>
    {% endif %}

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' or label == 'error' ? 'danger' : 'success' }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Stats Cards #}
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card text-white bg-primary mb-3 shadow-sm border-0">
                <div class="card-body text-center p-3">
                    <div class="text-uppercase small mb-1">Total</div>
                    <div class="fs-4 fw-bold">{{ stats.total }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-dark bg-warning mb-3 shadow-sm border-0">
                <div class="card-body text-center p-3">
                    <div class="text-uppercase small mb-1">En attente</div>
                    <div class="fs-4 fw-bold">{{ stats.en_attente }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-info mb-3 shadow-sm border-0">
                <div class="card-body text-center p-3">
                    <div class="text-uppercase small mb-1">En cours</div>
                    <div class="fs-4 fw-bold">{{ stats.en_cours }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-success mb-3 shadow-sm border-0">
                <div class="card-body text-center p-3">
                    <div class="text-uppercase small mb-1">Traitées</div>
                    <div class="fs-4 fw-bold">{{ stats.traitees }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-secondary mb-3 shadow-sm border-0">
                <div class="card-body text-center p-3">
                    <div class="text-uppercase small mb-1">Fermées</div>
                    <div class="fs-4 fw-bold">{{ stats.fermees }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-white bg-danger mb-3 shadow-sm border-0" style="animation: blinker 1.5s linear infinite;">
                <div class="card-body text-center p-3">
                    <div class="text-uppercase small mb-1">Urgentes</div>
                    <div class="fs-4 fw-bold">{{ stats.urgentes }}</div>
                </div>
            </div>
        </div>
    </div>

    {# Filtres #}
    <div class="card mb-4 bg-transparent border-light border-opacity-10">
        <div class="card-body">
            <form method="GET" class="d-flex align-items-end gap-3 flex-wrap">
                <div>
                    <label class="text-light fw-bold mb-1">Statut :</label>
                    <select name="statut" class="form-select bg-dark text-light border-secondary">
                        <option value="">Tous</option>
                        <option value="En attente" {{ currentStatut == 'En attente' ? 'selected' : '' }}>En attente</option>
                        <option value="En cours" {{ currentStatut == 'En cours' ? 'selected' : '' }}>En cours</option>
                        <option value="Traitée" {{ currentStatut == 'Traitée' ? 'selected' : '' }}>Traitée</option>
                        <option value="Fermée" {{ currentStatut == 'Fermée' ? 'selected' : '' }}>Fermée</option>
                    </select>
                </div>
                <div>
                    <label class="text-light fw-bold mb-1">Priorité :</label>
                    <select name="priorite" class="form-select bg-dark text-light border-secondary">
                        <option value="">Toutes</option>
                        <option value="Basse" {{ currentPriorite == 'Basse' ? 'selected' : '' }}>Basse</option>
                        <option value="Moyenne" {{ currentPriorite == 'Moyenne' ? 'selected' : '' }}>Moyenne</option>
                        <option value="Haute" {{ currentPriorite == 'Haute' ? 'selected' : '' }}>Haute</option>
                        <option value="Urgente" {{ currentPriorite == 'Urgente' ? 'selected' : '' }}>Urgente</option>
                    </select>
                </div>
                <div>
                    <button type="submit" class="btn btn-outline-light">Filtrer</button>
                    <a href="{{ path('admin_reclamation_index') }}" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    {# Tableau #}
    <style>
        .blink_me { animation: blinker 1.5s linear infinite; }
        @keyframes blinker { 50% { opacity: 0; } }
    </style>
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle" style="background: rgba(0,0,0,0.2);">
            <thead class="table-active">
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Type</th>
                    <th>Priorité</th>
                    <th>Statut</th>
                    <th>Avis lié</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for rec in reclamations %}
                    <tr>
                        <td class="fw-bold">#{{ rec.id }}</td>
                        <td>{{ rec.titre }}</td>
                        <td>{{ rec.type.nom }}</td>
                        <td>
                            {% if rec.priorite == 'Basse' %}
                                <span class="badge bg-secondary">Basse</span>
                            {% elseif rec.priorite == 'Moyenne' %}
                                <span class="badge bg-info">Moyenne</span>
                            {% elseif rec.priorite == 'Haute' %}
                                <span class="badge" style="background-color: #fd7e14;">Haute</span>
                            {% elseif rec.priorite == 'Urgente' %}
                                <span class="badge bg-danger blink_me">Urgente</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if rec.statut == 'En attente' %}
                                <span class="badge bg-warning text-dark">En attente</span>
                            {% elseif rec.statut == 'En cours' %}
                                <span class="badge bg-primary">En cours</span>
                            {% elseif rec.statut == 'Traitée' %}
                                <span class="badge bg-success">Traitée</span>
                            {% elseif rec.statut == 'Fermée' %}
                                <span class="badge bg-secondary">Fermée</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if rec.avis %}
                                <a href="{{ path('admin_reclamation_show', {'id': rec.id}) }}" class="badge rounded-pill border bg-light text-dark text-decoration-none">
                                    Avis #{{ rec.avis.id }} ({{ rec.avis.nbEtoiles }}★)
                                </a>
                            {% else %}
                                <span class="text-muted fst-italic">Manuel</span>
                            {% endif %}
                        </td>
                        <td>{{ rec.dateCreation ? rec.dateCreation|date('d/m/Y') : '' }}</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <a href="{{ path('admin_reclamation_show', {'id': rec.id}) }}" class="btn btn-sm btn-outline-info" title="Voir">
                                    <i class="fas fa-eye"></i>
                                </a>
                                
                                <form method="POST" action="{{ path('admin_reclamation_statut', {'id': rec.id}) }}" class="m-0">
                                    <select name="statut" onchange="this.form.submit()" class="form-select form-select-sm bg-dark text-light border-secondary" style="width: auto;">
                                        <option value="En attente" {{ rec.statut == 'En attente' ? 'selected' : '' }}>En attente</option>
                                        <option value="En cours" {{ rec.statut == 'En cours' ? 'selected' : '' }}>En cours</option>
                                        <option value="Traitée" {{ rec.statut == 'Traitée' ? 'selected' : '' }}>Traitée</option>
                                        <option value="Fermée" {{ rec.statut == 'Fermée' ? 'selected' : '' }}>Fermée</option>
                                    </select>
                                </form>

                                <form method="POST" action="{{ path('admin_reclamation_delete', {'id': rec.id}) }}" onsubmit="return confirm('Supprimer définitivement cette réclamation ?');" class="m-0">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ rec.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-4">Aucune réclamation trouvée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
