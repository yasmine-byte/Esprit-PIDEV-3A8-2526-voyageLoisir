{# ── Pagination ─────────────────────────────── #}
{% if totalPages is defined and totalPages > 1 %}
<div style="display:flex; justify-content:space-between; align-items:center; margin-top:24px; padding: 16px 20px; border-radius:12px; border:1px solid;"
     class="pag-wrap">
    <div style="font-size:0.82rem; opacity:0.5;">
        Page <strong>{{ currentPage }}</strong> / <strong>{{ totalPages }}</strong>
        &mdash; <strong>{{ totalItems }}</strong> réclamation(s)
    </div>
    <div style="display:flex; gap:6px; align-items:center;">

        {# Précédent #}
        {% if currentPage > 1 %}
        <a href="?page={{ currentPage - 1 }}&statut={{ currentStatut }}&priorite={{ currentPriorite }}&recherche={{ currentRecherche }}"
           style="width:34px;height:34px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;font-weight:700;font-size:1rem;"
           class="pag-btn">&laquo;</a>
        {% else %}
        <span style="width:34px;height:34px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;opacity:0.25;font-weight:700;font-size:1rem;"
              class="pag-btn">&laquo;</span>
        {% endif %}

        {# Pages #}
        {% for p in 1..totalPages %}
            {% if p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                {% if p == currentPage %}
                <span style="width:34px;height:34px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;background:#4a9eff;color:#fff;">{{ p }}</span>
                {% else %}
                <a href="?page={{ p }}&statut={{ currentStatut }}&priorite={{ currentPriorite }}&recherche={{ currentRecherche }}"
                   style="width:34px;height:34px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.85rem;font-weight:600;"
                   class="pag-btn">{{ p }}</a>
                {% endif %}
            {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                <span style="opacity:0.4;padding:0 4px;">...</span>
            {% endif %}
        {% endfor %}

        {# Suivant #}
        {% if currentPage < totalPages %}
        <a href="?page={{ currentPage + 1 }}&statut={{ currentStatut }}&priorite={{ currentPriorite }}&recherche={{ currentRecherche }}"
           style="width:34px;height:34px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;text-decoration:none;font-weight:700;font-size:1rem;"
           class="pag-btn">&raquo;</a>
        {% else %}
        <span style="width:34px;height:34px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;opacity:0.25;font-weight:700;font-size:1rem;"
              class="pag-btn">&raquo;</span>
        {% endif %}

    </div>
</div>

