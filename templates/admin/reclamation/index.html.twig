{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Réclamations{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <h2>Gestion des Réclamations</h2>
    <hr>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="mb-4">
        <form method="GET" class="row g-2">
            <div class="col-md-3">
                <input type="text" name="recherche" class="form-control" placeholder="Recherche par sujet ou ID..." value="{{ currentRecherche|default('') }}">
            </div>
            <div class="col-md-3">
                <select name="statut" class="form-select">
                    <option value="">Tous les statuts</option>
                    <option value="En attente" {{ currentStatut == 'En attente' ? 'selected' : '' }}>En attente</option>
                    <option value="En cours" {{ currentStatut == 'En cours' ? 'selected' : '' }}>En cours</option>
                    <option value="Traitée" {{ currentStatut == 'Traitée' ? 'selected' : '' }}>Traitée</option>
                    <option value="Fermée" {{ currentStatut == 'Fermée' ? 'selected' : '' }}>Fermée</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="priorite" class="form-select">
                    <option value="">Toutes les priorités</option>
                    <option value="Basse" {{ currentPriorite == 'Basse' ? 'selected' : '' }}>Basse</option>
                    <option value="Moyenne" {{ currentPriorite == 'Moyenne' ? 'selected' : '' }}>Moyenne</option>
                    <option value="Haute" {{ currentPriorite == 'Haute' ? 'selected' : '' }}>Haute</option>
                    <option value="Urgente" {{ currentPriorite == 'Urgente' ? 'selected' : '' }}>Urgente</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary">Filtrer</button>
                <a href="{{ path('admin_reclamation_index') }}" class="btn btn-secondary">Reset</a>
            </div>
        </form>
    </div>

    <table class="table table-striped table-bordered text-center align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Client</th>
                <th>Sujet</th>
                <th>Message</th>
                <th>Date</th>
                <th>Priorité</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for rec in reclamations %}
                <tr>
                    <td>{{ rec.id }}</td>
                    <td>{{ rec.userId }}</td>
                    <td>{{ rec.titre }}</td>
                    <td>{{ rec.contenu }}</td>
                    <td>{{ rec.dateCreation ? rec.dateCreation|date('d/m/Y') : '-' }}</td>
                    <td>{{ rec.priorite }}</td>
                    <td>
                        <form method="POST" action="{{ path('admin_reclamation_statut', {'id': rec.id}) }}" class="m-0">
                            <select name="statut" onchange="this.form.submit()" class="form-select form-select-sm">
                                <option value="En attente" {{ rec.statut == 'En attente' ? 'selected' : '' }}>En attente</option>
                                <option value="En cours" {{ rec.statut == 'En cours' ? 'selected' : '' }}>En cours</option>
                                <option value="Traitée" {{ rec.statut == 'Traitée' ? 'selected' : '' }}>Traitée</option>
                                <option value="Fermée" {{ rec.statut == 'Fermée' ? 'selected' : '' }}>Fermée</option>
                            </select>
                        </form>
                    </td>
                    <td>
                        <div class="d-flex justify-content-center gap-1">
                            <a href="{{ path('admin_reclamation_show', {'id': rec.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                            <button type="button" class="btn btn-sm btn-info text-white" data-bs-toggle="modal" data-bs-target="#modalRecl{{ rec.id }}">Répondre</button>
                            <form method="POST" action="{{ path('admin_reclamation_delete', {'id': rec.id}) }}" class="d-inline" onsubmit="return confirm('Confirmer la suppression ?');">
                                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                            </form>
                        </div>

                        <!-- Modal Répondre -->
                        <div class="modal fade text-start" id="modalRecl{{ rec.id }}" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Répondre à la réclamation #{{ rec.id }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="POST" action="{{ path('admin_reclamation_repondre', {'id': rec.id}) }}">
                                        <div class="modal-body">
                                            <p><strong>Problème :</strong> {{ rec.contenu }}</p>
                                            <div class="form-group">
                                                <label>Votre solution :</label>
                                                <textarea class="form-control" name="reponse" rows="3" required>{{ rec.reponse }}</textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                                            <button type="submit" class="btn btn-primary">Envoyer</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8">Aucune réclamation trouvée.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
