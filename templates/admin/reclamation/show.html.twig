{% extends 'admin/base_admin.html.twig' %}

{% block title %}Détails Réclamation #{{ reclamation.id }}{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-light">Réclamation #{{ reclamation.id }}</h2>
        <a href="{{ path('admin_reclamation_index') }}" class="btn btn-outline-light"><i class="fas fa-arrow-left me-1"></i>Retour</a>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' or label == 'danger' ? 'danger' : 'success' }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row">
        <div class="col-lg-8">
            {# Card Principale #}
            <div class="card bg-dark text-light mb-4 shadow-sm" style="border: 1px solid rgba(255,255,255,0.1);">
                <div class="card-header border-bottom border-light border-opacity-10 py-3">
                    <h4 class="mb-0">{{ reclamation.titre }}</h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h6 class="text-muted text-uppercase small fw-bold">Description</h6>
                        <div class="p-3 rounded" style="background: rgba(255,255,255,0.05);">
                            {{ reclamation.contenu|nl2br }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold">Détails</h6>
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2"><strong>Type :</strong> {{ reclamation.type.nom }}</li>
                                <li class="mb-2"><strong>Date de création :</strong> {{ reclamation.dateCreation ? reclamation.dateCreation|date('d/m/Y H:i') : '' }}</li>
                                <li class="mb-2"><strong>User ID :</strong> {{ reclamation.userId }}</li>
                            </ul>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold">État actuel</h6>
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2"><strong>Priorité :</strong> 
                                    {% if reclamation.priorite == 'Basse' %}
                                        <span class="badge bg-secondary">Basse</span>
                                    {% elseif reclamation.priorite == 'Moyenne' %}
                                        <span class="badge bg-info">Moyenne</span>
                                    {% elseif reclamation.priorite == 'Haute' %}
                                        <span class="badge" style="background-color: #fd7e14;">Haute</span>
                                    {% elseif reclamation.priorite == 'Urgente' %}
                                        <span class="badge bg-danger">Urgente</span>
                                    {% endif %}
                                </li>
                                <li class="mb-2"><strong>Statut :</strong> 
                                    {% if reclamation.statut == 'En attente' %}
                                        <span class="badge bg-warning text-dark">En attente</span>
                                    {% elseif reclamation.statut == 'En cours' %}
                                        <span class="badge bg-primary">En cours</span>
                                    {% elseif reclamation.statut == 'Traitée' %}
                                        <span class="badge bg-success">Traitée</span>
                                    {% elseif reclamation.statut == 'Fermée' %}
                                        <span class="badge bg-secondary">Fermée</span>
                                    {% endif %}
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            {# Card Secondaire : Avis #}
            {% if avis %}
            <div class="card bg-dark text-light mb-4 shadow-sm" style="border: none; border-left: 4px solid #ff4444; background: rgba(255,68,68,0.05) !important;">
                <div class="card-header border-bottom border-danger border-opacity-25 py-3">
                    <h5 class="mb-0 text-danger"><i class="fas fa-star me-2"></i>Avis à l'origine de cette réclamation</h5>
                </div>
                <div class="card-body">
                    <p class="mb-3"><strong>Contenu de l'avis :</strong><br>
                        <span class="fst-italic">"{{ avis.contenu }}"</span>
                    </p>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>Note :</strong> <span class="text-warning">
                            {% for i in 1..5 %}
                                {% if i <= avis.nbEtoiles %}<i class="fas fa-star"></i>{% else %}<i class="far fa-star"></i>{% endif %}
                            {% endfor %}
                        </span></li>
                        <li class="mb-2"><strong>Type :</strong> {{ avis.type.nom }}</li>
                        <li class="mb-2"><strong>Date :</strong> {{ avis.dateAvis|date('d/m/Y') }}</li>
                        <li class="mb-2"><strong>Statut avis :</strong> {{ avis.statut }}</li>
                    </ul>
                </div>
            </div>
            {% endif %}
        </div>
        
        <div class="col-lg-4">
            {# Formulaires d'action #}
            <div class="card bg-dark text-light mb-4 shadow-sm" style="border: 1px solid rgba(255,255,255,0.1);">
                <div class="card-header border-bottom border-light border-opacity-10 py-3">
                    <h5 class="mb-0">Actions Rapides</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('admin_reclamation_statut', {'id': reclamation.id}) }}" class="mb-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ reclamation.id) }}">
                        <label class="form-label text-muted small text-uppercase fw-bold">Modifier le statut</label>
                        <div class="input-group">
                            <select name="statut" class="form-select bg-dark text-light border-secondary">
                                <option value="En attente" {{ reclamation.statut == 'En attente' ? 'selected' : '' }}>En attente</option>
                                <option value="En cours" {{ reclamation.statut == 'En cours' ? 'selected' : '' }}>En cours</option>
                                <option value="Traitée" {{ reclamation.statut == 'Traitée' ? 'selected' : '' }}>Traitée</option>
                                <option value="Fermée" {{ reclamation.statut == 'Fermée' ? 'selected' : '' }}>Fermée</option>
                            </select>
                            <button type="submit" class="btn btn-primary">Ok</button>
                        </div>
                    </form>

                    <form method="POST" action="{{ path('admin_reclamation_priorite', {'id': reclamation.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('priorite' ~ reclamation.id) }}">
                        <label class="form-label text-muted small text-uppercase fw-bold">Changer la priorité</label>
                        <div class="input-group">
                            <select name="priorite" class="form-select bg-dark text-light border-secondary">
                                <option value="Basse" {{ reclamation.priorite == 'Basse' ? 'selected' : '' }}>Basse</option>
                                <option value="Moyenne" {{ reclamation.priorite == 'Moyenne' ? 'selected' : '' }}>Moyenne</option>
                                <option value="Haute" {{ reclamation.priorite == 'Haute' ? 'selected' : '' }}>Haute</option>
                                <option value="Urgente" {{ reclamation.priorite == 'Urgente' ? 'selected' : '' }}>Urgente</option>
                            </select>
                            <button type="submit" class="btn btn-warning text-dark">Ok</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
