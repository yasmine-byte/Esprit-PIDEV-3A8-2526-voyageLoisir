{% extends 'admin/base_admin.html.twig' %}

{% block title %}Wallet - CryptoVault{% endblock %}

{% block admin_content %}
    <div class="page-header">
        <h1>Wallet</h1>
        <p>Manage your crypto assets and transactions</p>
    </div>

    <div class="balance-cards">
        <div class="balance-card primary">
            <div class="balance-label">Total Balance</div>
            <div class="balance-value">$84,254.32</div>
            <div class="balance-change">+$2,847.50 (3.5%) this month</div>
        </div>
        <div class="balance-card">
            <div class="balance-label">Staked Assets</div>
            <div class="balance-value">$12,450.00</div>
            <div class="balance-change">Earning 8.2% APY</div>
        </div>
        <div class="balance-card">
            <div class="balance-label">Total Rewards</div>
            <div class="balance-value">$1,024.80</div>
            <div class="balance-change">+$45.20 this week</div>
        </div>
    </div>

    <div class="action-buttons">
        <button class="action-btn primary">Deposit</button>
        <button class="action-btn">Withdraw</button>
        <button class="action-btn">Swap</button>
        <button class="action-btn">Stake</button>
    </div>

    <div class="content-grid">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">Your Wallets</h2>
            </div>
            <div class="wallet-list">
                <div class="wallet-item">
                    <div class="wallet-icon btc">₿</div>
                    <div class="wallet-info">
                        <div class="wallet-name">Bitcoin</div>
                        <div class="wallet-address">bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh</div>
                    </div>
                    <div class="wallet-balance">
                        <div class="wallet-amount">0.8542 BTC</div>
                        <div class="wallet-usd">$36,942.50</div>
                    </div>
                </div>
                <div class="wallet-item">
                    <div class="wallet-icon eth">Ξ</div>
                    <div class="wallet-info">
                        <div class="wallet-name">Ethereum</div>
                        <div class="wallet-address">0x742d35Cc6634C0532925a3b844Bc9e7595f...</div>
                    </div>
                    <div class="wallet-balance">
                        <div class="wallet-amount">12.45 ETH</div>
                        <div class="wallet-usd">$28,442.25</div>
                    </div>
                </div>
                <div class="wallet-item">
                    <div class="wallet-icon sol">◎</div>
                    <div class="wallet-info">
                        <div class="wallet-name">Solana</div>
                        <div class="wallet-address">7EcDhSYGxXyscszYEp35KHN8vvw3svAuLK...</div>
                    </div>
                    <div class="wallet-balance">
                        <div class="wallet-amount">39.45 SOL</div>
                        <div class="wallet-usd">$3,869.57</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="margin-bottom: 32px;">
        <div class="card-header">
            <h2 class="card-title">Transaction History</h2>
        </div>
        <div class="transaction-list">
            <div class="transaction-item">
                <div class="transaction-info">
                    <div class="transaction-type">Deposit BTC</div>
                    <div class="transaction-date">Today, 2:45 PM</div>
                </div>
                <div class="transaction-amount">
                    <div class="transaction-value positive">+0.0567 BTC</div>
                    <span class="transaction-status completed">Completed</span>
                </div>
            </div>
            <div class="transaction-item">
                <div class="transaction-info">
                    <div class="transaction-type">Withdraw ETH</div>
                    <div class="transaction-date">Yesterday, 11:20 AM</div>
                </div>
                <div class="transaction-amount">
                    <div class="transaction-value negative">-0.805 ETH</div>
                    <span class="transaction-status completed">Completed</span>
                </div>
            </div>
        </div>
    </div>

    <footer class="copyright">
        Copyright &copy; 2026 CryptoVault
    </footer>
{% endblock %}