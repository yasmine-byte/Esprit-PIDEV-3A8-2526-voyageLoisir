{% extends 'admin/base_admin.html.twig' %}

{% block title %}Liste des utilisateurs{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Gestion des utilisateurs</h1>
    <p>Gérez tous les comptes utilisateurs enregistrés dans le système</p>
</div>

{# ── Messages flash ── #}
{% for message in app.flashes('success') %}
    <div class="alert alert-success">✓ {{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger">✗ {{ message }}</div>
{% endfor %}

<div class="card">
    <div class="card-header">
        <h3>Utilisateurs ({{ users.getTotalItemCount() }})</h3>
        <a href="{{ path('add_user') }}" class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="16"/>
                <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            Ajouter un utilisateur
        </a>
    </div>
    <div class="card-body">
        {% if users|length > 0 %}
            <div class="table-responsive">
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>Identifiant</th>
                            <th>Nom</th>
                            <th>Prénom</th>
                            <th>Adresse email</th>
                            <th>Téléphone</th>
                            <th>Rôles</th>
                            <th>Statut</th>
                            <th>Date de création</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr>
                                <td>{{ user.id }}</td>
                                <td>
                                    <a href="{{ path('admin_user_profile', {'id': user.id}) }}"
                                       style="color: #d4845a; text-decoration: none; font-weight: 600;"
                                       title="Voir le profil de {{ user.prenom }} {{ user.nom }}">
                                        {{ user.nom }}
                                    </a>
                                </td>
                                <td>
                                    <a href="{{ path('admin_user_profile', {'id': user.id}) }}"
                                       style="color: #d4845a; text-decoration: none; font-weight: 600;"
                                       title="Voir le profil de {{ user.prenom }} {{ user.nom }}">
                                        {{ user.prenom }}
                                    </a>
                                </td>
                                <td>{{ user.email }}</td>
                                <td>{{ user.telephone ?: 'Non renseigné' }}</td>
                                <td>
                                    <div class="roles-container">
                                        {% if user.rolesCollection|length > 0 %}
                                            {% for role in user.rolesCollection %}
                                                <span class="role-badge">{{ role.name }}</span>
                                            {% endfor %}
                                        {% else %}
                                            <span class="no-roles">Aucun rôle</span>
                                        {% endif %}
                                    </div>
                                </td>
                                <td>
                                    {% if user.isActive == true %}
                                        <span class="status-badge active">Actif</span>
                                    {% else %}
                                        <span class="status-badge inactive">Inactif</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if user.createdAt %}
                                        {{ user.createdAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        Non définie
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="action-buttons">

                                        {# ── Bouton Modifier ── #}
                                        <a href="{{ path('admin_user_edit', {'id': user.id}) }}"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Modifier cet utilisateur">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                        </a>

                                        {# ── Bouton Activer / Désactiver ── #}
                                        <form method="POST" action="{{ path('admin_user_toggle', {'id': user.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_user_' ~ user.id) }}">
                                            <button type="submit"
                                                    class="btn btn-sm {{ user.isActive ? 'btn-outline-warning' : 'btn-outline-success' }}"
                                                    title="{{ user.isActive ? 'Désactiver ce compte' : 'Activer ce compte' }}">
                                                {% if user.isActive %}
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <circle cx="12" cy="12" r="10"/>
                                                        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                                                    </svg>
                                                {% else %}
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <circle cx="12" cy="12" r="10"/>
                                                        <polyline points="9 11 12 14 22 4"/>
                                                    </svg>
                                                {% endif %}
                                            </button>
                                        </form>

                                        {# ── Bouton Supprimer ── #}
                                        <form method="POST" action="{{ path('admin_user_delete', {'id': user.id}) }}"
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer le compte de {{ user.nom }} {{ user.prenom }} ? Cette action est irréversible.')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer cet utilisateur">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"/>
                                                    <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                                                </svg>
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {# ── Pagination ── #}
                <div class="pagination-wrapper">
                    {{ knp_pagination_render(users) }}
                </div>
            </div>
        {% else %}
            <div class="empty-state">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <h3>Aucun utilisateur trouvé</h3>
                <p>Il n'y a aucun utilisateur enregistré dans le système.</p>
                <a href="{{ path('add_user') }}" class="btn btn-primary">
                    Ajouter le premier utilisateur
                </a>
            </div>
        {% endif %}
    </div>
</div>

<style>
.alert { padding: 14px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; }
.alert-success { background: rgba(52, 211, 153, 0.1); border: 1px solid rgba(52, 211, 153, 0.3); color: var(--gain); }
.alert-danger { background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: var(--loss); }

.users-table { width: 100%; border-collapse: collapse; background: var(--bg-card); border-radius: 10px; overflow: hidden; }
.users-table th { background: var(--bg-secondary); padding: 16px; text-align: left; font-weight: 600; color: var(--text-primary); border-bottom: 1px solid var(--border); }
.users-table td { padding: 16px; border-bottom: 1px solid var(--border); color: var(--text-secondary); }
.users-table tr:hover { background: var(--bg-card-hover); }

.roles-container { display: flex; flex-wrap: wrap; gap: 4px; }
.role-badge { background: var(--accent-gradient); color: #1c1c1e; padding: 4px 8px; border-radius: 12px; font-size: 12px; font-weight: 600; }
.no-roles { color: var(--text-muted); font-style: italic; }

.status-badge { padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
.status-badge.active { background: var(--gain); color: white; }
.status-badge.inactive { background: var(--loss); color: white; }

.action-buttons { display: flex; gap: 8px; align-items: center; }

.card-header { display: flex; justify-content: space-between; align-items: center; padding: 20px; border-bottom: 1px solid var(--border); }
.card-header h3 { margin: 0; color: var(--text-primary); }

.empty-state { text-align: center; padding: 48px; color: var(--text-secondary); }
.empty-state svg { margin-bottom: 16px; color: var(--text-muted); }
.empty-state h3 { margin-bottom: 8px; color: var(--text-primary); }
.empty-state p { margin-bottom: 24px; }

.btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card); color: var(--text-primary); text-decoration: none; font-size: 14px; font-weight: 500; cursor: pointer; transition: all 0.2s ease; }
.btn:hover { background: var(--bg-card-hover); border-color: var(--accent-copper); }
.btn-primary { background: var(--accent-gradient); color: #1c1c1e; border: none; }
.btn-primary:hover { background: var(--accent-gradient-hover); }
.btn-secondary { border-color: var(--border); }
.btn-outline-primary { color: var(--accent-copper); border-color: var(--accent-copper); }
.btn-outline-primary:hover { background: var(--accent-copper); color: white; }
.btn-outline-danger { color: var(--loss); border-color: var(--loss); }
.btn-outline-danger:hover { background: var(--loss); color: white; }
.btn-outline-warning { color: #f59e0b; border-color: #f59e0b; }
.btn-outline-warning:hover { background: #f59e0b; color: white; }
.btn-outline-success { color: var(--gain); border-color: var(--gain); }
.btn-outline-success:hover { background: var(--gain); color: white; }
.btn-sm { padding: 6px 12px; font-size: 12px; }

form { margin: 0; }
.pagination-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 20px;
    padding: 10px 0;
}
.pagination-wrapper .pagination {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
}
.pagination-wrapper .page-item .page-link {
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-primary);
    text-decoration: none;
    font-size: 14px;
}
.pagination-wrapper .page-item.active .page-link {
    background: var(--accent-copper);
    color: #1c1c1e;
    border-color: var(--accent-copper);
}
.pagination-wrapper .page-item .page-link:hover {
    border-color: var(--accent-copper);
    color: var(--accent-copper);
}
</style>
{% endblock %}