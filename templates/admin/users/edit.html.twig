{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier Utilisateur{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Modifier l'utilisateur</h1>
    <p>Modifiez les informations de {{ user.nom }} {{ user.prenom }}</p>
</div>

<div class="card">
    <div class="card-header">
        <h3>Informations de l'utilisateur</h3>
        <a href="{{ path('admin_users_list') }}" class="btn btn-secondary">← Retour à la liste</a>
    </div>
    <div class="card-body">

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">✔ {{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">✗ {{ message }}</div>
        {% endfor %}

        {% if globalError is defined and globalError %}
            <div class="alert alert-danger"><strong>{{ globalError }}</strong></div>
        {% endif %}

        <form method="POST" action="{{ path('admin_user_edit', {'id': user.id}) }}" class="user-form" novalidate>

            <div class="form-row">
                <div class="form-group">
                    <label for="nom">Nom *</label>
                    <input type="text" id="nom" name="nom"
                           class="form-control {% if fieldErrors is defined and fieldErrors.nom is defined %}input-error{% endif %}"
                           value="{{ user.nom }}" maxlength="50">
                    {% if fieldErrors is defined and fieldErrors.nom is defined %}
                        <span class="field-error-msg">{{ fieldErrors.nom }}</span>
                    {% endif %}
                </div>
                <div class="form-group">
                    <label for="prenom">Prénom *</label>
                    <input type="text" id="prenom" name="prenom"
                           class="form-control {% if fieldErrors is defined and fieldErrors.prenom is defined %}input-error{% endif %}"
                           value="{{ user.prenom }}" maxlength="50">
                    {% if fieldErrors is defined and fieldErrors.prenom is defined %}
                        <span class="field-error-msg">{{ fieldErrors.prenom }}</span>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email *</label>
                <input type="text" id="email" name="email"
                       class="form-control {% if fieldErrors is defined and fieldErrors.email is defined %}input-error{% endif %}"
                       value="{{ user.email }}" maxlength="100">
                {% if fieldErrors is defined and fieldErrors.email is defined %}
                    <span class="field-error-msg">{{ fieldErrors.email }}</span>
                {% endif %}
            </div>

            <div class="form-group">
                <label for="telephone">Téléphone *</label>
                <input type="text" id="telephone" name="telephone"
                       class="form-control {% if fieldErrors is defined and fieldErrors.telephone is defined %}input-error{% endif %}"
                       value="{{ user.telephone }}" maxlength="8">
                {% if fieldErrors is defined and fieldErrors.telephone is defined %}
                    <span class="field-error-msg">{{ fieldErrors.telephone }}</span>
                {% endif %}
            </div>

            <div class="form-group">
                <label for="password">Nouveau mot de passe</label>
                <input type="password" id="password" name="password"
                       class="form-control {% if fieldErrors is defined and fieldErrors.password is defined %}input-error{% endif %}"
                       placeholder="Laisser vide pour ne pas changer">
                <small class="form-help">Min. 6 car. : Majuscule, minuscule, chiffre et caractère spécial — laisser vide pour conserver l'actuel</small>
                {% if fieldErrors is defined and fieldErrors.password is defined %}
                    <span class="field-error-msg">{{ fieldErrors.password }}</span>
                {% endif %}
            </div>

            <div class="form-group">
                <label>Rôles</label>
                <div class="checkbox-group">
                    {% for role in roles %}
                        <label class="checkbox-label">
                            <input type="checkbox" name="roles[]" value="{{ role.id }}"
                                   class="checkbox-input"
                                   {% for userRole in user.rolesCollection %}
                                       {% if userRole.id == role.id %}checked{% endif %}
                                   {% endfor %}>
                            <span class="checkbox-text">{{ role.name }}</span>
                        </label>
                    {% endfor %}
                </div>
            </div>

            <div class="form-group">
                <label class="checkbox-label">
                    <input type="checkbox" name="is_active" class="checkbox-input"
                           {{ user.isActive ? 'checked' : '' }}>
                    <span class="checkbox-text">Compte actif</span>
                </label>
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_users_list') }}" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
            </div>
        </form>
    </div>
</div>*

<style>
.user-form { max-width: 800px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
.form-group { margin-bottom: 20px; }
.form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-primary); }
.form-control { width: 100%; padding: 12px 16px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card); color: var(--text-primary); font-size: 15px; box-sizing: border-box; }
.form-control:focus { outline: none; border-color: var(--accent-copper); }
.input-error { border-color: #ef4444 !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.1); }
.field-error-msg { display: block; color: #ef4444; font-size: 12px; margin-top: 5px; }
.form-help { display: block; margin-top: 4px; font-size: 12px; color: var(--text-muted); }
.checkbox-group { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; }
.checkbox-label { display: flex; align-items: center; gap: 8px; cursor: pointer; color: var(--text-primary); }
.checkbox-input { width: 18px; height: 18px; accent-color: var(--accent-copper); }
.form-actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 30px; padding-top: 20px; border-top: 1px solid var(--border); }
.alert { padding: 16px; border-radius: 8px; margin-bottom: 20px; }
.alert-success { background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.3); color: #34d399; }
.alert-danger { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }
.card-header { display: flex; justify-content: space-between; align-items: center; padding: 20px; border-bottom: 1px solid var(--border); }
</style>
{% endblock %}
