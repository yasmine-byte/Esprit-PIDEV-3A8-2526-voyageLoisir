{% extends 'admin/base_admin.html.twig' %}

{% block title %}Ajouter un utilisateur{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Ajouter un utilisateur</h1>
    <p>Créez un nouveau compte utilisateur dans le système</p>
</div>

<div class="card">
    <div class="card-header">
        <h3>Informations de l'utilisateur</h3>
        <a href="{{ path('admin_users_list') }}" class="btn btn-secondary">
            ← Retour à la liste
        </a>
    </div>
    <div class="card-body">

        {# ── Message de succès inline ── #}
        {% if successMsg is defined and successMsg %}
            <div class="alert alert-success">
                <strong>✓ Succès —</strong> {{ successMsg }}
                <a href="{{ path('admin_users_list') }}" class="alert-link">Voir la liste des utilisateurs</a>
            </div>
        {% endif %}

        {# ── Bloc d'erreur global ── #}
        {% if globalError is defined and globalError %}
            <div class="alert alert-danger">
                <strong>{{ globalError }}</strong>
            </div>
        {% endif %}

        <form method="POST" action="{{ path('add_user') }}" class="user-form" id="addUserForm">

            <div class="form-row">

                {# ── Nom ── #}
                <div class="form-group">
                    <label for="nom">Nom *</label>
                    <input type="text" id="nom" name="nom"
                           class="form-control {% if fieldErrors is defined and fieldErrors.nom is defined %}input-error{% endif %}"
                           value="{{ formData.nom ?? '' }}"
                           placeholder="Ex : Dupont"
                           maxlength="50">
                    {% if fieldErrors is defined and fieldErrors.nom is defined %}
                        <span class="field-error-msg">{{ fieldErrors.nom }}</span>
                    {% endif %}
                </div>

                {# ── Prénom ── #}
                <div class="form-group">
                    <label for="prenom">Prénom *</label>
                    <input type="text" id="prenom" name="prenom"
                           class="form-control {% if fieldErrors is defined and fieldErrors.prenom is defined %}input-error{% endif %}"
                           value="{{ formData.prenom ?? '' }}"
                           placeholder="Ex : Jean"
                           maxlength="50">
                    {% if fieldErrors is defined and fieldErrors.prenom is defined %}
                        <span class="field-error-msg">{{ fieldErrors.prenom }}</span>
                    {% endif %}
                </div>

            </div>

            {# ── Email ── #}
            <div class="form-group">
                <label for="email">Adresse email *</label>
                <input type="email" id="email" name="email"
                       class="form-control {% if fieldErrors is defined and fieldErrors.email is defined %}input-error{% endif %}"
                       value="{{ formData.email ?? '' }}"
                       placeholder="jean.dupont@email.com"
                       maxlength="100">
                {% if fieldErrors is defined and fieldErrors.email is defined %}
                    <span class="field-error-msg">{{ fieldErrors.email }}</span>
                {% endif %}
            </div>

            {# ── Téléphone ── #}
            <div class="form-group">
                <label for="telephone">Numéro de téléphone *</label>
                <input type="tel" id="telephone" name="telephone"
                       class="form-control {% if fieldErrors is defined and fieldErrors.telephone is defined %}input-error{% endif %}"
                       value="{{ formData.telephone ?? '' }}"
                       placeholder="Ex : 12345678"
                       maxlength="8">
                {% if fieldErrors is defined and fieldErrors.telephone is defined %}
                    <span class="field-error-msg">{{ fieldErrors.telephone }}</span>
                {% endif %}
            </div>

            <div class="form-row">

                {# ── Mot de passe ── #}
                <div class="form-group">
                    <label for="password">Mot de passe *</label>
                    <input type="password" id="password" name="password"
                           class="form-control {% if fieldErrors is defined and fieldErrors.password is defined %}input-error{% endif %}"
                           placeholder="Minimum 8 caractères"
                           maxlength="128">
                    {% if fieldErrors is defined and fieldErrors.password is defined %}
                        <span class="field-error-msg">{{ fieldErrors.password }}</span>
                    {% endif %}
                </div>

                {# ── Confirmation mot de passe ── #}
                <div class="form-group">
                    <label for="confirm_password">Confirmer le mot de passe *</label>
                    <input type="password" id="confirm_password" name="confirm_password"
                           class="form-control {% if fieldErrors is defined and fieldErrors.confirm_password is defined %}input-error{% endif %}"
                           placeholder="Confirmez le mot de passe"
                           maxlength="128">
                    {% if fieldErrors is defined and fieldErrors.confirm_password is defined %}
                        <span class="field-error-msg">{{ fieldErrors.confirm_password }}</span>
                    {% endif %}
                </div>

            </div>

            {# ── Rôles ── #}
            <div class="form-group">
                <label>Rôles *</label>
                <div class="checkbox-group">
                    {% for role in roles %}
                        <label class="checkbox-label">
                            <input type="checkbox" name="roles[]" value="{{ role.id }}"
                                   class="checkbox-input" id="role_{{ role.id }}"
                                   {% if loop.first %}checked{% endif %}>
                            <span class="checkbox-text">{{ role.name }}</span>
                        </label>
                    {% endfor %}
                </div>
                {% if fieldErrors is defined and fieldErrors.roles is defined %}
                    <span class="field-error-msg">{{ fieldErrors.roles }}</span>
                {% endif %}
            </div>

            {# ── Statut du compte ── #}
            <div class="form-group">
                <label class="checkbox-label">
                    <input type="checkbox" name="is_active" class="checkbox-input" id="isActive" checked>
                    <span class="checkbox-text">Compte actif</span>
                </label>
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_users_list') }}" class="btn btn-secondary">
                    Annuler
                </a>
                <button type="submit" class="btn btn-primary">
                    ➕ Créer l'utilisateur
                </button>
            </div>

        </form>
    </div>
</div>

<style>
.user-form { max-width: 800px; }

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.form-group { margin-bottom: 20px; }

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-primary);
}

.form-control {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-primary);
    font-size: 15px;
    transition: all 0.2s ease;
    box-sizing: border-box;
}

.form-control:focus {
    outline: none;
    border-color: var(--accent-copper);
    box-shadow: 0 0 0 3px rgba(255, 159, 67, 0.1);
}

.input-error {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
}

.field-error-msg {
    display: block;
    color: #ef4444;
    font-size: 12px;
    margin-top: 5px;
    padding-left: 2px;
}

.checkbox-group {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
}

.checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    color: var(--text-primary);
}

.checkbox-input {
    width: 18px;
    height: 18px;
    accent-color: var(--accent-copper);
}

.checkbox-text { font-size: 14px; }

.form-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
}

.alert {
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 14px;
}

.alert-success {
    background: rgba(52, 211, 153, 0.1);
    border: 1px solid rgba(52, 211, 153, 0.3);
    color: var(--gain);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.alert-link {
    color: var(--gain);
    text-decoration: underline;
    margin-left: 8px;
}

.alert-danger {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: var(--loss);
}

@media (max-width: 768px) {
    .form-row { grid-template-columns: 1fr; }
    .form-actions { flex-direction: column; }
    .btn { width: 100%; justify-content: center; }
}
</style>
{% endblock %}
