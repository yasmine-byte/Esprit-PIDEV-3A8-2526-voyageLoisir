{% extends 'admin/base_admin.html.twig' %}

{% block title %}Statistiques des Avis{% endblock %}

{% block admin_content %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row mb-4">
    <div class="col-12">
        <h2 class="text-light">Statistiques des Avis</h2>
        <p class="text-muted">Analyse simple des retours clients.</p>
    </div>
</div>

<!-- LIGNE 1 : KPI -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-dark text-light border-secondary mb-3">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Total des Avis</h5>
                <h2 class="fw-bold">{{ stats.total|default(0) }}</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-light border-secondary mb-3">
            <div class="card-body text-center">
                <h5 class="card-title text-muted">Note Moyenne</h5>
                <h2 class="text-warning fw-bold">{{ stats.moy_etoiles|default(0)|number_format(1) }} / 5</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-dark text-light border-success mb-3">
            <div class="card-body text-center">
                <h5 class="card-title text-success">Taux de Validation</h5>
                <h2 class="text-success fw-bold">{{ stats.total > 0 ? (stats.valides / stats.total * 100)|round : 0 }} %</h2>
            </div>
        </div>
    </div>
</div>

<!-- LIGNE 2 : Charts -->
<div class="row mb-4 g-3">
    <div class="col-md-6">
        <div class="card bg-dark text-light border-secondary h-100">
            <div class="card-header border-secondary">
                Répartition des Statuts
            </div>
            <div class="card-body" style="height: 300px;">
                <canvas id="chartStatuts"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card bg-dark text-light border-secondary h-100">
            <div class="card-header border-secondary">
                Évolution sur 7 Jours
            </div>
            <div class="card-body" style="height: 300px;">
                <canvas id="chartEvol"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card bg-dark text-light border-secondary">
            <div class="card-header border-secondary">
                Distribution des Étoiles
            </div>
            <div class="card-body" style="height: 300px;">
                <canvas id="chartEtoiles"></canvas>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        Chart.defaults.color = 'rgba(255, 255, 255, 0.7)';

        const ctx1 = document.getElementById('chartStatuts').getContext('2d');
        new Chart(ctx1, {
            type: 'pie',
            data: {
                labels: ['En attente', 'Validé', 'Rejeté'],
                datasets: [{
                    data: [{{ stats.en_attente|default(0) }}, {{ stats.valides|default(0) }}, {{ stats.rejetes|default(0) }}],
                    backgroundColor: ['#ffc107', '#28a745', '#dc3545']
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

        const ctx2 = document.getElementById('chartEvol').getContext('2d');
        new Chart(ctx2, {
            type: 'line',
            data: {
                labels: {{ avisParJour.labels | default('[]') | json_encode | raw }},
                datasets: [{
                    label: 'Nombre d\'avis',
                    data: {{ avisParJour.data | default('[]') | json_encode | raw }},
                    borderColor: '#4a9eff',
                    backgroundColor: 'rgba(74, 158, 255, 0.2)',
                    fill: true
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });

        const ctx3 = document.getElementById('chartEtoiles').getContext('2d');
        new Chart(ctx3, {
            type: 'bar',
            data: {
                labels: ['1 ★', '2 ★', '3 ★', '4 ★', '5 ★'],
                datasets: [{
                    label: 'Avis',
                    data: {{ etoilesDistrib | default('[]') | json_encode | raw }},
                    backgroundColor: ['#dc3545', '#fd7e14', '#ffc107', '#20c997', '#28a745']
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { 
                    x: { grid: { color: 'rgba(255,255,255,0.1)' } },
                    y: { beginAtZero: true, stepSize: 1, grid: { color: 'rgba(255,255,255,0.1)' } } 
                }
            }
        });
    });
</script>
{% endblock %}
