{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Avis{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <h2>Gestion des Avis</h2>
    <hr>
    
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="mb-4">
        <form method="GET" class="row g-2">
            <div class="col-md-5">
                <input type="text" name="recherche" class="form-control" placeholder="Rechercher par contenu ou ID" value="{{ currentRecherche|default('') }}">
            </div>
            <div class="col-md-4">
                <select name="statut" class="form-select">
                    <option value="">Tous les statuts</option>
                    <option value="En attente" {{ currentStatut == 'En attente' ? 'selected' : '' }}>En attente</option>
                    <option value="Validé" {{ currentStatut == 'Validé' ? 'selected' : '' }}>Validé</option>
                    <option value="Rejeté" {{ currentStatut == 'Rejeté' ? 'selected' : '' }}>Rejeté</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary">Rechercher</button>
                <a href="{{ path('admin_avis_index') }}" class="btn btn-secondary">Réinitialiser</a>
            </div>
        </form>
    </div>

    <table class="table table-striped table-bordered text-center align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Auteur</th>
                <th>Catégorie</th>
                <th>Note</th>
                <th>Contenu</th>
                <th>Date</th>
                <th>Statut</th>
                <th>Réponse Admin</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for avis in avis_list %}
                <tr>
                    <td>{{ avis.id }}</td>
                    <td>{{ avis.userId }}</td>
                    <td>{{ avis.type ? avis.type.nom : '-' }}</td>
                    <td>{{ avis.nbEtoiles }} ★</td>
                    <td>{{ avis.contenu }}</td>
                    <td>{{ avis.dateAvis ? avis.dateAvis|date('d/m/Y') : '-' }}</td>
                    <td>{{ avis.statut }}</td>
                    <td>{{ avis.reponse ?: '-' }}</td>
                    <td>
                        {% if avis.statut != 'Validé' %}
                            <form method="POST" action="{{ path('admin_avis_valider', {'id': avis.id}) }}" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-success">Valider</button>
                            </form>
                        {% endif %}
                        {% if avis.statut != 'Rejeté' %}
                            <form method="POST" action="{{ path('admin_avis_rejeter', {'id': avis.id}) }}" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-warning">Rejeter</button>
                            </form>
                        {% endif %}
                        <button type="button" class="btn btn-sm btn-info text-white" data-bs-toggle="modal" data-bs-target="#modalAvis{{ avis.id }}">Répondre</button>
                        <form method="POST" action="{{ path('admin_avis_delete', {'id': avis.id}) }}" class="d-inline" onsubmit="return confirm('Confirmer la suppression ?');">
                            <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                        </form>

                        <!-- Modal Réponse -->
                        <div class="modal fade text-start" id="modalAvis{{ avis.id }}" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Répondre à l'avis #{{ avis.id }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="POST" action="{{ path('admin_avis_repondre', {'id': avis.id}) }}">
                                        <div class="modal-body">
                                            <p><strong>Avis :</strong> {{ avis.contenu }}</p>
                                            <div class="form-group">
                                                <label>Votre réponse :</label>
                                                <textarea class="form-control" name="reponse" rows="3" required>{{ avis.reponse }}</textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                                            <button type="submit" class="btn btn-primary">Envoyer</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="9">Aucun avis trouvé.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
