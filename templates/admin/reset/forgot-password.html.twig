{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - ViaNoVa{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets_back/css/css/templatemo-crypto-style.css') }}">
    <link rel="stylesheet" href="{{ asset('assets_back/css/css/templatemo-crypto-login.css') }}">
    <style>
        .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; }
        .alert-danger { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }
        .alert-success { background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.3); color: #34d399; }
        .field-error-msg { display: block; color: #ef4444; font-size: 12px; margin-top: 5px; }
        .input-error { border-color: #ef4444 !important; }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-branding">
        <div class="branding-content">
            <div class="branding-logo">VN</div>
            <h1 class="branding-title">VIANOVA</h1>
            <p class="branding-subtitle">Réinitialisation du mot de passe</p>
        </div>
    </div>

    <div class="auth-form-container">
        <div class="auth-form-wrapper">
            <div class="form-header">
                <h1>Mot de passe oublié</h1>
                <p>Entrez votre email pour recevoir un lien de réinitialisation</p>
            </div>

            {% if successMsg %}
                <div class="alert alert-success">✔ {{ successMsg }}</div>
            {% endif %}

            {% if errorMsg %}
                <div class="alert alert-danger">✗ {{ errorMsg }}</div>
            {% endif %}

            {% if not successMsg %}
                <form method="POST" action="{{ path('forgot_password') }}" novalidate>
                    <div class="form-group">
                        <label class="form-label">Adresse email *</label>
                        <div class="form-input-wrapper">
                            <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            <input type="text" class="form-input" name="email"
                                   placeholder="Votre adresse email">
                        </div>
                    </div>

                    <button type="submit" class="submit-btn">
                        Envoyer le lien de réinitialisation
                    </button>
                </form>
            {% endif %}

            <p style="text-align:center; margin-top:20px; font-size:14px; color:var(--text-muted);">
                <a href="{{ path('admin_login') }}" style="color:var(--accent-copper);">
                    ← Retour à la connexion
                </a>
            </p>
        </div>
    </div>
{% endblock %}
