{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe - ViaNoVa{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets_back/css/css/templatemo-crypto-style.css') }}">
    <link rel="stylesheet" href="{{ asset('assets_back/css/css/templatemo-crypto-login.css') }}">
    <style>
        .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; }
        .alert-danger { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }
        .field-error-msg { display: block; color: #ef4444; font-size: 12px; margin-top: 5px; }
        .input-error { border-color: #ef4444 !important; }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-branding">
        <div class="branding-content">
            <div class="branding-logo">VN</div>
            <h1 class="branding-title">VIANOVA</h1>
            <p class="branding-subtitle">Nouveau mot de passe</p>
        </div>
    </div>

    <div class="auth-form-container">
        <div class="auth-form-wrapper">
            <div class="form-header">
                <h1>Nouveau mot de passe</h1>
                <p>Choisissez un mot de passe sécurisé</p>
            </div>

            {% if globalError %}
                <div class="alert alert-danger">{{ globalError }}</div>
            {% endif %}

            <form method="POST" action="{{ path('reset_password', {'token': token}) }}" novalidate>

                <div class="form-group">
                    <label class="form-label">Nouveau mot de passe *</label>
                    <div class="form-input-wrapper {% if fieldErrors.password is defined %}has-error{% endif %}">
                        <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                        <input type="password"
                               class="form-input {% if fieldErrors.password is defined %}input-error{% endif %}"
                               id="password" name="password"
                               placeholder="Min. 6 car. : Aa1@...">
                        <button type="button" class="password-toggle" data-target="password">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    {% if fieldErrors.password is defined %}
                        <span class="field-error-msg">{{ fieldErrors.password }}</span>
                    {% endif %}
                    <small style="color:var(--text-muted); font-size:12px; margin-top:4px; display:block;">
                        Majuscule, minuscule, chiffre et caractère spécial requis
                    </small>
                </div>

                <div class="form-group">
                    <label class="form-label">Confirmer le mot de passe *</label>
                    <div class="form-input-wrapper {% if fieldErrors.confirm_password is defined %}has-error{% endif %}">
                        <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                        <input type="password"
                               class="form-input {% if fieldErrors.confirm_password is defined %}input-error{% endif %}"
                               id="confirm_password" name="confirm_password"
                               placeholder="Confirmez votre mot de passe">
                        <button type="button" class="password-toggle" data-target="confirm_password">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    {% if fieldErrors.confirm_password is defined %}
                        <span class="field-error-msg">{{ fieldErrors.confirm_password }}</span>
                    {% endif %}
                </div>

                <button type="submit" class="submit-btn">
                    Réinitialiser le mot de passe
                </button>
            </form>

            <p style="text-align:center; margin-top:20px; font-size:14px; color:var(--text-muted);">
                <a href="{{ path('admin_login') }}" style="color:var(--accent-copper);">
                    ← Retour à la connexion
                </a>
            </p>
        </div>
    </div>
{% endblock %}
