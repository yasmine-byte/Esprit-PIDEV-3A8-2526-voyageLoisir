{% extends 'admin/base_admin.html.twig' %}
{% block title %}Gestion Chambres{% endblock %}
{% block admin_content %}

    <div class="page-header">
        <h1>Gestion des Chambres</h1>
        <p>{{ chambres|length }} chambre(s) enregistrée(s)</p>
    </div>

    <div style="margin-bottom:20px;">
        <a href="{{ path('app_chambre_new') }}" style="background:var(--accent-gradient); color:#1c1c1e; padding:10px 20px; border-radius:8px; text-decoration:none; font-weight:600; display:inline-flex; align-items:center; gap:8px;">
            + Nouvelle Chambre
        </a>
    </div>

    <div class="card">
        <table class="market-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Hébergement</th>
                    <th>Numéro</th>
                    <th>Type</th>
                    <th>Prix/Nuit</th>
                    <th>Capacité</th>
                    <th>Équipements</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for chambre in chambres %}
                <tr>
                    <td>{{ chambre.id }}</td>
                    <td style="max-width:150px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                        {{ chambre.hebergement ? chambre.hebergement.description|slice(0,25) ~ '...' : 'N/A' }}
                    </td>
                    <td><strong>{{ chambre.numero }}</strong></td>
                    <td>
                        <span style="background:var(--bg-secondary); color:var(--accent-copper); padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600;">
                            {{ chambre.typeChambre }}
                        </span>
                    </td>
                    <td class="price-cell">{{ chambre.prixNuit }} TND</td>
                    <td>{{ chambre.capacite }} pers.</td>
                    <td style="max-width:150px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                        {{ chambre.equipements }}
                    </td>
                    <td>
                        <div style="display:flex; gap:8px;">
                            <a href="{{ path('app_chambre_show', {'id': chambre.id}) }}" style="background:#3b82f620; color:#3b82f6; padding:5px 12px; border-radius:6px; text-decoration:none; font-size:13px; font-weight:500;">Voir</a>
                            <a href="{{ path('app_chambre_edit', {'id': chambre.id}) }}" style="background:#f59e0b20; color:#f59e0b; padding:5px 12px; border-radius:6px; text-decoration:none; font-size:13px; font-weight:500;">Modifier</a>
                            {{ include('chambre/_delete_form.html.twig') }}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" style="text-align:center; padding:40px; color:var(--text-secondary);">
                        Aucune chambre trouvée
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <footer class="copyright">Copyright &copy; 2026 Voyage</footer>

{% endblock %}
