{% extends 'admin/base_admin.html.twig' %}
{% block title %}Modifier Chambre{% endblock %}
{% block admin_content %}

    <div class="page-header">
        <h1>Modifier Chambre #{{ chambre.id }}</h1>
        <p><a href="{{ path('app_chambre_index') }}" style="color:var(--accent-copper);">← Retour à la liste</a></p>
    </div>

    <div class="card" style="max-width:700px;">
        {{ include('chambre/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>

    <div style="margin-top:16px; max-width:700px;">
        {{ include('chambre/_delete_form.html.twig') }}
    </div>

    <footer class="copyright">Copyright &copy; 2026 Voyage</footer>

{% endblock %}
