{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
    <div>
        <label class="form-label">Type de Transport *</label>
        {{ form_widget(form.type_transport, {'attr': {'class': 'form-select'}}) }}
        {% for err in form.type_transport.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Voyage *</label>
        {{ form_widget(form.voyage, {'attr': {'class': 'form-select'}}) }}
        {% for err in form.voyage.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:3px">{{ err.message }}</small>
        {% endfor %}
    </div>
</div>

<button type="submit" class="btn primary">Sauvegarder</button>
{{ form_end(form) }}
