{{ form_start(form, {'attr': {'id': 'form-transport'}}) }}

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
    <div>
        <label class="form-label">Type de Transport *</label>
        {{ form_widget(form.type_transport, {'attr': {'class': 'form-select', 'id': 'f-type', 'onchange': 'lvType(this)'}}) }}
        <small id="msg-type" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.type_transport.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div>
        <label class="form-label">Destination *</label>
        {{ form_widget(form.destination, {'attr': {'class': 'form-select', 'id': 'f-dest', 'onchange': 'lvDest(this)'}}) }}
        <small id="msg-dest" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.destination.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px">{{ err.message }}</small>
        {% endfor %}
    </div>
</div>

<div id="info-transport" style="display:none;margin-bottom:16px;padding:10px 14px;border-radius:8px;font-size:13px;font-weight:500;border-left:4px solid #888"></div>

<button type="submit" class="btn primary">Sauvegarder</button>
{{ form_end(form) }}

<script>
var INFO = {
    "Avion"  : { txt: "Ideal pour les longues distances.", bg: "#1a2a3a", border: "#378ADD" },
    "Bus"    : { txt: "Option economique pour trajets regionaux.", bg: "#1a2e1a", border: "#639922" },
    "Voiture": { txt: "Flexible pour petits groupes.", bg: "#2e2a1a", border: "#BA7517" },
    "Train"  : { txt: "Confortable pour moyennes distances.", bg: "#2a1a2e", border: "#7F77DD" }
};

function ok(id, msg) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "#1D9E75";
    if (m)  { m.style.color = "#1D9E75"; m.textContent = "OK - " + msg; }
}
function er(id, msg) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "#E24B4A";
    if (m)  { m.style.color = "#E24B4A"; m.textContent = "Erreur - " + msg; }
}
function clr(id) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "";
    if (m)  m.textContent = "";
}

function lvType(el) {
    var info = document.getElementById("info-transport");
    if (!el.value) {
        er("f-type", "Veuillez choisir un type de transport");
        info.style.display = "none";
        return;
    }
    var i = INFO[el.value];
    if (i) {
        info.style.display     = "block";
        info.style.background  = i.bg;
        info.style.borderColor = i.border;
        info.textContent       = el.value + " - " + i.txt;
    }
    ok("f-type", el.value + " selectionne");
}

function lvDest(el) {
    if (!el.value) {
        er("f-dest", "La destination est obligatoire");
        return;
    }
    ok("f-dest", "Destination selectionnee");
}

document.getElementById("form-transport").addEventListener("submit", function(e) {
    var valide = true;

    var type = document.getElementById("f-type");
    if (!type.value) {
        er("f-type", "Le type de transport est obligatoire");
        valide = false;
    }

    var dest = document.getElementById("f-dest");
    if (!dest.value) {
        er("f-dest", "La destination est obligatoire");
        valide = false;
    }

    if (!valide) {
        e.preventDefault();
        window.scrollTo(0, 0);
    }
});
</script>
