{% extends 'admin/base_admin.html.twig' %}
{% block title %}Transports{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Transports</h1>
    <p>Gérer tous les transports</p>
</div>

{# ===== FILTRES ===== #}
<div class="card" style="margin-bottom:20px">
    <div class="card-header">
        <h3 class="card-title">Filtres & Recherche</h3>
    </div>
    <form method="GET" action="{{ path('app_transport_index') }}"
          style="display:flex;flex-wrap:wrap;gap:12px;padding:16px;align-items:flex-end">

        <div style="flex:1;min-width:200px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">
                Recherche (ID transport, type, ID voyage)
            </label>
            <input type="text" name="search" value="{{ search }}"
                   placeholder="Ex: Paris, 3, France..."
                   style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
        </div>

        <div style="min-width:150px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Type Transport</label>
            <select name="type"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="">Tous</option>
                <option value="Avion"   {{ type == 'Avion'   ? 'selected' : '' }}>✈ Avion</option>
                <option value="Bus"     {{ type == 'Bus'     ? 'selected' : '' }}>🚌 Bus</option>
                <option value="Voiture" {{ type == 'Voiture' ? 'selected' : '' }}>🚗 Voiture</option>
                <option value="Train"   {{ type == 'Train'   ? 'selected' : '' }}>🚆 Train</option>
            </select>
        </div>

        <div style="min-width:160px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Trier par</label>
            <select name="tri"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="t.id"             {{ tri == 't.id'             ? 'selected' : '' }}>ID Transport</option>
                <option value="t.type_transport" {{ tri == 't.type_transport' ? 'selected' : '' }}>Type Transport</option>
                <option value="d.id"             {{ tri == 'd.id'             ? 'selected' : '' }}>ID Destination</option>
                <option value="d.nom"            {{ tri == 'd.nom'            ? 'selected' : '' }}>Nom Destination</option>
                <option value="d.pays"           {{ tri == 'd.pays'           ? 'selected' : '' }}>Pays Destination</option>
            </select>
        </div>

        <div style="min-width:120px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Ordre</label>
            <select name="ordre"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="ASC"  {{ ordre == 'ASC'  ? 'selected' : '' }}>▲ Croissant</option>
                <option value="DESC" {{ ordre == 'DESC' ? 'selected' : '' }}>▼ Décroissant</option>
            </select>
        </div>

        <div style="display:flex;gap:8px">
            <button type="submit"
                    style="padding:8px 18px;border-radius:6px;border:none;background:#6c63ff;color:#fff;font-size:13px;cursor:pointer;font-weight:600">
                🔍 Filtrer
            </button>
            <a href="{{ path('app_transport_index') }}"
               style="padding:8px 18px;border-radius:6px;border:1px solid #555;color:#aaa;font-size:13px;text-decoration:none;display:flex;align-items:center">
                ✕ Reset
            </a>
        </div>
    </form>
</div>

{# ===== TABLEAU ===== #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Liste des Transports
            <span style="font-size:13px;color:#888;font-weight:normal;margin-left:8px">
                ({{ transports|length }} résultat{{ transports|length > 1 ? 's' : '' }})
            </span>
        </h3>
        <a href="{{ path('app_transport_new') }}" class="action-btn primary">+ Ajouter</a>
    </div>

    {% set params = {search: search, type: type} %}

    <style>
        .tp-table { width:100%; border-collapse:separate; border-spacing:0; }
        .tp-table thead tr { background:#12122a; }
        .tp-table thead th {
            padding:12px 16px; font-size:11px; font-weight:700;
            letter-spacing:.08em; text-transform:uppercase;
            color:#6b7280; border-bottom:1px solid #1e1e3a; white-space:nowrap;
        }
        .tp-table thead th a { color:inherit; text-decoration:none; }
        .tp-table thead th a:hover { color:#e0e0e0; }
        .tp-table tbody tr { transition:background .15s; border-bottom:1px solid #1a1a30; }
        .tp-table tbody tr:hover { background:#14142a; }
        .tp-table tbody td { padding:13px 16px; vertical-align:middle; }

        .tpbadge-id    { background:#1e1e2a; color:#818cf8; border-radius:6px; padding:3px 9px; font-size:12px; font-weight:700; }
        .tpbadge-voy   { background:#1e1e2a; color:#fb923c; border:1px solid #2e2018; border-radius:6px; padding:3px 9px; font-size:12px; font-weight:600; }
        .tpbadge-Avion   { background:#0e1e30; color:#7dd3fc; border:1px solid #1a3050; border-radius:6px; padding:4px 10px; font-size:12px; font-weight:600; }
        .tpbadge-Bus     { background:#1a2e0e; color:#86efac; border:1px solid #1e4018; border-radius:6px; padding:4px 10px; font-size:12px; font-weight:600; }
        .tpbadge-Voiture { background:#1e1e2a; color:#94a3b8; border:1px solid #2a2a3a; border-radius:6px; padding:4px 10px; font-size:12px; font-weight:600; }
        .tpbadge-Train   { background:#2e1e06; color:#fbbf24; border:1px solid #4a3010; border-radius:6px; padding:4px 10px; font-size:12px; font-weight:600; }

        .tpact { display:flex; gap:6px; align-items:center; }
        .tpbtn {
            display:inline-flex; align-items:center; gap:4px;
            padding:5px 11px; border-radius:6px; font-size:12px; font-weight:500;
            text-decoration:none; border:1px solid #2a2a3a; cursor:pointer;
            background:#1a1a28; color:#94a3b8;
            transition:color .15s, border-color .15s; white-space:nowrap;
        }
        .tpbtn:hover { color:#e0e0e0; border-color:#444; }
        .tpbtn-edit { color:#818cf8; border-color:#2e2e50; }
        .tpbtn-del  { color:#f87171; border-color:#3d1f1f; }
        .tpbtn-del form, .tpbtn-del button {
            margin:0; padding:0; background:none; border:none;
            color:inherit; font:inherit; font-size:12px; font-weight:500;
            cursor:pointer; display:inline;
        }
    </style>

    {% set tp_icons = {'Avion': '✈', 'Bus': '🚌', 'Voiture': '🚗', 'Train': '🚆'} %}

    <div style="overflow-x:auto">
    <table class="tp-table">
        <thead>
            <tr>
                <th><a href="{{ path('app_transport_index', params|merge({tri: 't.id', ordre: (tri == 't.id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">ID {% if tri == 't.id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th><a href="{{ path('app_transport_index', params|merge({tri: 't.type_transport', ordre: (tri == 't.type_transport' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">Type {% if tri == 't.type_transport' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th><a href="{{ path('app_transport_index', params|merge({tri: 'v.id', ordre: (tri == 'v.id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}">Voyage {% if tri == 'v.id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}</a></th>
                <th>Trajet</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for transport in transports %}
            <tr>
                <td><span class="tpbadge-id">#{{ transport.id }}</span></td>

                <td>
                    {% set t = transport.typeTransport ?? '' %}
                    <span class="tpbadge-{{ t }}">{{ tp_icons[t] ?? '' }} {{ t ?: '—' }}</span>
                </td>

                <td>
                    {% if transport.voyage %}
                        <span class="tpbadge-voy">#{{ transport.voyage.id }}</span>
                    {% else %}
                        <span style="color:#4b5563">—</span>
                    {% endif %}
                </td>

                <td style="white-space:nowrap">
                    {% if transport.voyage %}
                        <span style="font-size:13px;color:#e2e8f0;font-weight:600">{{ transport.voyage.pointDepart ?? '?' }}</span>
                        <span style="color:#f97316;margin:0 5px;font-size:12px">→</span>
                        <span style="font-size:13px;color:#e2e8f0;font-weight:600">{{ transport.voyage.pointArrivee ?? '?' }}</span>
                    {% else %}
                        <span style="color:#4b5563">—</span>
                    {% endif %}
                </td>

                <td>
                    <div class="tpact">
                        <a href="{{ path('app_transport_show', {'id': transport.id}) }}" class="tpbtn">👁 Voir</a>
                        <a href="{{ path('app_transport_edit', {'id': transport.id}) }}" class="tpbtn tpbtn-edit">✏️ Modifier</a>
                        <span class="tpbtn tpbtn-del">{{ include('transport/_delete_form.html.twig') }}</span>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" style="text-align:center;color:#4b5563;padding:40px;font-size:14px">
                    Aucun transport trouvé
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
</div>

<footer class="copyright">Copyright &copy; 2026 VoyageLoisir</footer>
{% endblock %}