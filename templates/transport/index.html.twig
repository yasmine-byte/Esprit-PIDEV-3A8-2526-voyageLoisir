{% extends 'admin/base_admin.html.twig' %}
{% block title %}Transports{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Transports</h1>
    <p>Gérer tous les transports</p>
</div>

{# ===== FILTRES ===== #}
<div class="card" style="margin-bottom:20px">
    <div class="card-header">
        <h3 class="card-title">Filtres & Recherche</h3>
    </div>
    <form method="GET" action="{{ path('app_transport_index') }}"
          style="display:flex;flex-wrap:wrap;gap:12px;padding:16px;align-items:flex-end">

        <div style="flex:1;min-width:200px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">
                Recherche (ID transport, ID destination, nom destination, pays)
            </label>
            <input type="text" name="search" value="{{ search }}"
                   placeholder="Ex: Paris, 3, France..."
                   style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
        </div>

        <div style="min-width:150px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Type Transport</label>
            <select name="type"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="">Tous</option>
                <option value="Avion"   {{ type == 'Avion'   ? 'selected' : '' }}>✈ Avion</option>
                <option value="Bus"     {{ type == 'Bus'     ? 'selected' : '' }}>🚌 Bus</option>
                <option value="Voiture" {{ type == 'Voiture' ? 'selected' : '' }}>🚗 Voiture</option>
                <option value="Train"   {{ type == 'Train'   ? 'selected' : '' }}>🚆 Train</option>
            </select>
        </div>

        <div style="min-width:160px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Trier par</label>
            <select name="tri"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="t.id"             {{ tri == 't.id'             ? 'selected' : '' }}>ID Transport</option>
                <option value="t.type_transport" {{ tri == 't.type_transport' ? 'selected' : '' }}>Type Transport</option>
                <option value="d.id"             {{ tri == 'd.id'             ? 'selected' : '' }}>ID Destination</option>
                <option value="d.nom"            {{ tri == 'd.nom'            ? 'selected' : '' }}>Nom Destination</option>
                <option value="d.pays"           {{ tri == 'd.pays'           ? 'selected' : '' }}>Pays Destination</option>
            </select>
        </div>

        <div style="min-width:120px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Ordre</label>
            <select name="ordre"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="ASC"  {{ ordre == 'ASC'  ? 'selected' : '' }}>▲ Croissant</option>
                <option value="DESC" {{ ordre == 'DESC' ? 'selected' : '' }}>▼ Décroissant</option>
            </select>
        </div>

        <div style="display:flex;gap:8px">
            <button type="submit"
                    style="padding:8px 18px;border-radius:6px;border:none;background:#6c63ff;color:#fff;font-size:13px;cursor:pointer;font-weight:600">
                🔍 Filtrer
            </button>
            <a href="{{ path('app_transport_index') }}"
               style="padding:8px 18px;border-radius:6px;border:1px solid #555;color:#aaa;font-size:13px;text-decoration:none;display:flex;align-items:center">
                ✕ Reset
            </a>
        </div>
    </form>
</div>

{# ===== TABLEAU ===== #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Liste des Transports
            <span style="font-size:13px;color:#888;font-weight:normal;margin-left:8px">
                ({{ transports|length }} résultat{{ transports|length > 1 ? 's' : '' }})
            </span>
        </h3>
        <a href="{{ path('app_transport_new') }}" class="action-btn primary">+ Ajouter</a>
    </div>

    {% set params = {search: search, type: type} %}

    <table class="market-table">
        <thead>
            <tr>
                <th>
                    <a href="{{ path('app_transport_index', params|merge({tri: 't.id', ordre: (tri == 't.id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        ID {% if tri == 't.id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_transport_index', params|merge({tri: 't.type_transport', ordre: (tri == 't.type_transport' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Type {% if tri == 't.type_transport' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_transport_index', params|merge({tri: 'd.id', ordre: (tri == 'd.id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        ID Destination {% if tri == 'd.id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_transport_index', params|merge({tri: 'd.nom', ordre: (tri == 'd.nom' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Destination {% if tri == 'd.nom' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_transport_index', params|merge({tri: 'd.pays', ordre: (tri == 'd.pays' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Pays {% if tri == 'd.pays' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for transport in transports %}
            <tr>
                <td>{{ transport.id }}</td>
                <td>
                    {% if transport.typeTransport == 'Avion' %}   ✈
                    {% elseif transport.typeTransport == 'Bus' %}  🚌
                    {% elseif transport.typeTransport == 'Voiture' %} 🚗
                    {% elseif transport.typeTransport == 'Train' %} 🚆
                    {% endif %}
                    {{ transport.typeTransport ?? '-' }}
                </td>
                <td>{{ transport.destination ? transport.destination.id : '-' }}</td>
                <td>{{ transport.destination ? transport.destination.nom : '-' }}</td>
                <td>{{ transport.destination ? transport.destination.pays : '-' }}</td>
                <td>
                    <a href="{{ path('app_transport_show', {'id': transport.id}) }}" class="action-btn">Voir</a>
                    <a href="{{ path('app_transport_edit', {'id': transport.id}) }}" class="action-btn">Modifier</a>
                    {{ include('transport/_delete_form.html.twig') }}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" style="text-align:center;color:#888;padding:30px">
                    Aucun transport trouvé
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<footer class="copyright">Copyright &copy; 2026 VoyageLoisir</footer>
{% endblock %}