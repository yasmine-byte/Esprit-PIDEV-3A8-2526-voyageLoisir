{% extends "admin/base_admin.html.twig" %}

{% block title %}Image #{{ image.id }}{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Detail Image</h1>
    <p>Informations de l image</p>
</div>

<div class="card" style="max-width:600px">
    <table class="market-table">
        <tr>
            <th>ID</th>
            <td>{{ image.id }}</td>
        </tr>
        <tr>
            <th>Image</th>
            <td>
                {% if image.urlImage %}
                    <img src="{{ asset(image.urlImage) }}" alt="Image"
                         style="max-width:200px;max-height:150px;border-radius:8px;object-fit:cover;border:1px solid #eee">
                {% else %}
                    -
                {% endif %}
            </td>
        </tr>
        <tr>
            <th>Destination</th>
            <td>{{ image.destination ? image.destination.id ~ " - " ~ image.destination.nom : "-" }}</td>
        </tr>
    </table>

    <div style="margin-top:20px;display:flex;gap:10px">
        <a href="{{ path("app_image_index") }}" class="action-btn">Retour</a>
        <a href="{{ path("app_image_edit", {"id": image.id}) }}" class="action-btn">Modifier</a>
        {{ include("image/_delete_form.html.twig") }}
    </div>
</div>
{% endblock %}
