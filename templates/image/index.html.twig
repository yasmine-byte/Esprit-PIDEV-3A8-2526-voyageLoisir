{% extends 'admin/base_admin.html.twig' %}
{% block title %}Images{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1>Images</h1>
    <p>Gérer toutes les images</p>
</div>

{# ===== FILTRES ===== #}
<div class="card" style="margin-bottom:20px">
    <div class="card-header">
        <h3 class="card-title">Filtres & Recherche</h3>
    </div>
    <form method="GET" action="{{ path('app_image_index') }}"
          style="display:flex;flex-wrap:wrap;gap:12px;padding:16px;align-items:flex-end">

        <div style="flex:1;min-width:220px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">
                Recherche (ID image, ID destination, nom destination, pays)
            </label>
            <input type="text" name="search" value="{{ search }}"
                   placeholder="Ex: Paris, 3, France..."
                   style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
        </div>

        <div style="min-width:160px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Trier par</label>
            <select name="tri"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="i.id" {{ tri == 'i.id' ? 'selected' : '' }}>ID Image</option>
                <option value="d.id" {{ tri == 'd.id' ? 'selected' : '' }}>ID Destination</option>
                <option value="d.nom" {{ tri == 'd.nom' ? 'selected' : '' }}>Nom Destination</option>
                <option value="d.pays" {{ tri == 'd.pays' ? 'selected' : '' }}>Pays Destination</option>
            </select>
        </div>

        <div style="min-width:120px">
            <label style="display:block;font-size:12px;margin-bottom:4px;color:#888">Ordre</label>
            <select name="ordre"
                    style="width:100%;padding:8px 12px;border-radius:6px;border:1px solid #333;background:#1a1a2e;color:#fff;font-size:13px">
                <option value="ASC"  {{ ordre == 'ASC'  ? 'selected' : '' }}>▲ Croissant</option>
                <option value="DESC" {{ ordre == 'DESC' ? 'selected' : '' }}>▼ Décroissant</option>
            </select>
        </div>

        <div style="display:flex;gap:8px">
            <button type="submit"
                    style="padding:8px 18px;border-radius:6px;border:none;background:#6c63ff;color:#fff;font-size:13px;cursor:pointer;font-weight:600">
                🔍 Filtrer
            </button>
            <a href="{{ path('app_image_index') }}"
               style="padding:8px 18px;border-radius:6px;border:1px solid #555;color:#aaa;font-size:13px;text-decoration:none;display:flex;align-items:center">
                ✕ Reset
            </a>
        </div>
    </form>
</div>

{# ===== TABLEAU ===== #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Liste des Images
            <span style="font-size:13px;color:#888;font-weight:normal;margin-left:8px">
                ({{ images|length }} résultat{{ images|length > 1 ? 's' : '' }})
            </span>
        </h3>
        <a href="{{ path('app_image_new') }}" class="action-btn primary">+ Ajouter</a>
    </div>

    {% set params = {search: search} %}

    <table class="market-table">
        <thead>
            <tr>
                <th>
                    <a href="{{ path('app_image_index', params|merge({tri: 'i.id', ordre: (tri == 'i.id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        ID Image {% if tri == 'i.id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>Aperçu</th>
                <th>URL</th>
                <th>
                    <a href="{{ path('app_image_index', params|merge({tri: 'd.id', ordre: (tri == 'd.id' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        ID Destination {% if tri == 'd.id' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_image_index', params|merge({tri: 'd.nom', ordre: (tri == 'd.nom' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Destination {% if tri == 'd.nom' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>
                    <a href="{{ path('app_image_index', params|merge({tri: 'd.pays', ordre: (tri == 'd.pays' and ordre == 'ASC') ? 'DESC' : 'ASC'})) }}"
                       style="color:inherit;text-decoration:none;white-space:nowrap">
                        Pays {% if tri == 'd.pays' %}{{ ordre == 'ASC' ? '▲' : '▼' }}{% endif %}
                    </a>
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for image in images %}
            <tr>
                <td>{{ image.id }}</td>
                <td>
                    <img src="{{ image.urlImage }}"
                         style="width:60px;height:40px;object-fit:cover;border-radius:4px;">
                </td>
                <td style="font-size:11px;color:#888;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    {{ image.urlImage }}
                </td>
                <td>{{ image.destination ? image.destination.id : '-' }}</td>
                <td>{{ image.destination ? image.destination.nom : '-' }}</td>
                <td>{{ image.destination ? image.destination.pays : '-' }}</td>
                <td>
                    <a href="{{ path('app_image_show', {'id': image.id}) }}" class="action-btn">Voir</a>
                    <a href="{{ path('app_image_edit', {'id': image.id}) }}" class="action-btn">Modifier</a>
                    {{ include('image/_delete_form.html.twig') }}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" style="text-align:center;color:#888;padding:30px">
                    Aucune image trouvée
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<footer class="copyright">Copyright &copy; 2026 VoyageLoisir</footer>
{% endblock %}