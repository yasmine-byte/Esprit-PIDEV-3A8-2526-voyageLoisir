{{ form_start(form, {'attr': {'id': 'form-image'}}) }}

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
    <div style="grid-column: span 2;">
        <label class="form-label">Image (fichier) *</label>
        {{ form_widget(form.url_image, {'attr': {'class': 'form-input', 'id': 'f-img', 'onchange': 'lvImage(this)'}}) }}
        <small id="msg-img" style="display:block;min-height:16px;font-size:12px;margin-top:3px">Formats acceptes : jpg, png, gif, webp - max 5 Mo</small>
        <div id="preview-wrap" style="display:none;margin-top:10px;">
            <img id="img-preview" src="" alt="Apercu" style="max-width:200px;max-height:150px;border-radius:6px;border:1px solid #444">
            <div style="height:4px;background:#333;border-radius:2px;margin-top:6px;max-width:200px">
                <div id="img-bar" style="height:100%;border-radius:2px;width:0;transition:width .3s,background .3s"></div>
            </div>
            <small id="img-info" style="display:block;font-size:11px;color:#888;margin-top:3px"></small>
        </div>
        {% for err in form.url_image.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
    <div style="grid-column: span 2;">
        <label class="form-label">Destination *</label>
        {{ form_widget(form.destination, {'attr': {'class': 'form-select', 'id': 'f-dest', 'onchange': 'lvDest(this)'}}) }}
        <small id="msg-dest" style="display:block;min-height:16px;font-size:12px;margin-top:3px"></small>
        {% for err in form.destination.vars.errors %}
            <small style="display:block;color:#E24B4A;font-size:12px;margin-top:2px">{{ err.message }}</small>
        {% endfor %}
    </div>
</div>

<button type="submit" class="btn primary">Sauvegarder</button>
{{ form_end(form) }}

<script>
function ok(id, msg) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "#1D9E75";
    if (m)  { m.style.color = "#1D9E75"; m.textContent = "OK - " + msg; }
}
function er(id, msg) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "#E24B4A";
    if (m)  { m.style.color = "#E24B4A"; m.textContent = "Erreur - " + msg; }
}
function clr(id) {
    var el = document.getElementById(id);
    var m  = document.getElementById("msg-" + id.replace("f-",""));
    if (el) el.style.borderColor = "";
    if (m)  m.textContent = "";
}

function lvImage(input) {
    var f       = input.files[0];
    var wrap    = document.getElementById("preview-wrap");
    var preview = document.getElementById("img-preview");
    var bar     = document.getElementById("img-bar");
    var info    = document.getElementById("img-info");
    var allowed = ["image/jpeg","image/png","image/gif","image/webp"];
    var max     = 5 * 1024 * 1024;

    if (!f) { clr("f-img"); wrap.style.display = "none"; return; }

    if (!allowed.includes(f.type)) {
        er("f-img", "Format non accepte. Utilisez jpg, png, gif ou webp");
        wrap.style.display = "none";
        return;
    }
    if (f.size > max) {
        er("f-img", "Fichier trop lourd : " + (f.size/1024/1024).toFixed(2) + " Mo (max 5 Mo)");
        wrap.style.display = "none";
        return;
    }

    var pct = Math.min(100, Math.round(f.size / max * 100));
    bar.style.width      = pct + "%";
    bar.style.background = pct > 80 ? "#BA7517" : "#1D9E75";
    info.textContent     = f.name + " - " + (f.size/1024/1024).toFixed(2) + " Mo";
    preview.src          = URL.createObjectURL(f);
    wrap.style.display   = "block";
    ok("f-img", "Image valide");
}

function lvDest(el) {
    if (!el.value) {
        er("f-dest", "La destination est obligatoire");
        return;
    }
    ok("f-dest", "Destination selectionnee");
}

document.getElementById("form-image").addEventListener("submit", function(e) {
    var valide = true;

    var img = document.getElementById("f-img");
    if (!img.files || img.files.length === 0) {
        er("f-img", "L image est obligatoire");
        valide = false;
    }

    var dest = document.getElementById("f-dest");
    if (!dest.value) {
        er("f-dest", "La destination est obligatoire");
        valide = false;
    }

    if (!valide) {
        e.preventDefault();
        window.scrollTo(0, 0);
    }
});
</script>
