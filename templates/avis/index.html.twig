{% extends 'base_front.html.twig' %}

{% block title %}Mes Avis - Villa Agency{% endblock %}

{% block body %}
    

    <div class="page-heading header-text">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <span class="breadcrumb"><a href="{{ path('app_home') }}">Home</a> / Avis</span>
                    <h3>Mes Avis</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-5 mb-5 pb-5 pt-3" style="min-height:50vh;">

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}

        {# Header #}
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <h4 class="mb-0 fw-bold">Tous mes avis</h4>
            <a href="{{ path('avis_new') }}" class="btn text-white rounded-pill px-4 py-2"
               style="background-color:#f35525; font-weight:600;">
                <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="margin-right:5px;"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/></svg>
                Donner mon avis
            </a>
        </div>

        {# Barre de filtres — recherche + statut + étoiles + tri : TOUT AUTO via JS #}
        <div class="row g-2 mb-4 align-items-center">
            <div class="col-md-4">
                <input type="text" id="searchInput" class="form-control rounded-pill"
                       placeholder="🔍 Rechercher dans vos avis...">
            </div>
            <div class="col-md-3">
                <select id="filterStatut" class="form-select rounded-pill">
                    <option value="">Tous les statuts</option>
                    <option value="En attente">⏳ En attente</option>
                    <option value="Validé">✓ Validé</option>
                    <option value="Rejeté">✗ Rejeté</option>
                </select>
            </div>
            <div class="col-md-2">
                <select id="filterEtoiles" class="form-select rounded-pill">
                    <option value="">Toutes notes</option>
                    <option value="1">1 ★</option>
                    <option value="2">2 ★</option>
                    <option value="3">3 ★</option>
                    <option value="4">4 ★</option>
                    <option value="5">5 ★</option>
                </select>
            </div>
            <div class="col-md-3">
                <select id="sortSelect" class="form-select rounded-pill">
                    <option value="">Trier par...</option>
                    <option value="date-desc">Date ↓ (récent)</option>
                    <option value="date-asc">Date ↑ (ancien)</option>
                    <option value="etoiles-desc">Note ↓ (meilleure)</option>
                    <option value="etoiles-asc">Note ↑ (plus basse)</option>
                </select>
            </div>
        </div>

        {# Compteur résultats #}
        <div id="resultCount" class="mb-2" style="font-size:0.85rem; color:#888;"></div>

        {# Tableau #}
        <div class="table-responsive shadow-sm bg-white rounded-3 p-3">
            <table class="table table-hover align-middle mb-0" id="avisTable">
                <thead style="background:#f8f9fa;">
                    <tr>
                        <th style="color:#f35525; cursor:pointer;" data-col="0" class="sort-th">
                            Contenu <span class="sort-icon">⇅</span>
                        </th>
                        <th style="color:#f35525; cursor:pointer;" data-col="1" class="sort-th">
                            Note <span class="sort-icon">⇅</span>
                        </th>
                        <th style="color:#f35525;">Type</th>
                        <th style="color:#f35525; cursor:pointer;" data-col="3" class="sort-th">
                            Statut <span class="sort-icon">⇅</span>
                        </th>
                        <th style="color:#f35525; cursor:pointer;" data-col="4" class="sort-th">
                            Date <span class="sort-icon">⇅</span>
                        </th>
                        <th style="color:#f35525;">💬 Réponse admin</th>
                        <th style="color:#f35525;">Actions</th>
                    </tr>
                </thead>
                <tbody id="avisBody">
                {% for avi in avis %}
                    <tr
                        data-contenu="{{ avi.contenu|lower }}"
                        data-statut="{{ avi.statut }}"
                        data-etoiles="{{ avi.nbEtoiles }}"
                        data-date="{{ avi.dateAvis ? avi.dateAvis|date('Y-m-d') : '0000-00-00' }}"
                    >
                        <td style="max-width:220px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                            title="{{ avi.contenu }}">
                            {{ avi.contenu }}
                        </td>
                        <td style="white-space:nowrap;" data-val="{{ avi.nbEtoiles }}">
                            {% for i in 1..5 %}
                                {% if i <= avi.nbEtoiles %}
                                    <span style="color:#f35525;">★</span>
                                {% else %}
                                    <span style="color:#ddd;">★</span>
                                {% endif %}
                            {% endfor %}
                        </td>
                        <td>{{ avi.type ? avi.type.nom : '—' }}</td>
                        <td>
                            {% if avi.statut == 'Validé' %}
                                <span class="badge rounded-pill bg-success">✓ Validé</span>
                            {% elseif avi.statut == 'Rejeté' %}
                                <span class="badge rounded-pill bg-danger">✗ Rejeté</span>
                            {% else %}
                                <span class="badge rounded-pill bg-warning text-dark">⏳ En attente</span>
                            {% endif %}
                        </td>
                        <td style="white-space:nowrap; font-size:0.85rem; color:#888;">
                            {{ avi.dateAvis ? avi.dateAvis|date('d/m/Y') : '—' }}
                        </td>
                        <td style="max-width:200px;">
                            {% if avi.reponse %}
                                <div style="background:#f0fff4; border-left:3px solid #28a745; border-radius:6px; padding:6px 10px;">
                                    <div style="font-size:0.7rem; color:#28a745; font-weight:600; margin-bottom:2px;">Réponse admin :</div>
                                    <div style="font-size:0.82rem; color:#333;">{{ avi.reponse }}</div>
                                </div>
                            {% else %}
                                <span style="font-size:0.8rem; color:#bbb; font-style:italic;">En attente...</span>
                            {% endif %}
                        </td>
                        <td style="white-space:nowrap;">
                            <div style="display:flex; gap:5px; align-items:center; flex-wrap:nowrap;">

                                {# 👁 Voir — toujours actif #}
                                <a href="{{ path('avis_show', {'id': avi.id}) }}"
                                   class="btn btn-sm rounded-pill"
                                   style="background:#f0f5ff; color:#3a7bd5; border:1px solid #c5d8ff; font-size:0.78rem; padding:4px 10px; font-weight:600;">
                                    👁 Voir
                                </a>

                                {# ✏ Modifier — actif si En attente, grisé sinon #}
                                {% if avi.statut == 'En attente' %}
                                <a href="{{ path('avis_edit', {'id': avi.id}) }}"
                                   class="btn btn-sm rounded-pill"
                                   style="background:#fff8e1; color:#e65100; border:1px solid #ffcc80; font-size:0.78rem; padding:4px 10px; font-weight:600;">
                                    ✏ Modifier
                                </a>
                                {% else %}
                                <span class="btn btn-sm rounded-pill"
                                      style="background:#f5f5f5; color:#bbb; border:1px solid #e0e0e0; font-size:0.78rem; padding:4px 10px; font-weight:600; cursor:not-allowed;"
                                      title="Non modifiable ({{ avi.statut }})">
                                    ✏ Modifier
                                </span>
                                {% endif %}

                                {# 🗑 Supprimer — actif si En attente, grisé sinon #}
                                {% if avi.statut == 'En attente' %}
                                <form method="post" action="{{ path('avis_delete', {'id': avi.id}) }}"
                                      onsubmit="return confirm('Supprimer cet avis ?');" style="display:inline-block; margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ avi.id) }}">
                                    <button type="submit" class="btn btn-sm rounded-pill"
                                            style="background:#fff0f0; color:#c0392b; border:1px solid #ffb3b3; font-size:0.78rem; padding:4px 10px; font-weight:600;">
                                        🗑 Supprimer
                                    </button>
                                </form>
                                {% else %}
                                <span class="btn btn-sm rounded-pill"
                                      style="background:#f5f5f5; color:#bbb; border:1px solid #e0e0e0; font-size:0.78rem; padding:4px 10px; font-weight:600; cursor:not-allowed;"
                                      title="Non supprimable ({{ avi.statut }})">
                                    🗑 Supprimer
                                </span>
                                {% endif %}

                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr id="emptyRow">
                        <td colspan="7" class="text-center py-5" style="color:#bbb;">
                            <div style="font-size:2.5rem; margin-bottom:10px;">⭐</div>
                            Vous n'avez pas encore soumis d'avis.<br>
                            <a href="{{ path('avis_new') }}" style="color:#f35525;">Donnez votre premier avis !</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            <div id="noResults" style="display:none; text-align:center; padding:40px; color:#bbb;">
                Aucun avis ne correspond à votre recherche.
            </div>
        </div>
    </div>

    

<script>
// ── Recherche AJAX côté serveur — avis ───────────────────────────────────
// Remplace le filtrage JS client par des appels AJAX vers GET /avis/search
// Debounce 300ms sur l'input texte pour éviter les requêtes intempestives
(function () {
  'use strict';

  const searchURL    = '{{ path("avis_search") }}';
  const searchInput  = document.getElementById('searchInput');
  const filterStatut = document.getElementById('filterStatut');
  const filterEtoiles= document.getElementById('filterEtoiles');
  const sortSelect   = document.getElementById('sortSelect');
  const tbody        = document.getElementById('avisBody');
  const resultCount  = document.getElementById('resultCount');
  const noResults    = document.getElementById('noResults');

  // Spinner (ajouté dynamiquement)
  const spinner = document.createElement('div');
  spinner.id    = 'ajax-spinner';
  spinner.innerHTML = '<div style="text-align:center; padding:20px; color:#f35525;">⏳ Recherche en cours...</div>';
  spinner.style.display = 'none';
  if (tbody.parentNode) tbody.parentNode.insertBefore(spinner, tbody);

  // ── Reconstruction des lignes du tableau depuis JSON ────────────────────
  function renderRows(results) {
    tbody.innerHTML = '';

    if (results.length === 0) {
      tbody.innerHTML = `
        <tr><td colspan="7" class="text-center py-5" style="color:#bbb;">
          <div style="font-size:2.5rem; margin-bottom:10px;">🔍</div>
          Aucun avis ne correspond à votre recherche.
        </td></tr>`;
      if (noResults) noResults.style.display = 'none';
    } else {
      results.forEach(function (a) {
        // Étoiles
        let stars = '';
        for (let i = 1; i <= 5; i++) {
          stars += `<span style="color:${i <= a.nbEtoiles ? '#f35525' : '#ddd'};">★</span>`;
        }

        // Badge statut
        const statutBadge = a.statut === 'Validé'
          ? '<span class="badge rounded-pill bg-success">✓ Validé</span>'
          : a.statut === 'Rejeté'
            ? '<span class="badge rounded-pill bg-danger">✗ Rejeté</span>'
            : '<span class="badge rounded-pill bg-warning text-dark">⏳ En attente</span>';

        // Réponse admin
        const reponseHtml = a.reponse
          ? `<div style="background:#f0fff4;border-left:3px solid #28a745;border-radius:6px;padding:6px 10px;">
               <div style="font-size:0.7rem;color:#28a745;font-weight:600;margin-bottom:2px;">Réponse admin :</div>
               <div style="font-size:0.82rem;color:#333;">${a.reponse}</div>
             </div>`
          : '<span style="font-size:0.8rem;color:#bbb;font-style:italic;">En attente...</span>';

        // Boutons d'action selon statut
        const canEdit   = a.statut === 'En attente';
        const editBtn   = canEdit
          ? `<a href="${a.editUrl}" class="btn btn-sm rounded-pill" style="background:#fff8e1;color:#e65100;border:1px solid #ffcc80;font-size:0.78rem;padding:4px 10px;font-weight:600;">✏ Modifier</a>`
          : `<span class="btn btn-sm rounded-pill" style="background:#f5f5f5;color:#bbb;border:1px solid #e0e0e0;font-size:0.78rem;padding:4px 10px;cursor:not-allowed;">✏ Modifier</span>`;

        const delBtn  = a.statut === 'En attente'
        ? `<form method="post" action="${a.deleteUrl}" onsubmit="return confirm('Supprimer cet avis ?');" style="display:inline;margin:0;">
             <input type="hidden" name="_token" value="${a.csrfToken}">
             <button class="btn btn-sm rounded-pill" style="background:#fff0f0;color:#c0392b;border:1px solid #ffb3b3;font-size:0.78rem;padding:4px 10px;font-weight:600;">🗑 Supprimer</button></form>`
        : `<span class="btn btn-sm rounded-pill" style="background:#f5f5f5;color:#bbb;border:1px solid #e0e0e0;font-size:0.78rem;padding:4px 10px;cursor:not-allowed;">🗑 Supprimer</span>`;

        tbody.insertAdjacentHTML('beforeend', `
          <tr>
            <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${a.contenu}">${a.contenu}</td>
            <td style="white-space:nowrap;">${stars}</td>
            <td>${a.type}</td>
            <td>${statutBadge}</td>
            <td style="white-space:nowrap;font-size:0.85rem;color:#888;">${a.dateAvis}</td>
            <td style="max-width:200px;">${reponseHtml}</td>
            <td style="white-space:nowrap;">
              <div style="display:flex;gap:5px;align-items:center;flex-wrap:nowrap;">
                <a href="${a.showUrl}" class="btn btn-sm rounded-pill" style="background:#f0f5ff;color:#3a7bd5;border:1px solid #c5d8ff;font-size:0.78rem;padding:4px 10px;font-weight:600;">👁 Voir</a>
                ${editBtn}
                ${delBtn}
              </div>
            </td>
          </tr>`);
      });
    }

    if (resultCount) {
      resultCount.textContent = results.length + ' avis affiché' + (results.length > 1 ? 's' : '');
    }
  }

  // ── Appel AJAX ─────────────────────────────────────────────────────────
  async function doSearch() {
    spinner.style.display = 'block';
    tbody.style.opacity   = '0.4';

    const params = new URLSearchParams({
      q:       searchInput  ? searchInput.value.trim()  : '',
      statut:  filterStatut ? filterStatut.value        : '',
      etoiles: filterEtoiles? filterEtoiles.value       : '',
      sort:    sortSelect   ? sortSelect.value          : 'date-desc',
    });

    try {
      const res  = await fetch(searchURL + '?' + params.toString());
      const data = await res.json();
      renderRows(data.results || []);
    } catch (e) {
      tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-danger">Erreur lors de la recherche.</td></tr>';
    } finally {
      spinner.style.display = 'none';
      tbody.style.opacity   = '1';
    }
  }

  // ── Debounce pour l'input texte (300ms) ────────────────────────────────
  let debounceTimer = null;
  function debounced() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doSearch, 300);
  }

  if (searchInput)   searchInput.addEventListener('input',  debounced);
  if (filterStatut)  filterStatut.addEventListener('change', doSearch);
  if (filterEtoiles) filterEtoiles.addEventListener('change', doSearch);
  if (sortSelect)    sortSelect.addEventListener('change',    doSearch);

  // Chargement initial
  doSearch();
})();
</script>
{% endblock %}
