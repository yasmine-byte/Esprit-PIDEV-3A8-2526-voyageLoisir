{% extends 'base_front.html.twig' %}
{% block title %}Donner mon avis - Villa Agency{% endblock %}
{% block body %}
    {% include 'home/partials/header.html.twig' %}
    <style>
        @keyframes fadeInUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
        @keyframes bounce{0%,100%{transform:scale(1);}50%{transform:scale(1.3) rotate(10deg);}}
        @keyframes slideDown{from{opacity:0;max-height:0;padding:0;margin:0;border:none;}to{opacity:1;max-height:100px;}}
        @keyframes spin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
        .animate-fade{animation:fadeInUp 0.6s ease forwards;}
        .floating-card{background:#fff;border-radius:20px;box-shadow:0 20px 40px rgba(0,0,0,0.1);padding:40px;position:relative;z-index:10;margin-top:-50px;}
        .stars-creative{display:flex;justify-content:center;gap:15px;margin:20px 0;}
        .star-box{font-size:3rem;color:#e9ecef;cursor:pointer;transition:all 0.2s;}
        .star-box:hover{transform:scale(1.15) rotate(5deg);}
        .star-box.gold{color:#ffc107;text-shadow:0 0 10px rgba(255,193,7,0.5);}
        .star-box.bounce-anim{animation:bounce 0.4s ease;}
        #star-message{font-weight:bold;text-align:center;min-height:25px;font-size:1.1rem;transition:color 0.3s;}
        .negative-warning{background:#fff3cd;border-left:5px solid #ffc107;color:#856404;padding:15px;border-radius:8px;display:none;overflow:hidden;}
        .negative-warning.show{display:block;animation:slideDown 0.4s ease forwards;}
        .custom-select-new{border:2px solid #e9ecef;border-radius:12px;padding:12px 15px;transition:border-color 0.3s;appearance:none;background:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='%236c757d' viewBox='0 0 16 16'><path fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/></svg>") no-repeat right 15px center;background-size:16px;width:100%;}
        .custom-select-new:focus{border-color:#f35525;outline:none;box-shadow:0 0 0 3px rgba(243,85,37,0.1);}
        .custom-textarea{border:2px solid #e9ecef;border-radius:12px;padding:15px;transition:border-color 0.3s;resize:none;width:100%;}
        .custom-textarea:focus{border-color:#f35525;outline:none;box-shadow:0 0 0 3px rgba(243,85,37,0.1);}
        .char-counter{text-align:right;font-size:0.85rem;font-weight:600;margin-top:5px;color:#28a745;}
        .btn-submit-creative{background:linear-gradient(45deg,#f35525,#dc3545);color:#fff;border:none;border-radius:50px;padding:14px 36px;font-size:1rem;font-weight:700;transition:transform 0.3s,box-shadow 0.3s;display:inline-flex;align-items:center;gap:10px;}
        .btn-submit-creative:hover{transform:scale(1.05);box-shadow:0 10px 20px rgba(243,85,37,0.3);color:#fff;}
        .btn-cancel-new{background:#fff;color:#888;border:2px solid #e0e0e0;border-radius:50px;padding:14px 36px;font-size:1rem;font-weight:600;transition:all 0.25s;display:inline-flex;align-items:center;gap:8px;text-decoration:none;}
        .btn-cancel-new:hover{background:#f5f5f5;border-color:#bbb;color:#444;text-decoration:none;}
        .spinner-icon{display:none;animation:spin 1s linear infinite;}
        .btn-submit-creative.loading .submit-icon{display:none;}
        .btn-submit-creative.loading .spinner-icon{display:inline-block;}
    </style>

    <div class="page-heading header-text" style="padding-bottom:120px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <span class="breadcrumb"><a href="{{ path('avis_index') }}">Avis</a> / Donner mon avis</span>
                    <h3>Votre Expérience</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="container mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-7">
                <div class="floating-card animate-fade">
                    <h4 class="text-center mb-4 fw-bold">Qu'avez-vous pensé de nos services ?</h4>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'form-avis'}}) }}

                        <div class="mb-4">
                            <div class="stars-creative" id="starContainer">
                                <span class="star-box" data-val="1">★</span>
                                <span class="star-box" data-val="2">★</span>
                                <span class="star-box" data-val="3">★</span>
                                <span class="star-box" data-val="4">★</span>
                                <span class="star-box" data-val="5">★</span>
                            </div>
                            <div id="star-message" class="mb-2"></div>
                            <div id="negativeWarning" class="negative-warning mt-3">
                                ⚠️ <strong>Note basse :</strong> Un avis de 1 ou 2 étoiles génèrera automatiquement une réclamation.
                            </div>
                            <div class="d-none">{{ form_widget(form.nbEtoiles, {'id': 'hidden_etoiles'}) }}</div>
                            <div class="text-danger small text-center mt-1 fw-bold">{{ form_errors(form.nbEtoiles) }}</div>
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.type, 'Catégorie de l\'avis', {'label_attr': {'class': 'form-label fw-bold text-muted'}}) }}
                            {{ form_widget(form.type, {'attr': {'class': 'form-select custom-select-new'}}) }}
                            <div class="text-danger small mt-1">{{ form_errors(form.type) }}</div>
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.contenu, 'Dites-nous tout', {'label_attr': {'class': 'form-label fw-bold text-muted'}}) }}
                            {{ form_widget(form.contenu, {'attr': {'class': 'form-control custom-textarea', 'rows': 5, 'placeholder': 'Racontez-nous votre expérience... Chaque détail compte ! ✍️', 'maxlength': 500, 'id': 'review-text'}}) }}
                            <div class="char-counter" id="char-count">0 / 500 caractères</div>
                            <div class="text-danger small mt-1">{{ form_errors(form.contenu) }}</div>
                        </div>

                        <div class="mt-5 d-flex justify-content-center gap-3 flex-wrap">
                            <button type="submit" class="btn-submit-creative" id="btn-submit">
                                <span class="submit-text">Publier mon avis</span>
                                <i class="fas fa-paper-plane submit-icon"></i>
                                <i class="fas fa-spinner spinner-icon"></i>
                            </button>
                            <a href="{{ path('avis_index') }}" class="btn-cancel-new">✕ Annuler</a>
                        </div>

                        <div class="d-none">{{ form_rest(form) }}</div>
                    {{ form_end(form, {'render_rest': false}) }}
                </div>
            </div>
        </div>
    </div>

    {% include 'home/partials/footer.html.twig' %}
    <script>
    document.addEventListener("DOMContentLoaded", function() {
        const stars = document.querySelectorAll('.star-box');
        const hiddenInput = document.getElementById('hidden_etoiles');
        const starMessage = document.getElementById('star-message');
        const warningBox  = document.getElementById('negativeWarning');
        const msgs = {1:{t:"😞 Très déçu(e)",c:"#dc3545"},2:{t:"😕 Déçu(e)",c:"#fd7e14"},3:{t:"😐 Correct",c:"#ffc107"},4:{t:"😊 Satisfait(e)",c:"#0dcaf0"},5:{t:"🤩 Excellent !",c:"#28a745"}};

        function updateStars(val, click) {
            stars.forEach(function(s){
                const sv=parseInt(s.getAttribute('data-val'));
                s.classList.toggle('gold', sv<=val);
                if(click && sv<=val){s.classList.remove('bounce-anim');void s.offsetWidth;s.classList.add('bounce-anim');}
            });
            if(val>0){starMessage.textContent=msgs[val].t;starMessage.style.color=msgs[val].c;warningBox.classList.toggle('show',val<=2);}
            else{starMessage.textContent='';warningBox.classList.remove('show');}
        }

        stars.forEach(function(s){
            s.addEventListener('mouseover',function(){updateStars(parseInt(this.getAttribute('data-val')));});
            s.addEventListener('mouseout', function(){updateStars(parseInt(hiddenInput.value)||0);});
            s.addEventListener('click',    function(){const v=parseInt(this.getAttribute('data-val'));hiddenInput.value=v;updateStars(v,true);});
        });
        if(hiddenInput.value) updateStars(parseInt(hiddenInput.value));

        const ta=document.getElementById('review-text'), cc=document.getElementById('char-count');
        ta.addEventListener('input',function(){const l=this.value.length;cc.textContent=l+' / 500 caractères';cc.style.color=l<400?'#28a745':(l<500?'#fd7e14':'#dc3545');});
        ta.dispatchEvent(new Event('input'));

        document.getElementById('form-avis').addEventListener('submit',function(){
            const b=document.getElementById('btn-submit');b.classList.add('loading');b.querySelector('.submit-text').textContent='Envoi en cours...';
        });
    });
    </script>
{% endblock %}
